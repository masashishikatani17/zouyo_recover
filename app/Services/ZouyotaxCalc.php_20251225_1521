    /**
     * 暦年贈与税額控除（3年/改正後ルックバック） recipientごと（円）
     */
    private function calcGiftTaxCreditsByRecipient(int $dataId, \DateTimeImmutable $deathDate, array $targetIdxList = []): array
    {
        $result = [];
        for ($i = 2; $i <= 10; $i++) $result[$i] = ['calendar_yen' => 0, 'total_yen' => 0];


        // ★「課税価格の取得がある人」フィルタ（未定義変数エラー防止）
        //   targetIdxList が空ならフィルタ無し（従来互換）
        $targetSet = [];
        foreach ($targetIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) {
                $targetSet[$i] = true;
            }
        }
        $hasTargetFilter = !empty($targetSet);


        [$rangeStart, $rangeEnd] = $this->determineCalendarGiftLookbackRange($deathDate);

        $rows = PastGiftCalendarEntry::query()
            ->where('data_id', $dataId)
            ->get(['recipient_no','gift_year','gift_month','gift_day','tax_thousand']);

        foreach ($rows as $r) {
            $no  = (int)$r->recipient_no;
            $tax = (int)($r->tax_thousand ?? 0);
            if ($no < 2 || $no > 10 || $tax <= 0) continue;
            // ★課税価格の取得が無い人は、贈与税額控除の対象外
            if ($hasTargetFilter && !isset($targetSet[$no])) continue;
            // ★月日欠損でも控除漏れしない（年のみ入力 → 12/31 扱い）
            $gd = $this->safeDateYmd(
                (int)($r->gift_year ?? 0),
                (int)($r->gift_month ?? 0),
                (int)($r->gift_day ?? 0)
            );
            if (!$gd) {
                continue;
            }
            if ($gd >= $rangeStart && $gd <= $rangeEnd) {
                $result[$no]['calendar_yen'] += $this->toYen($tax);
            }
        }

        foreach ($result as $no => $v) {
            $result[$no]['total_yen'] = $v['calendar_yen'];
        }
        
        
        return $result;
    }


    /**
     * （拡張版）贈与税額控除（暦年）に仮想（将来）贈与分の“税額”を合算
     * - buildVirtualGiftsIndex() で作った $virtual から、対象死亡日キーの calendar_tax を取り出して合算する
     * - 返却形式は calcGiftTaxCreditsByRecipient() と同一（['calendar_yen','total_yen']）
     */
    private function calcGiftTaxCreditsByRecipientWithVirtual(
        int $dataId,
        \DateTimeImmutable $deathDate,
        array $virtual,
        array $targetIdxList = []
    ): array {

        // 1) まず既存（過去贈与＝PastGiftCalendarEntry 由来）の控除額をベースとして取得
        //    ※暦年贈与税額控除なので、精算贈与税ではなく「暦年」の控除額がベース
        $base = $this->calcGiftTaxCreditsByRecipient($dataId, $deathDate, $targetIdxList);

        // ★「課税価格の取得がある人」フィルタ（暦年贈与税額控除は従来どおり）
        $targetSet = [];
        foreach ($targetIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) $targetSet[$i] = true;
        }
        $hasTargetFilter = !empty($targetSet);

        // 2) 対象死亡日の仮想インデックスを取得（無ければ空配列で扱う）
        $key = $deathDate->format('Y-m-d');
        $v   = $virtual[$key] ?? [
            'calendar_tax' => [],
        ];


        // 3) virtual の calendar_tax（将来贈与分の暦年贈与税額）をマージ
        //    - recipient_no = 2〜10 のみ対象（UI上の受贈者2〜10）
        //    - DB 由来の calendar_yen に“足し込み”する
        foreach (($v['calendar_tax'] ?? []) as $no => $yen) {
            $idx = (int)$no;
            if ($idx < 2 || $idx > 10) {
                continue;
            }
            if ($hasTargetFilter && !isset($targetSet[$idx])) continue;
            if (!isset($base[$idx])) {
                // 過去分が無い受贈者（No.7・8 など「これからの贈与」専用）用の器を用意
                $base[$idx] = [
                    'calendar_yen' => 0,
                    'total_yen'    => 0,
                ];
            }
            // virtual 側は既に「円」単位なので、そのまま加算
            $base[$idx]['calendar_yen'] += max(0, (int)$yen);
        }

        // 4) total_yen フィールドを calendar_yen で上書き整合
        foreach ($base as $no => $rec) {
            $base[$no]['total_yen'] = (int)($rec['calendar_yen'] ?? 0);
        }

        /*
        // ★デバッグ：virtual マージ後の暦年贈与税額控除をログ
        Log::info('[ZouyotaxCalc][gift_tax_credits_with_virtual]', [
            'death_date' => $deathDate->format('Y-m-d'),
            'credits'    => $base,
        ]);
        */



        return $base;

    }




    /** 実取得額（円） */
    private function resolveActualShareYenForIdx(array $payload, int $idx, int $estateYen, float $legalRatio): int
    {
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        if ($mode === 'manual') {
            $kyen = $this->readKyen($payload, 'id_taxable_manu', $idx);
            if ($kyen > 0) return $this->toYen($kyen);
        }
        return (int)round($estateYen * $legalRatio);
    }


/** 過年度の精算課税の贈与税額（円）：recipientごと（★全員・全額。取得者フィルタ禁止） */
