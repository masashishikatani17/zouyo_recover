            'settlement_tax_amount_thousand',
            'tax_thousand',
        ];
        foreach ($candidates as $col) {
            $v = (int)($r->{$col} ?? 0);
            if ($v > $val) { $val = $v; }
        }

        if ($val <= 0) {
            $attrs = method_exists($r, 'getAttributes') ? (array)$r->getAttributes() : [];
            foreach ($attrs as $k => $v) {
                if (!is_numeric($v)) continue;
                $kk = (string)$k;
                if (preg_match('/^settlement_.*tax.*_thousand$/i', $kk)) {
                    $vv = (int)$v;
                    if ($vv > $val) { $val = $vv; }
                }
            }
        }

        if ($val <= 0 && (int)($r->settlement_amount_thousand ?? 0) > 0 && (bool)config('app.debug')) {
            Log::debug('[ZouyotaxCalc][future_plan][settlement_tax_missing]', [
                'id'            => (int)($r->id ?? 0),
                'data_id'        => (int)($r->data_id ?? 0),
                'recipient_no'   => (int)($r->recipient_no ?? 0),
                'row_no'         => (int)($r->row_no ?? 0),
                'amount_thousand'=> (int)($r->settlement_amount_thousand ?? 0),
                'settlement_tax20_thousand' => (int)($r->settlement_tax20_thousand ?? 0),
                'settlement_tax_thousand'   => (int)($r->settlement_tax_thousand ?? 0),
                'tax_thousand'              => (int)($r->tax_thousand ?? 0),
                'attr_keys'                 => array_keys((array)$r->getAttributes()),
            ]);
        }

        return max(0, $val);
    }
    
    
    
