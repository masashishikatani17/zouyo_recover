    /** 内部ユーティリティ：row_no→合計(千円) の配列へ変換 */
    private function FutureGiftPlanFromDb($builder): array
    {
        $res = $builder->get();
        if ($res->isEmpty()) { return []; }
        $out = array_fill(1, 20, 0);
        foreach ($res as $r) {
            $t = $this->normalizeFuturePlanT((int)$r->row_no);
            if ($t >= 1 && $t <= 20) {
                $out[$t] = (int)$r->k;
            }
        }
        return $out;
    }


    /**
     * future_gift_plan_entries.row_no が 0始まりかどうかを DB から判定し、補正値を返す
     * - 「実データ（暦年/精算の金額が>0）」だけを対象に min/max を見る
     * - min=0 かつ max<=19 のときだけ 0始まり（0..19）と判定して +1
     *   ※ row_no=0 のダミー/空行が混ざっていても、これで誤判定しない
     */
    private function resolveFuturePlanRowNoOffset(int $dataId): int
    {
        try {
            $q = FutureGiftPlanEntry::query()
                ->where('data_id', $dataId)
                ->whereBetween('recipient_no', [2, 10])
                ->where(function ($qq) {
                    $qq->where('calendar_amount_thousand', '>', 0)
                       ->orWhere('settlement_amount_thousand', '>', 0);
                });

            $min = $q->min('row_no');
            $max = $q->max('row_no');

            // ★ row_no=0 が “実データ(>0)” として存在するか（空行の row_no=0 は除外）
            $hasRow0 = (clone $q)->where('row_no', 0)->exists();
            // ★ row_no=1 も実データとして存在するか
            $hasRow1 = (clone $q)->where('row_no', 1)->exists();

            if ($min === null || $max === null) {
                return 0;
            }

            $min = (int)$min;
            $max = (int)$max;

            // ★混在でも row_no=0 の実データがあるなら +1 を優先（t=1落ち防止）
            if ($hasRow0 && !$hasRow1) {
                return 1;
            }
            return 0;
        } catch (\Throwable $e) {
            Log::warning('[ZouyotaxCalc][resolveFuturePlanRowNoOffset] failed', [
                'data_id' => $dataId,
                'error'   => $e->getMessage(),
            ]);
            return 0;
        }
    }



    /**
     * 「対策後(after)」および「年次プロジェクション(projections.after)」の
     * 課税遺産総額(taxable_estate) を
     *
     *   各相続人の生前贈与加算後の課税価格 P_i(t)
     *   （= per_idx[idx]['price_for_ratio']）
     *
     * の比率で按分した値を heirs[].taxable_share_yen として付与する。
     *
     * 期待式:
     *   taxable_share_yen_i(t)
     *     = taxable_estate(t) * P_i(t) / Σ_j P_j(t)
     *
     * per_idx が無い／全員0などの場合のみ、
     * manual_price_yen or legal_ratio による従来比率へフォールバックする。
     */
    private function allocateTaxableEstateByFixedRatios(array $after, array $projAfter): array
    {
        if (!isset($after['heirs']) || !is_array($after['heirs'])) {
            return [$after, $projAfter];
        }

        // t=0 after.heirs から row_index => 行 へマップ
        $heirsByIdx = [];
        foreach ($after['heirs'] as $row) {
            if (!isset($row['row_index'])) continue;
            $heirsByIdx[(int)$row['row_index']] = $row;
        }
        if (empty($heirsByIdx)) {
            return [$after, $projAfter];
        }

        // --- 相続取得財産の按分比率（遺産分割比率）を決定 ---
        //   ・manual：heirs[].manual_price_yen の比率
        //   ・auto  ：heirs[].legal_ratio の比率
        $sumPrice   = 0;
        $priceByIdx = [];
        foreach ($heirsByIdx as $idx => $row) {
            $price = (int)($row['manual_price_yen'] ?? 0);
            if ($price > 0) {
                $priceByIdx[$idx] = $price;
                $sumPrice        += $price;
            }
        }

        $fallbackRatioByIdx = [];
        if ($sumPrice > 0) {
            // manual: 課税価格（manual_price_yen）の比率で按分
            foreach ($priceByIdx as $idx => $price) {
                $fallbackRatioByIdx[$idx] = $price / $sumPrice;
            }
        } else {
            // auto: legal_ratio の比率で按分
            $sumRatio = 0.0;
            foreach ($heirsByIdx as $idx => $row) {
                $r = (float)($row['legal_ratio'] ?? 0.0);
                $fallbackRatioByIdx[$idx] = $r;
                $sumRatio                 += $r;
            }
            if ($sumRatio > 0.0) {
                foreach ($fallbackRatioByIdx as $idx => $r) {
                    $fallbackRatioByIdx[$idx] = $r / $sumRatio;
                }
            }
        }

        // per_idx（price_for_ratio）から比率を作るヘルパ
        $buildRatiosFromPerIdx = function (?array $perIdx, array $fallback) {
            $perIdx = $perIdx ?? [];
            $sumP   = 0;
            $ratio  = [];
            foreach ($perIdx as $idx => $rec) {
                $p = (int)($rec['price_for_ratio'] ?? 0);
                if ($p <= 0) continue;
                $ratio[(int)$idx] = $p;
                $sumP            += $p;
            }
            if ($sumP > 0) {
                foreach ($ratio as $idx => $p) {
                    $ratio[$idx] = $p / $sumP;
                }
                return $ratio;
            }
            // 全員0／未設定ならフォールバック（manual / legal_ratio）
            return $fallback;
        };

        // 内部ユーティリティ：指定された合計額を ratio で按分して taxable_share_yen を付与
        $applyAllocation = function (&$heirs, int $total, array $ratios): void {
            if ($total <= 0 || !is_array($heirs)) return;
            $lastKey   = null;
            $allocated = 0;
            foreach ($heirs as $k => &$row) {
                $idx = $row['row_index'] ?? null;
                if ($idx === null || !isset($ratios[$idx])) continue;
                $lastKey = $k;
                $share   = (int)floor($total * $ratios[$idx]);
                $row['taxable_share_yen'] = $share;
                $allocated               += $share;
            }
            // 端数は最後の一人に寄せる
            if ($lastKey !== null) {
                $heirs[$lastKey]['taxable_share_yen'] =
                    ($heirs[$lastKey]['taxable_share_yen'] ?? 0) + ($total - $allocated);
            }
        };

        // 2) after(t=0)：per_idx(0年目の P_i(0)) から比率を作って按分
        $perIdxAfter   = $after['per_idx'] ?? null;
        $ratiosAfter   = $buildRatiosFromPerIdx($perIdxAfter, $fallbackRatioByIdx);
        $totalAfter    = (int)($after['summary']['taxable_estate'] ?? 0);
        $applyAllocation($after['heirs'], $totalAfter, $ratiosAfter);

        // 3) 年次プロジェクション after[t]：各年の per_idx[t] があればそれで比率を作る
        if (is_array($projAfter)) {
            foreach ($projAfter as $t => $row) {
                if (!isset($row['summary']['taxable_estate'], $row['heirs']) || !is_array($row['heirs'])) {
                    continue;
                }
                $perIdxT   = $row['per_idx'] ?? null;
                $ratiosT   = $buildRatiosFromPerIdx($perIdxT, $ratiosAfter); // 年ごとに P_i(t) 優先、無ければ t=0 比率
                $totalT    = (int)$row['summary']['taxable_estate'];
                $heirsT    =& $row['heirs'];
                $applyAllocation($heirsT, $totalT, $ratiosT);
                $row['heirs'] = $heirsT;
                $projAfter[$t] = $row;
            }
        }

        return [$after, $projAfter];
    }



    /**
     * 「対策後(after)」および「年次プロジェクション(projections.after)」の
     * 所有財産（= 贈与後の相続財産の額: estate_after_yen）を
     * 「各相続人の課税価格比率」で按分した値を
     * heirs[].estate_base_share_yen として付与する。
     *
     * ・按分比率の決め方は allocateTaxableEstateByFixedRatios と同じ
     *   - manual: heirs[].manual_price_yen（課税価格）比率
     *   - auto  : heirs[].legal_ratio 比率
     * ・年次プロジェクション after[t] でも、各年の estate_after_yen を按分する
     *
     * NOTE:
     *  - summary['estate_base_yen'] は「贈与前総資産（比較用）」として保持しているため、
     *    “分割の基になる所有財産”は summary['estate_after_yen'] を採用する。
     */
    private function allocateEstateBaseByFixedRatios(array $after, array $projAfter, array $payload): array
    {
        if (!isset($after['heirs']) || !is_array($after['heirs'])) {
            return [$after, $projAfter];
        }

        // t=0 after.heirs から row_index => 行 へマップ
        $heirsByIdx = [];
        foreach ($after['heirs'] as $row) {
            if (!isset($row['row_index'])) continue;
            $heirsByIdx[(int)$row['row_index']] = $row;
        }
        if (empty($heirsByIdx)) {
            return [$after, $projAfter];
        }


        // ★ あなた仕様の遺産分割比率（固定）を作る：
        //  - 法定：金融/その他とも legal_ratio（民法割合）
        //  - 手入力：
        //      ・金融資産なし：その他比率は id_other_share、金融は0
        //      ・金融資産あり：金融比率は id_cash_share、その他比率は id_other_share
        $splitRatios = $this->resolveEstateSplitRatiosFixed($payload, $heirsByIdx);
        $cashRatioByIdx  = $splitRatios['cash']  ?? [];
        $otherRatioByIdx = $splitRatios['other'] ?? [];

        // 内部ユーティリティ：指定合計を ratio で按分（端数は最後へ）
        $applyAllocation = function (&$heirs, int $total, array $ratios, string $field): void {
            if ($total <= 0 || !is_array($heirs)) return;
            $lastKey   = null;
            $allocated = 0;
            foreach ($heirs as $k => &$row) {
                $idx = $row['row_index'] ?? null;
                if ($idx === null || !isset($ratios[$idx])) continue;
                $lastKey = $k;
                $share   = (int)floor($total * $ratios[$idx]);
                $row[$field] = $share;
                $allocated                   += $share;
            }
            // 端数は最後の一人に寄せる
            if ($lastKey !== null) {
                $heirs[$lastKey][$field] =
                    ($heirs[$lastKey][$field] ?? 0) + ($total - $allocated);
            }
        };

        // 2) after(t=0)：金融/その他を別々に按分し、合計も作る
        $cash0  = (int)($after['summary']['estate_after_cash_yen']  ?? 0);
        $oth0   = (int)($after['summary']['estate_after_other_yen'] ?? 0);
        $applyAllocation($after['heirs'], $cash0, $cashRatioByIdx,  'estate_cash_share_yen');
        $applyAllocation($after['heirs'], $oth0,  $otherRatioByIdx, 'estate_other_share_yen');
        foreach ($after['heirs'] as &$row) {
            $row['estate_base_share_yen'] =
                (int)($row['estate_cash_share_yen'] ?? 0) + (int)($row['estate_other_share_yen'] ?? 0);
        }
        unset($row);

        // 3) 年次プロジェクション after[t] も同じ比率（t=0固定）で按分
        if (is_array($projAfter)) {
            foreach ($projAfter as $t => $row) {
                if (!isset($row['summary']['estate_base_yen'], $row['heirs']) || !is_array($row['heirs'])) {
                    continue;
                }
                $cashT = (int)($row['summary']['estate_after_cash_yen']  ?? 0);
                $othT  = (int)($row['summary']['estate_after_other_yen'] ?? 0);
                $applyAllocation($row['heirs'], $cashT, $cashRatioByIdx,  'estate_cash_share_yen');
                $applyAllocation($row['heirs'], $othT,  $otherRatioByIdx, 'estate_other_share_yen');
                foreach ($row['heirs'] as &$hr) {
                    $hr['estate_base_share_yen'] =
                        (int)($hr['estate_cash_share_yen'] ?? 0) + (int)($hr['estate_other_share_yen'] ?? 0);
                }
                unset($hr);
                $projAfter[$t] = $row;
            }
        }

        return [$after, $projAfter];
    }


    /**
     * 「課税価格の取得がある人（相続/遺贈で財産を取得する人）」の idx(2..10) を決定する。
     *
     * 仕様：
     * - auto  : 法定相続人（bunsi/bunbo がある行）のみ
     * - manual: id_taxable_manu（手入力の課税価格）が >0 の行のみ
     *          ※ manual で 1件も無い場合は互換性のため heirs にフォールバック
     *
     * ここで決まった idx のみが「生前贈与加算」「贈与税額控除」「精算課税贈与税控除」の対象となる。
     *
     * @param array $payload
     * @param array $heirs collectHeirs() の結果
     * @return int[] idx の配列（昇順・ユニーク）
     */
    private function resolveTaxableAcquirerIdxList(array $payload, array $heirs): array
    {
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));

        $idxs = [];
        if ($mode === 'manual') {
            for ($i = 2; $i <= 10; $i++) {
                $kyen = $this->readKyen($payload, 'id_taxable_manu', $i);
                if ($kyen > 0) {
                    $idxs[] = $i;
                }
            }
            // manual 入力が1件も無い場合は heirs を採用（互換性確保）
            if (empty($idxs)) {
                foreach ($heirs as $h) {
                    $idx = (int)($h['idx'] ?? 0);
                    if ($idx >= 2 && $idx <= 10) $idxs[] = $idx;
                }
            }
        } else {
            foreach ($heirs as $h) {
                $idx = (int)($h['idx'] ?? 0);
            if ($idx >= 2 && $idx <= 10) $idxs[] = $idx;
            }
        }

        $idxs = array_values(array_unique(array_filter($idxs, fn($v) => is_int($v) && $v >= 2 && $v <= 10)));
        sort($idxs);
        return $idxs;
    }


    // ============================================================
    // ★ 4ケース判定・補助
    // ============================================================

    private function resolveCaseConfig(array $payload, int $dataId): array
    {
        $allocation = $this->resolveAllocationModeFromPayload($payload); // 'legal'|'manual'
        $hasFinance = $this->resolveHasFinanceFromPayloadOrDb($payload, $dataId); // bool

        // まずケースの素の config を取得
        if ($hasFinance) {
            $cfg = $allocation === 'manual'
                ? HasFinanceManualCase::config()
                : HasFinanceLegalCase::config();
        } else {
            $cfg = $allocation === 'manual'
                ? NoFinanceManualCase::config()
                : NoFinanceLegalCase::config();
        }

        // ★重要：以後の判定はこの2キーを正として必ず持たせる（Case::config() のキー揺れ吸収）
        // - isNoFinanceLegalCase()
        // - resolveEstateSplitRatiosFixed()
        // - （将来）その他ケース分岐
        $cfg['allocation_mode'] = ($allocation === 'manual') ? 'manual' : 'legal';
        $cfg['has_finance']     = (bool)$hasFinance;

        return $cfg;
    }

    private function resolveAllocationModeFromPayload(array $payload): string
    {
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        return $mode === 'manual' ? 'manual' : 'legal';
    }

    /**
     * 金融資産あり/なし判定：
     *  - 全員(1..10)の金融資産欄（cash）が「すべて0」なら金融資産なし
     *  - payload で取れない場合は DB（proposal_family_members.cash_thousand）で判定
     */
    private function resolveHasFinanceFromPayloadOrDb(array $payload, int $dataId): bool
    {
        $sumK = 0;
        for ($i = 1; $i <= 10; $i++) {
            $k = $this->readKyen($payload, 'cash', $i); // 千円
            if ($k > 0) $sumK += $k;
        }
        if ($sumK > 0) return true;

        // payload が空/未送信のケースをDBでフォールバック
        try {
            $dbSum = (int) ProposalFamilyMember::query()
                ->where('data_id', $dataId)
                ->whereBetween('row_no', [1, 10])
                ->sum('cash_thousand');
            return $dbSum > 0;
        } catch (\Throwable $e) {
            //Log::warning('2025.12.17 10001 [ZouyotaxCalc][has_finance] DB fallback failed', ['error' => $e->getMessage()]);
            return false;
        }
    }

    /**
     * 被相続人(No=1)の金融資産は運用しない（t=0..20で一定）
     * ※将来、ケースにより運用可にする余地は残す（configで切替）
     */
    private function decedentCashAtYear(int $cashNowYen, int $yearsAhead, float $rate): int
    {
        $grows = (bool)($this->caseConfig['decedent_cash_grows'] ?? false);
        if (!$grows) {
            return max(0, $cashNowYen);
        }
        $safeRate = max($rate, -0.999999);
        return (int)round(max(0, $cashNowYen) * pow(1 + $safeRate, max(0, $yearsAhead)));
    }

    /**
     * 将来贈与の原資上限（No=1のみ）
     *  - 金融資産あり：No=1 cash
     *  - 金融資産なし：No=1 nonCash
     */
    private function giftBudgetYenForDecedent(int $nonCashYen, int $cashYenAtYear): int
    {
        $source = (string)($this->caseConfig['gift_funding_source'] ?? 'cash1');
        if ($source === 'noncash1') {
            return max(0, $nonCashYen);
        }
        return max(0, $cashYenAtYear);
    }
    

    /**
     * 遺産分割（t=0..20固定）の比率を作る（あなた仕様）
     * - 法定相続割合：金融/その他とも legal_ratio（民法割合）
     * - 手入力：
     *   ・金融資産なし：その他は id_other_share の比率、金融は全員0
     *   ・金融資産あり：金融は id_cash_share、その他は id_other_share の比率
     *
     * $heirsByIdx は after.heirs を row_index=>row にしたもの（legal_ratioが入っている想定）
     */
    private function resolveEstateSplitRatiosFixed(array $payload, array $heirsByIdx): array
    {
        $mode = (string)($this->caseConfig['allocation_mode'] ?? 'legal'); // 'legal'|'manual'
        $hasFinance = (bool)($this->caseConfig['has_finance'] ?? false);

        $cash = [];
        $other = [];
        for ($no = 2; $no <= 10; $no++) {
            $cash[$no] = 0.0;
            $other[$no] = 0.0;
        }

        // 1) 法定：legal_ratio を両方に採用（正規化）
        if ($mode === 'legal') {
            $sum = 0.0;
            for ($no = 2; $no <= 10; $no++) {
                $r = (float)($heirsByIdx[$no]['legal_ratio'] ?? 0.0);
                if ($r > 0) $sum += $r;
            }
            if ($sum <= 0.0) return ['cash'=>$cash,'other'=>$other];
            for ($no = 2; $no <= 10; $no++) {
                $r = (float)($heirsByIdx[$no]['legal_ratio'] ?? 0.0);
                $v = $r > 0 ? ($r / $sum) : 0.0;
                $cash[$no] = $v;
                $other[$no] = $v;
            }
            return ['cash'=>$cash,'other'=>$other];
        }

        // 2) 手入力：入力値で比率化（0なら法定へフォールバック）
        $readK = function(string $base, int $no) use ($payload): int {
            $raw = \Illuminate\Support\Arr::get($payload, "{$base}.{$no}", '');
            if (!is_string($raw) && !is_numeric($raw)) return 0;
            $normalized = preg_replace('/[^\d\-]/u', '', (string)$raw) ?? '0';
            return (int)$normalized;
        };

        // 2-1) その他資産比率（常に id_other_share）
        $sumOther = 0;
        $wOther = [];
        for ($no = 2; $no <= 10; $no++) {
            $v = max(0, $readK('id_other_share', $no));
            $wOther[$no] = $v;
            $sumOther += $v;
        }
        if ($sumOther > 0) {
            for ($no = 2; $no <= 10; $no++) {
                $other[$no] = ($wOther[$no] ?? 0) / $sumOther;
            }
        }

        // 2-2) 金融資産比率（金融資産ありのときだけ id_cash_share）
        if ($hasFinance) {
            $sumCash = 0;
            $wCash = [];
            for ($no = 2; $no <= 10; $no++) {
                $v = max(0, $readK('id_cash_share', $no));
                $wCash[$no] = $v;
                $sumCash += $v;
            }
            if ($sumCash > 0) {
                for ($no = 2; $no <= 10; $no++) {
                    $cash[$no] = ($wCash[$no] ?? 0) / $sumCash;
                }
            }
        }

        // フォールバック：比率が全部0なら法定へ
        $sumCheck = array_sum($cash) + array_sum($other);
        if ($sumCheck <= 0.0) {
            $cfgBak = $this->caseConfig;
            $this->caseConfig['allocation_mode'] = 'legal';
            $out = $this->resolveEstateSplitRatiosFixed($payload, $heirsByIdx);
            $this->caseConfig = $cfgBak;
            return $out;
        }

        return ['cash'=>$cash,'other'=>$other];
    }


    /**
     * gift_year/month/day の欠損に強い日付生成（PastGift* の月日欠損で算入漏れしないため）
     * - month/day が 0/欠損なら 12/31 扱い（年だけ入力のレコードを年末扱いで評価）
     * - 2/31 等の不正日は「当月末日」に丸める
     */
    private function safeDateYmd(int $y, int $m, int $d): ?\DateTimeImmutable
    {
        if ($y < 1900) {
            return null;
        }
        if ($m < 1 || $m > 12) {
            $m = 12;
        }
        if ($d < 1 || $d > 31) {
            $d = 31;
        }
        try {
            return new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $y, $m, $d));
        } catch (\Throwable $e) {
            // 例：2024-02-31 のような不正日 → 当月末日へ丸める
            try {
                $first = new \DateTimeImmutable(sprintf('%04d-%02d-01', $y, $m));
                return $first->modify('last day of this month');
            } catch (\Throwable $e2) {
                return null;
            }
        }
    }


    /**
     * FutureGiftPlanEntry から「暦年贈与税（千円）」を安全に取り出す。
     * - 列名揺れを吸収（special / general / normal / legacy）
     * - それでも 0 の場合は attributes を走査して自動検出（1人分だけ税額が欠ける対策）
     */
    private function resolveFutureCalendarTaxK(FutureGiftPlanEntry $r): int
    {
        $val = 0;
        $candidates = [
            'calendar_special_tax_thousand',
            'calendar_tax_thousand',
            'calendar_general_tax_thousand',
            'calendar_normal_tax_thousand',
            'calendar_calc_tax_thousand',
            'tax_thousand',
        ];
        foreach ($candidates as $col) {
            $v = (int)($r->{$col} ?? 0);
            if ($v > $val) { $val = $v; }
        }

        // まだ 0 の場合：attributes から "calendar*tax*thousand" を自動検出
        if ($val <= 0) {
            $attrs = method_exists($r, 'getAttributes') ? (array)$r->getAttributes() : [];
            foreach ($attrs as $k => $v) {
                if (!is_numeric($v)) continue;
                $kk = (string)$k;
                // 例: calendar_*tax*_thousand / calendar_*_tax*_thousand 等
                if (preg_match('/^calendar_.*tax.*_thousand$/i', $kk)) {
                    $vv = (int)$v;
                    if ($vv > $val) { $val = $vv; }
                }
            }
        }

        // デバッグ：金額があるのに税額が 0 の行だけ吐く（本番ノイズ抑制）
        if ($val <= 0 && (int)($r->calendar_amount_thousand ?? 0) > 0 && (bool)config('app.debug')) {
            Log::debug('[ZouyotaxCalc][future_plan][calendar_tax_missing]', [
                'id'            => (int)($r->id ?? 0),
                'data_id'        => (int)($r->data_id ?? 0),
                'recipient_no'   => (int)($r->recipient_no ?? 0),
                'row_no'         => (int)($r->row_no ?? 0),
                'amount_thousand'=> (int)($r->calendar_amount_thousand ?? 0),
                // よく使う候補列も併記（原因特定用）
                'calendar_special_tax_thousand' => (int)($r->calendar_special_tax_thousand ?? 0),
                'calendar_tax_thousand'         => (int)($r->calendar_tax_thousand ?? 0),
                'tax_thousand'                  => (int)($r->tax_thousand ?? 0),
                'attr_keys'                     => array_keys((array)$r->getAttributes()),
            ]);
        }

        return max(0, $val);
    }

    /**
     * FutureGiftPlanEntry から「精算課税贈与税（千円）」を安全に取り出す。
     * - 列名揺れ吸収
     * - それでも 0 の場合は attributes を走査して自動検出
     */
