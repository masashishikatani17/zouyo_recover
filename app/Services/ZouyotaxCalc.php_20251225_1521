    /**
     * 暦年課税の対象期間（開始日・終了日）を死亡日に応じて返す
     */
    private function determineCalendarGiftLookbackRange(\DateTimeImmutable $deathDate): array
    {
        $end        = $deathDate;
        $r8End      = new \DateTimeImmutable('2026-12-31');
        $r9Start    = new \DateTimeImmutable('2027-01-01');
        // ★JS(future_zouyo.blade)に合わせる：固定開始の特例は 2030-12-31 まで
        $r12End     = new \DateTimeImmutable('2030-12-31');
        $fixedStart = new \DateTimeImmutable('2024-01-01');

        if ($deathDate <= $r8End) {
            // ～2026年死亡：従来どおり「死亡前3年」
            $start = $deathDate->sub(new \DateInterval('P3Y')); // 3年
            return [$start, $end];

        } elseif ($deathDate >= $r9Start && $deathDate <= $r12End) {
            // 2027-01-01 ～ 2030-12-31 死亡：
            //   暦年課税の算入期間は一律 2024-01-01 から死亡日まで
            return [$fixedStart, $end]; // 2024-01-01 ～ 当日

        } else {
            // 2032-01-01 以降死亡：一般ルールとして「死亡前7年」
            $start = $deathDate->sub(new \DateInterval('P7Y')); // 7年
            return [$start, $end];
        }
    }

    
