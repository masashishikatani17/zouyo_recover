/**
 * 相続税の対策前（これからの贈与は無視）計算
 * - 被相続人（行1）の「所有財産＋金融資産＋改正に基づく過年度贈与算入」をベース資産とする
 * - 基礎控除：3,000万円 + 600万円 × 法定相続人の数
 * - 相続税総額は「法定相続分課税」に速算表を当てて合計
 * - 個人配賦（算出税額）は「相続税総額 × あん分割合」
 *   - manual のあん分割合：id_taxable_manu[2..10] の“課税価格の割合”
 *   - auto   のあん分割合：法定相続割合（legal_ratio）
 * - 2割加算、暦年贈与税額控除、配偶者軽減、その他控除、精算課税贈与税控除の順に適用
 * - 画面単位「千円」→ 内部「円」で計算
 */
class ZouyotaxCalc
{





    /**
     * future_gift_plan_entries.row_no の基準補正
     * - DBに 0..19 で保存されているデータがある場合：+1して 1..20 に正規化する
     * - 1..20 の場合：補正なし（0）
     */
    private int $futurePlanRowNoOffset = 0;

    /**
     * future_gift_plan_entries.row_no を t(1..20) に正規化する
     * - 0始まり(0..19) の場合は +1 して 1..20 へ
     * - 1..20 の場合はそのまま
     */
    private function normalizeFuturePlanT(int $rowNo): int
    {
        if ($this->futurePlanRowNoOffset === 1) {
            if ($rowNo >= 0 && $rowNo <= 19) return $rowNo + 1;
        }
        return $rowNo;
    }



    /** @var array<string,mixed> */
    private array $caseConfig = [];

    /**
     * projections（年次表）用の「基準死亡日」を JS(future_zouyo.blade) と一致させる。
     *
     * JS の死亡日は new Date(2024 + i, inherit_base_month/day...) で作られているため、
     * PHP 側も「年=2024固定」「月日=inherit_base_month/day」を採用する。
     *
     * 優先順位（month/day）:
     *  1) payload inherit_base_month / inherit_base_day
     *  2) PastGiftInput inherit_month / inherit_day（後方互換）
     *  3) 12/31
     */
    private function resolveProjectionBaseDeathDate(array $payload, int $dataId): \DateTimeImmutable
    {
        $mm = (int)preg_replace('/[^\d]/', '', (string)Arr::get($payload, 'inherit_base_month', '')) ?: 0;
        $dd = (int)preg_replace('/[^\d]/', '', (string)Arr::get($payload, 'inherit_base_day',   '')) ?: 0;

 
        // ★UI側で死亡日（月日）を header_* で持っている場合があるため、ここでも拾う
        //   inherit_base_* が未入力なら header_* を採用する（年は projections のため使わない）
        if ($mm < 1 || $mm > 12 || $dd < 1 || $dd > 31) {
            $mm2 = (int)preg_replace('/[^\d]/', '', (string)Arr::get($payload, 'header_month', '')) ?: 0;
            $dd2 = (int)preg_replace('/[^\d]/', '', (string)Arr::get($payload, 'header_day',   '')) ?: 0;
            if ($mm2 >= 1 && $mm2 <= 12 && $dd2 >= 1 && $dd2 <= 31) {
                $mm = $mm2;
                $dd = $dd2;
            }
        }


        // 後方互換：PastGiftInput の月日を読む（yearは使わない）
        if ($mm < 1 || $mm > 12 || $dd < 1 || $dd > 31) {
            try {
                $pg = PastGiftInput::query()
                    ->where('data_id', $dataId)
                    ->first(['inherit_month','inherit_day']);
                if ($pg) {
                    $mm = (int)($pg->inherit_month ?? 0);
                    $dd = (int)($pg->inherit_day   ?? 0);
                }
            } catch (\Throwable $e) {
                // 何もしない（下のフォールバックへ）
            }
        }

        if ($mm < 1 || $mm > 12) { $mm = 12; }
        if ($dd < 1 || $dd > 31) { $dd = 31; }

        // ★基準年は JS と同じく 2024 固定
        return new \DateTimeImmutable(sprintf('2024-%02d-%02d', $mm, $dd));
    }




    /**
     * エントリポイント
     * @param array $payload  request()->all() を想定
     * @return array {
     *   before:      {...},   // 対策前
     *   after:       {...},   // 対策後（将来贈与プラン反映）
     *   delta:       {...},   // 差額（after - before）
     *   projections: { before:[], after:[], delta:[] }
     * }
     */
    public function compute(array $payload, array $heirs): array
    {
        
        // ★ data_id は当面固定（既存仕様を踏襲）
        //$dataId   = (int)($payload['data_id'] ?? 0);
        $dataId = 1;

        //2025.12.18 01

        // ★ future_gift_plan_entries.row_no の 0始まり混在を吸収（1年ズレ対策）
        $this->futurePlanRowNoOffset = $this->resolveFuturePlanRowNoOffset($dataId);
        
        /*
        Log::debug('[ZouyotaxCalc][future_plan_row_no_offset]', [
            'data_id' => $dataId,
            'offset'  => $this->futurePlanRowNoOffset,
        ]);
        */

        // ------------------------------------------------------------
        // ★ ケース判定（4ケース）
        //   - 金融資産あり/なし：全員(1..10)の金融資産欄合計が0なら「なし」
        //   - 遺産分割：input_mode（manual/auto）
        // ------------------------------------------------------------
        $this->caseConfig = $this->resolveCaseConfig($payload, $dataId);
        
        //Log::info('2025.12.17 000001 [ZouyotaxCalc][case]', $this->caseConfig);

        $brackets = $this->loadInheritanceBrackets();
        

        // ▼ 暦年贈与の年次合計（千円）は「保存済みのDB（FutureGiftPlanEntry）」から取得（必須要件）
        //   ※DBに無い/未保存の年だけに限り、最後の手段で payload を参照
        $calAmountByYearK = $this->readSavedFutureCalAmountByYearK($dataId); // [1..20]=>千円
        if (empty($calAmountByYearK)) {
            // フォールバック：どうしてもDBに見つからない場合のみ、POST値を使用
            $calAmountByYearK = $this->readPlanKyenArrayAllRecipients($payload, 'cal_amount');
        }

        // 暦年課税（cal_amount）の年次合計（千円）
        $sumCalAmountK = function(int $t) use ($calAmountByYearK): int {
            if ($t <= 0) return 0;
            return (int)($calAmountByYearK[$t] ?? 0);
        };
        // 精算課税（set_amount）の年次合計（千円）
        $setAmountByYearK = $this->readSavedFutureSetAmountByYearK($dataId);
        if (empty($setAmountByYearK)) {
            $setAmountByYearK = $this->readPlanKyenArrayAllRecipients($payload, 'set_amount');
        }
        $sumSetAmountK = function(int $t) use ($setAmountByYearK): int {
            return $t > 0 ? (int)($setAmountByYearK[$t] ?? 0) : 0;
        };


        // 1) ベース資産（円）… POST が無ければ DB からフェイルオーバー取得
        //    propertyNowYen は「総資産（現時点）」、cashNowYen はその内訳の一部（運用対象）
        [$propertyNowYen, $cashNowYen, $rate] = $this->resolveBaseFromPayloadOrDb($payload, $dataId);
        $nonCashNowYen = max(0, $propertyNowYen - $cashNowYen); // ★“非現金”部分
        
        // 🎯 1. 遺産資産ベースを初期化（将来贈与によって減らさない）
        $propertyNowYenInitial = $propertyNowYen;
        
        // 🎯 2. 相続人一覧を取得（課税対象者リスト作成に必要）
        
        // 🎯 3. 死亡日（t=0）
        $baseDeathDate = $this->resolveDeathDateFromPayload($payload, $dataId);


        // 🎯 4. 課税対象者リスト（贈与加算対象を限定するため）
        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);
        
        // 🎯 5. 対策前の贈与加算（t=0のみで固定）
        $giftInclFixed = $this->calcPastGiftsIncludedInEstateByRecipient(
            $dataId,
            $baseDeathDate,
            $taxableAcquirerIdxList
        );

        // ★ ここで死亡日を解決しておく（下で $deathDate を使用するため）
        $deathDate = $this->resolveDeathDateFromPayload($payload, $dataId);
        

        // 2) 法定相続人候補（bunsi>=1 && bunbo>=1 の行2..10）
        // ★ $heirs を必ずここで定義（Undefined variable $heirs 対策）
        $heirs = $this->collectHeirs($payload);
        if (!is_array($heirs)) {
            $heirs = [];
        }

        $bunsiCount = count(array_filter($heirs, function ($h) {
            // 配列でもオブジェクトでも動くように吸収
            $bunsi = is_array($h) ? ($h['bunsi'] ?? 0) : ($h->bunsi ?? 0);
            return (int)$bunsi >= 1;
        }));
 
        /*
        Log::debug('2025.12.15 bunsi>=1 count', ['bunsiCount' => $bunsiCount]);
        */
 
        $heirCount = $bunsiCount;

        // ★「課税価格の取得がある人（相続/遺贈で取得する人）」のみを生前贈与加算の対象にする
        //   - auto  : heirs のみ
        //   - manual: id_taxable_manu >0 の行のみ（空なら heirs にフォールバック）
        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);
 


        // 1.5) 0年目の相続財産（対策前：過年度贈与を合算）
        // ★ property は総資産に cash を含むため、ここで cash を再加算しない
        $estateBaseNoGiftsYen = $propertyNowYen;


        // 相続人別の生前贈与加算額（対策前）を先に算定
        $giftIncl   = $this->calcPastGiftsIncludedInEstateByRecipient(
            $dataId,
            $deathDate,
            $taxableAcquirerIdxList
        );


        // 元遺産 + 贈与合計（法上の算入は遺産合計に対して実施）
        $estateYen  = $estateBaseNoGiftsYen + (int)($giftIncl['total_yen'] ?? 0);

            
            /*
            Log::info('2025.12.19 30001 [ZouyotaxCalc][6-03] legal share', [
                'estateYen'      => $estateYen,
            ]);
            */


        // 3) 基礎控除
        $basicDeduction = 30_000_000 + 6_000_000 * $heirCount;

        // 4) 課税遺産総額（auto用の標準値）
        $taxableEstate = max(0, $estateYen - $basicDeduction);

        // 5) 法定相続割合の正規化用合計
        // ★ per_idx（price_for_ratio）は「民法上の法定相続割合（civil）」を正とする
        //   → tax(bunsi/bunbo) ではなく civil_share_* を優先（未入力時のみフォールバック）
        $totalRatio = 0.0;
        foreach ($heirs as $h) {
            $r = (float)$this->civilRatio($h);
            if ($r > 0) {
                $totalRatio += $r;
            }
        }

        // 以降、各人の按分は「(bunsi/bunbo) / totalRatio」を使う
        // 例：
        // $ratio = (($bunsi / $bunbo) / $totalRatio);
        // $shareYen = (int) floor($taxableEstate * $ratio);


        // (A) manual 表示用
        //     ① 手入力 P_i に各人贈与 G_i を加えて合計 → ②合計から基礎控除を一括控除 → ③残額を P_i 比で按分
        $manualShares = $this->buildManualTaxableShares($payload, $basicDeduction, $giftIncl['per_idx'] ?? []);
        // manual の控除後合計（画面「課税遺産総額」に出す値）を取得し、
        // manual 有効時のみ 6-1 の速算ベースに採用
        $manualTotalTaxableYen = (int)($manualShares['total_taxable_yen'] ?? 0);
        $inputMode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        $isManualActive = ($inputMode === 'manual') && ($manualTotalTaxableYen > 0);
        $taxableEstateUsed = $isManualActive ? $manualTotalTaxableYen : $taxableEstate;


            /*
            // ★ここで課税遺産総額を確認
            Log::info('[ZouyotaxCalc][6-0] legal share', [
                'data_id'                => $dataId,
                'idx'                    => $h['idx'],
                'tax_able_EstateUsed'    => $taxableEstateUsed,
                'is_ManualActive'        => $isManualActive,
                'manual_TotalTaxableYen' => $manualTotalTaxableYen,
                'tax_ableEstate'         => $taxableEstate,
            ]);
            */

        // (B) 6-1 前の法定相続分テーブル
        $legalShareRows = [];

        // (C) 6-1：法定相続分課税の速算（相続税総額のベース）
        // ★税務上の法定相続割合（bunsi/bunbo）の正規化合計を作る
        $totalTaxRatio = 0.0;
        foreach ($heirs as $__h) {
            $bunsi = (int)($__h['bunsi'] ?? 0);
            $bunbo = (int)($__h['bunbo'] ?? 0);
            if ($bunsi >= 1 && $bunbo >= 1) {
                $totalTaxRatio += ($bunsi / $bunbo);
            }
        }
        $totalTaxRatio = $totalTaxRatio > 0 ? $totalTaxRatio : 1.0;

        //  1) 対策前（before：t=0）の相続税総額の計算処理
        $totalLegalShareTax = 0;
        foreach ($heirs as $h) {
            // ★税務上の法定相続割合で按分（bunsi/bunbo）
            $bunsi = (int)($h['bunsi'] ?? 0);
            $bunbo = (int)($h['bunbo'] ?? 0);
            $taxRatio = ($bunsi >= 1 && $bunbo >= 1) ? ($bunsi / $bunbo) : 0.0;
            $legalRatio = $taxRatio / $totalTaxRatio;

            $legalShareBase = (int)round($taxableEstateUsed * $legalRatio);
            
            //速算表より計算した各人の税額　相続税の総額の各人の欄に表示
            //  相続税総額の計算処理            
            $legalTax       = $this->applyInheritanceTable($legalShareBase, $brackets);

            $totalLegalShareTax += $legalTax;
        
            
            /*
            // ★ここで法定算出税額の中身を確認
            Log::info('2025.12.15 20001 [ZouyotaxCalc][6-1] legal share', [
                'data_id'            => $dataId,
                'idx'                => $h['idx'],
                'bunsi'              => $h['bunsi'],
                'bunbo'              => $h['bunbo'],
                'legal_ratio'        => $legalRatio,
                'taxableEstateUsed'  => $taxableEstateUsed,
                'legal_share_base'   => $legalShareBase,
                'legal_tax_yen'      => $legalTax,
            ]);
            */
            
            
            
        
            $legalShareRows[$h['idx']] = [
                'legal_ratio'     => $legalRatio,
                'legal_share_yen' => $legalShareBase,
                'legal_tax_yen'   => $legalTax,

                // 表示・保持用（税務上）
                'bunsi'           => (int)($h['bunsi'] ?? 0),
                'bunbo'           => (int)($h['bunbo'] ?? 1),
                // ★民法上（参考として持っておく）
                'civil_bunsi'     => (int)($h['civil_bunsi'] ?? 0),
                'civil_bunbo'     => (int)($h['civil_bunbo'] ?? 1),

                'two_tenths'      => (bool)$h['two_tenths'],
                'rel_code'        => (int)($h['rel_code'] ?? 0),
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$h['idx']] ?? 0),
            ];
        }
        

        /*
        // 合計もログ
        Log::info('[ZouyotaxCalc][6-1] total', [
            'data_id'           => $dataId,
            'taxableEstateUsed' => $taxableEstateUsed,
            'totalLegalShareTax'=> $totalLegalShareTax,
        ]);
        */

        // (D) 6-1直後：あん分割合の構築
        $anbun = $this->buildAnbunRatios($payload, $heirs, $legalShareRows);
        $anbunMode      = $anbun['mode'];    // 'manual' | 'auto'
        $anbunRatios    = $anbun['ratios'];  // idx => ratio（manualは2..10全員）
        $anbunTotalKyen = $anbun['total_kyen'];


        // ★ t=0(before) の「あん分割合／算出税額」はここで確定（課税価格合計割合）
        //    - あん分割合：buildAnbunRatios() が返す ratios（= id_taxable_manu + 生前贈与加算 の合計割合）
        //    - 算出税額：相続税総額 × あん分割合（floor配分 + 端数は最後へ寄せ）
        $sanzutsuTaxByIdx = array_fill(2, 9, 0);
        $allocated = 0;
        $lastIdx = null;
        for ($i = 2; $i <= 10; $i++) {
            $r = (float)($anbunRatios[$i] ?? 0.0);
            if ($r <= 0) continue;
            $lastIdx = $i;
            $tax = (int)floor($totalLegalShareTax * $r);
            $sanzutsuTaxByIdx[$i] = $tax;
            $allocated += $tax;
        }
        if ($lastIdx !== null) {
            $sanzutsuTaxByIdx[$lastIdx] += ($totalLegalShareTax - $allocated);
        }

        // ★ 安全のため初期化（全パスで必ず定義されている状態にする）
        $estateBaseForAlloc = 0;

        // ★ この年(t=0)の「贈与加算前ベース資産」を推定
        //    estateYen = estateBaseForAlloc + 贈与算入額(total_yen) という構造なので、
        //    贈与分を差し引くことで「ベース資産部分」を取り出す。
        $estateBaseForAlloc = $estateYen - (int)($giftIncl['total_yen'] ?? 0);
        if ($estateBaseForAlloc < 0) {
            $estateBaseForAlloc = 0;
        }

        // ★ 各 idx(2..10) について、その年(t=0)の「課税価格」を算定
        //   課税価格 P_i(0) ＝ ベース資産シェア_i(0) ＋ 現時点に算入される贈与分_i(0)
        //   ・manual: 入力された所有財産（id_taxable_manu）をそのままベース資産とする
        //   ・auto  : 原則 t=0 時点のあん分比率(anbunRatios)で estateBaseForAlloc を按分
        //            ★ただし「金融資産なし × 法定(民法)」は civil 比率で按分する
        //   ・法定相続人でない行でも、贈与加算額があれば課税価格に含めて按分対象とする
        $priceForRatioByIdx = [];
        $sumPriceForRatio   = 0;

        // ★NoFinanceLegalCase では「遺産部分」を civil 比率で floor 配分して固定する
        $baseShareYenByIdx0 = null;
        if ($this->isNoFinanceLegalCase()) {
            $civilRatios = $this->normalizedCivilRatiosByIdx($payload, $heirs);
            if (!empty($civilRatios)) {
                
                
                $baseShareYenByIdx0 = $this->allocateFloorByRatios($estateBaseForAlloc, $civilRatios);

                log::debug('2025.12.18 00002', [' baseShareYenByIdx0 = '=>$baseShareYenByIdx0]);
                
            }
        }

        for ($idx = 2; $idx <= 10; $idx++) {
            // t=0 のあん分比率（manual: id_taxable_manu 比率 / auto: 法定相続割合）
            $baseRatio  = (float)($anbunRatios[$idx] ?? 0.0);
            $manualKyen = 0; // ログ用に初期化（千円）

            // ベース資産シェア（贈与算入前の部分）
            if ($anbunMode === 'manual') {
                // manual モード：
                //  入力された各相続人の「所有財産（id_taxable_manu：千円）」を
                //  そのままベース資産とする（比率は掛けない）
                $manualKyen = $this->readKyen($payload, 'id_taxable_manu', $idx); // 千円
                if ($manualKyen < 0) {
                    $manualKyen = 0;
                }
                $baseShareYen = $this->toYen((int)$manualKyen); // 円に変換
            } else {
                // auto モード：
                //  原則はあん分比率で按分
                //  ★NoFinanceLegalCase のときだけ civil 比率（floor配分済み）を採用
                if (is_array($baseShareYenByIdx0)) {
                    $baseShareYen = (int)($baseShareYenByIdx0[$idx] ?? 0);
                } else {
                    $baseShareYen = (int)round($estateBaseForAlloc * $baseRatio);
                }
                
                //log::debug('2025.12.18 00003', [' baseShareYen = '=>$baseShareYen]);
                
            }

            // 現時点で estate に算入される贈与加算額（暦年＋精算）
            $giftYen = (int)($giftIncl['per_idx'][$idx] ?? 0);

            // 課税価格 P_i(0)
            $price = max(0, $baseShareYen + $giftYen);


            if ($price <= 0) {
                continue;
            }
            $priceForRatioByIdx[$idx] = $price;
            $sumPriceForRatio        += $price;

            /*
            log::debug('2025.12.18 00004', [' price = '=>$price]);
            */
            
            /*
            Log::info('10000_[ZouyotaxCalc][before_proj_per_idx]', [
                'idx'        => $idx,
                'manualKyen' => $manualKyen, // manual 時のみ実値、auto 時は 0
                '$price'     => $price,
            ]);
            */

        }

        // ★ 課税価格に基づく「t=0 のあん分比率」
        $anbunRatiosForYear = [];
        if ($sumPriceForRatio > 0) {
            foreach ($priceForRatioByIdx as $idx => $price) {
                $anbunRatiosForYear[$idx] = $price / $sumPriceForRatio;
            }
        } else {
            // フォールバック：全員0なら従来の比率をそのまま使用
            $anbunRatiosForYear = $anbunRatios;
        }



        // ★ この年(t)の「各相続人の生前贈与後の課税価格 P_i(t)」を per_idx として保持
        //   P_i(t) = 遺産按分額（baseShareYen） + 生前贈与加算（giftYen）
        //   ※ priceForRatioByIdx は $price<=0 の場合にキーが作られず 0 になり得るため、
        //     per_idx は必ず baseShareYenByIdx + giftIncl(per_idx) から直接組み立てる。
        $perIdx = [];
        for ($idx = 2; $idx <= 10; $idx++) {
            $baseShareYen = (int)($baseShareYenByIdx[$idx] ?? 0);
            $giftYen      = (int)($giftIncl['per_idx'][$idx] ?? 0);
            $perIdx[$idx] = [
                'price_for_ratio' => max(0, $baseShareYen + $giftYen),
            ];
        }


        // 暦年贈与税額控除（贈与税控除額）は “その年の死亡日” で評価する
        // ※ projections では compute() 外で作った結果を優先して受け取れるようにする
        // ★ override は未定義でも落ちないように null 合体で読む
        $giftTaxCredits = $giftTaxCreditsOverride ?? null;

        if ($giftTaxCredits === null) {
            $giftTaxCredits = $this->calcGiftTaxCreditsByRecipient(
                $dataId,
                $deathDate,
                $taxableAcquirerIdxList
            );
        }

        // ★精算課税贈与税控除は「受贈者全員・全額」（取得者フィルタ禁止）
        $settlementGiftTaxes = $this->calcSettlementGiftTaxesByRecipient($dataId);

        // 個別集計（projection でも idx=2..10 全員を対象）
        $finalTotalAfterSurcharge  = 0;
        $totalGiftTaxCredits       = 0;
        $totalPayableAfterCredits  = 0;
        $totalSpouseRelief         = 0;
        $totalPayableAfterSpouse   = 0;
        $totalOtherCredits         = 0;
        $totalPayableAfterOthers   = 0;
        $totalSashihikiTax         = 0;
        $totalSettlementGiftTaxes  = 0; // ★実際に控除できた精算贈与税（相続税の範囲内）
        $totalFinalAfterSettlement = 0; // ★支払税額合計（負値は入れない）
        $totalRefundTax            = 0; // ★還付合計（精算控除が相続税を上回った分）

        // 法定相続人マップ（rel_code / legal_ratio 等を引くため）
        $heirMap = [];
        foreach ($heirs as $h) {
            $idx = $h['idx'];
            $heirMap[$idx] = [
                'rel_code'        => (int)($h['rel_code'] ?? 0),
                'bunsi'           => (int)$h['bunsi'],
                'bunbo'           => (int)$h['bunbo'],
                'legal_ratio'     => $legalShareRows[$idx]['legal_ratio']     ?? 0.0,
                'legal_share_yen' => $legalShareRows[$idx]['legal_share_yen'] ?? 0,
                'legal_tax_yen'   => $legalShareRows[$idx]['legal_tax_yen']   ?? 0,
            ];
        }

        $breakdown = [];
        for ($idx = 2; $idx <= 10; $idx++) {
            $isHeir  = isset($heirMap[$idx]);
            $relCode = $heirMap[$idx]['rel_code'] ?? 0;

            // ★ t=0(before) の最終あん分割合（課税価格合計割合）
            $anbunRatio = (float)($anbunRatios[$idx] ?? 0.0);

            // ★ 算出税額（t=0確定値）：floor配分＋端数寄せで合計が必ず総額に一致する
            $sanzutsu = (int)($sanzutsuTaxByIdx[$idx] ?? 0);

            // 2割加算（チェックボックスで判定：法定相続人限定ではない）
            $twoTenths = $this->checkboxOn($payload, 'twenty_percent_add', $idx);
            $finalTax  = $twoTenths ? (int)round($sanzutsu * 1.2) : $sanzutsu;
            $finalTotalAfterSurcharge += $finalTax;
            
            
            /*
            // ★ 年次プロジェクション用：各人ごとの算出税額と2割加算後税額をログ出力
                Log::info('10001_[ZouyotaxCalc][before_proj_per_idx]', [
                    'estate_yen'   => $estateYen,
                    'idx'          => $idx,
                    'is_heir'      => $isHeir,
                    'anbun_ratio'  => $anbunRatio,
                    'sanzutsu'     => $sanzutsu,
                    'two_tenths'   => $twoTenths,
                    'final_tax'    => $finalTax,
                ]);
            */
            

            // 暦年贈与税額控除
            $creditCalendar  = (int)($giftTaxCredits[$idx]['calendar_yen'] ?? 0);
            $payAfterCalCred = max(0, $finalTax - max(0, $creditCalendar));
            $totalGiftTaxCredits      += min($finalTax, max(0, $creditCalendar));
            $totalPayableAfterCredits += $payAfterCalCred;

            // 配偶者軽減
            $spouseRelief   = 0;
            $payAfterSpouse = $payAfterCalCred;
            if ($isHeir && in_array($relCode, [3,4], true) && $payAfterCalCred > 0) {
                $legalRatioForIdx = (float)($heirMap[$idx]['legal_ratio'] ?? 0.0);
                $actualShareYen   = $this->resolveActualShareYenForIdx($payload, $idx, $estateYen, $legalRatioForIdx);
                $legalAmountYen   = (int)round($estateYen * $legalRatioForIdx);
                $targetBaseYen    = min($actualShareYen, max($legalAmountYen, 160_000_000));
                if ($actualShareYen > 0 && $targetBaseYen > 0) {
                    $spouseRelief = (int)floor($payAfterCalCred * ($targetBaseYen / $actualShareYen));
                    if ($spouseRelief > $payAfterCalCred) $spouseRelief = $payAfterCalCred;
                    if ($spouseRelief < 0) $spouseRelief = 0;
                    $payAfterSpouse = $payAfterCalCred - $spouseRelief;
                }
            }
            $totalSpouseRelief       += $spouseRelief;
            $totalPayableAfterSpouse += $payAfterSpouse;

            // その他控除
            $otherCreditYen = $this->toYen($this->readKyen($payload, 'id_other_credit', $idx));
            if ($otherCreditYen < 0) $otherCreditYen = 0;
            $payAfterOthers = max(0, $payAfterSpouse - $otherCreditYen);
            $totalOtherCredits       += min($payAfterSpouse, $otherCreditYen);
            $totalPayableAfterOthers += $payAfterOthers;

            // 差引税額
            $sashihikiTax = $payAfterOthers;
            $totalSashihikiTax += $sashihikiTax;

            // 対策前　精算課税贈与税控除
            $settlementGiftTaxYen = max(0, (int)($settlementGiftTaxes[$idx] ?? 0));
            $appliedSetCredit     = min(max(0, $sashihikiTax), $settlementGiftTaxYen);
            $finalAfterSettlement = $sashihikiTax - $appliedSetCredit; // ★必ず >=0
            $refundYen            = max(0, $settlementGiftTaxYen - $appliedSetCredit);

            $totalSettlementGiftTaxes  += $appliedSetCredit;
            $totalFinalAfterSettlement += $finalAfterSettlement;
            $totalRefundTax            += $refundYen;

            $breakdown[] = [
                'row_index'   => $idx,
                'bunsi'       => $isHeir ? ($heirMap[$idx]['bunsi'] ?? 0) : 0,
                'bunbo'       => $isHeir ? ($heirMap[$idx]['bunbo'] ?? 1) : 1,
                'legal_ratio' => $heirMap[$idx]['legal_ratio']     ?? 0.0,
                'legal_share_yen' => $heirMap[$idx]['legal_share_yen'] ?? 0,
                'legal_tax_yen'   => $heirMap[$idx]['legal_tax_yen']   ?? 0,
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$idx] ?? 0),
                'anbun_ratio'     => $anbunRatio,
                'sanzutsu_tax_yen'=> $sanzutsu,
                'final_tax_yen'   => $finalTax,
                'two_tenths_added'=> $twoTenths,
                'is_spouse'       => $isHeir ? in_array($relCode, [3,4], true) : false,
                'gift_tax_credit_calendar_yen'      => max(0, $creditCalendar),
                'payable_after_calendar_credit_yen' => $payAfterCalCred,
                'spouse_relief_yen'  => $spouseRelief,
                'payable_after_spouse_yen' => $payAfterSpouse,
                'other_credit_yen'   => $otherCreditYen,
                'payable_after_others_yen' => $payAfterOthers,
                'sashihiki_tax_yen'  => $sashihikiTax,
                'settlement_gift_tax_yen' => max(0, $settlementGiftTaxYen),
                'final_after_settlement_yen' => $finalAfterSettlement,
                'payable_tax_yen' => $finalAfterSettlement > 0 ? $finalAfterSettlement : 0,
                'refund_tax_yen'  => $finalAfterSettlement < 0 ? abs($finalAfterSettlement) : 0,
            ];
            
            

        }

        
        /*
        // ここまでで $finalTotalAfterSurcharge / $totalGiftTaxCredits ... が決まる
       Log::info('2025.12.18 40001 [ZouyotaxCalc][before_proj_sum_check]', [
           'estate_yen'           => $estateYen,
           'final_total'          => $finalTotalAfterSurcharge,
           'sum_final_tax_yen'    => array_sum(array_column($breakdown, 'final_tax_yen')),
           'total_gift_tax_credits' => $totalGiftTaxCredits,
           'total_pay_after_credits' => $totalPayableAfterCredits,
           'totalFinalAfterSettlement' => $totalFinalAfterSettlement
           
       ]);
       */
       


        // -------------------------
        // 対策前（before）サマリ生成
        // -------------------------


        // ★ 贈与税累計（暦年＋精算）※生前贈与加算対象かどうかは無関係
        //   受贈者 2..10 全員分の「実際に支払った贈与税」を合算する
        $giftTaxCumYen = 0;

        // 暦年贈与税（過去分）
        $calendarTaxAll = PastGiftCalendarEntry::query()
            ->where('data_id', $dataId)
            ->sum('tax_thousand');
        $giftTaxCumYen += $this->toYen((int)$calendarTaxAll);

        // 精算課税贈与税（過去分）
        $settlementTaxAll = PastGiftSettlementEntry::query()
            ->where('data_id', $dataId)
            ->sum('tax_thousand');
        $giftTaxCumYen += $this->toYen((int)$settlementTaxAll);


        $before = [
            'data_id' => $dataId,
            'summary' => [
                'estate_base_yen'  => $estateBaseNoGiftsYen,          // ★追加：ベース資産
                'estate_yen'       => $estateYen,
                'heir_count'       => $heirCount,
                'basic_deduction'  => $basicDeduction,
                'taxable_estate'                => $taxableEstateUsed,
                'past_gift_included_total_yen'  => (int)($giftIncl['total_yen'] ?? 0),
                // 過年度贈与の内訳（暦年／精算）… lookback ロジックの結果そのもの
                'incl_calendar_yen'             => (int)($giftIncl['calendar_total_yen']   ?? 0),
                'incl_settlement_yen'           => (int)($giftIncl['settlement_total_yen'] ?? 0),
                'past_gift_included_per_idx'    => $giftIncl['per_idx'] ?? [],
                'sozoku_tax_total'              => $totalLegalShareTax,
                'total_after_surcharge'         => $finalTotalAfterSurcharge,
                'total_gift_tax_credits'        => $totalGiftTaxCredits,
                'total_payable_after_calendar_credits' => $totalPayableAfterCredits,
                'total_spouse_relief' => $totalSpouseRelief,
                'total_payable_after_spouse' => $totalPayableAfterSpouse,
                'total_other_credits' => $totalOtherCredits,
                'total_payable_after_others'    => $totalPayableAfterOthers,
                'total_sashihiki_tax'           => $totalSashihikiTax,
                'total_settlement_gift_taxes'   => $totalSettlementGiftTaxes,
                'total_final_after_settlement'  => $totalFinalAfterSettlement,

                // ★ 贈与税累計（暦年＋精算）※受贈者全員分
                'gift_tax_cum_yen'              => $giftTaxCumYen,
                
                // ★最終相続税額（精算課税分控除後）＝画面表示用
                'final_after_settlement_yen'    => $totalFinalAfterSettlement,

                'anbun_mode' => $anbunMode,
                'anbun_total_kyen' => $anbunTotalKyen,
                // ★進行表用：t=0 の減少額（初期値は 0 に固定）
                'gift_decr_calendar_yen' => 0,
                'gift_decr_payment_yen'  => 0, // ← 精算課税（set）の累計マイナス表示用
            ],
            'heirs' => $breakdown,
            'meta'  => [
                'mode'    => 'inheritance_only_without_future_gifts',
                'version' => 'v1.0-manual-total-alloc',
                'ts'      => now()->toDateTimeString(),
                'anbun_mode' => $anbunMode,
            ],
        ];

        /*
        Log::info('[ZouyotaxCalc] computed(before)', [
            'data_id' => $dataId,
            'estate'  => $estateYen,
            'heirs'   => $heirCount,
            'sozoku_tax_total'      => $totalLegalShareTax,
            'total_after_surcharge' => $finalTotalAfterSurcharge,
            'anbun_mode'            => $anbunMode,
            'anbun_total_kyen'      => $anbunTotalKyen,
            // 追記：人別の過年度贈与加算をログに出力
            'past_gift_included_total_yen' => (int)($giftIncl['total_yen'] ?? 0),
            'past_gift_included_per_idx'   => $giftIncl['per_idx'] ?? [],
         ]);
         */

        // -------------------------
        // 対策後（after）を計算
        // -------------------------
        $futurePlan = $this->extractFuturePlanFromPayload($payload);
        
        /*
        Log::info('[DEBUG futurePlan]', $futurePlan);
        */

        // ★ 将来贈与プラン（暦年/精算）の「贈与税額（tax_thousand）」を年次ごとに集計（千円）
        $futureCalendarTaxByYearK  = array_fill(1, 20, 0);
        $futureSettlementTaxByYearK = array_fill(1, 20, 0);
        //暦年贈与
        foreach (($futurePlan['calendar'] ?? []) as $row) {
            $tRow = (int)($row['t'] ?? 0);
            if ($tRow >= 1 && $tRow <= 20) {
                $futureCalendarTaxByYearK[$tRow] += (int)($row['tax_thousand'] ?? 0);
            }
        }
        //精算課税贈与
        foreach (($futurePlan['settlement'] ?? []) as $row) {
            $tRow = (int)($row['t'] ?? 0);
            if ($tRow >= 1 && $tRow <= 20) {
                $futureSettlementTaxByYearK[$tRow] += (int)($row['settlement_tax20_thousand'] ?? 0);
                
                /*
                Log::debug('2025.12.08 000001 settlement_tax20_thousand = ', ['t' => $tRow, 'rows' => $row]);
                */
                
            }
        }

        // ★ t ごとの「これからの贈与税額」（暦年＋精算）の累計（千円）
        $cumFutureCalendarTaxK   = [0 => 0];
        $cumFutureSettlementTaxK = [0 => 0];
        $runCalK = 0;
        $runSetK = 0;
        for ($tt = 1; $tt <= 20; $tt++) {
            $runCalK += $futureCalendarTaxByYearK[$tt]   ?? 0;
            $runSetK += $futureSettlementTaxByYearK[$tt] ?? 0;
            $cumFutureCalendarTaxK[$tt]   = $runCalK;
            $cumFutureSettlementTaxK[$tt] = $runSetK;
        }

        // ★ 過去の「暦年贈与税額（tax_thousand）」累計（千円）→ 円
        $pastCalendarGiftTaxCumK = PastGiftCalendarEntry::query()
            ->where('data_id', $dataId)
            ->sum('tax_thousand');
        $pastCalendarGiftTaxCumYen = $this->toYen((int)$pastCalendarGiftTaxCumK);

        // ★ 過去の「精算課税に係る贈与税額（tax_thousand）」累計（千円）→ 円
        $pastSettlementGiftTaxCumK = PastGiftSettlementEntry::query()
            ->where('data_id', $dataId)
            ->sum('tax_thousand');
        $pastSettlementGiftTaxCumYen = $this->toYen((int)$pastSettlementGiftTaxCumK);

        // ★ ベースとなる「過去分のみの贈与税額累計」（暦年＋精算）
        $baseGiftTaxCumYen = $pastCalendarGiftTaxCumYen + $pastSettlementGiftTaxCumYen;

        // 「これからの贈与」が一切無いかどうか
        //  - 暦年/精算の年次金額（cal_amount / set_amount）がすべて 0
        //  - 将来贈与の calendar/settlement 配列も空
        $hasFuturePlanEntries =
            (array_sum($calAmountByYearK ?? []) > 0)
            || (array_sum($setAmountByYearK ?? []) > 0)
            || !empty($futurePlan['calendar'])
            || !empty($futurePlan['settlement']);

        // ★ 対策後シナリオへは「非現金」を渡す（総資産を再加算しないため）
        // ★ t=0（現時点）の after は「これからの贈与」を一切考慮しない
        //   → before と完全に同じ税額フローになるように、将来贈与プランを無視するフラグを立てて計算
        $after      = $this->computeScenario(
            $payload,
            $heirs,
            $basicDeduction,
            $nonCashNowYen,  // ← 修正：$propertyNowYen ではなく “非現金”
            $cashNowYen,
            $rate,
            $deathDate,
            $brackets,
            $futurePlan,
            true  // ← ignoreFuturePlanAtT0: t=0 では「これからの贈与」を無視
        );

        // ★ after(t=0) の表示用補助フィールドを初期化（現時点から必要なキーをすべて用意）
        $after['summary']['estate_base_yen']        = $estateBaseNoGiftsYen;
        $after['summary']['gift_decr_calendar_yen'] = 0; // 暦年の減少（累計・負値）※t=0は0
        $after['summary']['gift_decr_payment_yen']  = 0; // 精算の減少（累計・負値）※t=0は0
        // ★ t=0 は「過去分のみ」の贈与税額累計（暦年＋精算）
        $after['summary']['calendar_gift_tax_cum_yen'] = $baseGiftTaxCumYen;

        // ★projections（年次表）の死亡日基準は JS(future_zouyo.blade) と一致させる
        //   - 基準年は 2024 固定
        //   - 月日は inherit_base_month/day（無ければ header_month/day）を採用
        //  これにより incl_calendar_yen の年次ズレ（1年早く減る）を解消する。
        $projectionBaseDeathDate = $this->resolveProjectionBaseDeathDate($payload, $dataId);



        // ------------------------------------------------------------
        // 年次プロジェクション（t=0..20）
        // ------------------------------------------------------------

        $projBefore = [];
        $projAfter  = [];
        $projDelta  = [];
        $cumCalK = 0;
        $cumSetK = 0;

        for ($t = 0; $t <= 20; $t++) {
            // ★ 年次ごとの死亡日（projections 用：JS と一致）
            $deathDateT = (clone $projectionBaseDeathDate)->modify('+' . $t . ' year');

/*
Log::debug('2025.12.24 00001 [proj deathDateT]', ['t'=>$t, 'deathDateT'=>$deathDateT->format('Y-m-d')]);
*/
        
            // ★ 現金は利回りを反映、非現金は固定
            $cashT = $this->decedentCashAtYear($cashNowYen, $t, $rate);
            $estateBaseT = $nonCashNowYen + $cashT;

            // ------------------------------------------------------------
            // ★対策前プロジェクションの生前贈与加算は「その年の死亡日」で再評価する
            //   ※ ここを t=0 固定にすると、
            //      - 課税価格（総額）と
            //      - computeForGivenEstateAndDate() 内の per_idx/控除/比率
            //      が別々の贈与算入を参照してしまい、t>=2 で破綻する。
            // ------------------------------------------------------------
            $giftInclT = $this->calcPastGiftsIncludedInEstateByRecipient(
                $dataId,
                $deathDateT,
                $taxableAcquirerIdxList
            );


            // ★ 暦年贈与税額控除（贈与税控除額）は「その年の死亡日」で再評価する（固定しない）
            $giftTaxCreditsT = $this->calcGiftTaxCreditsByRecipient(
                $dataId,
                $deathDateT,
                $taxableAcquirerIdxList
            );

            //2025.12.23 1001
            // 課税価格（対策前）：現時点資産 + 当年死亡日の生前贈与加算
            $estateT = $estateBaseT + (int)($giftInclT['total_yen'] ?? 0);

            // 対策前プロジェクションのフル計算
            $projBefore[$t] = $this->computeForGivenEstateAndDate(
                $t,
                $payload,
                $heirs,
                $basicDeduction,
                $estateT,
                $deathDateT,
                $brackets,
                'before_proj',
                [],      // virtual（対策前は使用しない）
                null,    // estateAfterYenForAlloc
                $giftInclT,      // ★同じ giftIncl を関数内でも使う（不整合防止）
                $giftTaxCreditsT // ★暦年贈与税額控除も同じ deathDateT の結果を渡す（不整合防止）
            );
            $projBefore[$t]['summary']['estate_base_yen']        = $estateBaseT;
            $projBefore[$t]['summary']['gift_decr_calendar_yen'] = 0;
            $projBefore[$t]['summary']['gift_decr_payment_yen']  = 0;

            /*
            Log::info('2025.12.18 70001 [ZouyotaxCalc][proj][estate_check]', [
                't' => $t,
                'estate_yen' => $projBefore[$t]['summary']['estate_yen'] ?? null,
                'kazei_price_yen' => $projBefore[$t]['summary']['kazei_price_yen'] ?? null,
            ]);
            */

            // 対策後：将来贈与プランをT年次まで反映
            $projAfter[$t] = $this->computeScenarioForGivenDate(
                $t,
                $payload, $heirs, $basicDeduction,
                $nonCashNowYen, $cashNowYen, $rate,
                $deathDateT, $brackets, $futurePlan,
                $giftTaxCreditsT // ★暦年贈与税額控除（年次）を明示的に渡す
            );

            // ★ 贈与前の比較用（表示用途のみ）
            $projAfter[$t]['summary']['estate_before_gifts_yen']
                = (int)($projAfter[$t]['summary']['estate_base_yen'] ?? $estateBaseT);

            // 生前贈与額（累計の減少額）
            if ($t >= 1) {
                $cumCalK += $sumCalAmountK($t);
                $cumSetK += $sumSetAmountK($t);
            }
            $projAfter[$t]['summary']['gift_decr_calendar_yen'] = - $this->toYen($cumCalK);
            $projAfter[$t]['summary']['gift_decr_payment_yen']  = - $this->toYen($cumSetK);

            // ★ t ごとの「贈与税額累計」（暦年＋精算）の合計（千円）
            $futureTaxKTillT = (int)($cumFutureCalendarTaxK[$t] ?? 0)
                             + (int)($cumFutureSettlementTaxK[$t] ?? 0);

            // ★ 贈与税額累計（円）：過去分＋将来分（t年次まで）
            $projAfter[$t]['summary']['calendar_gift_tax_cum_yen']
                = $baseGiftTaxCumYen + $this->toYen($futureTaxKTillT);

        $projDelta[$t] = $this->buildDelta($projBefore[$t], $projAfter[$t]);
        } // end for t


        // ★ 「これからの贈与」が一切無い場合は、対策後シナリオを対策前と完全一致させる
        //   （相続税・贈与税累計・合計が before / projections.before と同じになるよう強制）
        if (!$hasFuturePlanEntries) {
            // ▼ 贈与税累計額（gift_tax_cum_yen）を1つだけ決めて、
            //    before / projections.before / after / projections.after ですべて同じ値を使う
            $giftCumYen = (int)(
                ($before['summary']['gift_tax_cum_yen'] ?? $before['summary']['gift_tax_total_yen'] ?? null)
                ?? (
                    (int)($before['summary']['total_gift_tax_credits']      ?? 0)
                  + (int)($before['summary']['total_settlement_gift_taxes'] ?? 0)
                )
            );
            // before(t=0) にセット
            $before['summary']['gift_tax_cum_yen'] = $giftCumYen;
            // projections.before[t] 全行に同じ値をセット
            foreach ($projBefore as $tt => $row) {
                if (!isset($projBefore[$tt]['summary']) || !is_array($projBefore[$tt]['summary'])) {
                    continue;
                }
                $projBefore[$tt]['summary']['gift_tax_cum_yen'] = $giftCumYen;
            }

            // after / projections.after は before / projections.before の完全コピー
            $after      = $before;
            $projAfter  = $projBefore;

            // 差額はすべて 0 に揃える
            $delta = $this->buildDelta($before, $before);

            $projDelta = [];
            foreach ($projBefore as $t => $beforeRow) {
                $projDelta[$t] = $this->buildDelta($beforeRow, $beforeRow);
            }


            return [
                'before'      => $before,
                'after'       => $after,
                'delta'       => $delta,
                'projections' => [
                    'before' => $projBefore,
                    'after'  => $projAfter,
                    'delta'  => $projDelta,
                ],
            ];
        }


        // ★ 課税価格の定義を統一：
        //   taxable_estate = estate_after_yen + incl_calendar_yen + incl_settlement_yen
        //   （対策後 after ＋ 年次プロジェクション projections.after に適用）
        [$after, $projAfter] = $this->normalizeTaxableEstateForAfter($after, $projAfter);

        // ★ after／年次プロジェクションの課税遺産総額を「各相続人の課税価格比率」で按分
        [$after, $projAfter] = $this->allocateTaxableEstateByFixedRatios($after, $projAfter);

        // ★ after／年次プロジェクションの所有財産(estate_base_yen)も
        //   同じ比率で各相続人に按分（heirs[].estate_base_share_yen）
        [$after, $projAfter] = $this->allocateEstateBaseByFixedRatios($after, $projAfter, $payload);

        // ★ 各受贈者（行2〜10）の「対策前の所有財産の推移」＋
        //   将来贈与・相続取得・相続税を persons.timeline に格納
        //   - asset_total_yen              … 元々の所有財産の推移（運用のみ反映）
        //   - gift_*                       … 将来贈与プランに基づく受領額／贈与税
        //   - inherit_net_yen              … 相続による取得財産（生前贈与加算前）
        //   - inherit_tax_yen              … 相続税額（final_after_settlement_yen）
        //   - investment_gain_yen          … 運用による増加額
        //   - asset_after_yen              … 上記の純増を反映した対策後残高（簡易版）
        $after['persons'] = $this->buildPersonBaselineTimelines(
            $payload,
            $dataId,
            $rate,
            $futurePlan,
            $after,
            $projAfter
        );



        // ★ 通常ルート（将来贈与あり）でも delta を必ず定義する
        //    ※ 正規化・按分・persons 反映後の “最終 after” と before で差分を作る
        $delta = $this->buildDelta($before, $after);


        return [
            'before'      => $before,
            'after'       => $after,
            'delta'       => $delta,
            'projections' => [
                'before' => $projBefore,
                'after'  => $projAfter,
                'delta'  => $projDelta,
            ],
        ];


    }




    /**
     * 「対策後(after)」および「年次プロジェクション(projections.after)」の
     * 「課税価格」と「課税遺産総額」を定義し直す。
     *
     *   課税価格（kazei_price_yen）
     *     = estate_after_yen + incl_calendar_yen + incl_settlement_yen
     *
     *   課税遺産総額（taxable_estate）
     *     = max(0, 課税価格 - basic_deduction)
     *
     * とし、summary['taxable_estate'] には「課税遺産総額」を格納する。
     *
     * estate_after_yen が未設定の場合は、
     *   estate_base_yen + gift_decr_calendar_yen + gift_decr_payment_yen
     * から補完する。
     */
    private function normalizeTaxableEstateForAfter(array $after, array $projAfter): array
    {
        $normalize = function (array $summary): array {
            $base    = (int)($summary['estate_base_yen']          ?? 0);
            $decrCal = (int)($summary['gift_decr_calendar_yen']   ?? 0);
            $decrSet = (int)($summary['gift_decr_payment_yen']    ?? 0);

            
            // ★（贈与後）相続財産の額（減額後）
            //   - computeScenarioForGivenDate() が正の値（現金流出控除後）を返している場合があるため、
            //     それを最優先する。
            //   - 無い場合のみ、従来通り base + decr で補完する。
            if (array_key_exists('estate_after_yen', $summary) && $summary['estate_after_yen'] !== null) {
                $estateAfter = (int)$summary['estate_after_yen'];
            } else {
                $estateAfter = $base + $decrCal + $decrSet;
            }
            if ($estateAfter < 0) $estateAfter = 0;

            // 生前贈与加算（暦年／精算）
            // ★ incl_* が未設定の場合は past_gift_included_total_yen から補完
            $inclCal = array_key_exists('incl_calendar_yen', $summary)
                ? (int)$summary['incl_calendar_yen']
                : 0;
    
            $inclSet = array_key_exists('incl_settlement_yen', $summary)
                ? (int)$summary['incl_settlement_yen']
                : 0;
    
            if ($inclCal === 0 && $inclSet === 0 && isset($summary['past_gift_included_total_yen'])) {
                // 内訳が無い場合は「合計をそのまま課税価格に足す」
                // （内訳比率は不要なので分解しない）
                $inclCal = (int)$summary['past_gift_included_total_yen'];
                $inclSet = 0;
            }
    

            // 課税価格（= 相続財産の額 + 贈与加算額）
            $kazeiPrice = $estateAfter + $inclCal + $inclSet;

            // 基礎控除額
            $basicDeduction = (int)($summary['basic_deduction'] ?? 0);

            // 課税価格・課税遺産総額を格納
            $summary['estate_after_yen'] = $estateAfter;
            $summary['kazei_price_yen']  = $kazeiPrice; // 課税価格（参考表示用）

            // ★修正：課税遺産総額を $kazeiPriceYen に基づいて強制的に上書き
            $summary['taxable_estate']   = max(0, $summary['kazei_price_yen'] - $basicDeduction);
            
            return $summary;
        };

        // 対策後(after) 本体
        if (isset($after['summary']) && is_array($after['summary'])) {
            $after['summary'] = $normalize($after['summary']);
        }

        // 年次プロジェクション after[t]
        if (is_array($projAfter)) {
            foreach ($projAfter as $t => $row) {
                if (!isset($row['summary']) || !is_array($row['summary'])) {
                    continue;
                }
                $row['summary']  = $normalize($row['summary']);
                $projAfter[$t]   = $row;
            }
        }

        /*
        Log::debug('2025.12.19 600001 [CHECK normalize]', $after['summary']);
        */
        


        return [$after, $projAfter];
    }

    /** payload の plan配列（例：cal_amount[i] / set_amount[i]：千円）や *_all を年次合算して返す */
    private function readPlanKyenArrayAllRecipients(array $payload, string $key): array
    {
        $sum = array_fill(1, 20, 0);
        // ① 受贈者横断の集計キー（例：cal_amount_all[recipient_no][t] / set_amount_all[recipient_no][t]）
        for ($rn = 2; $rn <= 10; $rn++) {
            for ($t = 1; $t <= 20; $t++) {
                $v = Arr::get($payload, "{$key}_all.{$rn}.{$t}");
                if ($v === null || $v === '') { continue; }
                $n = (int)preg_replace('/[^\d\-]/u', '', (string)$v);
                $sum[$t] += $n;
            }
        }
        // ② “現在開いている受贈者タブ” の一次元配列（plan[key][t] or key[t]）
        for ($t = 1; $t <= 20; $t++) {
            $v = Arr::get($payload, "{$key}.{$t}");
            if ($v === null) { $v = Arr::get($payload, "plan.{$key}.{$t}"); }
            if ($v === null || $v === '') { continue; }
            $n = (int)preg_replace('/[^\d\-]/u', '', (string)$v);
            $sum[$t] += $n;
        }
        return $sum;
    }




    // ===== 基本ユーティリティ =====

    /**
     * 死亡日（基準日）
     *
     * 優先順位：
     *  1. 提案書日付（ProposalHeader）  ★方針変更：死亡日＝提案書日付
     *  2. payload.header_year / header_month / header_day
     *  3. PastGiftInput の inherit_year/month/day（後方互換フォールバック）
     *  4. today()
     */
    private function resolveDeathDateFromPayload(array $payload, int $dataId): \DateTimeImmutable
    
    {

        // ① 画面入力の死亡日（header_*）を最優先
        //    ProposalHeader を最優先にすると、画面で死亡日を変更しても反映されない。

        // ② payload header（画面ヘッダ）フォールバック
        $rawYear  = Arr::get($payload, 'header_year');
        $rawMonth = Arr::get($payload, 'header_month');
        $rawDay   = Arr::get($payload, 'header_day');

        $headerYear  = (int)preg_replace('/[^\d]/', '', (string)$rawYear)  ?: 0;
        $headerMonth = (int)preg_replace('/[^\d]/', '', (string)$rawMonth) ?: 0;
        $headerDay   = (int)preg_replace('/[^\d]/', '', (string)$rawDay)   ?: 0;

        /*
        Log::info('[ZouyotaxCalc][resolveDeathDate] header raw', [
            'header_year_raw'  => $rawYear,
            'header_month_raw' => $rawMonth,
            'header_day_raw'   => $rawDay,
            'header_year_int'  => $headerYear,
            'header_month_int' => $headerMonth,
            'header_day_int'   => $headerDay,
        ]);
        */

        try {
            
            if ($headerYear >= 1900 && $headerMonth >= 1 && $headerMonth <= 12 && $headerDay >= 1 && $headerDay <= 31) {
                $date = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $headerYear, $headerMonth, $headerDay));
                return $date;
            }
        
            
        } catch (\Throwable $e) {
            // 次へ
        }

        // ② 提案書日付（ProposalHeader）をフォールバックとして採用
        $proposalDate = $this->resolveDeathDateFromProposalHeader($dataId);
        if ($proposalDate instanceof \DateTimeImmutable) {
            return $proposalDate;
        }

        // ③ PastGiftInput（後方互換フォールバック：提案書日付が無い/不明の場合のみ）
        try {

            $pg = PastGiftInput::query()
                ->where('data_id', $dataId)
                ->first(['inherit_year','inherit_month','inherit_day']);

            if ($pg) {
                $yy = (int)($pg->inherit_year ?? 0);
                $mm = (int)($pg->inherit_month ?? 0);
                $dd = (int)($pg->inherit_day ?? 0);

                // 年が PastGiftInput に無い場合はヘッダ年、さらに無ければ当年
                if ($yy < 1900) {
                    $yy = $headerYear >= 1900 ? $headerYear : (int)date('Y');
                }
                if ($mm < 1 || $mm > 12) {
                    $mm = $headerMonth >= 1 && $headerMonth <= 12 ? $headerMonth : 12;
                }
                if ($dd < 1 || $dd > 31) {
                    $dd = $headerDay >= 1 && $headerDay <= 31 ? $headerDay : 31;
                }

                $date = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $yy, $mm, $dd));
                
                /*
                Log::info('[ZouyotaxCalc][resolveDeathDate] use PastGiftInput (month/day) + header/today year', [
                    'data_id'        => $dataId,
                    'inherit_year'   => $pg->inherit_year,
                    'inherit_month'  => $pg->inherit_month,
                    'inherit_day'    => $pg->inherit_day,
                    'resolved'       => $date->format('Y-m-d'),
                ]);
                */
                
                /*
                Log::info('[ZouyotaxCalc][resolveDeathDate] use PastGiftInput date (fallback)', [
                    'data_id'  => $dataId,
                    'resolved' => $date->format('Y-m-d'),
                ]);
                */
                
                return $date;

            }
        
            
        } catch (\Throwable $e) {
            /*
            Log::warning('[ZouyotaxCalc][resolveDeathDate] PastGiftInput lookup failed', [
                'data_id' => $dataId,
                'error' => $e->getMessage(),
            ]);
            */
        }

        // ④ それでも決まらなければ today()
        $today = new \DateTimeImmutable('today');
        /*
        Log::info('[ZouyotaxCalc][resolveDeathDate] fallback to today', [
            'data_id'  => $dataId,
            'resolved' => $today->format('Y-m-d'),
        ]);
        */
        
        return $today;
    }



    /**
     * 提案書日付（ProposalHeader）から死亡日（相続開始日）を解決する
     * - スキーマ差異に強くするため、存在するカラムだけ参照する
     * - 優先順：proposal_date → proposal_year/month/day → created_at（最後の砦）
     */
    private function resolveDeathDateFromProposalHeader(int $dataId): ?\DateTimeImmutable
    {
        try {
            // proposal_date（date or datetime）を優先
            if (Schema::hasTable('proposal_headers') && Schema::hasColumn('proposal_headers', 'proposal_date')) {
                $ph = ProposalHeader::query()->where('data_id', $dataId)->first(['proposal_date']);
                $raw = $ph?->proposal_date ?? null;
                if ($raw) {
                    try {
                        $dt = new \DateTimeImmutable((string)$raw);
                        // time は不要なので日付に丸める（Y-m-d）
                        $date = new \DateTimeImmutable($dt->format('Y-m-d'));
                        
                        /*
                        Log::info('[ZouyotaxCalc][resolveDeathDate] use ProposalHeader.proposal_date', [
                            'data_id'  => $dataId,
                            'resolved' => $date->format('Y-m-d'),
                        ]);
                        */
                        
                        return $date;
                    } catch (\Throwable $e) {
                        // 次の候補へ
                    }
                }
            }

            // proposal_year / proposal_month / proposal_day がある場合
            $hasY = Schema::hasTable('proposal_headers') && Schema::hasColumn('proposal_headers', 'proposal_year');
            $hasM = Schema::hasTable('proposal_headers') && Schema::hasColumn('proposal_headers', 'proposal_month');
            $hasD = Schema::hasTable('proposal_headers') && Schema::hasColumn('proposal_headers', 'proposal_day');
            if ($hasY && $hasM && $hasD) {
                $ph = ProposalHeader::query()->where('data_id', $dataId)->first(['proposal_year','proposal_month','proposal_day']);
                if ($ph) {
                    $yy = (int)($ph->proposal_year ?? 0);
                    $mm = (int)($ph->proposal_month ?? 0);
                    $dd = (int)($ph->proposal_day ?? 0);
                    if ($yy >= 1900) {
                        if ($mm < 1 || $mm > 12) $mm = 12;
                        if ($dd < 1 || $dd > 31) $dd = 31;
                        $date = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $yy, $mm, $dd));
                        
                        /*
                        Log::info('[ZouyotaxCalc][resolveDeathDate] use ProposalHeader.proposal_year/month/day', [
                            'data_id'  => $dataId,
                            'resolved' => $date->format('Y-m-d'),
                        ]);
                        */
                        
                        
                        return $date;
                    }
                }
            }

            // created_at（最後の砦）
            if (Schema::hasTable('proposal_headers') && Schema::hasColumn('proposal_headers', 'created_at')) {
                $ph = ProposalHeader::query()->where('data_id', $dataId)->first(['created_at']);
                $raw = $ph?->created_at ?? null;
                if ($raw) {
                    $dt = new \DateTimeImmutable((string)$raw);
                    $date = new \DateTimeImmutable($dt->format('Y-m-d'));
                    
                    /*
                    Log::info('[ZouyotaxCalc][resolveDeathDate] use ProposalHeader.created_at (fallback)', [
                        'data_id'  => $dataId,
                        'resolved' => $date->format('Y-m-d'),
                    ]);
                    */
                    
                    
                    return $date;
                }
            }
        } catch (\Throwable $e) {
            
            /*
            Log::warning('[ZouyotaxCalc][resolveDeathDate] ProposalHeader lookup failed', [
                'data_id' => $dataId,
                'error'   => $e->getMessage(),
            ]);
            */
            
        }
        return null;
    }
 
    /**
     * 相続財産に算入する過年度贈与（相続人別＆合計）
     * - 暦年課税：改正ルックバック期間内のみ
     *   ・2027-01-02 以降に死亡する場合は「受贈者×年」の合計から 1,000,000 円控除した“超過分のみ”算入
     * - 精算課税：全件
     * - 受贈者が「現在の法定相続人かどうか」に関わらず recipient_no=2..10 を集計対象とする
     *
     * @param int   $dataId
     * @param \DateTimeImmutable $deathDate
     * @param int[] $heirIdxList   例: [2,3,5] （※現在は絞り込みには使用しない）
     * @return array{
     *   total_yen:int,
     *   per_idx:array<int,int>,
     *   calendar_total_yen:int,
     *   settlement_total_yen:int,
     *   calendar_per_idx:array<int,int>,
     *   settlement_per_idx:array<int,int>
     * }
     */
    private function calcPastGiftsIncludedInEstateByRecipient(
        int $dataId,
        \DateTimeImmutable $deathDate,
        array $heirIdxList
    ): array {
        // ★ 生前贈与加算の対象：
        //   「相続/遺贈で課税価格を取得する人（=課税価格の取得がある人）」のみ
        //   -> 呼び出し側で決定した $heirIdxList（idx配列）でフィルタする

        $targetSet = [];
        foreach ($heirIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) $targetSet[$i] = true;
        }
        $hasTargetFilter = !empty($targetSet);

        // デバッグ/将来拡張用（未定義Notice回避）
        $perCalYearK = [];

        // 暦年・精算・合計：受贈者2..10 で必ず初期化する（相続人でなくても）
        $perCal = [];
        $perSet = [];
        $per    = [];
        for ($i=2; $i<=10; $i++) {
            $perCal[$i] = 0;
            $perSet[$i] = 0;
            $per[$i]    = 0;
        }


        [$rangeStart, $rangeEnd] = $this->determineCalendarGiftLookbackRange($deathDate);

        // ★ 3年経過判定用の境界日
        //   - deathDate から3年引いた日より前の贈与は「3年超」
        //   - それ以降の贈与は「3年以内」
        $threeYearsAgo = $deathDate->sub(new \DateInterval('P3Y'));
        
        //DD("3年以内判定日",$threeYearsAgo);

        // ★ 100万円控除の適用開始
        //   ★JS(future_zouyo.blade)に合わせる：
        //   「3年超」の部分に対して 1000千円控除を常に適用（死亡年条件は掛けない）
        $useOneMillionExemption = true;

        // 暦年：受贈者×年ごとに「3年以内」と「3年超」の金額を別管理する（単位：千円）
        $perCalWithin3K = []; // [recipient_no][gift_year] => int
        $perCalOver3K   = []; // [recipient_no][gift_year] => int


        $calendar = PastGiftCalendarEntry::query()
             ->where('data_id', $dataId)
             ->get(['recipient_no','gift_year','gift_month','gift_day','amount_thousand']);
             
             
        foreach ($calendar as $row) {
            $no  = (int)($row->recipient_no ?? 0);
            if ($no < 2 || $no > 10) {
                continue; // 想定範囲外は除外
            }
            // ★暦年は「課税価格の取得がある人」のみ生前贈与加算対象
            if ($hasTargetFilter && !isset($targetSet[$no])) {
                continue;
            }
            $amtK = (int)($row->amount_thousand ?? 0);
            if ($amtK <= 0) {
                continue;
            }
            // ★月日欠損でも算入漏れしない（年のみ入力 → 12/31 扱い）
            $gd = $this->safeDateYmd(
                (int)($row->gift_year ?? 0),
                (int)($row->gift_month ?? 0),
                (int)($row->gift_day ?? 0)
            );
            if (!$gd) {
                continue;
            }
            if ($gd < $rangeStart || $gd > $rangeEnd) {
                continue;
            }
            
            $giftYear = (int)$row->gift_year; if (!isset($perCalYearK[$no])) { $perCalYearK[$no] = []; }

            // ★ deathDate から見て「3年以内」か「3年超」かで分ける
            if ($gd >= $threeYearsAgo) {
                // 3年以内：従来どおり全額算入（100万円控除の対象外）
                if (!isset($perCalWithin3K[$no])) {
                    $perCalWithin3K[$no] = [];
                }
                $perCalWithin3K[$no][$giftYear] = ($perCalWithin3K[$no][$giftYear] ?? 0) + $amtK;
            } else {
                // 3年超：100万円控除の対象候補
                if (!isset($perCalOver3K[$no])) {
                    $perCalOver3K[$no] = [];
                }
                $perCalOver3K[$no][$giftYear] = ($perCalOver3K[$no][$giftYear] ?? 0) + $amtK;
            }
            $perCalYearK[$no][$giftYear] = ($perCalYearK[$no][$giftYear] ?? 0) + $amtK;
        }

        // 修正: 年次ごとに $giftInclFixed をリセットし、再計算する
        foreach (range(2, 10) as $no) {
            // ★課税価格の取得が無い人は対象外（0のまま）
            if ($hasTargetFilter && !isset($targetSet[$no])) {
                continue;
            }
        
            // 3年以内と3年超の金額を動的に計算
            $within3K = 0;
            $over3K = 0;
            foreach ($perCalWithin3K[$no] ?? [] as $year => $amount) {
                $within3K += $amount;
            }
            foreach ($perCalOver3K[$no] ?? [] as $year => $amount) {
                $over3K += $amount;
            }
        
            // 100万円控除を適切に適用
            $includedK = $within3K + max(0, $over3K - 1000); // 3年超分からのみ100万円控除
        
            // 結果をyen単位で変換
            $sumYen = $this->toYen($includedK);
        
            // 年次ごとの $giftInclFixed をリセットして更新
            if ($sumYen > 0) {
                // t (年次)ごとの値を $giftInclFixed に反映
                $giftInclFixed = $sumYen; // 各年次ごとに異なる値を設定
        
                // 計算結果を適切に反映させる
                $perCal[$no] = $sumYen;
                $per[$no] = ($per[$no] ?? 0) + $sumYen;
        
                // デバッグ用ログを追加
                // Log::debug("Year: {$t}, idx: {$no}, $giftInclFixed: {$giftInclFixed}");
            }
        }
        

        // 精算：精算課税による贈与を受けた人は全員が生前贈与加算対象（課税価格取得の有無は問わない）
        $settlements = PastGiftSettlementEntry::query()
            ->where('data_id', $dataId)
            ->get(['recipient_no','gift_year','amount_thousand']);
            
            
        
        foreach ($settlements as $r) {


            $no = (int)($r->recipient_no ?? 0);
            if ($no < 2 || $no > 10) continue;

            // ★精算課税：生前贈与加算は「全件算入」（課税価格取得フィルタは掛けない）

            $year = (int)($r->gift_year ?? 0);
            
            // amount_thousand は「千円」単位なので、控除は 1100（=110万円）で行う
            if ($year >= 2024) {
                $amtK = max(0, (int)($r->amount_thousand ?? 0) - 1100);
            } else {
                $amtK = max(0, (int)($r->amount_thousand ?? 0));
            }
            if ($amtK > 0) {
                $yen           = $this->toYen($amtK);
                $perSet[$no]  += $yen;
                $per[$no]     += $yen;

                //Log::debug('2025.12.10 40001 ',  ['no'=>$no, $yen]);

            }


        }

        $totalCal = 0;
        $totalSet = 0;
        $total    = 0;
        // ★ 合計：暦年は（必要なら）取得者のみ、精算は受贈者全員（過去＋将来）
        for ($i = 2; $i <= 10; $i++) {

            $cal = (int)($perCal[$i] ?? 0);

            $set = (int)($perSet[$i] ?? 0);

            $totalCal += $cal;
            $totalSet += $set;
            $total    += (int)($per[$i] ?? ($cal + $set));
        }

        
        
        /*
        // ★ デバッグ用ログ：過年度贈与算入額の集計結果を確認
        Log::info('2025.12.10 300001 [ZouyotaxCalc][past_gifts_included]', [
            'data_id'              => $dataId,
            'death_date'           => $deathDate->format('Y-m-d'),
            'total_yen'            => $total,
            'calendar_total_yen'   => $totalCal,
            'settlement_total_yen' => $totalSet,
            'per_idx'              => $per,
            'calendar_per_idx'     => $perCal,
            'settlement_per_idx'   => $perSet,
        ]);
        */
        


        return [
            // 合算（暦年＋精算）
            'total_yen'             => $total,
            'per_idx'               => $per,
            // 内訳：暦年／精算（相続税の「課税価格」内訳確認用）
            'calendar_total_yen'    => $totalCal,
            'settlement_total_yen'  => $totalSet,
            'calendar_per_idx'      => $perCal,
            'settlement_per_idx'    => $perSet,
        ];
    }



    /**
     * （拡張版）相続財産算入額に「仮想（将来）贈与」も加算
     */
private function calcPastGiftsIncludedInEstateByRecipientWithVirtual(
    int $dataId,
    \DateTimeImmutable $deathDate,
    array $heirIdxList,
    array $virtual // buildVirtualGiftsIndex() の戻り
): array {
    
    // まず「過去贈与のみ」の集計結果を取得（暦年/精算の内訳付き）
    $base = $this->calcPastGiftsIncludedInEstateByRecipient($dataId, $deathDate, $heirIdxList);

    // ★暦年のみ「課税価格の取得がある人」フィルタ（精算は全員対象）
    $targetSet = [];
    foreach ($heirIdxList as $v) {
        $i = (int)$v;
        if ($i >= 2 && $i <= 10) $targetSet[$i] = true;
    }
    $hasTargetFilter = !empty($targetSet);

    // ベースを展開（存在しないキーは 0 / 空配列で初期化）
    $perCal = $base['calendar_per_idx'] ?? [];
    $perSet = $base['settlement_per_idx'] ?? [];
    $per = $base['per_idx'] ?? [];

    $totalCal = (int)($base['calendar_total_yen'] ?? 0);
    $totalSet = (int)($base['settlement_total_yen'] ?? 0);

    // 全受贈者分の器を作っておく
    for ($i = 2; $i <= 10; $i++) {
        if (!isset($perCal[$i])) $perCal[$i] = 0;
        if (!isset($perSet[$i])) $perSet[$i] = 0;
        if (!isset($per[$i])) $per[$i] = 0;
    }

    // 仮想：暦年算入（lookback 内のみ）＋精算は全件
    $v = $virtual[$deathDate->format('Y-m-d')] ?? [
        'calendar_included' => [],
        'settlement_all'    => [],
    ];

    // 変数の初期化
    $giftInclFixed = 0; // 初期化

    // 暦年分：lookback 算入対象分（calendar_included）を暦年側に加算
    foreach (($v['calendar_included'] ?? []) as $no => $yen) {
        $idx = (int)$no;
        if ($idx < 2 || $idx > 10) continue;
        if ($hasTargetFilter && !isset($targetSet[$idx])) {
            continue;
        }
        $yen = max(0, (int)$yen);
        $perCal[$idx] += $yen;
        $per[$idx] += $yen;
        $totalCal += $yen;

        // giftInclFixedをその都度加算
        $giftInclFixed += $yen; // 加算する
        
        /*
        Log::debug("After adding to calendar_included, idx: {$idx}, giftInclFixed: {$giftInclFixed}");
        */
        
    }

    // 精算分：全件算入（settlement_all）を精算側に加算（★取得者フィルタしない）
    foreach (($v['settlement_all'] ?? []) as $no => $yen) {
        $idx = (int)$no;
        if ($idx < 2 || $idx > 10) continue;
        $yen = max(0, (int)$yen);

        $perSet[$idx] += $yen;
        $per[$idx] += $yen;
        $totalSet += $yen;

        // giftInclFixedをその都度加算
        $giftInclFixed += $yen; // 加算する
        
        /*
        Log::debug("After adding to settlement_all, idx: {$idx}, giftInclFixed: {$giftInclFixed}");
        */
        
        
    }

    // 合算（暦年＋精算）
    $total = 0;
    for ($i = 2; $i <= 10; $i++) {
        $total += (int)($per[$i] ?? 0);
    }

    /*
    // 最後に total と giftInclFixed の最終結果を確認
    Log::debug("Final total: {$total}, Final giftInclFixed: {$giftInclFixed}");
    */

    return [
        'total_yen' => $total,
        'per_idx' => $per,
        'calendar_total_yen' => $totalCal,
        'settlement_total_yen' => $totalSet,
        'calendar_per_idx' => $perCal,
        'settlement_per_idx' => $perSet,
    ];
}


    /** 画面「千円」→ 円 */
    private function toYen(int $kYen): int
    {
        return $kYen * 1000;
    }


    /**
     * ★NoFinanceLegalCase 判定（金融資産なし × 遺産分割=法定(民法)）
     * - per_idx[*]['price_for_ratio'] の「遺産部分」を civil 比率で按分するために使用
     */
    private function isNoFinanceLegalCase(): bool
    {
        // ★キー揺れに強く（古い config でも落ちない）
        $mode =
            (string)($this->caseConfig['allocation_mode']
                ?? $this->caseConfig['allocation']
                ?? $this->caseConfig['mode']
                ?? 'legal');

        $hasFinance =
            (bool)($this->caseConfig['has_finance']
                ?? $this->caseConfig['hasFinance']
                ?? false);

        return ($mode === 'legal') && ($hasFinance === false);
}

    /**
     * ★民法上の法定相続割合（civilRatio）を idx=>比率(0..1) で正規化して返す
     * - heirs（collectHeirs結果）に含まれる人だけが対象（それ以外は 0）
     * - 合計が 0 の場合は空配列を返す（呼び出し側でフォールバック）
     *
     * @param array<int,array<string,mixed>> $heirs
     * @return array<int,float> idx => ratio
     */
    private function normalizedCivilRatiosByIdx(array $payload, array $heirs): array    
    {

        // ★最優先：civil_share が入力されている行だけで按分する
        //   ※重要：$heirs は「税務(bunsi/bunbo)がある行」だけになり得るため、
        //           civil_share だけ入力された行（例：idx=5）が $heirs に存在しないケースがある。
        //           → payload から civil_share を直接読む。
        $hasAnyCivil = false;
        for ($i = 2; $i <= 10; $i++) {
            $cbunsi = $this->readIntFromArray($payload, 'civil_share_bunsi', $i);
            $cbunbo = $this->readIntFromArray($payload, 'civil_share_bunbo', $i);
            if ($cbunsi >= 1 && $cbunbo >= 1) { $hasAnyCivil = true; break; }
        }
        if (!$hasAnyCivil) {
            // 後方互換：payload に無い/未POSTでも、$heirs に civil 情報が載っている場合がある
            foreach ($heirs as $h) {
                if (!empty($h['has_civil'])) { $hasAnyCivil = true; break; }
            }
        }

        // $heirs を idx=>row のマップにして参照しやすくする
        $heirByIdx = [];
        foreach ($heirs as $h) {
            $idx = (int)($h['idx'] ?? 0);
            if ($idx >= 2 && $idx <= 10) {
                $heirByIdx[$idx] = $h;
            }
        }

        $raw = [];
        $sum = 0.0;
        for ($idx = 2; $idx <= 10; $idx++) {
            if ($hasAnyCivil) {
                // civil 入力がある行だけ対象（payload を正）
                $cbunsi = $this->readIntFromArray($payload, 'civil_share_bunsi', $idx);
                $cbunbo = $this->readIntFromArray($payload, 'civil_share_bunbo', $idx);

                // payload に無い場合は $heirs 側の civil（後方互換）を拾う
                if (($cbunsi < 1 || $cbunbo < 1) && isset($heirByIdx[$idx]) && !empty($heirByIdx[$idx]['has_civil'])) {
                    $cbunsi = (int)($heirByIdx[$idx]['civil_bunsi'] ?? 0);
                    $cbunbo = (int)($heirByIdx[$idx]['civil_bunbo'] ?? 0);
                }
                if ($cbunsi < 1 || $cbunbo < 1) {
                    continue; // civil 入力が無い行は対象外
                }

                $r = (float)($cbunsi / $cbunbo);
                
                /*
                Log::debug('2025.12.24 00003 [civil_ratio]', ['idx' => $idx, 'r' => $r]);
                */
                
                
            } else {
                // civil が誰も入力されていない場合のみフォールバック（従来互換）
                if (isset($heirByIdx[$idx])) {
                    $r = (float)$this->civilRatio($heirByIdx[$idx]);
                } else {
                    // 念のため：$heirs にいない場合は payload の税務(bunsi/bunbo)へフォールバック
                    $bunsi = $this->readIntFromArray($payload, 'bunsi', $idx);
                    $bunbo = $this->readIntFromArray($payload, 'bunbo', $idx);
                    $r = ($bunsi >= 1 && $bunbo >= 1) ? (float)($bunsi / $bunbo) : 0.0;
                }
                if ($r <= 0) continue;
            }

            $raw[$idx] = $r;
            $sum += $r;
        }

        if ($sum <= 0.0) return [];

        $out = [];
        foreach ($raw as $idx => $r) {
            $out[$idx] = $r / $sum;
        }
        return $out;
    }

    /**
     * ★比率で floor 配分し、端数は最後の対象者へ寄せる（合計が必ず $total になる）
     *
     * @param int $total
     * @param array<int,float> $ratios idx => ratio(0..1)
     * @return array<int,int> idx => shareYen
     */
    private function allocateFloorByRatios(int $total, array $ratios): array
    {
        $shares = [];
        for ($i = 2; $i <= 10; $i++) { $shares[$i] = 0; }
        if ($total <= 0 || empty($ratios)) {
            return $shares;
        }
        $allocated = 0;
        $lastIdx   = null;
        for ($i = 2; $i <= 10; $i++) {
            $r = (float)($ratios[$i] ?? 0.0);
            if ($r <= 0.0) continue;
            $lastIdx = $i;
            $s = (int)floor($total * $r);
            $shares[$i] = $s;
            $allocated += $s;
        }
        if ($lastIdx !== null) {
            $shares[$lastIdx] = (int)$shares[$lastIdx] + ($total - $allocated);
        }
        return $shares;
    }

    /**
     * 民法上の法定相続割合（civil_share_*）を優先して ratio を返す
     * - civil が未入力/不正なら bunsi/bunbo（税務上の相続割合）へフォールバック
     */
    private function civilRatio(array $h): float
    {
        $cbunsi = (int)($h['civil_bunsi'] ?? 0);
        $cbunbo = (int)($h['civil_bunbo'] ?? 0);
        if ($cbunsi >= 1 && $cbunbo >= 1) {
            return $cbunsi / $cbunbo;
        }
        $bunsi = (int)($h['bunsi'] ?? 0);
        $bunbo = (int)($h['bunbo'] ?? 0);
        return ($bunsi >= 1 && $bunbo >= 1) ? ($bunsi / $bunbo) : 0.0;
    }


    /** 配列入力（千円）を整数化 */
    private function readKyen(array $payload, string $base, int $idx): int
    {
        $key = sprintf('%s.%d', $base, $idx);
        $raw = Arr::get($payload, $key, '');
        if (!is_string($raw) && !is_numeric($raw)) return 0;
        $normalized = preg_replace('/[^\d\-]/u', '', (string)$raw) ?? '0';
        return (int)$normalized;
    }

    /** 相続人（行2..10）：bunsi>=1 && bunbo>=1 を候補 */
    private function collectHeirs(array $payload): array
    {
        $heirs = [];
        for ($i = 2; $i <= 10; $i++) {

            // 税務上の相続割合（既存）
            $bunsi = $this->readIntFromArray($payload, 'bunsi', $i);
            $bunbo = $this->readIntFromArray($payload, 'bunbo', $i);

            // ★民法上の法定相続割合（新規：こちらを課税価格按分に使用）
            $civilBunsi = $this->readIntFromArray($payload, 'civil_share_bunsi', $i);
            $civilBunbo = $this->readIntFromArray($payload, 'civil_share_bunbo', $i);

            // ★税務上の法定相続割合（legal_ratio）の母集団は「税務(bunsi/bunbo)がある人」だけに限定する。
            //  civil_share は “按分の参考値” として保持するが、civil だけで相続人に採用しない。
            $hasCivil = ($civilBunsi >= 1 && $civilBunbo >= 1);
            $isHeir   = ($bunsi >= 1 && $bunbo >= 1);


            if ($isHeir) {

                $relCode = $this->readIntFromArray($payload, 'relationship', $i);
                $twoTenths = $this->checkboxOn($payload, 'twenty_percent_add', $i);
                $heirs[] = [
                     'idx'        => $i,
                     // 税務上（表示・互換用）
                     'bunsi'      => $bunsi,
                     'bunbo'      => $bunbo,
                     // ★民法上（入力値そのもの。未入力は 0 のまま保持）
                     'civil_bunsi'=> $civilBunsi,
                     'civil_bunbo'=> $civilBunbo,
                     // ★civil入力があるか（civil按分のフィルタ用）
                     'has_civil'  => $hasCivil,
 
                     'two_tenths' => $twoTenths,
                     'rel_code'   => $relCode,
                ];

            }
        }
        return $heirs;
    }

    private function readIntFromArray(array $payload, string $base, int $idx): int
    {
        $key = sprintf('%s.%d', $base, $idx);
        $s   = preg_replace('/[^\d\-]/u', '', (string)Arr::get($payload, $key, '')) ?? '0';
        return (int)$s;
    }

    private function checkboxOn(array $payload, string $base, int $idx): bool
    {
        $key = sprintf('%s.%d', $base, $idx);
        if (!Arr::has($payload, $key)) return false;
        $s = Str::lower((string)Arr::get($payload, $key));
        return in_array($s, ['1', 'on', 'true', 'yes'], true);
    }

    /**
     * 速算表適用（円）
     * @param int $shareYen
     * @param array<int, array{up_to:int, rate:float, quick:int}> $brackets
     */
    private function applyInheritanceTable(int $shareYen, array $brackets): int
    {
        $share = max(0, $shareYen);
        foreach ($brackets as $b) {
            if ($share <= $b['up_to']) {
                return (int)max(0, round($share * $b['rate']) - $b['quick']);
            }
        }
        return 0;
    }

    /** 速算表の読み込み（DB：sozoku_rates） */
    private function loadInheritanceBrackets(): array
    {
        $targetVersion = (int) SozokuRate::query()->max('version');
        if ($targetVersion === 0) {
            return $this->fallbackInheritanceBrackets();
        }

        $cacheKey = 'sozoku_rates:inheritance:v' . $targetVersion;
        return Cache::remember($cacheKey, now()->addDay(), function () use ($targetVersion) {
            $rows = SozokuRate::query()
                ->where('version', $targetVersion)
                ->orderBy('seq')
                ->get(['lower','upper','rate','deduction_amount']);

            if ($rows->isEmpty()) return $this->fallbackInheritanceBrackets();

            $list = [];
            foreach ($rows as $r) {
                $upper = (int)($r->upper ?? 0);
                $rate  = (float)$r->rate;
                if ($rate > 1) $rate = $rate / 100.0;
                $list[] = [
                    'up_to' => $upper > 0 ? $upper : PHP_INT_MAX,
                    'rate'  => $rate,
                    'quick' => (int)$r->deduction_amount,
                ];
            }
            return !empty($list) ? $list : $this->fallbackInheritanceBrackets();
        });
    }

