            $totalSpouseRelief += $spouseRelief;
            $totalPayableAfterSpouse += $payAfterSpouse;
            $otherCreditYen = $this->toYen($this->readKyen($payload, 'id_other_credit', $idx)); if ($otherCreditYen < 0) $otherCreditYen = 0;
