            ['up_to' =>300_000_000,  'rate' => 0.45, 'quick' =>27_000_000],
            ['up_to' =>600_000_000,  'rate' => 0.50, 'quick' =>42_000_000],
            ['up_to' =>PHP_INT_MAX,  'rate' => 0.55, 'quick' =>72_000_000],
        ];
    }

    /**
     * あん分割合の構築
     * ★あん分割合／算出税額は「課税価格（所有財産＋生前贈与加算）の合計割合」で計算する
     * - manual：入力された id_taxable_manu（千円）＋ past_gift_included（千円換算）で比率化
     * - auto   ：課税価格（id_taxable_manu + past_gift）が >0 の人を対象に比率化（bunsi/bunbo に依存しない）
     *
     * 返却:
     *  - mode       : 'manual' | 'auto'
     *  - ratios     : idx => ratio（0..1）
     *  - total_kyen : 課税価格合計（千円）
    */
    private function buildAnbunRatios(array $payload, array $heirs, array $legalShareRows): array
    {
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        $useManual = ($mode === 'manual');
    
        // 1) 各人の課税価格（千円）＝ 所有財産（id_taxable_manu：千円）＋ 生前贈与加算（円→千円）
        //    ※ auto でも id_taxable_manu は画面側（readonly）で値が入って POST される前提。
        //       bunsi/bunbo が 0（civil_share のみ入力）でも「課税価格>0」なら按分対象に含める。
        $baseKyenByIdx = [];
        for ($i = 2; $i <= 10; $i++) { $baseKyenByIdx[$i] = 0; }

        $totalKyen = 0;
        $targets = [];
        for ($idx = 2; $idx <= 10; $idx++) {
            $ownKyen = (int)$this->readKyen($payload, 'id_taxable_manu', $idx); // 千円
            if ($ownKyen < 0) { $ownKyen = 0; }

            $giftYen  = (int)($legalShareRows[$idx]['past_gift_included_yen'] ?? 0);
            $giftKyen = (int)round($giftYen / 1000);

                //log::Debug('2025.12.15 30002 giftYen ', ['$giftYen' => $giftYen, 'giftKyen' => $giftKyen ]);

            if ($giftKyen < 0) { $giftKyen = 0; }

            $baseKyen = $ownKyen + $giftKyen;
            if ($baseKyen < 0) { $baseKyen = 0; }

            $baseKyenByIdx[$idx] = $baseKyen;
            if ($baseKyen > 0) {
                $targets[] = $idx;         // ★課税価格がある人だけを按分対象にする
                $totalKyen += $baseKyen;
            }
        $targets = array_values(array_unique($targets));
        sort($targets);

        }

        // 3) 比率化（総和0なら全員0）
        $ratios = [];
        for ($i = 2; $i <= 10; $i++) $ratios[$i] = 0.0;
        if ($totalKyen > 0) {
            foreach ($targets as $idx) {
                $ratios[$idx] = ($baseKyenByIdx[$idx] ?? 0) / $totalKyen;
            }
        }

        return [
            'mode'       => $useManual ? 'manual' : 'auto',
            'ratios'     => $ratios,
            'total_kyen' => $totalKyen,
        ];

    }

    /**
     * manualモードの「課税遺産総額（個人）」表示値
     * 手順：
     *  ① 各人の手入力課税価格 P_i に対し、贈与加算 G_i（受贈者=相続人）を用いて合計 S = Σ(P_i + G_i) を作る
     *  ② T = max(0, S - 基礎控除)
     *  ③ T を “手入力課税価格 P_i の比率” で各人に按分（※G_i は配分比には使わない）
     *  ⇒ 各人 manual_taxable_yen = floor(T * (P_i / ΣP_i))（端数は最後の正値行へ寄せ）
     */
    private function buildManualTaxableShares(
            array $payload,
            int $basicDeduction,
            array $perGiftYenByIdx = []
        ): array
    {
        
        
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        
        
        if ($mode !== 'manual') {
            return ['mode' => 'auto', 'sum_kyen' => 0, 'shares' => [], 'total_taxable_yen' => 0];
        }
        
        
        
         // 1) 手入力課税価格（千円）を集計
        $sumKyen = 0;
        $manualKyenByIdx = [];
        for ($i = 2; $i <= 10; $i++) {
            $kyen = $this->readKyen($payload, 'id_taxable_manu', $i);
            if ($kyen < 0) $kyen = 0;
            $manualKyenByIdx[$i] = $kyen;
            $sumKyen += $kyen;
        }
        if ($sumKyen <= 0) {
            return ['mode' => 'manual', 'sum_kyen' => 0, 'shares' => [], 'total_taxable_yen' => 0];
        }
    
        // 2) 合計 S = Σ(P_i + G_i) を求め、T = max(0, S - 基礎控除) を算定
        //   ※ 現時点の生前贈与加算 G_i も「課税価格」に含める（P_i は画面上の課税価格千円）
        $sumYen = $this->toYen($sumKyen);  // ΣP_i（円）

        // 現時点の贈与加算額 G_i（円）を合算
        $giftSum = 0;
        for ($i = 2; $i <= 10; $i++) {
            $giftSum += max(0, (int)($perGiftYenByIdx[$i] ?? 0));
        }

        // ★ 課税遺産総額のベース：S = Σ(P_i + G_i)
        $sumWithGifts = $sumYen + $giftSum;

        // ★ 修正後：課税遺産総額 = Σ(P_i + G_i) − 基礎控除
        //   → 「課税遺産総額の合計 1,722,761千円」に現時点の生前贈与加算も含めた形に揃える
        $totalAfterDeduction = max(0, $sumWithGifts - $basicDeduction);

    
        // 3) 小計用に円へ（※ $sumYen は上で算出済み）


        // 4) 価格>0 の最後のインデックスを特定（残差寄せ用）
        $lastIdxWithPrice = null;
        for ($i = 2; $i <= 10; $i++) {
            if ($this->toYen($manualKyenByIdx[$i]) > 0) {
                $lastIdxWithPrice = $i;
            }
        }
    
        // 5) 按分（残差は最後の人）※配分比は P_i のみ（G_i は配分比に使わない）
        $shares = [];
        $allocated = 0;
        for ($i = 2; $i <= 10; $i++) {
            $priceYen = $this->toYen($manualKyenByIdx[$i] ?? 0);
            $alloc = 0;
            if ($i !== $lastIdxWithPrice) {
                $ratio = $sumYen > 0 ? ($priceYen / $sumYen) : 0.0;
                $alloc = (int)floor($totalAfterDeduction * $ratio);
                $allocated += $alloc;
            }
            $shares[$i] = [
                'manual_price_yen'   => $priceYen,
                'bd_share_yen'       => 0,      // 個人別の基礎控除配分はしない
                'manual_taxable_yen' => $alloc,
            ];
        }
        if (!is_null($lastIdxWithPrice)) {
            $shares[$lastIdxWithPrice]['manual_taxable_yen'] =
                $totalAfterDeduction - $allocated;    
        }

        return [
            'mode'               => 'manual',
            'sum_kyen'           => $sumKyen,
            'shares'             => $shares,
            
            // 合計は T = max(0, Σ(P_i + G_i) − 基礎控除)
            'total_taxable_yen'  => $totalAfterDeduction, // 返すと後段が楽
        ];
    }


