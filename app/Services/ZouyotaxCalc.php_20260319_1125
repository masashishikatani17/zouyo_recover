    ): array {


        //2025.12.18 02
        // ★ 現行仕様：compute() と同じく data_id=1 固定でプロジェクションも評価する
        $dataId = 1;


        // overrideがある場合のみ $giftIncl に代入（後続で上書きしない）
        $giftIncl = null;
        if (is_array($giftInclOverride) && !empty($giftInclOverride)) {
            $giftIncl = $giftInclOverride;
        }



        // ※既存コードがこの後に giftIncl/giftTaxCredits を生成している場合は、
        //   「未設定なら作る」方式に置き換える（下の差分参照）



        // ★年次でも「課税価格の取得がある人」を統一して使用（manual/auto）
        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);
        
        /*
        Log::debug('2026.01.21 4000000-1 ', [
            'heirs' => $heirs,
        ]);
        */
            


        // 6-1 前に：相続人別の贈与加算（参考値）を算出
        // ★ context に応じて「将来贈与分を含める／含めない」を切替
        //   virtual は "empty()" ではなく「キーが存在する」場合に有効とみなす
        $virtualKey = $deathDate->format('Y-m-d');
        $hasVirtual = (is_array($virtual) && array_key_exists($virtualKey, $virtual));

        if ($giftInclOverride !== null) {
             $giftIncl = $giftInclOverride;
        } elseif ($context === 'after_virtual' && $hasVirtual) {
            
            
            //Log::debug("2026.01.21 6000000-1");

            // calcPastGiftsIncludedInEstateByRecipientWithVirtual は
            // (dataId, deathDate, heirIdxList, virtual, payload, taxableAcquirerIdxList, heirs)
            // の 7 引数が必要
            $heirIdxList = [];
            foreach ($heirs as $h) {
                // heirs が配列想定（['idx'=>..]）。構造が違っても Notice を出さない
                if (is_array($h) && array_key_exists('idx', $h)) {
                    $heirIdxList[] = (int)$h['idx'];
                }
            }

            $giftIncl = $this->calcPastGiftsIncludedInEstateByRecipientWithVirtual(
                $dataId,
                $deathDate,
                $heirIdxList,
                $t,
                $virtual,
                $payload,
                $taxableAcquirerIdxList,
                $heirs
            );
        
            
        } else {

                    // ★未設定のときだけ計算（override 優先）
                    if ($giftIncl === null) {

                        /*
                        Log::debug("2026.01.27 1000000-5", [
                            '$deathDate' => $deathDate,
                            't' => $t,
                        ]);
                        */
                    
                        $giftIncl = $this->calcPastGiftsIncludedInEstateByRecipient(
                            $dataId,
                            $deathDate,
                            $payload,
                            $taxableAcquirerIdxList,
                            $heirs,
                            $t
                        );
                    }

        }

        // ★課税価格（kazei_price_yen）と「贈与後遺産（=将来贈与の現金流出控除後）」を分離して扱う
        //   - after_virtual では $estateYen は「贈与後遺産（控除後）」として受け取る
        //   - before_proj   では $estateYen は従来どおり「贈与算入込みの課税価格」として受け取る
        $inclCalForAlloc = (int)($giftIncl['calendar_total_yen']   ?? 0);
        $inclSetForAlloc = (int)($giftIncl['settlement_total_yen'] ?? 0);

        if ($context === 'after_virtual') {
