    private function GetPastFutureGift(
        int $dataId,
        array $payload,
        array $rekinen_past_gift_data,
        array $rekinen_Future_gift_data
    ): array {

        // 将来の贈与：各年(t)の生前贈与加算額と贈与税額控除額を求める
        // ★さらに「相続人別(no=2..10)」も返して、heirs[].past_gift_included_yen に反映できるようにする
 
        // ★キーは「年」ではなく「t」で持つ
        //   理由：t=0 と t=1 が同一年（例：2025）でも計算内容が違うため、年キーだと上書きが起きる。
        $rekinen_zouyo_kasan_by_t = [];
        $rekinen_zouyo_koujo_by_t = [];

        $rekinen_zouyo_kasan_per_no_by_t = []; // [t][no] => 千円
        $rekinen_zouyo_koujo_per_no_by_t = []; // [t][no] => 千円
 
        // ★相続開始日（死亡日）＝提案書日付、という仕様に合わせて基準日を解決する
        $baseDeathDate = $this->resolveDeathDateFromPayload($payload, $dataId);


        for ($t = 0; $t <= 20; $t++) {

            // ★年次ごとにリセット（累積バグ防止）
            $rekinen_kasan_kin = 0;
            $rekinen_koujo_kin = 0;


            // 相続人別（no=2..10）集計（千円）
            $kasanByNo = [];
            $koujoByNo = [];
            // ★100万円控除（1000千円）は「受贈者ごと」に適用するため、受贈者別に累計する（3年超分）
            $kasan100ByNo = [];
            for ($no = 2; $no <= 10; $no++) {
                $kasanByNo[$no] = 0;
                $koujoByNo[$no] = 0;
                $kasan100ByNo[$no] = 0;
            }
 
 
            // ★あなたの仕様：t=0 は将来贈与なし、t>=1 から将来贈与あり
            //   t=1 は「同一年（基準年）」で将来贈与を考慮するため、deathDate の年が t=0 と同じになる。
            //   だから年キーで配列を持つと必ず上書きされる → tキーで保持する。
            if ($t === 0) {
                $deathDate = $baseDeathDate;
            } else {
                $deathDate = $baseDeathDate->modify(sprintf('+%d year', ($t - 1)));
            }
            $zouyo_year = (int)$deathDate->format('Y');


            [$rangeStart, $rangeEnd, $pattern_kasan_case] = $this->determineCalendarGiftLookbackRange($deathDate);

            /*
            Log::debug('2026.01.26 100001', [
                't'                 => $t,
                'baseDeathDate'      => $baseDeathDate->format('Y-m-d'),
                'deathDate'          => $deathDate->format('Y-m-d'),
                'zouyo_year'         => $zouyo_year,
                'rangeStart'         => $rangeStart->format('Y-m-d'),
                'rangeEnd'           => $rangeEnd->format('Y-m-d'),
                'pattern_kasan_case' => $pattern_kasan_case,
            ]);
            */

            // ===============
            // 共通：配列から受贈者noを安全に取る（past/future のキー揺れに耐える）
            // ===============
            $pickNo = function(array $row): int {
                $cands = [
                    $row['no'] ?? null,
                    $row['recipient_no'] ?? null,
                    $row['rekinen_no'] ?? null,
                ];
                foreach ($cands as $c) {
                    if ($c === null) continue;
                    $n = (int)$c;
                    if ($n >= 2 && $n <= 10) return $n;
                }
                return 0;
            };

            if ($pattern_kasan_case === 1) {
                // ～2026-12-31までに死亡：従来どおり「死亡前3年」

                // 過年度分（DB）
                foreach ($rekinen_past_gift_data as $v) {
                    if (!isset($v['rekinen_gift_date']) || !($v['rekinen_gift_date'] instanceof \DateTimeImmutable)) continue;
                    if ($v['rekinen_gift_date'] < $rangeStart || $v['rekinen_gift_date'] > $rangeEnd) continue;

                    $no = $pickNo($v);
                    $kin = (int)($v['rekinen_gift_kin'] ?? 0); // 千円
                    $tax = (int)($v['rekinen_gift_tax'] ?? 0); // 千円

                    $rekinen_kasan_kin += $kin;
                    $rekinen_koujo_kin += $tax;
                    if ($no >= 2 && $no <= 10) {
                        $kasanByNo[$no] += $kin;
                        $koujoByNo[$no] += $tax;
                    }
                }

                // 将来分（t>=1のみ）
                if ($t !== 0) {
                    foreach ($rekinen_Future_gift_data as $v) {
                        if (!isset($v['rekinen_Futuregift_date']) || !($v['rekinen_Futuregift_date'] instanceof \DateTimeImmutable)) continue;

                        // ★死亡日までに実施済みの贈与のみを対象にする
                        if ($v['rekinen_Futuregift_date'] > $deathDate) continue;
                        if ($v['rekinen_Futuregift_date'] < $rangeStart || $v['rekinen_Futuregift_date'] > $rangeEnd) continue;

                        $no = $pickNo($v);
                        $kin = (int)($v['rekinen_Futuregift_kin'] ?? 0); // 千円
                        $tax = (int)($v['rekinen_Futuregift_tax'] ?? 0); // 千円

                        $rekinen_kasan_kin += $kin;
                        $rekinen_koujo_kin += $tax;
                        if ($no >= 2 && $no <= 10) {
                            $kasanByNo[$no] += $kin;
                            $koujoByNo[$no] += $tax;
                        }
                    }
                }

                $rekinen_zouyo_kasan_by_t[$t] = $rekinen_kasan_kin;
                $rekinen_zouyo_koujo_by_t[$t] = $rekinen_koujo_kin;
                $rekinen_zouyo_kasan_per_no_by_t[$t] = $kasanByNo;
                $rekinen_zouyo_koujo_per_no_by_t[$t] = $koujoByNo;

            } elseif ($pattern_kasan_case === 2) {
                // 2027-01-01 ～ 2030-12-31 死亡：
                // 暦年課税の算入期間は一律 2024-01-01 から死亡日まで
                // ★3年超分：受贈者ごとに(合計-1000千円)の超過分だけ加算

                $pattern_kojo100 = $deathDate->sub(new \DateInterval('P3Y')); // 3年

                // 過年度分（DB）
                foreach ($rekinen_past_gift_data as $v) {
                    if (!isset($v['rekinen_gift_date']) || !($v['rekinen_gift_date'] instanceof \DateTimeImmutable)) continue;
                    if ($v['rekinen_gift_date'] < $rangeStart || $v['rekinen_gift_date'] > $rangeEnd) continue;

                    $no = $pickNo($v);
                    $kin = (int)($v['rekinen_gift_kin'] ?? 0); // 千円
                    $tax = (int)($v['rekinen_gift_tax'] ?? 0); // 千円

                    // 控除額（贈与税額控除）は期間内なら素直に加算（受贈者別にも持つ）
                    $rekinen_koujo_kin += $tax;
                    if ($no >= 2 && $no <= 10) $koujoByNo[$no] += $tax;

                    if ($v['rekinen_gift_date'] < $pattern_kojo100) {
                        // 3年超（100万円控除対象のプール）
                        if ($no >= 2 && $no <= 10) $kasan100ByNo[$no] += $kin;
                    } else {
                        // 直近3年分はそのまま加算
                        $rekinen_kasan_kin += $kin;
                        if ($no >= 2 && $no <= 10) $kasanByNo[$no] += $kin;
                    }
                }

                // 将来分（t>=1のみ）
                if ($t !== 0) {
                    foreach ($rekinen_Future_gift_data as $v) {
                        if (!isset($v['rekinen_Futuregift_date']) || !($v['rekinen_Futuregift_date'] instanceof \DateTimeImmutable)) continue;

                        // ★死亡日までに実施済みの贈与のみを対象にする
                        if ($v['rekinen_Futuregift_date'] > $deathDate) continue;
                        if ($v['rekinen_Futuregift_date'] < $rangeStart || $v['rekinen_Futuregift_date'] > $rangeEnd) continue;

                        $no = $pickNo($v);
                        $kin = (int)($v['rekinen_Futuregift_kin'] ?? 0); // 千円
                        $tax = (int)($v['rekinen_Futuregift_tax'] ?? 0); // 千円

                        $rekinen_koujo_kin += $tax;
                        if ($no >= 2 && $no <= 10) $koujoByNo[$no] += $tax;

                        if ($v['rekinen_Futuregift_date'] < $pattern_kojo100) {
                            if ($no >= 2 && $no <= 10) $kasan100ByNo[$no] += $kin;
                        } else {
                            $rekinen_kasan_kin += $kin;
                            if ($no >= 2 && $no <= 10) $kasanByNo[$no] += $kin;
                        }
                    }
                }

                // ★受贈者ごとに「(3年超分の合計 - 1000千円)」を下限0で加算（全体 + 相続人別）
                $rekinen_kasan_kin_100_total = 0;
                for ($no = 2; $no <= 10; $no++) {
                    $excess = max(0, ((int)$kasan100ByNo[$no] - 1000));
                    $rekinen_kasan_kin_100_total += $excess;
                    $kasanByNo[$no] += $excess;
                }

                $rekinen_zouyo_kasan_by_t[$t] = $rekinen_kasan_kin + $rekinen_kasan_kin_100_total;
                $rekinen_zouyo_koujo_by_t[$t] = $rekinen_koujo_kin;
                $rekinen_zouyo_kasan_per_no_by_t[$t] = $kasanByNo;
                $rekinen_zouyo_koujo_per_no_by_t[$t] = $koujoByNo;

            } elseif ($pattern_kasan_case === 3) {
                // 2031-01-01 以降死亡：一般ルールとして「死亡前7年」
                // ★3年超分：受贈者ごとに(合計-1000千円)の超過分だけ加算

                $pattern_kojo100 = $deathDate->sub(new \DateInterval('P3Y')); // 3年

                // 過年度分（DB）
                foreach ($rekinen_past_gift_data as $v) {
                    if (!isset($v['rekinen_gift_date']) || !($v['rekinen_gift_date'] instanceof \DateTimeImmutable)) continue;
                    if ($v['rekinen_gift_date'] < $rangeStart || $v['rekinen_gift_date'] > $rangeEnd) continue;

                    $no = $pickNo($v);
                    $kin = (int)($v['rekinen_gift_kin'] ?? 0); // 千円
                    $tax = (int)($v['rekinen_gift_tax'] ?? 0); // 千円

                    $rekinen_koujo_kin += $tax;
                    if ($no >= 2 && $no <= 10) $koujoByNo[$no] += $tax;

                    if ($v['rekinen_gift_date'] < $pattern_kojo100) {
                        if ($no >= 2 && $no <= 10) $kasan100ByNo[$no] += $kin;
                    } else {
                        $rekinen_kasan_kin += $kin;
                        if ($no >= 2 && $no <= 10) $kasanByNo[$no] += $kin;
                    }
                }

                // 将来分（t>=1のみ）
                if ($t !== 0) {
                    foreach ($rekinen_Future_gift_data as $v) {
                        if (!isset($v['rekinen_Futuregift_date']) || !($v['rekinen_Futuregift_date'] instanceof \DateTimeImmutable)) continue;

                        if ($v['rekinen_Futuregift_date'] > $deathDate) continue;
                        if ($v['rekinen_Futuregift_date'] < $rangeStart || $v['rekinen_Futuregift_date'] > $rangeEnd) continue;

                        $no = $pickNo($v);
                        $kin = (int)($v['rekinen_Futuregift_kin'] ?? 0); // 千円
                        $tax = (int)($v['rekinen_Futuregift_tax'] ?? 0); // 千円

                        $rekinen_koujo_kin += $tax;
                        if ($no >= 2 && $no <= 10) $koujoByNo[$no] += $tax;

                        if ($v['rekinen_Futuregift_date'] < $pattern_kojo100) {
                            if ($no >= 2 && $no <= 10) $kasan100ByNo[$no] += $kin;
                        } else {
                            $rekinen_kasan_kin += $kin;
                            if ($no >= 2 && $no <= 10) $kasanByNo[$no] += $kin;
                        }
                    }
                }

                $rekinen_kasan_kin_100_total = 0;
                for ($no = 2; $no <= 10; $no++) {
                    $excess = max(0, ((int)$kasan100ByNo[$no] - 1000));
                    $rekinen_kasan_kin_100_total += $excess;
                    $kasanByNo[$no] += $excess;
                }

                $rekinen_zouyo_kasan_by_t[$t] = $rekinen_kasan_kin + $rekinen_kasan_kin_100_total;
                $rekinen_zouyo_koujo_by_t[$t] = $rekinen_koujo_kin;
                $rekinen_zouyo_kasan_per_no_by_t[$t] = $kasanByNo;
                $rekinen_zouyo_koujo_per_no_by_t[$t] = $koujoByNo;
            } else {
                // 想定外でも落とさない（全ゼロで返す）
                $rekinen_zouyo_kasan_by_t[$t] = 0;
                $rekinen_zouyo_koujo_by_t[$t] = 0;
                $rekinen_zouyo_kasan_per_no_by_t[$t] = $kasanByNo;
                $rekinen_zouyo_koujo_per_no_by_t[$t] = $koujoByNo;
            }
 
                    /*
                    Log::debug('2026.01.26 300001-3', [
                        't'                 => $t,
                        'baseDeathDate'      => $baseDeathDate->format('Y-m-d'),
                        'deathDate'          => $deathDate->format('Y-m-d'),
                        'zouyo_year'         => $zouyo_year,
                        'rekinen_zouyo_kasan' => $rekinen_zouyo_kasan_by_t[$t] ?? 0,
                    ]);
                    */

            /*
            Log::debug('2026.01.26 200001', [
                't'                 => $t,
                'baseDeathDate'      => $baseDeathDate->format('Y-m-d'),
