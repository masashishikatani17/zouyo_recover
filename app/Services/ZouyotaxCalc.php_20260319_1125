        $anbun = $this->buildAnbunRatios($payload, $heirs, $legalShareRows);
        $anbunMode      = $anbun['mode'];
        $anbunRatios    = $anbun['ratios'];   // idx => base ratio（t=0 由来）
        $anbunTotalKyen = $anbun['total_kyen'];

        // ★ この年の「贈与加算前ベース資産」を推定
        //   - 課税価格 kazei_price_yen は
        //       kazei = estate_after_yen + incl_calendar_yen + incl_settlement_yen
        //     という構造なので、
        //       estate_after_yen ≒ kazei_price_yen ? (暦年算入＋精算算入)
        //     とみなしてベース資産を復元する。
        $inclCalForAlloc = (int)($giftIncl['calendar_total_yen']   ?? 0);
