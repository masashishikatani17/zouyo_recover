        $calAmountByYearK = $this->readSavedFutureCalAmountByYearK($dataId); // [1..20]=>千円
        $calFallbackByYearK = $this->readPlanKyenArrayAllRecipients($payload, 'cal_amount'); // [1..20]=>千円

        // ★年単位フォールバック（DBが0の年だけ payload を採用）
        //  - DB優先は維持
        //  - DBに無い/保存漏れの年だけ補完
        for ($tt = 1; $tt <= 20; $tt++) {
            $dbv = (int)($calAmountByYearK[$tt] ?? 0);
            $pv  = (int)($calFallbackByYearK[$tt] ?? 0);
            if ($dbv <= 0 && $pv > 0) {
                $calAmountByYearK[$tt] = $pv;
            }
        }

        // 暦年課税（cal_amount）の年次合計（千円）
        $sumCalAmountK = function(int $t) use ($calAmountByYearK): int {
            if ($t <= 0) return 0;
            return (int)($calAmountByYearK[$t] ?? 0);
        };

        /*
        // ★デバッグ（暫定）：暦年の年次合計がどこで壊れているか特定
        Log::warning('[ZouyotaxCalc][future_cal_sum_check]', [
            'data_id' => $dataId,
            'cal_db_t1' => (int)($this->readSavedFutureCalAmountByYearK($dataId)[1] ?? 0),
            'cal_db_t2' => (int)($this->readSavedFutureCalAmountByYearK($dataId)[2] ?? 0),
            'cal_final_t1' => (int)($calAmountByYearK[1] ?? 0),
            'cal_final_t2' => (int)($calAmountByYearK[2] ?? 0),
            'cal_payload_t1' => (int)($calFallbackByYearK[1] ?? 0),
            'cal_payload_t2' => (int)($calFallbackByYearK[2] ?? 0),
        ]);
        */



        // 精算課税（set_amount）の年次合計（千円）
        $setAmountByYearK = $this->readSavedFutureSetAmountByYearK($dataId); // [1..20]=>千円
        $setFallbackByYearK = $this->readPlanKyenArrayAllRecipients($payload, 'set_amount'); // [1..20]=>千円

        // ★年単位フォールバック（DBが0の年だけ payload を採用）
        for ($tt = 1; $tt <= 20; $tt++) {
            $dbv = (int)($setAmountByYearK[$tt] ?? 0);
            $pv  = (int)($setFallbackByYearK[$tt] ?? 0);
            if ($dbv <= 0 && $pv > 0) {
                $setAmountByYearK[$tt] = $pv;
            }
        }

        /*
        // ★デバッグ（暫定）：精算の年次合計
        Log::warning('[ZouyotaxCalc][future_set_sum_check]', [
            'data_id' => $dataId,
            'set_db_t1' => (int)($this->readSavedFutureSetAmountByYearK($dataId)[1] ?? 0),
            'set_db_t2' => (int)($this->readSavedFutureSetAmountByYearK($dataId)[2] ?? 0),
            'set_final_t1' => (int)($setAmountByYearK[1] ?? 0),
            'set_final_t2' => (int)($setAmountByYearK[2] ?? 0),
            'set_payload_t1' => (int)($setFallbackByYearK[1] ?? 0),
            'set_payload_t2' => (int)($setFallbackByYearK[2] ?? 0),
        ]);
        */


        $sumSetAmountK = function(int $t) use ($setAmountByYearK): int {
            return $t > 0 ? (int)($setAmountByYearK[$t] ?? 0) : 0;
        };


        // 1) ベース資産（円）… POST が無ければ DB からフェイルオーバー取得
        //    propertyNowYen は「総資産（現時点）」、cashNowYen はその内訳の一部（運用対象）
        [$propertyNowYen, $cashNowYen, $rate] = $this->resolveBaseFromPayloadOrDb($payload, $dataId);
        $nonCashNowYen = max(0, $propertyNowYen - $cashNowYen); // ★“非現金”部分
        
        // ?? 1. 遺産資産ベースを初期化（将来贈与によって減らさない）
        $propertyNowYenInitial = $propertyNowYen;
        
        // ?? 2. 相続人一覧を取得（課税対象者リスト作成に必要）
        
        // ?? 3. 死亡日（t=0）
        $baseDeathDate = $this->resolveDeathDateFromPayload($payload, $dataId);


        // ?? 4. 課税対象者リスト（贈与加算対象を限定するため）
        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);
        
        // ?? 5. 対策前の贈与加算（t=0のみで固定）

        /*
        Log::debug("2026.01.27 1000000-1", [
            'baseDeathDate' => $baseDeathDate,
            't' => 0,
        ]);
        */

        // ★ここは compute()（t=0 の対策前）なので、t は 0 固定で正しい
        $giftInclFixed = $this->calcPastGiftsIncludedInEstateByRecipient(
            $dataId,
            $baseDeathDate,
            $payload,
            $taxableAcquirerIdxList,
            $heirs,
            0
        );

        // ★ ここで死亡日を解決しておく（下で $deathDate を使用するため）
        $deathDate = $this->resolveDeathDateFromPayload($payload, $dataId);
        
        /*
        log::debug('2026.01.20 98989898 ',[
            'deathDate' => $deathDate,
        ]);
        */
            
        // 2) 法定相続人候補（bunsi>=1 && bunbo>=1 の行2..10）
        // ★ Controller から渡された $heirs を正とする（上書きしない）
        //   空/未設定の場合のみ payload から組み立てる
        if (!is_array($heirs) || empty($heirs)) {
            $heirs = $this->collectHeirs($payload);
        }
        if (!is_array($heirs)) { $heirs = []; }


        // ★ 必須：$heirs の各要素に idx を必ず付与し、2..10 以外/不正行を除外する
        //   （Undefined array key "idx" を根絶）
        $heirs = $this->normalizeHeirsWithIdx($heirs);

        // ★ payload 側の bunsi / bunbo を heirs に補完する
        //   - Controller から渡された $heirs に bunsi/bunbo が入っていないケースを吸収
        //   - 画面入力値（old含む）を優先して人数カウントと後続計算を安定化
        $toIntOrZero = static function ($v): int {
            if (is_array($v)) {
                return 0;
            }
            $s = preg_replace('/[^\d\-]/u', '', (string)$v);
            return ($s === '' || $s === null) ? 0 : (int)$s;
        };

        $heirsByIdx = [];
        foreach ($heirs as $h) {
            $idx = (int)($h['idx'] ?? 0);
            if ($idx >= 2 && $idx <= 10) {
                $heirsByIdx[$idx] = $h;
            }
        }

        for ($idx = 2; $idx <= 10; $idx++) {
            $payloadBunsi = $toIntOrZero(data_get($payload, "bunsi.$idx", 0));
            $payloadBunbo = $toIntOrZero(data_get($payload, "bunbo.$idx", 0));

            if (!isset($heirsByIdx[$idx])) {
                $heirsByIdx[$idx] = [
                    'idx'   => $idx,
                    'bunsi' => $payloadBunsi,
                    'bunbo' => $payloadBunbo,
                ];
                continue;
            }

            if ((int)($heirsByIdx[$idx]['bunsi'] ?? 0) <= 0 && $payloadBunsi > 0) {
                $heirsByIdx[$idx]['bunsi'] = $payloadBunsi;
            }
            if ((int)($heirsByIdx[$idx]['bunbo'] ?? 0) <= 0 && $payloadBunbo > 0) {
                $heirsByIdx[$idx]['bunbo'] = $payloadBunbo;
            }
        }

        $heirs = array_values($heirsByIdx);

        /*
        Log::debug('2025.12.15 bunsi>=1 count', ['bunsiCount' => $bunsiCount]);
        */
 

        // ★ 相続人の人数（基礎控除用）
        //   まず payload の bunsi/bunbo を正として数え、
        //   payload が空の場合のみ heirs を見る
        $bunsiCount = 0;
        for ($idx = 2; $idx <= 10; $idx++) {
            $bunsi = $toIntOrZero(data_get($payload, "bunsi.$idx", 0));
            $bunbo = $toIntOrZero(data_get($payload, "bunbo.$idx", 0));
            if ($bunsi >= 1 && $bunbo >= 1) {
                $bunsiCount++;
            }
        }

        if ($bunsiCount === 0) {
            foreach ($heirs as $__h) {
                $bunsi = $toIntOrZero($__h['bunsi'] ?? 0);
                $bunbo = $toIntOrZero($__h['bunbo'] ?? 0);
                if ($bunsi >= 1 && $bunbo >= 1) {
                    $bunsiCount++;
                }
            }
        }

        // ★ heirCount は後続で参照されるため、この位置で必ず確定させる
