    private function resolveCaseConfig(array $payload, int $dataId): array
    {
        $allocation = $this->resolveAllocationModeFromPayload($payload); // 'legal'|'manual'
        $hasFinance = $this->resolveHasFinanceFromPayloadOrDb($payload, $dataId); // bool

        // まずケースの素の config を取得
        if ($hasFinance) {
            $cfg = $allocation === 'manual'
                ? HasFinanceManualCase::config()
                : HasFinanceLegalCase::config();
        } else {
            $cfg = $allocation === 'manual'
                ? NoFinanceManualCase::config()
                : NoFinanceLegalCase::config();
        }

        // ★重要：以後の判定はこの2キーを正として必ず持たせる（Case::config() のキー揺れ吸収）
        // - isNoFinanceLegalCase()
        // - resolveEstateSplitRatiosFixed()
        // - （将来）その他ケース分岐
        $cfg['allocation_mode'] = ($allocation === 'manual') ? 'manual' : 'legal';
        $cfg['has_finance']     = (bool)$hasFinance;

        return $cfg;
    }

    private function resolveAllocationModeFromPayload(array $payload): string
    {
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        return $mode === 'manual' ? 'manual' : 'legal';
    }

    /**
     * 金融資産あり/なし判定：
     *  - 全員(1..10)の金融資産欄（cash）が「すべて0」なら金融資産なし
     *  - payload で取れない場合は DB（proposal_family_members.cash_thousand）で判定
     */
    private function resolveHasFinanceFromPayloadOrDb(array $payload, int $dataId): bool
    {
        $sumK = 0;
        for ($i = 1; $i <= 10; $i++) {
            $k = $this->readKyen($payload, 'cash', $i); // 千円
            if ($k > 0) $sumK += $k;
        }
        if ($sumK > 0) return true;

        // payload が空/未送信のケースをDBでフォールバック
        try {
            $dbSum = (int) ProposalFamilyMember::query()
                ->where('data_id', $dataId)
                ->whereBetween('row_no', [1, 10])
                ->sum('cash_thousand');
            return $dbSum > 0;
        } catch (\Throwable $e) {
            //Log::warning('2025.12.17 10001 [ZouyotaxCalc][has_finance] DB fallback failed', ['error' => $e->getMessage()]);
            return false;
        }
    }

    /**
     * 被相続人(No=1)の金融資産は運用しない（t=0..20で一定）
     * ※将来、ケースにより運用可にする余地は残す（configで切替）
     */
    private function decedentCashAtYear(int $cashNowYen, int $yearsAhead, float $rate): int
    {
        $grows = (bool)($this->caseConfig['decedent_cash_grows'] ?? false);
        if (!$grows) {
            return max(0, $cashNowYen);
        }
        $safeRate = max($rate, -0.999999);
        return (int)round(max(0, $cashNowYen) * pow(1 + $safeRate, max(0, $yearsAhead)));
    }

    /**
     * 将来贈与の原資上限（No=1のみ）
     *  - 金融資産あり：No=1 cash
     *  - 金融資産なし：No=1 nonCash
     */
    private function giftBudgetYenForDecedent(int $nonCashYen, int $cashYenAtYear): int
    {
        $source = (string)($this->caseConfig['gift_funding_source'] ?? 'cash1');
        if ($source === 'noncash1') {
            return max(0, $nonCashYen);
        }
        return max(0, $cashYenAtYear);
    }
    

    /**
     * 遺産分割（t=0..20固定）の比率を作る（あなた仕様）
     * - 法定相続割合：金融/その他とも legal_ratio（民法割合）
     * - 手入力：
     *   ・金融資産なし：その他は id_other_share の比率、金融は全員0
     *   ・金融資産あり：金融は id_cash_share、その他は id_other_share の比率
     *
     * $heirsByIdx は after.heirs を row_index=>row にしたもの（legal_ratioが入っている想定）
     */
    private function resolveEstateSplitRatiosFixed(array $payload, array $heirsByIdx): array
    {
        $mode = (string)($this->caseConfig['allocation_mode'] ?? 'legal'); // 'legal'|'manual'
        $hasFinance = (bool)($this->caseConfig['has_finance'] ?? false);

        $cash = [];
        $other = [];
        for ($no = 2; $no <= 10; $no++) {
            $cash[$no] = 0.0;
            $other[$no] = 0.0;
        }

        // 1) 法定：legal_ratio を両方に採用（正規化）
        if ($mode === 'legal') {
            $sum = 0.0;
            for ($no = 2; $no <= 10; $no++) {
                $r = (float)($heirsByIdx[$no]['legal_ratio'] ?? 0.0);
                if ($r > 0) $sum += $r;
            }
            if ($sum <= 0.0) return ['cash'=>$cash,'other'=>$other];
            for ($no = 2; $no <= 10; $no++) {
                $r = (float)($heirsByIdx[$no]['legal_ratio'] ?? 0.0);
                $v = $r > 0 ? ($r / $sum) : 0.0;
                $cash[$no] = $v;
                $other[$no] = $v;
            }
            return ['cash'=>$cash,'other'=>$other];
        }

        // 2) 手入力：入力値で比率化（0なら法定へフォールバック）
        $readK = function(string $base, int $no) use ($payload): int {
            $raw = \Illuminate\Support\Arr::get($payload, "{$base}.{$no}", '');
            if (!is_string($raw) && !is_numeric($raw)) return 0;
            $normalized = preg_replace('/[^\d\-]/u', '', (string)$raw) ?? '0';
            return (int)$normalized;
        };

        // 2-1) その他資産比率（常に id_other_share）
        $sumOther = 0;
        $wOther = [];
        for ($no = 2; $no <= 10; $no++) {
            $v = max(0, $readK('id_other_share', $no));
            $wOther[$no] = $v;
            $sumOther += $v;
        }
        if ($sumOther > 0) {
            for ($no = 2; $no <= 10; $no++) {
                $other[$no] = ($wOther[$no] ?? 0) / $sumOther;
            }
        }

        // 2-2) 金融資産比率（金融資産ありのときだけ id_cash_share）
        if ($hasFinance) {
            $sumCash = 0;
            $wCash = [];
            for ($no = 2; $no <= 10; $no++) {
                $v = max(0, $readK('id_cash_share', $no));
                $wCash[$no] = $v;
                $sumCash += $v;
            }
            if ($sumCash > 0) {
                for ($no = 2; $no <= 10; $no++) {
                    $cash[$no] = ($wCash[$no] ?? 0) / $sumCash;
                }
            }
        }

        // フォールバック：比率が全部0なら法定へ
        $sumCheck = array_sum($cash) + array_sum($other);
        if ($sumCheck <= 0.0) {
            $cfgBak = $this->caseConfig;
            $this->caseConfig['allocation_mode'] = 'legal';
            $out = $this->resolveEstateSplitRatiosFixed($payload, $heirsByIdx);
            $this->caseConfig = $cfgBak;
            return $out;
        }

        return ['cash'=>$cash,'other'=>$other];
    }


    /**
     * gift_year/month/day の欠損に強い日付生成（PastGift* の月日欠損で算入漏れしないため）
     * - month/day が 0/欠損なら 12/31 扱い（年だけ入力のレコードを年末扱いで評価）
     * - 2/31 等の不正日は「当月末日」に丸める
     */
    private function safeDateYmd(int $y, int $m, int $d): ?\DateTimeImmutable
    {
        if ($y < 1900) {
            return null;
        }
        if ($m < 1 || $m > 12) {
            $m = 12;
        }
        if ($d < 1 || $d > 31) {
            $d = 31;
        }
        try {
            return new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $y, $m, $d));
        } catch (\Throwable $e) {
            // 例：2024-02-31 のような不正日 → 当月末日へ丸める
            try {
                $first = new \DateTimeImmutable(sprintf('%04d-%02d-01', $y, $m));
                return $first->modify('last day of this month');
            } catch (\Throwable $e2) {
                return null;
            }
        }
    }


