    /**
     * future_gift_plan_entries.row_no が 0始まりかどうかを DB から判定し、補正値を返す
     * - 「実データ（暦年/精算の金額が>0）」だけを対象に min/max を見る
     * - min=0 かつ max<=19 のときだけ 0始まり（0..19）と判定して +1
     *   ※ row_no=0 のダミー/空行が混ざっていても、これで誤判定しない
     */
    private function resolveFuturePlanRowNoOffset(int $dataId): int
    {
        try {
            $q = FutureGiftPlanEntry::query()
                ->where('data_id', $dataId)
                ->whereBetween('recipient_no', [2, 10])
                ->where(function ($qq) {
                    $qq->where('calendar_amount_thousand', '>', 0)
                       ->orWhere('settlement_amount_thousand', '>', 0);
                });

            $min = $q->min('row_no');
            $max = $q->max('row_no');

            // ★ row_no=0 が “実データ(>0)” として存在するか（空行の row_no=0 は除外）
            $hasRow0 = (clone $q)->where('row_no', 0)->exists();
            // ★ row_no=1 も実データとして存在するか
            $hasRow1 = (clone $q)->where('row_no', 1)->exists();

            if ($min === null || $max === null) {
                return 0;
            }

            $min = (int)$min;
            $max = (int)$max;

            // ★混在でも row_no=0 の実データがあるなら +1 を優先（t=1落ち防止）
            if ($hasRow0 && !$hasRow1) {
                return 1;
            }
            return 0;
        } catch (\Throwable $e) {
            Log::warning('[ZouyotaxCalc][resolveFuturePlanRowNoOffset] failed', [
                'data_id' => $dataId,
                'error'   => $e->getMessage(),
            ]);
            return 0;
        }
    }



    /**
     * 「対策後(after)」および「年次プロジェクション(projections.after)」の
     * 課税遺産総額(taxable_estate) を
     *
     *   各相続人の生前贈与加算後の課税価格 P_i(t)
     *   （= per_idx[idx]['price_for_ratio']）
     *
     * の比率で按分した値を heirs[].taxable_share_yen として付与する。
     *
     * 期待式:
     *   taxable_share_yen_i(t)
     *     = taxable_estate(t) * P_i(t) / Σ_j P_j(t)
     *
     * per_idx が無い／全員0などの場合のみ、
     * manual_price_yen or legal_ratio による従来比率へフォールバックする。
     */
    private function allocateTaxableEstateByFixedRatios(array $after, array $projAfter): array
    {
        if (!isset($after['heirs']) || !is_array($after['heirs'])) {
            return [$after, $projAfter];
        }

        // t=0 after.heirs から row_index => 行 へマップ
        $heirsByIdx = [];
        foreach ($after['heirs'] as $row) {
            if (!isset($row['row_index'])) continue;
            $heirsByIdx[(int)$row['row_index']] = $row;
        }
        if (empty($heirsByIdx)) {
            return [$after, $projAfter];
        }

        // --- 相続取得財産の按分比率（遺産分割比率）を決定 ---
        //   ・manual：heirs[].manual_price_yen の比率
        //   ・auto  ：heirs[].legal_ratio の比率
        $sumPrice   = 0;
        $priceByIdx = [];
        foreach ($heirsByIdx as $idx => $row) {
            $price = (int)($row['manual_price_yen'] ?? 0);
            if ($price > 0) {
                $priceByIdx[$idx] = $price;
                $sumPrice        += $price;
            }
        }

        $fallbackRatioByIdx = [];
        if ($sumPrice > 0) {
            // manual: 課税価格（manual_price_yen）の比率で按分
            foreach ($priceByIdx as $idx => $price) {
                $fallbackRatioByIdx[$idx] = $price / $sumPrice;
            }
        } else {
            // auto: legal_ratio の比率で按分
            $sumRatio = 0.0;
            foreach ($heirsByIdx as $idx => $row) {
                $r = (float)($row['legal_ratio'] ?? 0.0);
                $fallbackRatioByIdx[$idx] = $r;
                $sumRatio                 += $r;
            }
            if ($sumRatio > 0.0) {
                foreach ($fallbackRatioByIdx as $idx => $r) {
                    $fallbackRatioByIdx[$idx] = $r / $sumRatio;
                }
            }
        }

        // per_idx（price_for_ratio）から比率を作るヘルパ
        $buildRatiosFromPerIdx = function (?array $perIdx, array $fallback) {
            $perIdx = $perIdx ?? [];
            $sumP   = 0;
            $ratio  = [];
            foreach ($perIdx as $idx => $rec) {
                $p = (int)($rec['price_for_ratio'] ?? 0);
                if ($p <= 0) continue;
                $ratio[(int)$idx] = $p;
                $sumP            += $p;
            }
            if ($sumP > 0) {
                foreach ($ratio as $idx => $p) {
                    $ratio[$idx] = $p / $sumP;
                }
                return $ratio;
            }
            // 全員0／未設定ならフォールバック（manual / legal_ratio）
            return $fallback;
        };

        // 内部ユーティリティ：指定された合計額を ratio で按分して taxable_share_yen を付与
        $applyAllocation = function (&$heirs, int $total, array $ratios): void {
            if ($total <= 0 || !is_array($heirs)) return;
            // ★端数寄せ先：比率>0の「最初の対象者」
            $firstKey  = null;
            $lastKey   = null; // ★保険
            $allocated = 0;
            foreach ($heirs as $k => &$row) {
                $idx = $row['row_index'] ?? null;
                if ($idx === null || !isset($ratios[$idx])) continue;
                $r = (float)($ratios[$idx] ?? 0.0);
                if ($r <= 0.0) continue;
                if ($firstKey === null) { $firstKey = $k; }
                $lastKey = $k;
                $share   = (int)floor($total * $r);
                $row['taxable_share_yen'] = $share;
                $allocated               += $share;
            }
            // 端数は「最初の対象者」に寄せる（保険で last）
            $targetKey = $firstKey ?? $lastKey;
            if ($targetKey !== null) {
                $heirs[$targetKey]['taxable_share_yen'] =
                    ($heirs[$targetKey]['taxable_share_yen'] ?? 0) + ($total - $allocated);
            }
        };

        // 2) after(t=0)：per_idx(0年目の P_i(0)) から比率を作って按分
        $perIdxAfter   = $after['per_idx'] ?? null;
        $ratiosAfter   = $buildRatiosFromPerIdx($perIdxAfter, $fallbackRatioByIdx);
        $totalAfter    = (int)($after['summary']['taxable_estate'] ?? 0);
        $applyAllocation($after['heirs'], $totalAfter, $ratiosAfter);

        // 3) 年次プロジェクション after[t]：各年の per_idx[t] があればそれで比率を作る
        if (is_array($projAfter)) {
            foreach ($projAfter as $t => $row) {
                if (!isset($row['summary']['taxable_estate'], $row['heirs']) || !is_array($row['heirs'])) {
                    continue;
                }
                $perIdxT   = $row['per_idx'] ?? null;
                $ratiosT   = $buildRatiosFromPerIdx($perIdxT, $ratiosAfter); // 年ごとに P_i(t) 優先、無ければ t=0 比率
                $totalT    = (int)$row['summary']['taxable_estate'];
                $heirsT    =& $row['heirs'];
                $applyAllocation($heirsT, $totalT, $ratiosT);
                $row['heirs'] = $heirsT;
                $projAfter[$t] = $row;
            }
        }

        return [$after, $projAfter];
    }



    /**
     * 「対策後(after)」および「年次プロジェクション(projections.after)」の
     * 所有財産（= 贈与後の相続財産の額: estate_after_yen）を
     * 「各相続人の課税価格比率」で按分した値を
     * heirs[].estate_base_share_yen として付与する。
     *
     * ・按分比率の決め方は allocateTaxableEstateByFixedRatios と同じ
     *   - manual: heirs[].manual_price_yen（課税価格）比率
     *   - auto  : heirs[].legal_ratio 比率
     * ・年次プロジェクション after[t] でも、各年の estate_after_yen を按分する
     *
     * NOTE:
     *  - summary['estate_base_yen'] は「贈与前総資産（比較用）」として保持しているため、
     *    “分割の基になる所有財産”は summary['estate_after_yen'] を採用する。
     */
    private function allocateEstateBaseByFixedRatios(array $after, array $projAfter, array $payload): array
    {
        if (!isset($after['heirs']) || !is_array($after['heirs'])) {
            return [$after, $projAfter];
        }

        // t=0 after.heirs から row_index => 行 へマップ
        $heirsByIdx = [];
        foreach ($after['heirs'] as $row) {
            if (!isset($row['row_index'])) continue;
            $heirsByIdx[(int)$row['row_index']] = $row;
        }
        if (empty($heirsByIdx)) {
            return [$after, $projAfter];
        }


        // ★ あなた仕様の遺産分割比率（固定）を作る：
        //  - 法定：金融/その他とも legal_ratio（民法割合）
        //  - 手入力：
        //      ・金融資産なし：その他比率は id_other_share、金融は0
        //      ・金融資産あり：金融比率は id_cash_share、その他比率は id_other_share
        $splitRatios = $this->resolveEstateSplitRatiosFixed($payload, $heirsByIdx);
        $cashRatioByIdx  = $splitRatios['cash']  ?? [];
        $otherRatioByIdx = $splitRatios['other'] ?? [];

        // 内部ユーティリティ：指定合計を ratio で按分（端数は最後へ）
        $applyAllocation = function (&$heirs, int $total, array $ratios, string $field): void {
            if ($total <= 0 || !is_array($heirs)) return;
            // ★端数寄せ先：比率>0の「最初の対象者」
            $firstKey  = null;
            $lastKey   = null; // ★保険
            $allocated = 0;
            foreach ($heirs as $k => &$row) {
                $idx = $row['row_index'] ?? null;
                if ($idx === null || !isset($ratios[$idx])) continue;
                $r = (float)($ratios[$idx] ?? 0.0);
                if ($r <= 0.0) continue;
                if ($firstKey === null) { $firstKey = $k; }
                $lastKey = $k;
                $share   = (int)floor($total * $r);
                $row[$field] = $share;
                $allocated                   += $share;
            }
            // 端数は「最初の対象者」に寄せる（保険で last）
            $targetKey = $firstKey ?? $lastKey;
            if ($targetKey !== null) {
                $heirs[$targetKey][$field] =
                    ($heirs[$targetKey][$field] ?? 0) + ($total - $allocated);
            }
        };

        // 2) after(t=0)：金融/その他を別々に按分し、合計も作る
        $cash0  = (int)($after['summary']['estate_after_cash_yen']  ?? 0);
        $oth0   = (int)($after['summary']['estate_after_other_yen'] ?? 0);
        $applyAllocation($after['heirs'], $cash0, $cashRatioByIdx,  'estate_cash_share_yen');
        $applyAllocation($after['heirs'], $oth0,  $otherRatioByIdx, 'estate_other_share_yen');
        foreach ($after['heirs'] as &$row) {
            $row['estate_base_share_yen'] =
                (int)($row['estate_cash_share_yen'] ?? 0) + (int)($row['estate_other_share_yen'] ?? 0);
        }
        unset($row);

        // 3) 年次プロジェクション after[t] も同じ比率（t=0固定）で按分
        if (is_array($projAfter)) {
            foreach ($projAfter as $t => $row) {
                if (!isset($row['summary']['estate_base_yen'], $row['heirs']) || !is_array($row['heirs'])) {
                    continue;
                }
                $cashT = (int)($row['summary']['estate_after_cash_yen']  ?? 0);
                $othT  = (int)($row['summary']['estate_after_other_yen'] ?? 0);
                $applyAllocation($row['heirs'], $cashT, $cashRatioByIdx,  'estate_cash_share_yen');
                $applyAllocation($row['heirs'], $othT,  $otherRatioByIdx, 'estate_other_share_yen');
                foreach ($row['heirs'] as &$hr) {
                    $hr['estate_base_share_yen'] =
                        (int)($hr['estate_cash_share_yen'] ?? 0) + (int)($hr['estate_other_share_yen'] ?? 0);
                }
                unset($hr);
                $projAfter[$t] = $row;
            }
        }

        return [$after, $projAfter];
    }


    /**
     * 「課税価格の取得がある人（相続/遺贈で財産を取得する人）」の idx(2..10) を決定する。
     *
     * 仕様：
     * - auto  : 法定相続人（bunsi/bunbo がある行）のみ
     * - manual: id_taxable_manu（手入力の課税価格）が >0 の行のみ
     *          ※ manual で 1件も無い場合は互換性のため heirs にフォールバック
     *
     * ここで決まった idx のみが「生前贈与加算」「贈与税額控除」「精算課税贈与税控除」の対象となる。
     *
     * @param array $payload
     * @param array $heirs collectHeirs() の結果
     * @return int[] idx の配列（昇順・ユニーク）
     */
    private function resolveTaxableAcquirerIdxList(array $payload, array $heirs): array
    {
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));

        $idxs = [];
        if ($mode === 'manual') {
            for ($i = 2; $i <= 10; $i++) {
                $kyen = $this->readKyen($payload, 'id_taxable_manu', $i);
                if ($kyen > 0) {
                    $idxs[] = $i;
                }
            }
            // manual 入力が1件も無い場合は heirs を採用（互換性確保）
            if (empty($idxs)) {
                foreach ($heirs as $h) {
                    $idx = (int)($h['idx'] ?? 0);
                    if ($idx >= 2 && $idx <= 10) $idxs[] = $idx;
                }
            }
        } else {
            foreach ($heirs as $h) {
                $idx = (int)($h['idx'] ?? 0);
            if ($idx >= 2 && $idx <= 10) $idxs[] = $idx;
            }
        }

        $idxs = array_values(array_unique(array_filter($idxs, fn($v) => is_int($v) && $v >= 2 && $v <= 10)));
        sort($idxs);
        return $idxs;
    }


