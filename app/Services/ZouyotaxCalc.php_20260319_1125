/**
 * 相続税の対策前（これからの贈与は無視）計算
 * - 被相続人（行1）の「所有財産＋金融資産＋改正に基づく過年度贈与算入」をベース資産とする
 * - 基礎控除：3,000万円 + 600万円 × 法定相続人の数
 * - 相続税総額は「法定相続分課税」に速算表を当てて合計
 * - 個人配賦（算出税額）は「相続税総額 × あん分割合」
 *   - manual のあん分割合：id_taxable_manu[2..10] の“課税価格の割合”
 *   - auto   のあん分割合：法定相続割合（legal_ratio）
 * - 2割加算、暦年贈与税額控除、配偶者軽減、その他控除、精算課税贈与税控除の順に適用
 * - 画面単位「千円」→ 内部「円」で計算
 */
class ZouyotaxCalc
{



    /**
     * 贈与税率表キャッシュ（最新kihu_year・versionで読む。税率が年で変わらない前提でもOK）
     * @var array<string, array<int, array{lower:int, upper:?int, rate:float, quick:int}>>
     */
    private array $giftRateRowsCache = [];

    /** @var array<string,int> */
    private array $giftRateYearCache = [];

    /**
     * 税率表の対象年（最新のkihu_year）を解決
     */
    private function resolveGiftRateYear(bool $tokurei): int
    {
        $key = $tokurei ? 'tokurei' : 'general';
        if (isset($this->giftRateYearCache[$key])) {
            return $this->giftRateYearCache[$key];
        }
        $year = $tokurei
            ? (int)(ZouyoTokureiRate::query()->whereNull('company_id')->max('kihu_year') ?: 2026)
            : (int)(ZouyoGeneralRate::query()->whereNull('company_id')->max('kihu_year') ?: 2026);
        $this->giftRateYearCache[$key] = $year;
        return $year;
    }

    /**
     * 税率表（lower/upper/rate/quick）を読み込む（キャッシュ）
     *
     * @return array<int, array{lower:int, upper:?int, rate:float, quick:int}>
     */
    private function loadGiftRateRows(bool $tokurei): array
    {
        $year = $this->resolveGiftRateYear($tokurei);
        $ckey = ($tokurei ? 'tokurei:' : 'general:') . $year;
        if (isset($this->giftRateRowsCache[$ckey])) {
            return $this->giftRateRowsCache[$ckey];
        }

        if ($tokurei) {
            $ver = (int)(ZouyoTokureiRate::query()->whereNull('company_id')->where('kihu_year', $year)->max('version') ?: 1);
            $rows = ZouyoTokureiRate::query()
                ->whereNull('company_id')->where('kihu_year', $year)->where('version', $ver)
                ->orderBy('seq')
                ->get(['lower','upper','rate','deduction_amount']);
        } else {
            $ver = (int)(ZouyoGeneralRate::query()->whereNull('company_id')->where('kihu_year', $year)->max('version') ?: 1);
            $rows = ZouyoGeneralRate::query()
                ->whereNull('company_id')->where('kihu_year', $year)->where('version', $ver)
                ->orderBy('seq')
                ->get(['lower','upper','rate','deduction_amount']);
        }

        $out = [];
        foreach ($rows as $r) {
            $rate = (float)($r->rate ?? 0.0);
            if ($rate > 1.0) $rate = $rate / 100.0; // 10.000 → 0.10
            $out[] = [
                'lower' => (int)($r->lower ?? 0),
                'upper' => $r->upper === null ? null : (int)$r->upper,
                'rate'  => $rate,
                'quick' => (int)($r->deduction_amount ?? 0),
            ];
        }

        $this->giftRateRowsCache[$ckey] = $out;
        return $out;
    }

    /**
     * 暦年贈与税額（千円）を「基礎控除後の課税価格 afterK（千円）」から計算する
     */
    private function calcCalendarGiftTaxK(int $afterK, bool $tokurei): int
    {
        if ($afterK <= 0) return 0;
        $baseYen = $afterK * 1000; // 円
        $rows = $this->loadGiftRateRows($tokurei);
        if (empty($rows)) return 0;
        foreach ($rows as $b) {
            $lower = (int)$b['lower'];
            $upper = $b['upper'] === null ? PHP_INT_MAX : (int)$b['upper'];
            if ($baseYen < $lower || $baseYen > $upper) continue;
            $taxYen = (int)round($baseYen * (float)$b['rate']) - (int)$b['quick'];
            if ($taxYen < 0) $taxYen = 0;
            return (int)round($taxYen / 1000); // 千円
        }
        return 0;
    }

    /**
     * 受贈者(row_no=2..10)の tokurei_zouyo フラグをDBから取得（無ければ0）
     */
    private function isTokureiRecipient(int $dataId, int $recipientNo): bool
    {
        if ($recipientNo < 2 || $recipientNo > 10) return false;
        try {
            $v = (int)(ProposalFamilyMember::query()
                ->where('data_id', $dataId)
                ->where('row_no', $recipientNo)
                ->value('tokurei_zouyo') ?? 0);
            return $v === 1;
        } catch (\Throwable $e) {
            return false;
        }
    }


    /**
     * future_gift_plan_entries.row_no の基準補正
     * - DBに 0..19 で保存されているデータがある場合：+1して 1..20 に正規化する
     * - 1..20 の場合：補正なし（0）
     */
    private int $futurePlanRowNoOffset = 0;

    /**
     * future_gift_plan_entries.row_no を t(1..20) に正規化する
     * - 0始まり(0..19) の場合は +1 して 1..20 へ
     * - 1..20 の場合はそのまま
     */
    private function normalizeFuturePlanT(int $rowNo): int
    {
        if ($this->futurePlanRowNoOffset === 1) {
            // 0..19 保存を 1..20 に正規化
            if ($rowNo >= 0 && $rowNo <= 19) return $rowNo + 1;
            return $rowNo; // 想定外はそのまま返す
        }
        // 1..20 保存はそのまま
        return $rowNo;
    }



    /** @var array<string,mixed> */
