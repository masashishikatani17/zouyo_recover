            $virtualCalendarIncluded = $virtual[$key]['calendar_included'] ?? [];
        }

        
        /*
        if ( $t ===1 && $context === 'before_proj'){
            Log::info('2026.03.17 00001 [ZouyotaxCalc][incl_cal_projection]', [
                'context'                    => $context,                    // 'before_proj' / 'after_virtual'
                't'                          => $t,                          // 0?20 年
                'death_date'                 => $deathDate->format('Y-m-d'),
                'calendar_total_yen'         => (int)($giftIncl['calendar_total_yen'] ?? 0),
                'calendar_per_idx'           => $giftIncl['calendar_per_idx'] ?? [],
                'virtual_calendar_included'  => $virtualCalendarIncluded,
            ]);
        }
        */
        

        // manual 表示用：各人の課税価格 P_i（千円）→ 円へ（比率算出などで利用）
        //  ※ただし年次プロジェクションでは「総額の速算ベース」は常に auto 計算にする。
        //    （資金運用利回りで増えた課税価格の総額を、t=0 の比率で横展開するため）
        $manualShares = $this->buildManualTaxableShares($payload, $basicDeduction, $giftIncl['per_idx'] ?? []);

        // ★プロジェクション用の課税遺産総額（速算ベース）
        //   - before_proj : estateYen - basicDeduction
        //   - after_virtual: 上で定義した「課税価格ベース」の taxableEstate
        $taxableEstateUsed = $taxableEstate;




        $legalShareRows = [];
        $totalLegalShareTax = 0;
        foreach ($heirs as $h) {
            
            
            // ★税務上の法定相続割合（bunsi/bunbo）で按分
            $bunsi = (int)($h['bunsi'] ?? 0);
            $bunbo = (int)($h['bunbo'] ?? 0);
            $taxRatio  = ($bunsi >= 1 && $bunbo >= 1) ? ($bunsi / $bunbo) : 0.0;
            $legalRatio = $taxRatio / $totalRatio;

            // ★ 速算ベースはループ前で確定させた $taxableEstateUsed
            $legalShareBase = (int)round($taxableEstateUsed * $legalRatio);

            //　2) 対策前プロジェクション（projections.before[t]）の相続税総額の計算処理
            $legalTax       = $this->applyInheritanceTable($legalShareBase, $brackets);

            $totalLegalShareTax += $legalTax;

        
        
        if ($context === 'after_virtual' && $t <= 10 ) {
        //if ($t === 0 ) {
            
            /*
            // ★ここで法定算出税額の中身を確認
            Log::debug('2026.01.19 150001', [
