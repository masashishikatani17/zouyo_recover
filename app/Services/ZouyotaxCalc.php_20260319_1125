    /**
     * ★比率で floor 配分（千円単位）し、端数は「比率>0の最初の対象者」へ寄せる
     * - 画面入力は千円単位なので、split も千円で確定させる（円→千円の端数問題を避ける）
     *
     * @param int $totalKyen
     * @param array<int,float> $ratios idx => ratio(0..1)
     * @return array<int,int> idx => shareKyen
     */
    private function allocateFloorByRatiosKyen(int $totalKyen, array $ratios): array
    {
        $shares = [];
        for ($i = 2; $i <= 10; $i++) { $shares[$i] = 0; }
        if ($totalKyen <= 0 || empty($ratios)) {
            return $shares;
        }

        $allocated = 0;
        $firstIdx  = null;
        $lastIdx   = null; // ★保険
        for ($i = 2; $i <= 10; $i++) {
            $r = (float)($ratios[$i] ?? 0.0);
            if ($r <= 0.0) continue;
            if ($firstIdx === null) { $firstIdx = $i; }
            $lastIdx = $i;
            $s = (int)floor($totalKyen * $r);
            $shares[$i] = $s;
            $allocated += $s;
        }
        $targetIdx = $firstIdx ?? $lastIdx;
        if ($targetIdx !== null) {
            $shares[$targetIdx] = (int)$shares[$targetIdx] + ($totalKyen - $allocated);
        }
        return $shares;
    }

