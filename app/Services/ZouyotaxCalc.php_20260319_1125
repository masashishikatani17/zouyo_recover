    }

    /**
     * heirs 配列を正規化して、必ず idx(2..10) を持つ形にする
     * - idx が無い場合：row_no → 配列キー の順に補完
     * - idx が 2..10 以外、または補完不能は除外
     *
     * @param array $heirs
     * @return array
     */
    private function normalizeHeirsWithIdx(array $heirs): array
    {
        $out = [];
        foreach ($heirs as $k => $h) {
            if (!is_array($h)) { continue; }
            $idx = (int)($h['idx'] ?? 0);
            if ($idx === 0) {
                $idx = (int)($h['row_no'] ?? 0);
            }
            if ($idx === 0 && is_numeric($k)) {
                $idx = (int)$k;
            }
            if ($idx < 2 || $idx > 10) {
                continue;
            }
            $h['idx'] = $idx;

            // ★ 欠損しやすいキーをここで必ず補完（Undefined array key を根絶）
            // 税務上の法定相続分（bunsi/bunbo）
            $h['bunsi'] = (int)($h['bunsi'] ?? 0);
            $h['bunbo'] = (int)($h['bunbo'] ?? 1);
            if ($h['bunbo'] <= 0) { $h['bunbo'] = 1; }

            // 民法上（参考）
            $h['civil_bunsi'] = (int)($h['civil_bunsi'] ?? 0);
            $h['civil_bunbo'] = (int)($h['civil_bunbo'] ?? 1);
            if ($h['civil_bunbo'] <= 0) { $h['civil_bunbo'] = 1; }

            // 続柄・2割加算（保持用）
            $h['rel_code']   = (int)($h['rel_code'] ?? 0);
            $h['two_tenths'] = (bool)($h['two_tenths'] ?? false);



            $out[] = $h;
        }
        return $out;
    }




    /**
     * 「対策後(after)」および「年次プロジェクション(projections.after)」の
     * 「課税価格」と「課税遺産総額」を定義し直す。
     *
     *   課税価格（kazei_price_yen）
     *     = estate_after_yen + incl_calendar_yen + incl_settlement_yen
     *
     *   課税遺産総額（taxable_estate）
     *     = max(0, 課税価格 - basic_deduction)
     *
     * とし、summary['taxable_estate'] には「課税遺産総額」を格納する。
     *
     * estate_after_yen が未設定の場合は、
     *   estate_base_yen + gift_decr_calendar_yen + gift_decr_payment_yen
     * から補完する。
     */
    private function normalizeTaxableEstateForAfter(array $after, array $projAfter): array
    {
        $normalize = function (array $summary): array {
            $base    = (int)($summary['estate_base_yen']          ?? 0);
            $decrCal = (int)($summary['gift_decr_calendar_yen']   ?? 0);
            $decrSet = (int)($summary['gift_decr_payment_yen']    ?? 0);

            
            // ★（贈与後）相続財産の額（減額後）
            // 要件：
            //   「将来贈与した分を各年の財産の額から差し引く」
            //
            // gift_decr_* は累計の“減少額（負値）”として compute() の年次ループで確定しているため、
            // gift_decr_* が非ゼロの年は必ず base + decr（=差し引き後）を正として採用する。
            //
            // ※ estate_after_yen が既に入っていても、差し引き前の値が紛れ得るため、
            //    decr がある年は estate_after_yen を信用しない。
            if ($decrCal !== 0 || $decrSet !== 0) {
                $estateAfter = $base + $decrCal + $decrSet;
            } elseif (array_key_exists('estate_after_yen', $summary) && $summary['estate_after_yen'] !== null) {
                $estateAfter = (int)$summary['estate_after_yen'];
            } else {
                $estateAfter = $base; // t=0等（decrなし）の安全な既定
            }

            if ($estateAfter < 0) $estateAfter = 0;

            // 生前贈与加算（暦年／精算）
            // ★ incl_* が未設定の場合は past_gift_included_total_yen から補完
            $inclCal = array_key_exists('incl_calendar_yen', $summary)
                ? (int)$summary['incl_calendar_yen']
                : 0;
    
            $inclSet = array_key_exists('incl_settlement_yen', $summary)
                ? (int)$summary['incl_settlement_yen']
                : 0;
                
                //DD('2026.01.20 9100000', $summary);
                
    
            if ($inclCal === 0 && $inclSet === 0 && isset($summary['past_gift_included_total_yen'])) {
                // 内訳が無い場合は「合計をそのまま課税価格に足す」
                // （内訳比率は不要なので分解しない）
                $inclCal = (int)$summary['past_gift_included_total_yen'];
                $inclSet = 0;
            }
    

            // 課税価格（= 相続財産の額 + 贈与加算額）
            $kazeiPrice = $estateAfter + $inclCal + $inclSet;

    
            /*
            Log::debug('2026.01.19 600001 [CHECK 課税価格]', [
                        'kazeiPriceice ' => $kazeiPrice,
                        'inclCal ' =>    $inclCal,
                        'inclSet ' =>    $inclSet
            ]);
            */



            // 基礎控除額
            $basicDeduction = (int)($summary['basic_deduction'] ?? 0);

            // 課税価格・課税遺産総額を格納
            $summary['estate_after_yen'] = $estateAfter;
            $summary['kazei_price_yen']  = $kazeiPrice; // 課税価格（参考表示用）

            // ★修正：課税遺産総額を $kazeiPriceYen に基づいて強制的に上書き
            $summary['taxable_estate']   = max(0, $summary['kazei_price_yen'] - $basicDeduction);
            
            return $summary;
        };

        // 対策後(after) 本体
        if (isset($after['summary']) && is_array($after['summary'])) {
            $after['summary'] = $normalize($after['summary']);
        }

        // 年次プロジェクション after[t]
        if (is_array($projAfter)) {
            foreach ($projAfter as $t => $row) {
                if (!isset($row['summary']) || !is_array($row['summary'])) {
                    continue;
                }
                $row['summary']  = $normalize($row['summary']);
                $projAfter[$t]   = $row;
            }
        }

        /*
        Log::debug('2025.12.19 600001 [CHECK normalize]', $after['summary']);
        */
        


        return [$after, $projAfter];
    }

    /** payload の plan配列（例：cal_amount[i] / set_amount[i]：千円）や *_all を年次合算して返す */
    private function readPlanKyenArrayAllRecipients(array $payload, string $key): array
    {
        $sum = array_fill(1, 20, 0);
        $usedAll = false;

        // ① 受贈者横断の集計キー（例：cal_amount_all[recipient_no][t] / set_amount_all[recipient_no][t]）
        for ($rn = 2; $rn <= 10; $rn++) {
            for ($t = 1; $t <= 20; $t++) {
                $v = Arr::get($payload, "{$key}_all.{$rn}.{$t}");
                if ($v === null || $v === '') { continue; }
                $n = (int)preg_replace('/[^\d\-]/u', '', (string)$v);
                $sum[$t] += $n;
                $usedAll = true;                
            }
        }
        // ② “現在開いている受贈者タブ” の一次元配列（plan[key][t] or key[t]）
        // ★ *_all が送られている場合は二重計上を避けるため一次元は無視する
        if (!$usedAll) {
            for ($t = 1; $t <= 20; $t++) {
                $v = Arr::get($payload, "{$key}.{$t}");
                if ($v === null) { $v = Arr::get($payload, "plan.{$key}.{$t}"); }
                if ($v === null || $v === '') { continue; }
                $n = (int)preg_replace('/[^\d\-]/u', '', (string)$v);
                $sum[$t] += $n;
            }
        }
        return $sum;
    }



    /**
     * 将来贈与プラン（DB保存分）を「年次合計（千円）」に畳み込んで返す。
     *
     * ★重要：ここでは「相続で取得する人（課税取得者）」のフィルタを絶対に掛けない。
     *  gift_decr_*（被相続人の財産減少）は「誰に贈与したか」に依らず、
     *  受贈者 2..10 全員への将来贈与を合算して作る必要があるため。
     *
     * @param int    $dataId
     * @param string $kind  'calendar' | 'settlement'
     * @return array<int,int> [1..20] => 千円
     */
    private function readSavedFutureAmountByYearK(int $dataId, string $kind): array
    {
        $sum = array_fill(1, 20, 0);

        // 念のため（想定外の kind は 0）
        $kind = strtolower($kind);
        if (!in_array($kind, ['calendar', 'settlement'], true)) {
            return $sum;
        }

        // ------------------------------------------------------------
        // ★重要：暦年/精算の混入を防ぐ
        //  - cal_amount_thousand / set_amount_thousand があるならそれを最優先
        //  - 無い場合のみ amount_thousand にフォールバック
        // ------------------------------------------------------------
        if (!Schema::hasTable('future_gift_plan_entries')) {
            return $sum;
        }

        $hasCalCol = Schema::hasColumn('future_gift_plan_entries', 'cal_amount_thousand')
                  || Schema::hasColumn('future_gift_plan_entries', 'calendar_amount_thousand');
        $hasSetCol = Schema::hasColumn('future_gift_plan_entries', 'set_amount_thousand')
                  || Schema::hasColumn('future_gift_plan_entries', 'settlement_amount_thousand');

        $amountCol = null;
        if ($kind === 'calendar') {
            if (Schema::hasColumn('future_gift_plan_entries', 'cal_amount_thousand')) {
                $amountCol = 'cal_amount_thousand';
            } elseif (Schema::hasColumn('future_gift_plan_entries', 'calendar_amount_thousand')) {
                $amountCol = 'calendar_amount_thousand';
            } elseif (Schema::hasColumn('future_gift_plan_entries', 'amount_thousand')) {
                $amountCol = 'amount_thousand';
            }
        } else { // settlement
            if (Schema::hasColumn('future_gift_plan_entries', 'set_amount_thousand')) {
                $amountCol = 'set_amount_thousand';
            } elseif (Schema::hasColumn('future_gift_plan_entries', 'settlement_amount_thousand')) {
                $amountCol = 'settlement_amount_thousand';
            } elseif (Schema::hasColumn('future_gift_plan_entries', 'amount_thousand')) {
                $amountCol = 'amount_thousand';
            }
        }
        if ($amountCol === null) {
            return $sum;
        }
 
 
        // kind を区別するカラムがある場合のみ利用（無ければ全行を読み、amountCol で吸収）
        $hasKindCol =
            Schema::hasColumn('future_gift_plan_entries', 'gift_kind')
            || Schema::hasColumn('future_gift_plan_entries', 'gift_type');
        $kindCol = Schema::hasColumn('future_gift_plan_entries', 'gift_kind') ? 'gift_kind'
                 : (Schema::hasColumn('future_gift_plan_entries', 'gift_type') ? 'gift_type' : null);

        $q = FutureGiftPlanEntry::query()
            ->where('data_id', $dataId)
            // ★受贈者は 2..10 全員（相続取得者に限定しない）
            ->whereBetween('recipient_no', [2, 10])
            // ★混入防止：対象カラムが null/0 の行は除外
            ->whereNotNull($amountCol)
            ->where($amountCol, '!=', 0);


        if ($hasKindCol && $kindCol) {
            // DBの値揺れ対策（calendar/cal/1 など）
            $vals = ($kind === 'calendar')
                ? ['calendar','cal','c','0','1',0,1]
                : ['settlement','set','s','2','9',2,9];
            $q->whereIn($kindCol, $vals);
        } else {
            // kind列が無い場合でも、cal/set専用カラムがあるなら混入は起きない。
            // ただし amount_thousand しか無い場合は「混在テーブル」の可能性があるため、
            // その場合はカラム側での排他ができない（=別途スキーマ合わせが必要）。
            // ここでは最低限、cal/set 専用カラムが存在するケースでは amount_thousand を使わないようにしている。
        }
         

        $rows = $q->get(['recipient_no', 'row_no', $amountCol]);

        // ============================================================
        // ★重要：row_no 正規化は「offset（data_idごとの保存方式）」を唯一の正とする
        //
        // - resolveFuturePlanRowNoOffset($dataId) により、
        //   0始まり保存（0..19）なのか 1始まり保存（1..20）なのかを決めている。
        // - hasOneBased のような “存在判定” で揺らすと、
        //   混在データで必要行まで捨てて t=1 が欠ける事故が起きる（今回）。
        // ============================================================
        $offset = (int)($this->futurePlanRowNoOffset ?? 0); // 0 or 1



        foreach ($rows as $r) {
            $rowNo = (int)($r->row_no ?? 0);

            // row_no 正規化（offsetで固定）
            if ($offset === 1) {
                // 0..19 を +1 で 1..20
                if ($rowNo < 0 || $rowNo > 19) {
                    continue; // 1..20 等は混在ゴミとして無視
                }
                $t = $rowNo + 1;
            } else {
                // 1..20 をそのまま
                if ($rowNo < 1 || $rowNo > 20) {
                    continue; // 0..19 等は混在ゴミとして無視
                }
                $t = $rowNo;
            }

            
            if ($t < 1 || $t > 20) {
                continue;
            }

            $amt = (int)($r->{$amountCol} ?? 0);
            if ($amt === 0) continue;
            $sum[$t] += $amt;
        }

        
        /*
