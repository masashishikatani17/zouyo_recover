                $kazeiPriceYen = (int)$estateYen;
                $estateAfterYen = max(0, $kazeiPriceYen);
    
            } else {
                $estateAfterYen = $estateAfterYenForAlloc !== null ? (int)$estateAfterYenForAlloc : (int)$estateYen;
                if ($estateAfterYen < 0) $estateAfterYen = 0;
                $kazeiPriceYen = $estateAfterYen + $inclCalForAlloc + $inclSetForAlloc;
            }        

        } else if ($context === 'before_proj') {
            //対策前
            
            // ?? 対策前：estateYen はそのまま課税価格として使う（上書きしない）
            $kazeiPriceYen = (int)$estateYen;
            $estateAfterYen = max(0, $kazeiPriceYen);



        } else {
            // その他のケース（念のため）：従来どおり
            //$kazeiPriceYen = max(0, (int)$estateYen);
            //$estateAfterYen = max(0, $kazeiPriceYen - $inclCalForAlloc - $inclSetForAlloc);
        }

        
        /*
        if ($context === 'before_proj') {
    
            if ($t === 1) {
            
                // ★ここで法定算出税額の中身を確認
                Log::debug('2025.12.15 20003 [ZouyotaxCalc][6-03] legal share', [
                    'data_id'            => $dataId,
                    't'                  => $t,
