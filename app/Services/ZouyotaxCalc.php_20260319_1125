    /**
     * 「現時点（基準日）から20年後まで」の“基準日”を決める。
     * 期待：将来贈与データがある場合は、その最小日付（最初の贈与日）を基準にする。
     * 無い場合は今日（server timezone）を基準にする。
     */
    private function resolveProjectionBaseDeathDateFromFuture(array $rekinen_Future_gift_data): \DateTimeImmutable
    {
        $min = null;
        foreach ($rekinen_Future_gift_data as $r) {
            if (!isset($r['rekinen_Futuregift_date']) || !($r['rekinen_Futuregift_date'] instanceof \DateTimeImmutable)) {
                continue;
            }
            $d = $r['rekinen_Futuregift_date'];
            if ($min === null || $d->getTimestamp() < $min->getTimestamp()) {
                $min = $d;
            }
        }
        return $min ?? new \DateTimeImmutable('today');
    }


    /**
     * 「第1回目贈与年月日（future_base_*）」の月日をDBから取得し、
     * future_gift_plan_entries.gift_month/day が未保存(0)の時に使う。
     *
     * 優先順：
     *  1) future_gift_headers（存在すれば）
     *  2) proposal_headers（存在すれば）
     *  3) フォールバック（12/31）
     */
    private function resolveFutureBaseGiftMonthDay(int $dataId): array
    {
        $m = 0;
        $d = 0;

        // 1) future_gift_headers（テーブル名/カラム名は環境差があるので存在チェック）
        if (Schema::hasTable('future_gift_headers')) {
            $row = DB::table('future_gift_headers')->where('data_id', $dataId)->first();
            if ($row) {
                $m = (int)($row->future_base_month ?? $row->base_month ?? $row->gift_month ?? 0);
                $d = (int)($row->future_base_day   ?? $row->base_day   ?? $row->gift_day   ?? 0);
            }
        }

        // 2) proposal_headers（ここに future_base_* を持っている構成もあるため）
        if (($m <= 0 || $d <= 0) && Schema::hasTable('proposal_headers')) {
            $row = DB::table('proposal_headers')->where('data_id', $dataId)->first();
            if ($row) {
                $m = $m > 0 ? $m : (int)($row->future_base_month ?? 0);
                $d = $d > 0 ? $d : (int)($row->future_base_day   ?? 0);
            }
        }

        // 3) 最終フォールバック（安全値）
        if ($m <= 0 || $d <= 0 || !checkdate($m, $d, 2024)) {
            $m = 12;
            $d = 31;
        }

        return [$m, $d];
    }
    
    
