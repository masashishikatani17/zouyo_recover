    /** POSTから将来贈与プラン（暦年/精算）を読み出す（不正は自動スキップ） */
    private function extractFuturePlanFromPayload(array $payload): array
    {

        /*
        Log::info('[DEBUG cal_amount raw]', Arr::get($payload, 'cal_amount'));

        Log::info('[DEBUG futurePlan extract:start]', ['payload_keys'=>array_keys($payload)]);
        */

        // ★ 初期化（この2キーだけ固定）
        $out = ['calendar' => [], 'settlement' => []];

        // ------------------------------------------------------------
        // ① 将来贈与は payload ではなく DB の future_gift_plan_entries を唯一の正として扱う
        // ------------------------------------------------------------
        $dataId = (int)($payload['data_id'] ?? 1);

        $saved = FutureGiftPlanEntry::where('data_id', $dataId)
                   // ★ 0始まり（0..19）データの混在も拾う
                   ->whereBetween('row_no', [0,20])
                   ->whereBetween('recipient_no', [2,10])
                   ->orderBy('row_no')
                   ->get();

        foreach ($saved as $r) {
            // ★ row_no を 1..20 に正規化（0始まりなら +1）
            $t = $this->normalizeFuturePlanT((int)($r->row_no ?? 0));
            if ($t < 1 || $t > 20) {
                continue;
            }

            // 暦年贈与（calendar）
            if ((int)$r->calendar_amount_thousand > 0) {
                
                
                // ★暦年贈与税（千円）はDB列が未保存(0)でも落とさない。
                //   まず既存列から拾い、それでも0なら税率表から再計算して埋める（全受贈者分を合算するため）
                $calTaxK = $this->resolveFutureCalendarTaxK($r);
                if ($calTaxK <= 0) {
                    $amtK = (int)($r->calendar_amount_thousand ?? 0);
                    if ($amtK > 0) {
                        // JSと同様：afterK = max(amountK - 1100, 0)
                        $afterK = max($amtK - 1100, 0);
                        $isTok  = $this->isTokureiRecipient($dataId, (int)$r->recipient_no);
                        $calTaxK = $this->calcCalendarGiftTaxK($afterK, $isTok);
                    }
                }

                $out['calendar'][] = [
                    // ★重要：贈与日（DB保存値）を唯一の正として渡す
                    //   これが null のままだと buildVirtualGiftsIndex() 側で cash_out_total が積めず、
                    //   将来贈与の現金流出控除が効かない
                    'y' => $r->gift_year  ?? null,
                    'm' => $r->gift_month ?? null,
                    'd' => $r->gift_day   ?? null,
                    'no'=> (int)$r->recipient_no,
                    'amount_thousand' => (int)$r->calendar_amount_thousand,
                    // ★暦年贈与税（千円）…全員分を累計に入れる（相続取得の有無は無関係）
                    'tax_thousand'    => $calTaxK,
                    't' => $t,
                ];
            }

            // 精算課税（settlement）
            if ((int)$r->settlement_amount_thousand > 0) {

                // ★精算贈与税（千円）も「全員・全額」を累計に入れる
                $setTaxK = $this->resolveFutureSettlementTaxK($r);


                $out['settlement'][] = [
                    'y' => $r->gift_year ?? null,
                    'm' => $r->gift_month ?? null,
                    'd' => $r->gift_day ?? null,
                    'no'=> (int)$r->recipient_no,
                    'amount_thousand' => (int)$r->settlement_amount_thousand,
                    'settlement_tax20_thousand' => $setTaxK,
                    't' => $t,
                ];


                /*
                Log::debug('SET TAX CHECK', [
                    'entry_id' => $r->id,
                    'no'       => $r->recipient_no,
                    't'        => $r->row_no,
                    'sett_amount' => $r->settlement_amount_thousand,
                    'sett_tax'    => $r->settlement_tax20_thousand,
                ]);        
                */


            }
        }
        
        
            
        // ------------------------------------------------------------
        // ② 基準贈与日（future_base_*）
        // ------------------------------------------------------------
        $baseY = (int)Arr::get($payload, 'future_base_year', 0);
        $baseM = (int)Arr::get($payload, 'future_base_month', 0);
        $baseD = (int)Arr::get($payload, 'future_base_day', 0);

        // ★ base が未入力（0）でも動くようにフォールバック
        //   - まず DB 上の将来贈与（暦年/精算）の gift_year/month/day を探す
        //   - それでも無ければ “当年12/31” を使う（贈与日が未確定で控除が死ぬのを防ぐ）
        if ($baseY <= 0 || $baseM <= 0 || $baseD <= 0) {
            foreach (array_merge($out['calendar'] ?? [], $out['settlement'] ?? []) as $row) {
                $yy = (int)($row['y'] ?? 0);
                $mm = (int)($row['m'] ?? 0);
                $dd = (int)($row['d'] ?? 0);
                if ($yy >= 1900 && $mm >= 1 && $mm <= 12 && $dd >= 1 && $dd <= 31) {
                    $baseY = $yy; $baseM = $mm; $baseD = $dd;
                    break;
                }
            }
            if ($baseY <= 0 || $baseM <= 0 || $baseD <= 0) {
                // ★最後の砦：死亡日（inherit）を使う
                $death = $this->resolveDeathDateFromPayload($payload, $dataId);
                if ($baseY <= 0) { $baseY = (int)$death->format('Y'); }
                if ($baseM <= 0) { $baseM = (int)$death->format('m'); }
                if ($baseD <= 0) { $baseD = (int)$death->format('d'); }
            }

        }


        $out['base'] = [
            'y' => $baseY,
            'm' => $baseM,
            'd' => $baseD,
        ];

        return $out;

    }

    /**
     * 将来贈与プランを「死亡日までに実施済みのもの」に限定し、
     * - 暦年：lookback算入分 / 暦年税額（控除用）
     * - 精算：全件算入 / 精算税額（控除用）
     * - 現金流出：全実施分の金額合計
     * を「死亡日文字列key」=> インデックスとして構築。
     */
     private function buildVirtualGiftsIndex(
         array $futurePlan,
         \DateTimeImmutable $deathDateT,
         array $pastIncluded,  // ← 過去贈与（calcPastGiftsIncluded... の結果）
         array $taxableIdxList = [], // ← ★課税価格の取得がある人のみ算入・控除の対象
         int $yearsAhead = 0,         // ← ★プロジェクション年次 t（この年次まで実施済みの贈与だけを対象）
         int $giftBudgetYen = 0       // ← ★No=1の原資上限（円）
     ): array
    {

        /*
        Log::warning('[ZouyotaxCalc][virtual_called]', [
            'deathDateT' => $deathDateT->format('Y-m-d'),
            'yearsAhead' => $yearsAhead,
            'set_rows'   => count((array)($futurePlan['settlement'] ?? [])),
        ]);
        */


        $key = $deathDateT->format('Y-m-d');
        $idx = [$key => [
            'calendar_included' => [], // recipient_no => yen（lookback内）
            'calendar_tax'      => [], // recipient_no => yen（税額控除）
            'settlement_all'    => [], // recipient_no => yen（全件算入）
            'settlement_tax'    => [], // recipient_no => yen（税額控除）
            'cash_out_total'    => 0,  // 円（現金流出）
        ]];
        
        //DD('2026.01.20 70000001', $key);  2025.05.07
        /*
                Log::debug('2026.01.20 0707070707 [ZouyoTaxCalc] calendar_included', [
                    'key' => $key,
                ]);
        */
        
        
        // ★No=1原資の残高（これが尽きたら、それ以降の将来贈与は「未実行」扱い）
        $remainingBudgetYen = max(0, $giftBudgetYen);

        
        [$start, $end, $kasan_case] = $this->determineCalendarGiftLookbackRange($deathDateT);

        $targetSet = [];
        foreach ($taxableIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) $targetSet[$i] = true;
        }
        $hasTargetFilter = !empty($targetSet);

        // ★修正：
        //   deathDateT は “その年の死亡日” として computeScenarioForGivenDate() から渡される値を
        //   そのまま使うべきであり、ここで上書きしてはいけない。
        //   → 上記ループは完全削除する。



        // ?? 毎年の贈与日（フォールバック）：
        //    「t年後」= base に対して +t年（t=1 が +1年）として扱う
        $base = $futurePlan['base'] ?? ['y'=>0,'m'=>0,'d'=>0];
        $baseY = (int)$base['y'];
        $baseM = (int)$base['m'];
        $baseD = (int)$base['d'];




        // 100万円控除用
        // ★ 正：3年超判定は「死亡日前◯年」で決定する（改正後は 4～7 年 へ自動延長）
        //   determineCalendarGiftLookbackRange() が「開始日(start)」は算入期間用に決めるが、
        //   控除判定は死亡日からの backwards 年数で行う必要がある。
        //   （2027～2031死亡は start=2024-01-01 だが、控除判定は死亡日前◯年）
        $threeYearsAgo = $deathDateT->sub(new \DateInterval('P3Y'));

        // ★JS(future_zouyo.blade)に合わせる：死亡年条件なしで常に控除対象（3年超に対して）
        $useOneMillionExemption = true;

        // ★受贈者ごとの「その死亡年における100万円控除適用フラグ」
        $used100mLocal = array_fill(2, 9, false);


        /**
         * ============================================================
         *  暦年贈与（将来贈与）
         *  ・贈与日は hidden の gift_year[i]/gift_month[i]/gift_day[i] を唯一の正として使用する
         *  ・t>=1 なら gift_year = base_year + (t-1)
         *  ・lookback に入る場合のみ算入
         *  ・3年超かつ death>=2027-01-01 の場合「100万円控除」
         * ============================================================
         */

        foreach ((array)$futurePlan['calendar'] as $r) {
            $rowNo = (int)($r['t'] ?? 0);

            //if ($rowNo < 1) continue;
            if ($rowNo < 0) continue;
            
            
            // ★年次tまでに実施済みの贈与だけを対象（控除が確実に効くように）
            if ($yearsAhead >= 0 && $rowNo > $yearsAhead) {
                continue;
            }

            // ?? gift_date は FutureGiftPlanEntry に保存した値を優先。ただし欠損が多いので「欠けた部品だけ」補完する
            $giftY = (int)($r['y'] ?? 0);
            $giftM = (int)($r['m'] ?? 0);
            $giftD = (int)($r['d'] ?? 0);

            // base の安全化（DBにbaseが無い/壊れていても落ちないように）
            if ($baseM < 1 || $baseM > 12) { $baseM = 12; }
            if ($baseD < 1 || $baseD > 31) { $baseD = 31; }

            // ★欠損補完（重要）：
            //  - 年が無い：t=1は「1年後」なので baseY + rowNo（= +1年）を採用
            //  - 月日が無い：年は尊重し、月日だけ base の月日に補完（giftDate を必ず作れるようにする）
            if ($giftY < 1900) {
                $giftY = ($baseY >= 1900) ? ($baseY + $rowNo) : (int)$deathDateT->format('Y') + $rowNo;
            }
            if ($giftM < 1 || $giftM > 12) { $giftM = $baseM; }
            if ($giftD < 1 || $giftD > 31) { $giftD = $baseD; }

            // ★既存DBが「baseY + (t-1)」で入っている場合の補正（t=1が+0年問題）
            if ($baseY >= 1900 && $rowNo >= 1 && $giftY === ($baseY + ($rowNo - 1))) {
                $giftY = $baseY + ($rowNo - 1);
            }


            $no   = (int)($r['no'] ?? 0);
            $amtK = (int)($r['amount_thousand'] ?? 0); // 千円
            $taxK = (int)($r['tax_thousand'] ?? 0);    // 千円

                /*
                Log::debug('2026.01.21 6666666 [ZouyotaxCalc][virtual][invalid_gift_date]', [
                    'rowNo' => $rowNo,
                    'no'    => (int)($r['no'] ?? 0),
                    'y'     => $giftY,
                    'm'     => $giftM,
                    'd'     => $giftD,
                    'd'     => $giftD,
                    'd'     => $giftD,
                ]);
                */


            if ($no < 2 || $no > 10 || $amtK <= 0) {
                continue;
            }

            $plannedYen = $this->toYen($amtK);

            $giftDate = null;
            try {
                $giftDate = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $giftY, $giftM, $giftD));
            } catch (\Throwable $e) {
                $giftDate = null; // ← cash_out_total は積んだのでここでは落とさない
                
                /*
                Log::debug('[ZouyotaxCalc][virtual][invalid_gift_date]', [
                    'rowNo' => $rowNo,
                    'no'    => (int)($r['no'] ?? 0),
                    'y'     => $giftY,
                    'm'     => $giftM,
                    'd'     => $giftD,
                ]);
                */
                
                
            }

            // ★修正：二重加算を削除（上で既に cash_out_total を積んでいる）
            // $idx[$key]['cash_out_total'] += $this->toYen($amtK);

            // ★重要：未実施判定は「yearsAhead(rowNo<=yearsAhead)」で一本化する
            //  - giftDate は lookback 判定（算入対象期間）にだけ使う
            //  - DB保存の gift_date が年次とズレていても、年次上「実施済み」なら反映させる
            /*
            if ($giftDate !== null && $giftDate <= $deathDateT) {
                
                
                Log::debug('2026.01.19 000001 [ZouyotaxCalc][virtual][date_ahead_but_included_by_year]', [
                    'death_date'  => $deathDateT->format('Y-m-d'),
                    'gift_date'   => $giftDate->format('Y-m-d'),
                    'yearsAhead'  => $yearsAhead,
                    'rowNo'       => $rowNo,
                    'no'          => (int)($r['no'] ?? 0),
                ]);
                
            }
            */

            // ★原資不足なら以降の贈与は未実行（年次順なので break でOK）
            if ($remainingBudgetYen < $plannedYen) {
                break;
            }
            $remainingBudgetYen -= $plannedYen;
            
            //$key = $giftDate;
            //$key = $giftDate->format('Y-m-d');
                
                /*
                Log::debug('2026.01.20 4777777 [ZouyoTaxCalc] calendar_included', [
                    'giftDate' => $giftDate,
                    'no'   => $no,
                    'key'  => $key,
                    'amtK' => $amtK,
                ]);
                */
            
            //DD('2026.01.21 key', $key);
            
            
            // ============================================================
            // ★必須：この日付キーがまだ作られていないケースがある（控除/算入対象がいない日など）
            // その場合でも「現金流出（cash_out_total）」は全贈与分を集計したいので、
            // ここで必ず初期化してから加算する。
            // ============================================================
            if (!array_key_exists($key, $idx) || !is_array($idx[$key])) {
                $idx[$key] = [];
            }
            if (!array_key_exists('cash_out_total', $idx[$key]) || !is_int($idx[$key]['cash_out_total'])) {
                $idx[$key]['cash_out_total'] = 0;
            }
            $idx[$key]['cash_out_total'] += $plannedYen;




            // ★算入・税額控除は「課税価格の取得がある人のみ」
            if ($hasTargetFilter && !isset($targetSet[$no])) {
                continue;
            }


            // 日付が無い/壊れている場合は「算入・税額控除」はスキップ（控除だけは効く）
            if ($giftDate === null) {
                continue;
            }


            // ルックバック外は「課税価格への算入」はしない（現金流出だけ反映済み）
            if (!($giftDate >= $start && $giftDate <= $end)) {
                continue;
            }


            // ==========================
            // ★修正仕様：
            //   「過去贈与が無い受贈者だけ」将来贈与で 100 万円控除を 1 回だけ適用する
            //   過去贈与がある受贈者は virtual では控除しない
            //
            // 今回の不具合：
            //   t=4〜7 で future_calendar_yen が 40,000千円 → 39,000千円に落ちていた。
            //   原因は、過去贈与が既にある受贈者に対しても
            //   3年超へ移行した将来贈与へ 1000千円控除を適用していたため。
            // ==========================

            // ★過去贈与の有無は「過去贈与算入結果」から判定する
            $pastCal  = (int)($pastIncluded['calendar_per_idx'][$no]   ?? 0);
            $pastSet  = (int)($pastIncluded['settlement_per_idx'][$no] ?? 0);
            $hasPastGift = ($pastCal > 0 || $pastSet > 0);

            if ($giftDate >= $threeYearsAgo) {
                // 3年以内 → 控除なし
                $includeK = $amtK;
            } else {
                // 3年超
                // ★過去贈与がある受贈者には 100万円控除を適用しない
                if ($hasPastGift) {
                    $includeK = $amtK;
                } elseif (!$used100mLocal[$no]) {
                    $includeK = max(0, $amtK - 1000);
                    $used100mLocal[$no] = true;
                } else {
                    $includeK = $amtK;
                }
            }


                /*
                Log::debug('2026.01.20 6999999 [ZouyoTaxCalc] calendar_included', [
                    'no' => $no,
                    'key' => $key,
                ]);
                */


            // 暦年贈与算入額（円）
            $idx[$key]['calendar_included'][$no]
                = ($idx[$key]['calendar_included'][$no] ?? 0)
                + $this->toYen($includeK);
            
                /*
                Log::debug('2026.01.20 700001 [ZouyoTaxCalc] calendar_included', [
                    'no' => $no,
                    'key' => $key,
                    'calendar_included' => $idx[$key]['calendar_included'][$no],
                ]);
                */

            // 贈与税額控除（税額はそのまま）
            $idx[$key]['calendar_tax'][$no]
                = ($idx[$key]['calendar_tax'][$no] ?? 0)
                + $this->toYen($taxK);
        }

        
        // 精算（現金流出は全員 / 算入は全員 / 税額控除は別途ロジックで扱う）
        foreach ((array)$futurePlan['settlement'] as $r){
            $rowNo = (int)($r['t'] ?? 0);

            /*
            // ログ出力: 受贈者の情報を確認
            Log::debug('2025.12.24 100001 [ZouyoTaxCalc] Settlement entry', [
                'rowNo' => $rowNo,
                't' => $r['t'],
                'no' => $r['no'],
                'amount_thousand' => $r['amount_thousand'],
                'settlement_tax20_thousand' => $r['settlement_tax20_thousand']
            ]);
            */


            if ($rowNo < 1) continue;
            // ★年次tまでに実施済みの精算贈与だけを対象
            if ($yearsAhead >= 0 && $rowNo > $yearsAhead) {
                continue;
            }
            $no = (int)($r['no'] ?? 0);
            $amtK = (int)($r['amount_thousand'] ?? 0);
            if ($no < 2 || $no > 10 || $amtK <= 0) {
                continue;
            }

            /*
            // ログ出力: 受贈者が対象になる場合の詳細
            Log::debug('2025.12.24 200001 [ZouyoTaxCalc] Valid settlement', [
                'rowNo' => $rowNo,
                'no' => $no,
                'amtK' => $amtK,
            ]);
            */

            $yen = $this->toYen($amtK);


            // ★重要：精算も未実施判定は yearsAhead(rowNo<=yearsAhead) のみ
            // （日付ベースで落とすと、incl_* が年次より1年遅れる原因になる）


            // ★原資不足なら以降の贈与は未実行
            if ($remainingBudgetYen < $yen) {
                break;
            }
            $remainingBudgetYen -= $yen;
            $idx[$key]['cash_out_total'] += max(0, $yen);

            
        /*
        // ★ デバッグ：cash_out_total が 0 のままなら、将来贈与が「読めていない」か「金額が0」。
        Log::debug('[ZouyotaxCalc][virtual] built', [
            'key'          => $key,
            'yearsAhead'   => $yearsAhead,
            'cash_out_yen' => (int)($idx[$key]['cash_out_total'] ?? 0),
            'cal_count'    => count($futurePlan['calendar'] ?? []),
            'set_count'    => count($futurePlan['settlement'] ?? []),
        ]);
        */
            
            // ★精算：現金流出は全員分
            // ★精算：算入・税額控除も「精算課税贈与を受けた人は全員」対象（課税価格取得の有無は問わない）

            $yenKasan = 0;
            
            // $yen は上で確定済み（控除にも使った）
            
               //2025.
               // 2024年以降の場合は1100000円を控除
               $giftYear = (int)substr($deathDateT->format('Y'), 0, 4);  // 贈与年を取得
               if ($giftYear >= 2024) {
                   $yenKasan = max(0, $yen - 1100000);  // 控除後の金額
                   //log::DEBUG('2025.12.10 50003 giftYear = '.$giftYear,['yen',$yenKasan]);
               }
            
            
            $taxYen = $this->toYen((int)($r['settlement_tax20_thousand'] ?? 0));


            $idx[$key]['settlement_all'][$no] = ($idx[$key]['settlement_all'][$no] ?? 0) + max(0,$yenKasan);
            $idx[$key]['settlement_tax'][$no] = ($idx[$key]['settlement_tax'][$no] ?? 0) + max(0,$taxYen);


        }
        
        
        /*
        // ★デバッグ：この死亡日に対して構築された virtual の暦年税額を確認
        Log::info('2025.12.15 10001 [ZouyotaxCalc][virtual_calendar_tax]', [
            'death_date'      => $deathDate->format('Y-m-d'),
            'calendar_tax'    => $idx[$key]['calendar_tax'] ?? [],
            'calendar_incl'   => $idx[$key]['calendar_included'] ?? [],
            'cash_out_total'  => $idx[$key]['cash_out_total'] ?? 0,
        ]);
        */
        

        // ★検証：精算課税の settlement_all が yearsAhead で増えるか
        $setSum = 0;
        foreach (($idx[$key]['settlement_all'] ?? []) as $v) {
            $setSum += (int)$v;
        }
        
        /*
        Log::warning('[ZouyotaxCalc][virtual_built_set_sum]', [
            'deathDateT'  => $deathDateT->format('Y-m-d'),
            'yearsAhead'  => $yearsAhead,
            'set_sum_yen' => $setSum,
            'set_keys'    => array_keys((array)($idx[$key]['settlement_all'] ?? [])),
        ]);
        */

        return $idx;
    }

    /**
     * 将来贈与で減額した後の「No=1 遺産（金融/その他の内訳付き）」を返す
     * - 金融資産あり: 原資は No=1 cash（運用しないので一定）
     * - 金融資産なし: 原資は No=1 nonCash
     */
    private function applyFuturePlanToEstateParts(
        int $nonCashYen,
        int $cashYenAtYear,
        array $virtualByDate,
        \DateTimeImmutable $deathDate
    ): array {
        $key = $deathDate->format('Y-m-d');
        $plannedOut = (int)($virtualByDate[$key]['cash_out_total'] ?? 0);

        $source = (string)($this->caseConfig['gift_funding_source'] ?? 'cash1'); // 'cash1' | 'noncash1'
        $cashAfter   = max(0, $cashYenAtYear);
        $nonCashAfter= max(0, $nonCashYen);

        if ($source === 'noncash1') {
            // ★金融資産なし：No=1 その他資産から控除
            $actualOut   = min($plannedOut, $nonCashAfter);
            $nonCashAfter= max(0, $nonCashAfter - $actualOut);
        } else {
            // ★金融資産あり：No=1 金融資産から控除
            $actualOut = min($plannedOut, $cashAfter);
            $cashAfter = max(0, $cashAfter - $actualOut);
        }

        $estateAfter = $nonCashAfter + $cashAfter;

        /*
        Log::debug('2025.12.17 20001 [ZouyotaxCalc][estate_after]', [
            'key'                => $key,
            'funding_source'     => $source,
            'planned_out_yen'    => $plannedOut,
            'noncash_after_yen'  => $nonCashAfter,
            'cash_after_yen'     => $cashAfter,
            'estate_after_yen'   => $estateAfter,
        ]);
        */

        return [
            'estate_after_yen'      => $estateAfter,
            'estate_after_cash_yen' => $cashAfter,
            'estate_after_other_yen'=> $nonCashAfter,
        ];
    }

    /** 既存互換：遺産（合計）だけ欲しい呼び出し向け */
    private function applyFuturePlanToEstate(int $nonCashYen, int $cashYenAtYear, array $virtualByDate, \DateTimeImmutable $deathDate): int
    {
        return (int)($this->applyFuturePlanToEstateParts($nonCashYen, $cashYenAtYear, $virtualByDate, $deathDate)['estate_after_yen'] ?? 0);
    }

    /** 共通シナリオ計算（対策前/対策後を切り替え） */
    private function computeScenario(
        array $payload,
        array $heirs,
        int $basicDeduction,
        int $propertyNonCashYen,
        int $cashNowYen,
        float $rate,
        \DateTimeImmutable $deathDate,
        array $brackets,
        array $futurePlan = [],
        bool $ignoreFuturePlanAtT0 = false,
        ?array $giftTaxCreditsOverride = null,
        int $t = 0
    ): array {
        $dataId = 1;

        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);


        // ★仕様：No=1の金融資産は運用しない（t=0はそのまま）
        $cashGrown = $this->decedentCashAtYear($cashNowYen, 0, $rate);

        // ★ 贈与前（比較用）の遺産：非現金 + 成長後現金（t=0なので現金はそのまま）
        $estateBefore = $propertyNonCashYen + $cashGrown;

        // ★ $useFuturePlan=false のときも参照するので、必ず初期化しておく（Undefined variable $parts 対策）
        $parts = [
            'estate_after_yen'       => $estateBefore,
            'estate_after_cash_yen'  => $cashGrown,
            'estate_after_other_yen' => $propertyNonCashYen,
        ];

        // 将来贈与を考慮するかどうか（t=0 は無視、それ以外は futurePlan を反映）
        // ?? 修正：compute() は t=0 専用なので、将来贈与は常に無視
        if (empty($futurePlan)) {
            // t=0または贈与プランなし：過去贈与のみ評価（将来贈与は含めない）
            $virtual = [];
            $estateBase = $propertyNonCashYen + $cashGrown;
            // ★未設定のときだけ計算（override 優先）
            if ($giftIncl === null) {
                
                
                /*
                Log::debug("2026.01.27 1000000-6", [
                    'deathDate' => $deathDate,
                    't' => $t,
                ]);
                */
            
                $giftIncl = $this->calcPastGiftsIncludedInEstateByRecipient(
                    $dataId,
                    $deathDate,
                    $payload,
                    $taxableAcquirerIdxList,
                    $heirs,
                    $t
                );
            }
        } else {
            // t=1以降：将来贈与を含めた virtual シナリオを使用
            $giftBudgetYen = $this->giftBudgetYenForDecedent($propertyNonCashYen, $cashGrown);

            /*
            Log::debug("2026.01.27 1000000-7", [
                'deathDate' => $deathDate,
                't' => 0,
            ]);
            */
            
            $pastOnly = $this->calcPastGiftsIncludedInEstateByRecipient(
                $dataId, 
                $deathDate, 
                $payload,
                $taxableAcquirerIdxList,
                $heirs,
                0
            );
            
            /*
            Log::debug("2026.01.21 7000000-2");
            */
            
            $virtual = $this->buildVirtualGiftsIndex(
                $futurePlan,
                $deathDate,
                $pastOnly,
                $taxableAcquirerIdxList,
                $t,
                $giftBudgetYen
            );
            
            
            
            $parts = $this->applyFuturePlanToEstateParts($propertyNonCashYen, $cashGrown, $virtual, $deathDate);
            $estateBase = (int)($parts['estate_after_yen'] ?? 0);

            //Log::debug("2026.01.21 6000000-2");
            // calcPastGiftsIncludedInEstateByRecipientWithVirtual は
            // (dataId, deathDate, heirIdxList, virtual, payload, taxableAcquirerIdxList, heirs)
            // の 7 引数が必要
            $heirIdxList = [];
            foreach ($heirs as $h) {
                // heirs が配列想定（['idx'=>..]）。構造が違っても Notice を出さない
                if (is_array($h) && array_key_exists('idx', $h)) {
                    $heirIdxList[] = (int)$h['idx'];
                }
            }

            $giftIncl = $this->calcPastGiftsIncludedInEstateByRecipientWithVirtual(
                $dataId,
                $deathDate,
                $heirIdxList,
                $t,
                $virtual,
                $payload,
                $taxableAcquirerIdxList,
                $heirs
            );
        }
        
/*        
Log::warning('[ZouyotaxCalc][settlement_ref_check]', [
  't' => $t,
  'deathDate' => $deathDate->format('Y-m-d'),
  'pastOnly_set_yen' => (int)($pastOnly['settlement_total_yen'] ?? 0),
  'giftIncl_set_yen' => (int)($giftIncl['settlement_total_yen'] ?? 0),
  'v_set_sum_yen' => array_sum(array_map('intval', ($virtual[$deathDate->format('Y-m-d')]['settlement_all'] ?? []))),
]);
*/


        // ★ 贈与後（実際の贈与額控除後）の遺産（= 相続財産の額のベース）
        $estateAfter = $estateBase;

        // 課税価格（相続税計算用の総額）= 贈与後遺産 +（過去＋将来の算入額）
        $estateYen = $estateAfter + (int)($giftIncl['total_yen'] ?? 0);

        // 以降は compute() 冒頭と同様
        $taxableEstate = max(0, $estateYen - $basicDeduction);

        // manual表示の取り扱い（贈与算入は per_idx を渡す）
        $manualShares = $this->buildManualTaxableShares($payload, $basicDeduction, $giftIncl['per_idx'] ?? []);
        $manualTotalTaxableYen = (int)($manualShares['total_taxable_yen'] ?? 0);
        $inputMode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        $isManualActive = ($inputMode === 'manual') && ($manualTotalTaxableYen > 0);
        $taxableEstateUsed = $isManualActive ? $manualTotalTaxableYen : $taxableEstate;

        // 法定分課税
        $totalRatio = 0.0; 
        foreach ($heirs as $h) {
            $totalRatio += $this->civilRatio($h); // ★民法上の法定相続割合
        } 
        
        $totalRatio = $totalRatio>0 ? $totalRatio : 1.0;
        $legalShareRows = []; $totalLegalShareTax = 0;

        foreach ($heirs as $h) {
            $legalRatio     = ($this->civilRatio($h)) / $totalRatio; // ★民法上の法定相続割合で按分
            $legalShareBase = (int)round($taxableEstateUsed * $legalRatio);
            
            //  3) 対策後（after：t=0）の相続税総額の計算処理
            $legalTax       = $this->applyInheritanceTable($legalShareBase, $brackets);
            $totalLegalShareTax += $legalTax;
            
            
            $legalShareRows[$h['idx']] = [
                'legal_ratio'     => $legalRatio,
                'legal_share_yen' => $legalShareBase,
                'legal_tax_yen'   => $legalTax,

                // ★ keys欠損で落ちるため null-safe
                'bunsi'           => (int)($h['bunsi'] ?? 0),
                'bunbo'           => (int)($h['bunbo'] ?? 1),

                'two_tenths'      => (bool)($h['two_tenths'] ?? false),
                'rel_code'        => (int)($h['rel_code'] ?? 0),
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$h['idx']] ?? 0),
            ];
        }

        // あん分割合（t=0 時点の入力に基づく比率：manual/auto）
        //   → ここでは「ベース資産（贈与加算前）の割り振り比率」として使い、
        //     さらに「その年に算入される贈与分」を足した課税価格で最終比率を決める。
        $anbun = $this->buildAnbunRatios($payload, $heirs, $legalShareRows);
        $anbunMode      = $anbun['mode'];
        $anbunRatios    = $anbun['ratios'];   // idx => base ratio (t=0 由来)
        $anbunTotalKyen = $anbun['total_kyen'];

        // ★ この年(t=0)の「贈与加算前ベース資産」を推定
        //    estateYen = estateBaseForAlloc + 贈与算入額(total_yen) という構造なので、
        //    贈与分を差し引くことで「ベース資産部分」を取り出す。
        $estateBaseForAlloc = $estateYen - (int)($giftIncl['total_yen'] ?? 0);
        if ($estateBaseForAlloc < 0) {
            $estateBaseForAlloc = 0;
        }

        // ★ 各 idx(2..10) について、その年(t=0)の「課税価格」を算定
        //   課税価格 P_i(0) ＝ ベース資産シェア_i(0) ＋ その年に算入される贈与分_i(0)
        //   ※ manual モードでは非法定相続人も id_taxable_manu に応じて baseRatio が付くため、
        //      2?10 行すべてを対象にする。
        $priceForRatioByIdx = [];
        $sumPriceForRatio   = 0;

        // ① まず t=0 の baseShareYen を再構築
        if ($anbunMode === 'manual') {
            // --------------------------------------------------
            // manual：id_taxable_manu をそのままベース資産とする
            // --------------------------------------------------
            $sumBaseShare = 0;
            for ($idx = 2; $idx <= 10; $idx++) {
                $manualKyen = $this->readKyen($payload, 'id_taxable_manu', $idx);
                if ($manualKyen < 0) {
                    $manualKyen = 0;
                }
                $yen = $this->toYen($manualKyen);
                $baseShareYenByIdx[$idx] = $yen;
                $sumBaseShare += $yen;
            }
            if ($sumBaseShare <= 0) {
                $sumBaseShare = 1;
            }

            $baseShareRatio = [];
            for ($idx = 2; $idx <= 10; $idx++) {
                $baseShareRatio[$idx] = $baseShareYenByIdx[$idx] / $sumBaseShare;
            }

        } else {
            // --------------------------------------------------
            // auto：民法上の法定相続割合（civil）を唯一の基準とする
            // --------------------------------------------------
            $civilRatios = $this->normalizedCivilRatiosByIdx($payload, $heirs);

            $baseShareRatio = [];
            for ($idx = 2; $idx <= 10; $idx++) {
                $baseShareRatio[$idx] = (float)($civilRatios[$idx] ?? 0.0);
                $baseShareYenByIdx[$idx] =
                    (int)floor($estateBaseForAlloc * $baseShareRatio[$idx]);
            }
        }


        for ($idx = 2; $idx <= 10; $idx++) {
            // t=0 の anbunRatios をベース資産の分割比率として利用（manual: id_taxable_manu 比率）

            // ★ 生前贈与加算額（暦年＋精算）
            $giftYen = (int)($giftIncl['per_idx'][$idx] ?? 0);

            // ★ 遺産部分（estateBase=贈与後遺産）をベース比率で按分
            $inheritPart = (int)round($estateBase * $baseShareRatio[$idx]);

            // ★ 課税価格 P_i(t)
            $price = max(0, $inheritPart + $giftYen);


            
            $priceForRatioByIdx[$idx] = $price;
            $sumPriceForRatio        += $price;
            
            
            
            /*
            Log::debug('2025.12.23 00002 生前贈与加算後課税価格 ', [
                'idx'        => $idx,
                'giftYen'    => $giftYen,
                '$price'     => $price,
            ]);
            */
            
            
            
        }


        // ★ この年(t=0)の「各相続人の生前贈与後の課税価格 P_i(0)」を per_idx として保持
        //   Blade 側では after['per_idx'][$idx]['price_for_ratio'] で参照できる
        $perIdx = [];
        for ($idx = 2; $idx <= 10; $idx++) {

            $inheritPart = (int)round($estateBase * $baseShareRatio[$idx]);
            $giftYen     = (int)($giftIncl['per_idx'][$idx] ?? 0);

            $perIdx[$idx] = [
                'price_for_ratio' => $inheritPart + $giftYen,
                'inherit_part_yen'=> $inheritPart,
                'gift_part_yen'   => $giftYen,
            ];

            /*
            Log::debug('30010_[ZouyotaxCalc][before_proj_per_idx]', [
                'idx'        => $idx,
                'price_for_ratio' => $inheritPart + $giftYen,
            ]);
            */
            


        }

        // ★ 課税価格に基づく「この年(t=0)のあん分比率」
        $anbunRatiosForYear = [];
        if ($sumPriceForRatio > 0) {
            foreach ($priceForRatioByIdx as $idx => $price) {
                $anbunRatiosForYear[$idx] = $price / $sumPriceForRatio;
            }
        } else {
            // 万一すべて 0 なら、従来どおり t=0 の比率をそのまま使用
            $anbunRatiosForYear = $anbunRatios;
        }

        // 控除（暦年・精算）
        //  - t=0: 「これからの贈与」を無視するため、過去分のみ（従来どおり）
        //  - t>0: 仮想（将来）贈与分も合算した控除額を使用
        // ?? compute()（t=0）では将来贈与は未実施のため、過去分のみ評価



        // ★未定義防止：ここに到達する前に $giftTaxCredits が作られていないパスがあるため、
        //   必ず初期化してから null 判定する（override があればそれを採用）
        if (!isset($giftTaxCredits)) {
            $giftTaxCredits = $giftTaxCreditsOverride ?? null;
        }

        // ★同様に未定義防止（後段で参照される）
        if (!isset($settlementGiftTaxes)) {
            $settlementGiftTaxes = array_fill(2, 9, 0);
        }


            // ★override を潰さない：未設定のときだけ計算
            if ($giftTaxCredits === null) {
                $giftTaxCredits = $this->calcGiftTaxCreditsByRecipient(
                    $dataId, $deathDate, $taxableAcquirerIdxList
                );
            }




        // ★精算課税贈与税控除は「受贈者全員・全額」（取得者フィルタ禁止）
        $settlementGiftTaxes = $this->calcSettlementGiftTaxesByRecipient($dataId);

        $finalTotalAfterSurcharge  = 0;
        $totalGiftTaxCredits       = 0;
        $totalPayableAfterCredits  = 0;
        $totalSpouseRelief         = 0;
        $totalPayableAfterSpouse   = 0;
        $totalOtherCredits         = 0;
        $totalPayableAfterOthers   = 0;
        $totalSashihikiTax         = 0;
        $totalSettlementGiftTaxes  = 0; // ★実際に控除できた精算贈与税（相続税の範囲内）
        $totalFinalAfterSettlement = 0; // ★支払税額合計（負値は入れない）
        $totalRefundTax            = 0; // ★還付合計（精算控除が相続税を上回った分）
        $breakdown = [];

        for ($idx = 2; $idx <= 10; $idx++) {
            $h = null;
            foreach ($heirs as $_h) {
                if ($_h['idx'] === $idx) {
                    $h = $_h;
                    break;
                }
            }
            $isHeir = !is_null($h);

            // ★ この年の課税価格に基づくあん分割合
            $ratio  = (float)($anbunRatiosForYear[$idx] ?? 0.0);
            $sanzutsu = (int)round($totalLegalShareTax * $ratio);

            // ★ 対策後シナリオでも 2割加算は「チェックボックス」で一元管理」
            $twoTenths = $this->checkboxOn($payload, 'twenty_percent_add', $idx);
            $finalTax  = $twoTenths ? (int)round($sanzutsu * 1.2) : $sanzutsu;

            $finalTotalAfterSurcharge += $finalTax;

            /*
            // ★ ログ：対策後(t=0)の算出税額・あん分割合
            Log::debug('2025.12.23 10001 対策後(t=0)の算出税額・あん分割合 ', [
                 //'context' => $context,
                 'estate_yen'        => $estateYen,
                 'idx'               => $idx,
                 'is_heir'           => $isHeir,
                 // ★注意：これは「課税価格（id_taxable_manu + 生前贈与加算）比率（t=0由来）」であって、
                 //   「税務上の法定相続割合」ではない
                 'anbun_ratio_t0'    => (float)($anbunRatios[$idx] ?? 0.0),
                 // ★税務上の法定相続割合（bunsi/bunbo 正規化）はこっち
                 'tax_legal_ratio'   => (float)($legalShareRows[$idx]['legal_ratio'] ?? 0.0),
                 'anbun_ratio'       => $ratio,
                 'price_for_ratio'   => $priceForRatioByIdx[$idx] ?? null,
                 'sanzutsu'          => $sanzutsu,
                 'two_tenths'        => $twoTenths,
                 'final_tax'         => $finalTax,
                 'totalLegalShareTax'=> $totalLegalShareTax,
             ]);
             */

             
            
            // 暦年贈与税額控除
            $creditCalendar  = (int)($giftTaxCredits[$idx]['calendar_yen'] ?? 0);
            $payAfterCalCred = max(0, $finalTax - max(0, $creditCalendar));
            $totalGiftTaxCredits      += min($finalTax, max(0, $creditCalendar));
            $totalPayableAfterCredits += $payAfterCalCred;

        /*
        Log::debug('2025.12.25 70001 ', [
            'idx'        => $idx,
            '$creditCalendar'           => $creditCalendar,
        ]);
        */

            // 配偶者軽減
            $spouseRelief = 0; $payAfterSpouse = $payAfterCalCred;
            if ($isHeir && in_array((int)($h['rel_code'] ?? 0), [3,4], true) && $payAfterCalCred > 0) {
                $actualShareYen = $this->resolveActualShareYenForIdx($payload, $idx, $estateYen, $legalShareRows[$idx]['legal_ratio'] ?? 0.0);
                $legalAmountYen = (int)round($estateYen * ($legalShareRows[$idx]['legal_ratio'] ?? 0.0));
                $targetBaseYen  = min($actualShareYen, max($legalAmountYen, 160_000_000));
                if ($actualShareYen > 0 && $targetBaseYen > 0){
                    $spouseRelief = (int)floor($payAfterCalCred * ($targetBaseYen / $actualShareYen));
                    if ($spouseRelief > $payAfterCalCred) $spouseRelief = $payAfterCalCred;
                    if ($spouseRelief < 0) $spouseRelief = 0;
                    $payAfterSpouse = $payAfterCalCred - $spouseRelief;
                }
            }
            $totalSpouseRelief += $spouseRelief;
            $totalPayableAfterSpouse += $payAfterSpouse;


            // その他控除
            $otherCreditYen = $this->toYen($this->readKyen($payload, 'id_other_credit', $idx)); if ($otherCreditYen < 0) $otherCreditYen = 0;
            $payAfterOthers = max(0, $payAfterSpouse - $otherCreditYen);
            $totalOtherCredits       += min($payAfterSpouse, $otherCreditYen);
            $totalPayableAfterOthers += $payAfterOthers;

            // 差引税額
            $sashihikiTax = $payAfterOthers; $totalSashihikiTax += $sashihikiTax;
            $settlementGiftTaxYen = max(0, (int)($settlementGiftTaxes[$idx] ?? 0));
            $appliedSetCredit     = min(max(0, $sashihikiTax), $settlementGiftTaxYen);
            $finalAfterSettlement = $sashihikiTax - $appliedSetCredit; // ★必ず >=0
            $refundYen            = max(0, $settlementGiftTaxYen - $appliedSetCredit);

            $totalSettlementGiftTaxes  += $appliedSetCredit;
            $totalFinalAfterSettlement += $finalAfterSettlement;
            $totalRefundTax            += $refundYen;

            
            /*
            Log::debug('2025.12.23 00003 ', [
                'idx'        => $idx,
                'estate_yen'           => $estateYen,
                'final_total'          => $finalTotalAfterSurcharge,
                'sum_final_tax_yen'    => array_sum(array_column($breakdown, 'final_tax_yen')),
                'total_gift_tax_credits' => $totalGiftTaxCredits,
                'total_pay_after_credits' => $totalPayableAfterCredits,
                'totalFinalAfterSettlement' => $totalFinalAfterSettlement,
                'sozoku_tax_total' => $totalLegalShareTax,
                'final_after_settlement_yen'    => $totalFinalAfterSettlement
               
            ]);
            */
            
        
       
            
            $breakdown[] = [
                'row_index'   => $idx,

                // ★ 法定相続分表示用：法定相続人のみ bunsi/bunbo をセット（非法定は 0/1）
                'bunsi'       => $isHeir ? (int)($h['bunsi'] ?? 0) : 0,
                'bunbo'       => $isHeir ? (int)($h['bunbo'] ?? 1) : 1,



                'legal_ratio' => $legalShareRows[$idx]['legal_ratio'] ?? 0.0,
                'legal_share_yen' => $legalShareRows[$idx]['legal_share_yen'] ?? 0,
                'legal_tax_yen'   => $legalShareRows[$idx]['legal_tax_yen'] ?? 0,
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$idx] ?? 0),
                'manual_price_yen'          => $manualShares['shares'][$idx]['manual_price_yen']   ?? null,
                'manual_bd_share_yen'       => $manualShares['shares'][$idx]['bd_share_yen']       ?? null,
                'manual_taxable_share_yen'  => $manualShares['shares'][$idx]['manual_taxable_yen'] ?? null,
                'anbun_ratio'     => $ratio,
                'sanzutsu_tax_yen'=> $sanzutsu,
                'final_tax_yen'   => $finalTax,
                'two_tenths_added'=> $isHeir ? (bool)($h['two_tenths'] ?? false) : false,
                'is_spouse'       => $isHeir ? in_array((int)($h['rel_code'] ?? 0), [3,4], true) : false,
                'gift_tax_credit_calendar_yen'      => max(0, $creditCalendar),
                'payable_after_calendar_credit_yen' => $payAfterCalCred,
                'spouse_relief_yen'  => $spouseRelief,
                'payable_after_spouse_yen' => $payAfterSpouse,
                'other_credit_yen'   => $otherCreditYen,
                'payable_after_others_yen' => $payAfterOthers,
                'sashihiki_tax_yen'  => $sashihikiTax,
                'settlement_gift_tax_yen' => max(0, $settlementGiftTaxYen),
                'final_after_settlement_yen' => $finalAfterSettlement,
                'payable_tax_yen' => $finalAfterSettlement > 0 ? $finalAfterSettlement : 0,
                'refund_tax_yen'  => $finalAfterSettlement < 0 ? abs($finalAfterSettlement) : 0,
            ];
        }
        

        //対策後
        return [
            'data_id' => $dataId,
            'summary' => [
                // ★ 贈与前（比較用） / 贈与後（実際の贈与額控除後）を明確に分離
                'estate_base_yen'  => $estateBefore,
                'estate_after_yen' => $estateAfter,

                // ★内訳（遺産分割で使う）
                'estate_after_cash_yen'  => (int)($parts['estate_after_cash_yen']  ?? $cashGrown),
                'estate_after_other_yen' => (int)($parts['estate_after_other_yen'] ?? $propertyNonCashYen),

                'estate_yen'       => $estateYen,
                'heir_count'       => count($heirs),
                'basic_deduction'  => $basicDeduction,
                'taxable_estate'   => $taxableEstateUsed,
                // 過年度＋（必要に応じて）仮想将来贈与の算入額
                'incl_calendar_yen'             => (int)($giftIncl['calendar_total_yen']   ?? 0),
                'incl_settlement_yen'           => (int)($giftIncl['settlement_total_yen'] ?? 0),
                'past_gift_included_total_yen' => (int)($giftIncl['total_yen'] ?? 0),
                'past_gift_included_per_idx'   => $giftIncl['per_idx'] ?? [],
                'sozoku_tax_total' => $totalLegalShareTax,
                'total_after_surcharge' => $finalTotalAfterSurcharge,
                'total_gift_tax_credits' => $totalGiftTaxCredits,
                'total_payable_after_calendar_credits' => $totalPayableAfterCredits,
                'total_spouse_relief' => $totalSpouseRelief,
                'total_payable_after_spouse' => $totalPayableAfterSpouse,
                'total_other_credits' => $totalOtherCredits,
                'total_payable_after_others' => $totalPayableAfterOthers,
                'total_sashihiki_tax'           => $totalSashihikiTax,
                'total_settlement_gift_taxes'   => $totalSettlementGiftTaxes,   // ★実際に控除できた分（合計）
                'total_refund_tax_yen'          => $totalRefundTax,             // ★還付合計
                'total_final_after_settlement'  => $totalFinalAfterSettlement,  // ★支払税額合計
                // ★画面の「相続税」は“支払税額合計”を表示（還付は別表示）
                'final_after_settlement_yen'    => $totalFinalAfterSettlement,
                'anbun_mode'        => $anbunMode,
                'anbun_total_kyen'  => $anbunTotalKyen,
                
                // t=0 の暦年贈与による減少額（画面で必須）※将来年分は projections.after 側で設定済み
                'gift_decr_calendar_yen' => 0,
                
            ],

            'heirs'   => $breakdown,
            // ★ t=0（対策後）の各相続人の課税価格 P_i(0)
            'per_idx' => $perIdx,

            'meta'  => [
                'mode'    => 'inheritance_with_future_gifts',
                'version' => 'v1.1-plan-applied',
                'ts'      => now()->toDateTimeString(),
                'anbun_mode' => $anbunMode,
            ],
        ];
    }



///////////////////後半2


    /** 任意日付版の対策後（プロジェクション用）：現金は t 年分の年率で反映 */    
    private function computeScenarioForGivenDate(
        int $t,
        array $payload,
        array $heirs,
        int $basicDeduction,
        int $propertyNonCashYen,
        int $cashNowYen,
        float $rate,
        \DateTimeImmutable $deathDateT,
        array $brackets,
        array $futurePlan,
        ?array $giftTaxCreditsOverride = null
    ): array {

        // ★重要：
        // 呼び出し元 compute() で、after projection 用の死亡日は
        // resolveProjectionBaseDeathDate() を基準に年次ごとに確定済み。
        // ここで再計算すると JS と PHP の基準日がズレて
        // incl_calendar_yen のローリング判定が壊れるため、引数の $deathDateT をそのまま使う。
        $dataId = (int)($payload['data_id'] ?? 1);


        /*
        Log::info('[ZouyotaxCalc][after_proj_death_date]', [
            't'          => $t,
            'deathDateT' => $deathDateT->format('Y-m-d'),
        ]);
        */

        // ★プロジェクションでも「課税価格の取得がある人」を一貫して使用
        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);

        // 暦年贈与税額控除（贈与税控除額）は “その年の死亡日” で評価する
        // 暦年贈与税額控除（贈与税控除額）
        // - override が渡されればそれを使用
        // - 無ければ従来通り、このシナリオの deathDate で算定
        $giftTaxCredits = $giftTaxCreditsOverride;
        if ($giftTaxCredits === null) {
            $giftTaxCredits = $this->calcGiftTaxCreditsByRecipient($dataId, $deathDateT, $taxableAcquirerIdxList);
        }


        // ★仕様：被相続人(No=1)の金融資産は運用しない（増額しない）
        $yearsAhead = max(0, $t);
        $cashGrown  = $this->decedentCashAtYear($cashNowYen, $yearsAhead, $rate);

        // ★ 贈与前（比較用）の遺産
        $estateBefore = $propertyNonCashYen + $cashGrown;

        
        // 将来贈与インデックス（T年の死亡日で評価：lookback や実施タイミング判定用）

        /*
        Log::debug("2026.01.27 1000000-8", [
            'deathDateT' => $deathDateT,
            't' => $t,
        ]);
        */


        $giftIncl = $this->calcPastGiftsIncludedInEstateByRecipient(
            $dataId, 
            $deathDateT, 
            $payload,
            $taxableAcquirerIdxList,
            $heirs,
            $t
        );



        // ★将来贈与の原資（上限）は「No=1のみ」
        //   - 金融資産あり: No=1 cash
        //   - 金融資産なし: No=1 その他資産（nonCash）
        $giftBudgetYen = $this->giftBudgetYenForDecedent($propertyNonCashYen, $cashGrown);

        /*
        Log::debug("2026.01.21 7000000-1");
        */
        
        $virtual   = $this->buildVirtualGiftsIndex(
            $futurePlan,
            $deathDateT,
            $giftIncl,
            $taxableAcquirerIdxList,
            $t,
            $giftBudgetYen
        );




        // ★ $useFuturePlan=false のときも参照するので、必ず初期化しておく（Undefined variable $parts 対策）
        $parts = [
            'estate_after_yen'       => $estateBefore,
            'estate_after_cash_yen'  => $cashGrown,
            'estate_after_other_yen' => $propertyNonCashYen,
        ];

        // ★ 贈与後（控除後）の遺産：金融/その他の内訳付き
        $parts = $this->applyFuturePlanToEstateParts($propertyNonCashYen, $cashGrown, $virtual, $deathDateT);
        $estateAfter = (int)$parts['estate_after_yen'];

        // 以降は computeForGivenEstateAndDate に「課税価格（kazei_price_yen）」を
        // 関数内で（estateAfter + 算入額）として組み立てる。
        // → estateYen は「贈与後遺産（控除後）」を渡す（ここが修正点）
        $res = $this->computeForGivenEstateAndDate(
            $t, $payload, $heirs, $basicDeduction,
            $estateAfter, $deathDateT, $brackets,
            'after_virtual', $virtual,
            // ★分割対象は「贈与後遺産（減額後）」を明示指定
            $estateAfter
        );


        // ============================================================
        // ★重要：
        // after_virtual の incl_calendar_yen は computeForGivenEstateAndDate()
        // 内で「過去＋virtual将来分」の合算値として確定済み。
        // ここで past-only の $giftIncl['calendar_total_yen'] で上書きすると、
        // 将来暦年贈与分が消えて年次表が過少になる。
        // → calendar は上書きしない。
        // ============================================================
        if (!isset($res['summary']) || !is_array($res['summary'])) {
            $res['summary'] = [];
        }
        
        // ============================================================
        // ★重要：精算課税（incl_settlement_yen）は virtual の settlement_all（累計）を必ず反映する
        //  - virtual_built_set_sum が yearsAhead に応じて増えていることはログで確認済み
        //  - ここが t=0 固定のままだと表（年次推移）が 111,658 から動かない
        // ============================================================
        $deathKey = $deathDateT->format('Y-m-d');

        // ★過去分（精算）はこの関数内で算出済みの $giftIncl から取る（PastGiftSettlementEntryの集計）
        //   ※ $pastOnly はこのスコープに存在しないため 0 扱いになり、111,658 が足されない原因になる
        $pastSetYen = (int)($giftIncl['settlement_total_yen'] ?? 0);


        // ★将来分（年次tまで実施済み累計）：virtual の settlement_all 合計
        $futureSetYen = 0;
        foreach (($virtual[$deathKey]['settlement_all'] ?? []) as $v) {
            $futureSetYen += (int)$v;
        }

        $inclSetYen = $pastSetYen + $futureSetYen;
        $res['summary']['incl_settlement_yen'] = $inclSetYen;
        $giftIncl['settlement_total_yen'] = $inclSetYen;
        
        // ★after_proj の合計は incl_* の合算で確定（futureも含める）
        $res['summary']['past_gift_included_total_yen']
            = (int)($res['summary']['incl_calendar_yen'] ?? 0) + (int)($res['summary']['incl_settlement_yen'] ?? 0);


        /*
        Log::info('[ZouyotaxCalc][after_proj_incl_fix]', [
            't'                    => $t,
            'death_date'           => $deathDateT->format('Y-m-d'),
            'incl_calendar_yen'    => (int)($res['summary']['incl_calendar_yen'] ?? 0),
            'incl_settlement_yen'  => (int)($res['summary']['incl_settlement_yen'] ?? 0),
            'past_incl_calendar'   => (int)($giftIncl['calendar_total_yen'] ?? 0),
            'future_calendar_yen'  => array_sum(array_map('intval', (array)($virtual[$deathKey]['calendar_included'] ?? []))),
            'future_settlement_yen'=> $futureSetYen,
        ]);
        */



        // ★ summary を “贈与前/贈与後” で確定させる（normalize 側で誤補完させない）
        $res['summary']['estate_base_yen']        = $estateBefore; // 比較用（贈与前）
        $res['summary']['estate_before_gifts_yen']= $estateBefore; // 互換キー
        $res['summary']['estate_after_yen']       = $estateAfter;                  // 合計
        $res['summary']['estate_after_cash_yen']  = (int)$parts['estate_after_cash_yen'];   // ★金融
        $res['summary']['estate_after_other_yen'] = (int)$parts['estate_after_other_yen'];  // ★その他
        return $res;
        
    }

    /** 差額（after - before）を要約と行ごとに生成 */
    private function buildDelta(array $before, array $after): array
    {
        $sumB = $before['summary'] ?? [];
        $sumA = $after['summary']  ?? [];
        $diffSummary = [];
        foreach (array_keys($sumA + $sumB) as $k){
            $diffSummary[$k] = (int)($sumA[$k] ?? 0) - (int)($sumB[$k] ?? 0);
        }
        $rows = [];
        $byIdxA = []; foreach (($after['heirs'] ?? []) as $r){ $byIdxA[$r['row_index']] = $r; }
        $byIdxB = []; foreach (($before['heirs']?? []) as $r){ $byIdxB[$r['row_index']] = $r; }
        for ($i=2;$i<=10;$i++){
            $A = $byIdxA[$i] ?? []; $B = $byIdxB[$i] ?? [];
            $row = ['row_index'=>$i];
            foreach (array_keys(($A+$B)) as $k){
                if ($k==='row_index') continue;
                $row[$k] = (int)($A[$k] ?? 0) - (int)($B[$k] ?? 0);
            }
            $rows[] = $row;
        }
        return [
            'summary' => $diffSummary,
            'heirs'   => $rows,
            'meta'    => ['mode'=>'delta','ts'=>now()->toDateTimeString()],
        ];
    }

    



    /**
     * POST値が無い/0のときは DB から被相続人(行1)の値を取得して返す。
     * 戻り値: [propertyNowYen, cashNowYen, rateFloat]
     *  - property/cash は「千円」→「円」へ
     *  - rate は % → 小数 (ex 1.5 => 0.015)
     */
    private function resolveBaseFromPayloadOrDb(array $payload, int $dataId): array
    {
        $propK = $this->readKyen($payload, 'property', 1); // 千円（POST）
        $cashK = $this->readKyen($payload, 'cash', 1);     // 千円（POST）
        $perRaw = Arr::get($payload, 'per', null);
        $rate = null;
        if ($perRaw !== null && $perRaw !== '') {
            $rate = (float)preg_replace('/[^\d\.\-]/', '', (string)$perRaw) / 100.0;
        }

        // DB フォールバック
        if ($propK === 0 || $cashK === 0 || $rate === null) {
            $pfm = ProposalFamilyMember::query()
                    ->where('data_id', $dataId)->where('row_no', 1)->first();
            if ($pfm) {
                if ($propK === 0) $propK = (int)$pfm->property_thousand;
                if ($cashK === 0) $cashK = (int)$pfm->cash_thousand;
            }
            if ($rate === null) {
                $ph = ProposalHeader::query()->where('data_id', $dataId)->first();
                if ($ph && $ph->after_tax_yield_percent !== null) {
                    $rate = ((float)$ph->after_tax_yield_percent) / 100.0;
                }
            }
        }
        // 千円→円
        $propertyNowYen = $propK * 1000;
        $cashNowYen     = $cashK * 1000;
        // rate が未決定なら 0.0 に
        $rate = $rate ?? 0.0;
        return [$propertyNowYen, $cashNowYen, $rate];
    }

    /**
     * 受贈者（row_no=2..10）について、POST値が無い/0のときは
     * DB から property_thousand / cash_thousand を取得して返す。
     *
     * 戻り値: [propertyYen, cashYen]
     */
    private function resolvePersonBaseFromPayloadOrDb(array $payload, int $dataId, int $rowNo): array
    {
        // 画面からの入力（千円）
        $propK = $this->readKyen($payload, 'property', $rowNo);
        $cashK = $this->readKyen($payload, 'cash', $rowNo);

        // DB フォールバック（proposal_family_members.row_no = $rowNo）
        if ($propK === 0 || $cashK === 0) {
            $pfm = ProposalFamilyMember::query()
                ->where('data_id', $dataId)
                ->where('row_no', $rowNo)
                ->first();

        if ($pfm) {
                if ($propK === 0) {
                    $propK = (int)($pfm->property_thousand ?? 0);
                }
                if ($cashK === 0) {
                    $cashK = (int)($pfm->cash_thousand ?? 0);

                    //2026.01.13
                    Log::debug('2026.01.13 00001 :', [
                        'dataId'       => $dataId,
                        'rowNo'        => $rowNo,
                        '$cashK'       => $cashK,
                    ]);

                }
            }
        }

        // 千円 → 円
        $propertyYen = max(0, $propK) * 1000;
        $cashYen     = max(0, $cashK) * 1000;

        return [$propertyYen, $cashYen];
    }

    /**
     * 各受贈者（行2?10）の「対策後 個人別財産推移」タイムラインを構築する。
     *
     * - asset_total_yen:
     *     非金融資産 ＋ 金融資産 * (1 + rate)^t
     *       …元々保有している財産の推移（贈与・相続による増減は含めない）
     * - gift_calendar_received_yen / gift_calendar_tax_yen:
     *     将来暦年贈与プラン（future_gift_plan_entries）の金額・税額（円）
     * - gift_settlement_received_yen / gift_settlement_tax_yen:
     *     将来精算課税贈与プランの金額・税額（円）
     * - inherit_net_yen:
     *     相続による取得財産（各相続人の遺産分割による取得財産で、生前贈与加算前）
     *     → heirs[].estate_base_share_yen を使用
     * - inherit_tax_yen:
     *     相続税額
     *     → heirs[].final_after_settlement_yen を使用
     * - investment_gain_yen:
     *     金融資産部分の運用による増加額のみ
     * - asset_after_yen:
     *     現段階では「元々の財産＋贈与純増（受領額?贈与税）」までを反映した対策後残高
     *
     * 返却形式:
     *   [
     *     2 => ['timeline' => [ t => [...], ... ]],
     *     3 => ['timeline' => [...]],
     *     ...
     *   ]
     */
    private function buildPersonBaselineTimelines(
        array $payload,
        int $dataId,
        float $rate,
        array $futurePlan,
        array $after,
        array $projAfter
    ): array {
        $persons = [];

        // 利回りの下限ガード（元の compute/projection と同じ扱い）
        $safeRate = max($rate, -0.999999);



        // --- 相続取得財産の按分比率（遺産分割比率）を決定（金融/その他の別比率） ---
        $heirsRows0 = $after['heirs'] ?? [];
        $heirsByIdx = [];
        foreach ($heirsRows0 as $row) {
            if (!isset($row['row_index'])) {
                continue;
            }
            $idx = (int)$row['row_index'];
            if ($idx < 2 || $idx > 10) {
                continue;
            }
            $heirsByIdx[$idx] = $row;
        }

        $splitRatios = $this->resolveEstateSplitRatiosFixed($payload, $heirsByIdx);
        $cashRatioByIdx  = $splitRatios['cash']  ?? [];
        $otherRatioByIdx = $splitRatios['other'] ?? [];

        // --- 年次×idx ごとの「相続取得財産（inherit_net_yen）・相続税（inherit_tax_yen）」マップ ---
        //   inherit_net_yen:
        //     各年の estate_after_yen（= これからの贈与で減少した後の財産）を ratioByIdx で按分
        //   inherit_tax_yen:
        //     heirs[].final_after_settlement_yen をそのまま採用
        $inheritByYearIdx = [];

        // 指定年 t の estate_after_yen を ratioByIdx で按分し、
        //   - inherit_net_yen … 比率に基づく取得財産
        //   - inherit_tax_yen … 各行の final_after_settlement_yen（相続税額）そのもの
        // を返す
$buildInheritForYear = function (?array $summary, ?array $heirsRows) use ($cashRatioByIdx, $otherRatioByIdx, $payload): array {
    $out = [];
    if (empty($summary) || empty($heirsRows)) {
        return $out;
    }

    // --- 相続取得財産の按分比率（遺産分割比率）を決定（金融/その他の別比率） ---
    $heirsByIdx = [];
    foreach ($heirsRows as $row) {
        if (!isset($row['row_index'])) {
            continue;
        }
        $idx = (int)$row['row_index'];
        if ($idx < 2 || $idx > 10) {
            continue;
        }
        $heirsByIdx[$idx] = $row;
    }

    // 法定相続割合（民法上の相続割合）を取得
    $civilRatios = $this->normalizedCivilRatiosByIdx($payload, $heirsRows);

    // 必要な比率を取得
    $splitRatios = $this->resolveEstateSplitRatiosFixed($payload, $heirsByIdx);
    $cashRatioByIdx  = $splitRatios['cash']  ?? [];
    $otherRatioByIdx = $splitRatios['other'] ?? [];

    $cashTotal  = (int)($summary['estate_after_cash_yen']  ?? 0);
    $otherTotal = (int)($summary['estate_after_other_yen'] ?? 0);
    if (($cashTotal + $otherTotal) <= 0) {
        return $out;
    }

    // まず比率に従って floor 配分（金融/その他別）
    $allocatedCash  = 0;
    $allocatedOther = 0;
    // ★端数寄せ先：民法上の法定相続割合>0 の「最初の人」
    $firstIdxCash   = null;
    $firstIdxOther  = null;
    // ★保険：もし全員が0なら従来通り最後の人に寄せる
    $lastIdxCash    = null;
    $lastIdxOther   = null;

    foreach ($heirsRows as $row) {
        $idx = (int)($row['row_index'] ?? 0);
        $rCash  = (float)($cashRatioByIdx[$idx]  ?? 0.0);
        $rOther = (float)($otherRatioByIdx[$idx] ?? 0.0);

        // 各相続人の法定相続割合（民法上の相続割合）を取得
        $lawOfInheritanceRatio = (float)($civilRatios[$idx] ?? 0.0); // civil_ratioを使う

        // 金融資産に比率を適用
        $shareCash = 0;
        if ($cashTotal > 0) {
            // ★端数寄せ候補（民法割合>0 の最初）
            if ($firstIdxCash === null && $lawOfInheritanceRatio > 0) {
                $firstIdxCash = $idx;
            }
            $lastIdxCash = $idx; // フォールバック用
            $shareCash = (int)floor($cashTotal * $lawOfInheritanceRatio); // 比率に基づく配分
            $allocatedCash += $shareCash;
        }

        // その他資産に比率を適用
        $shareOther = 0;
        if ($otherTotal > 0) {
            // ★端数寄せ候補（民法割合>0 の最初）
            if ($firstIdxOther === null && $lawOfInheritanceRatio > 0) {
                $firstIdxOther = $idx;
            }
            $lastIdxOther = $idx; // フォールバック用
            $shareOther = (int)floor($otherTotal * $lawOfInheritanceRatio); // 比率に基づく配分
            $allocatedOther += $shareOther;
        }

        $share = $shareCash + $shareOther;

        $out[$idx] = [
            'inherit_net_yen' => $share,
            'inherit_tax_yen' => (int)($row['final_after_settlement_yen'] ?? 0),
        ];

        /*
        //2025.12.26
        Log::debug('2025.12.26 00001 :', [
            'idx'                   => $idx,
            'cashRatioByIdx'        => $cashRatioByIdx[$idx],
            'otherRatioByIdx'       => $otherRatioByIdx[$idx],
            'lawOfInheritanceRatio' => $lawOfInheritanceRatio,
            'share'                 => $share,
        ]);
        */
    }

    // 端数は「民法上の法定相続割合>0 の最初の人」へ寄せる（金融/その他別）
    // 金融資産
    $targetCashIdx = $firstIdxCash ?? $lastIdxCash; // ★全員0なら従来通り最後へ（保険）
    if ($targetCashIdx !== null && $allocatedCash !== $cashTotal) {
        $diff = $cashTotal - $allocatedCash;
        $out[$targetCashIdx]['inherit_net_yen'] = ($out[$targetCashIdx]['inherit_net_yen'] ?? 0) + $diff;
    }
    // その他資産
    $targetOtherIdx = $firstIdxOther ?? $lastIdxOther; // ★全員0なら従来通り最後へ（保険）
    if ($targetOtherIdx !== null && $allocatedOther !== $otherTotal) {
        $diff = $otherTotal - $allocatedOther;
        $out[$targetOtherIdx]['inherit_net_yen'] = ($out[$targetOtherIdx]['inherit_net_yen'] ?? 0) + $diff;
    }

    return $out;
};

        // t=0（現時点）
        $inheritByYearIdx[0] = $buildInheritForYear(
            $after['summary'] ?? [],
            $after['heirs']   ?? []
        );

        // t=1..20（将来年次）
        if (is_array($projAfter)) {
            for ($t = 1; $t <= 20; $t++) {
                $summaryT   = $projAfter[$t]['summary'] ?? [];
                $heirsRowsT = $projAfter[$t]['heirs']   ?? [];
                $inheritByYearIdx[$t] = $buildInheritForYear($summaryT, $heirsRowsT);
            }
        }

        // まずは「元々の財産」ベースのタイムラインを作る
        for ($idx = 2; $idx <= 10; $idx++) {
            // 受贈者自身の property/cash（現時点）を解決
            [$propertyYen, $cashYen] = $this->resolvePersonBaseFromPayloadOrDb($payload, $dataId, $idx);

            $nonCash = max(0, $propertyYen - $cashYen);
            
            $nongrownCashYen = $cashYen;

            $timeline = [];

            for ($t = 0; $t <= 20; $t++) {

                // t年後の金融資産（利回り反映）
                $grownCash = (int)round(
                    $cashYen * pow(1 + $safeRate, max(0, $t))
                );
                // 受贈者がもともと持っている財産の推移
                //$assetTotal = $nonCash + $grownCash;
                //資金運用益はここでは加算しない
                $assetTotal = $nonCash + $nongrownCashYen;

                // 運用による増加額（金融資産部分のみ）
                $investmentGain = $grownCash - $cashYen;

                // 相続取得・相続税（該当が無ければ 0）
                $inheritForT = $inheritByYearIdx[$t][$idx] ?? ['inherit_net_yen' => 0, 'inherit_tax_yen' => 0];

                $timeline[$t] = [
                    // 所有財産の額（対策前の推移）
                    'asset_total_yen'              => $assetTotal,

                    // 贈与による純財産の増加（対策前ベース）
                    'gift_net_before_yen'          => 0,
                    'gift_calendar_received_yen'   => 0,
                    'gift_calendar_tax_yen'        => 0,
                    'gift_settlement_received_yen' => 0,
                    'gift_settlement_tax_yen'      => 0,

                    // 相続による純財産の増加（もともとの財産から将来贈与を控除した後、
                    // 各相続人が遺産分割で取得する財産）と相続税額
                    'inherit_net_yen'              => $inheritForT['inherit_net_yen'],
                    'inherit_tax_yen'              => $inheritForT['inherit_tax_yen'],

                    // 資産運用による増加額（★）
                    'investment_gain_yen'          => $investmentGain,

                    // 財産の額（対策後）…現段階では「元々の資産＋贈与純増」を想定
                    'asset_after_yen'              => $assetTotal,
                ];
            }

            $persons[$idx] = [
                'timeline'          => $timeline,
                // ★ 運用益再計算用に「元々の金融資産」と「非金融資産」を保持しておく
                'base_cash_yen'     => $cashYen,
                'base_non_cash_yen' => $nonCash,
            ];


        }

        // --- 将来贈与プランから暦年贈与を反映 ---
        foreach (($futurePlan['calendar'] ?? []) as $row) {
            $no = (int)($row['no'] ?? 0);
            $t  = (int)($row['t']  ?? 0);
            if ($no < 2 || $no > 10 || $t < 1 || $t > 20) {
                continue;
            }
            if (!isset($persons[$no]['timeline'][$t])) {
                continue;
            }

            $amountYen = $this->toYen((int)($row['amount_thousand'] ?? 0));
            $taxYen    = $this->toYen((int)($row['tax_thousand']    ?? 0));
            $netYen    = max(0, $amountYen - $taxYen);

            $persons[$no]['timeline'][$t]['gift_calendar_received_yen'] = $amountYen;
            $persons[$no]['timeline'][$t]['gift_calendar_tax_yen']      = $taxYen;
            $persons[$no]['timeline'][$t]['gift_net_before_yen']       += $netYen;

            // 対策後残高に純増分を足し込む（暫定仕様）
            $persons[$no]['timeline'][$t]['asset_after_yen']
                = ($persons[$no]['timeline'][$t]['asset_after_yen'] ?? 0) + $netYen;
        }


        // --- 贈与プランから精算課税贈与を反映 ---
        foreach (($futurePlan['settlement'] ?? []) as $row) {
            $no = (int)($row['no'] ?? 0);
            $t  = (int)($row['t']  ?? 0);

            if ($no < 2 || $no > 10 || $t < 1 || $t > 20) {
                continue;
            }
            if (!isset($persons[$no]['timeline'][$t])) {
                continue;
            }

            // 金額（円）
            $amountYen = $this->toYen((int)($row['amount_thousand'] ?? 0));
            $taxYen    = $this->toYen((int)($row['settlement_tax20_thousand']    ?? 0));
            $netYen    = max(0, $amountYen - $taxYen);

            // 取得額・贈与税額・純増を記録
            $persons[$no]['timeline'][$t]['gift_settlement_received_yen'] = $amountYen;
            $persons[$no]['timeline'][$t]['gift_settlement_tax_yen']      = $taxYen;
            $persons[$no]['timeline'][$t]['gift_net_before_yen']         += $netYen;

            // asset_after_yen にも純増分を反映（暫定仕様）
            $persons[$no]['timeline'][$t]['asset_after_yen']
                = ($persons[$no]['timeline'][$t]['asset_after_yen'] ?? 0) + $netYen;
        }


        
        
        // --- 贈与で取得した資産(贈与税控除後)も含めた「運用益」と
        //     「財産の額（対策後）」を再計算（いずれも“その年までの累計額”として扱う） ---
        //  ・gift_net_before_yen 累計    … その年までの贈与純増累計（暦年＋精算、受領額?贈与税）
        //  ・inherit_net_yen 累計        … その年までの相続による純財産増加累計
        //  ・investment_gain_yen 累計    … その年までの運用益累計
        //  asset_after_yen(t) = asset_total_yen(t)
        //                      + 累計 gift_net
        //                      + 累計 inherit_net
        //                      ? 累計 inherit_tax
        //                      + 累計 investment_gain
        foreach ($persons as $idx => &$person) {
            $timeline    = $person['timeline'] ?? [];
            $cashYen     = (int)($person['base_cash_yen'] ?? 0);      // 元々の金融資産（t=0 の元本）
            $nonCashYen  = (int)($person['base_non_cash_yen'] ?? 0);  // 元々の非金融資産

            if ($cashYen < 0)    { $cashYen = 0; }
            if ($nonCashYen < 0) { $nonCashYen = 0; }

            // 贈与で取得した純資産ポートフォリオの「期首残高」
            $giftValuePrev      = 0;
            // 贈与純増・相続純増・相続税・運用益の累計（t=0 からの累積）
            $giftNetCum         = 0;
            $inheritNetCum      = 0;
            $inheritTaxCum      = 0;
            $investmentGainCum  = 0;

            for ($t = 0; $t <= 20; $t++) {
                if (!isset($timeline[$t])) {
                    continue;
                }
                
                $nongrownCashYen = $cashYen;
                
                // ★ 元々の金融資産の当年の運用益（年次差分）
                //   grownCashPrev = 前年末残高
                //   grownCashCurr = 当年末残高
                $grownCashPrev = (int)round(
                    $cashYen * pow(1 + $safeRate, max(0, $t - 1))
                );
                $grownCashCurr = (int)round(
                    $cashYen * pow(1 + $safeRate, max(0, $t))
                );
                $origGainYear  = $grownCashCurr - $grownCashPrev;

                // ベースライン資産（非金融＋元々の金融資産の当年末残高）
                //資金運用益はここでは加算しない
                $assetBaseline = $nonCashYen + $nongrownCashYen;

                // ★ 当年の「純贈与元本」（受領額?贈与税）※この年だけの増分
                $netGiftThisYear = (int)($timeline[$t]['gift_net_before_yen'] ?? 0);
                // 贈与純増の累計（t=0?tの合計）
                $giftNetCum += $netGiftThisYear;

                // 将来贈与分については「贈与を受けた翌年から」運用益が発生するようにする。
                //   1) 期首残高 giftValuePrev にだけ利息を付ける
                //   2) 当年の純贈与元本 netGiftThisYear は利息計算の後に元本として追加
                $giftValueGrown = (int)round(
                    $giftValuePrev * (1 + $safeRate)
                );
                // 贈与分の当年運用益 = 期末（贈与前）残高 ? 期首残高
                $giftGainYear   = $giftValueGrown - $giftValuePrev;
                // 期末残高（贈与後）＝利息付与後の残高＋当年の純贈与元本
                $giftValueCurr  = $giftValueGrown + $netGiftThisYear;

                // 当年の総運用益（贈与分の運用益はマイナスにならないようガード）
                $investmentGainYear = $origGainYear + max(0, $giftGainYear);
                // 運用益の累計（t=0?tの合計）
                $investmentGainCum += $investmentGainYear;


                // 対策後の財産額 = 所有財産の額（対策前）＋贈与純増＋相続純増＋当年の運用益
                //  ・贈与純増       = gift_net_before_yen（暦年＋精算の受領額?贈与税）
                //  ・相続純増       = inherit_net_yen ? inherit_tax_yen
                //  ・運用益（当年分）= investment_gain_yen
                $giftNet    = (int)($timeline[$t]['gift_net_before_yen'] ?? 0);
                // 相続による純財産増加・相続税（この年の増分）
                $inheritNetThis = (int)($timeline[$t]['inherit_net_yen'] ?? 0);
                $inheritTaxThis = (int)($timeline[$t]['inherit_tax_yen'] ?? 0);
                $inheritNetCum  += $inheritNetThis;
                $inheritTaxCum  += $inheritTaxThis;

                // 表示用の各項目を上書き
                $timeline[$t]['asset_total_yen']     = $assetBaseline;
                // 運用益は「その年までの累計額」として表示
                $timeline[$t]['investment_gain_yen'] = $investmentGainYear;



                // 対策後の財産額（その年までの累計）:
                //   所有財産の額（対策前）＋贈与純増累計＋(単年度相続純増 ? 単年度相続税)＋運用益累計
                $timeline[$t]['asset_after_yen']
                    = $assetBaseline + $giftNetCum + $inheritNetThis - $inheritTaxThis + $investmentGainCum;

                // 次年度に繰り越す贈与ポートフォリオ期末残高
                $giftValuePrev = $giftValueCurr;
            }

            $person['timeline'] = $timeline;
        }
        unset($person);

        return $persons;
    }

    /**
     * future_gift_plan_entries の「金額(千円)」カラムの列名ゆれを吸収し、
     * 実在するカラムだけで COALESCE(...) 式を返す。
     *
     * - calendar:  calendar_amount_thousand / cal_amount_thousand / calendar_thousand 等（存在するものだけ）
     * - settlement: settlement_amount_thousand / set_amount_thousand / settlement_thousand 等（存在するものだけ）
     *
     * 存在する候補が1つも無い場合でも SQL が壊れないように "0" を返す。
     */
    private function buildFutureGiftAmountSumExpr(string $type): string
    {
        $table = 'future_gift_plan_entries';


        $dbg = (bool)config('app.debug');
        $picked = [];


        // ここはあなたの実スキーマに合わせて候補を増減してください（存在チェックするので増やしても安全）
        $candidates = ($type === 'settlement')
            ? [
                'settlement_amount_thousand',
                'set_amount_thousand',
                'settlement_thousand',
              ]
            : [
                'calendar_amount_thousand',
                'cal_amount_thousand',
                'calendar_thousand',
              ];

        $cols = [];
        foreach ($candidates as $col) {
            if (Schema::hasColumn($table, $col)) {
                $cols[] = $col;
                $picked[] = $col;
            }
        }

        if (empty($cols)) {

            if ($dbg) {
                Log::warning('[ZouyotaxCalc][future_sum_expr] no columns matched', [
                    'type'       => $type,
                    'table'      => $table,
                    'candidates' => $candidates,
                ]);
            }

            return '0';
        }

        
        $expr = 'COALESCE(' . implode(',', $cols) . ',0)';

        if ($dbg) {
            Log::debug('[ZouyotaxCalc][future_sum_expr] matched', [
                'type'   => $type,
                'cols'   => $picked,
                'expr'   => $expr,
            ]);
        }

        return $expr;

        
        
    }

    /** 保存済みの「贈与加算累計額（暦年）」= cal_cum（千円）を年次合計で取得（重複行を排除して最新のみ集計） */
    private function readSavedFutureCalCumByYearK(int $dataId): array
    {
        // 重複がある場合でも (data_id, recipient_no, row_no) の最新行だけを採用して row_no ごとに合算
        $latestIds = DB::table('future_gift_plan_entries as f')
            ->where('f.data_id', $dataId)
            ->whereBetween('f.recipient_no', [2, 10])
            // ★ 0始まり混在も拾う
            ->whereBetween('f.row_no', [0, 20])
            ->selectRaw('MAX(f.id) as id')
            ->groupBy('f.data_id','f.recipient_no','f.row_no')
            ->pluck('id');

        if ($latestIds->isEmpty()) return [];

        $res = DB::table('future_gift_plan_entries')
            ->whereIn('id', $latestIds)
            ->select('row_no', DB::raw('SUM(COALESCE(calendar_add_cum_thousand,0)) as k'))
            ->groupBy('row_no')
            ->get();

        $out = array_fill(1, 20, 0);
        foreach ($res as $r) {
            $t = (int)$r->row_no + $this->futurePlanRowNoOffset;
            if ($t >= 1 && $t <= 20) $out[$t] = (int)$r->k;
        }
        return $out;
    }


