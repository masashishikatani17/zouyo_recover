                ]);
            
            }    
    
        }
        */
        


        // 課税遺産総額 = 課税価格 ? 基礎控除
        $taxableEstate     = max(0, $kazeiPriceYen - $basicDeduction);
        $taxableEstateUsed = $taxableEstate;




        // ★税務上の法定相続割合（bunsi/bunbo）の合計
        $totalRatio = 0.0;
        foreach ($heirs as $h) {
            $bunsi = (int)($h['bunsi'] ?? 0);
            $bunbo = (int)($h['bunbo'] ?? 0);
            if ($bunsi >= 1 && $bunbo >= 1) {
                $totalRatio += ($bunsi / $bunbo);
            }
        }
        $totalRatio = $totalRatio > 0 ? $totalRatio : 1.0;

        // 6-1 前に：相続人別の贈与加算（参考値）を算出
        // ★ context に応じて「将来贈与分を含める／含めない」を切替
        
