<?php

namespace App\Services;

use Illuminate\Support\Arr;
use Illuminate\Support\Str;
use Illuminate\Support\Facades\Log;
use Illuminate\Support\Facades\Cache;
use App\Models\SozokuRate;
use App\Models\PastGiftCalendarEntry;
use App\Models\PastGiftSettlementEntry;

use App\Models\ProposalFamilyMember;
use App\Models\ProposalHeader;


use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Schema;
use App\Models\FutureGiftPlanEntry;

use App\Models\FutureGiftRecipient;

use App\Models\PastGiftInput;

/**
 * 相続税の対策前（これからの贈与は無視）計算
 * - 被相続人（行1）の「所有財産＋金融資産＋改正に基づく過年度贈与算入」をベース資産とする
 * - 基礎控除：3,000万円 + 600万円 × 法定相続人の数
 * - 相続税総額は「法定相続分課税」に速算表を当てて合計
 * - 個人配賦（算出税額）は「相続税総額 × あん分割合」
 *   - manual のあん分割合：id_taxable_manu[2..10] の“課税価格の割合”
 *   - auto   のあん分割合：法定相続割合（legal_ratio）
 * - 2割加算、暦年贈与税額控除、配偶者軽減、その他控除、精算課税贈与税控除の順に適用
 * - 画面単位「千円」→ 内部「円」で計算
 */
class ZouyotaxCalc
{


    private array $projAfter = [];
    private array $used100m = [];

    /**
     * エントリポイント
     * @param array $payload  request()->all() を想定
     * @return array {
     *   before:      {...},   // 対策前
     *   after:       {...},   // 対策後（将来贈与プラン反映）
     *   delta:       {...},   // 差額（after - before）
     *   projections: { before:[], after:[], delta:[] }
     * }
     */
    public function compute(array $payload): array
    {
        
        // ★ data_id は当面固定（既存仕様を踏襲）
        //$dataId   = (int)($payload['data_id'] ?? 0);
        $dataId = 1;


        $brackets = $this->loadInheritanceBrackets();
        
        // ★受贈者フラグの事前初期化（Undefined array key 対策）
        for ($i = 2; $i <= 10; $i++) {
                $this->used100m[$i] = 0;
        }
        


        // ▼ 暦年贈与の年次合計（千円）は「保存済みのDB（FutureGiftPlanEntry）」から取得（必須要件）
        //   ※DBに無い/未保存の年だけに限り、最後の手段で payload を参照
        $calAmountByYearK = $this->readSavedFutureCalAmountByYearK($dataId); // [1..20]=>千円
        if (empty($calAmountByYearK)) {
            // フォールバック：どうしてもDBに見つからない場合のみ、POST値を使用
            $calAmountByYearK = $this->readPlanKyenArrayAllRecipients($payload, 'cal_amount');
        }

        // 暦年課税（cal_amount）の年次合計（千円）
        $sumCalAmountK = function(int $t) use ($calAmountByYearK): int {
            if ($t <= 0) return 0;
            return (int)($calAmountByYearK[$t] ?? 0);
        };
        // 精算課税（set_amount）の年次合計（千円）
        $setAmountByYearK = $this->readSavedFutureSetAmountByYearK($dataId);
        if (empty($setAmountByYearK)) {
            $setAmountByYearK = $this->readPlanKyenArrayAllRecipients($payload, 'set_amount');
        }
        $sumSetAmountK = function(int $t) use ($setAmountByYearK): int {
            return $t > 0 ? (int)($setAmountByYearK[$t] ?? 0) : 0;
        };


        // 年次（row_no=t）ごとに、受贈者2〜10の “最新行だけ” を合計するサブクエリ方式
        $sumCalCumYearK = function (int $t) use ($dataId): int {
            if ($t <= 0) return 0;
            // ★ 受贈者マスタに“存在する受贈者のみ”を集計対象にする（幽霊 recipients を除外）
            $sub = DB::table('future_gift_plan_entries as f')
                ->join('future_gift_recipients as r', function($j){
                    $j->on('r.data_id','=','f.data_id')
                      ->on('r.recipient_no','=','f.recipient_no');
                })
                ->where('f.data_id', $dataId)
                ->whereBetween('f.recipient_no', [2, 10])
                ->where('f.row_no', $t)
                // ↓ future_gift_recipients にカラムが存在する場合のみ条件を付与
                ->when(\Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','deleted_at')
                      || \Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','is_active'),
                    function($q){
                        $q->where(function($w){
                            $hasDeleted = \Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','deleted_at');
                            $hasActive  = \Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','is_active');
                            if ($hasDeleted && $hasActive) {
                                $w->whereNull('r.deleted_at')->orWhere('r.is_active',1);
                            } elseif ($hasDeleted) {
                                $w->whereNull('r.deleted_at');
                            } elseif ($hasActive) {
                                $w->where('r.is_active',1);
                            }
                        });
                    })
                 ->groupBy('f.data_id','f.recipient_no','f.row_no')
                 ->selectRaw('MAX(f.id) as id');

            // デバッグ：t年目の最新レコードID一覧
            $latestIds = $sub->pluck('id')->all();
            //Log::debug('[incl_cal] latest ids', ['t'=>$t, 'ids'=>$latestIds]);

            // 合計（千円）
            $k = (int) DB::table('future_gift_plan_entries as x')
                ->joinSub($sub, 'latest', fn($j) => $j->on('latest.id','=','x.id'))
                ->sum(DB::raw('COALESCE(x.calendar_add_cum_thousand,0)'));

            // デバッグ：各受贈者ごとの内訳（必要に応じてコメントアウト可）
            $rows = DB::table('future_gift_plan_entries as x')
                ->joinSub(
                    (function() use ($dataId,$t){
                        $b = DB::table('future_gift_plan_entries as f')
                            ->join('future_gift_recipients as rr', function($j){
                                $j->on('rr.data_id','=','f.data_id')
                                  ->on('rr.recipient_no','=','f.recipient_no');
                            })
                            ->where('f.data_id', $dataId)
                            ->whereBetween('f.recipient_no', [2, 10])
                            ->where('f.row_no', $t);
                        if (\Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','deleted_at') ||
                            \Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','is_active')) {
                            $b->where(function($w){
                                $hasDeleted = \Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','deleted_at');
                                $hasActive  = \Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','is_active');
                                if ($hasDeleted && $hasActive) {
                                    $w->whereNull('rr.deleted_at')->orWhere('rr.is_active',1);
                                } elseif ($hasDeleted) {
                                    $w->whereNull('rr.deleted_at');
                                } elseif ($hasActive) {
                                    $w->where('rr.is_active',1);
                                }
                            });
                        }
                        return $b->groupBy('f.recipient_no')
                                 ->selectRaw('f.recipient_no, MAX(f.id) as id');
                    })(),
                    'r', fn($j)=>$j->on('r.id','=','x.id'))
                 ->get(['x.recipient_no','x.calendar_add_cum_thousand']);

            //Log::debug('[incl_cal] per recipient', ['t'=>$t, 'rows'=>$rows]);

            return $k;
        };

        $sumSetCumYearK = function (int $t) use ($dataId): int {
            if ($t <= 0) return 0;
            $sub = DB::table('future_gift_plan_entries as f')
                ->join('future_gift_recipients as r', function($j){
                     $j->on('r.data_id','=','f.data_id')
                       ->on('r.recipient_no','=','f.recipient_no');
                })
                ->where('f.data_id', $dataId)
                ->whereBetween('f.recipient_no', [2, 10])
                ->where('f.row_no', $t)
                ->when(\Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','deleted_at')
                      || \Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','is_active'),
                    function($q){
                        $q->where(function($w){
                            $hasDeleted = \Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','deleted_at');
                            $hasActive  = \Illuminate\Support\Facades\Schema::hasColumn('future_gift_recipients','is_active');
                            if ($hasDeleted && $hasActive) {
                                $w->whereNull('r.deleted_at')->orWhere('r.is_active',1);
                            } elseif ($hasDeleted) {
                                $w->whereNull('r.deleted_at');
                            } elseif ($hasActive) {
                                $w->where('r.is_active',1);
                            }
                        });
                    })
                 ->groupBy('f.data_id','f.recipient_no','f.row_no')
                 ->selectRaw('MAX(f.id) as id');

            // デバッグ：t年目の最新レコードID一覧
            $latestIds = $sub->pluck('id')->all();
            //Log::debug('[incl_set] latest ids', ['t'=>$t, 'ids'=>$latestIds]);

            // 合計（千円）
            $k = (int) DB::table('future_gift_plan_entries as x')
                ->joinSub($sub, 'latest', fn($j) => $j->on('latest.id','=','x.id'))
                ->sum(DB::raw('COALESCE(x.settlement_add_cum_thousand,0)'));

            // デバッグ：各受贈者ごとの内訳（必要に応じてコメントアウト可）
            $rows = DB::table('future_gift_plan_entries as x')
                ->joinSub(
                    (function() use ($dataId,$t){
                        $b = DB::table('future_gift_plan_entries as f')
                            ->join('future_gift_recipients as rr', function($j){
                                $j->on('rr.data_id','=','f.data_id')
                                  ->on('rr.recipient_no','=','f.recipient_no');
                            })
                            ->where('f.data_id', $dataId)
                            ->whereBetween('f.recipient_no', [2, 10])
                            ->where('f.row_no', $t);
                        // rr.deleted_at / rr.is_active が“存在する場合のみ”条件を付与（存在しない環境での Unknown column 対策）
                        if (Schema::hasColumn('future_gift_recipients','deleted_at') ||
                            Schema::hasColumn('future_gift_recipients','is_active')) {
                            $b->where(function($w){
                                $hasDeleted = Schema::hasColumn('future_gift_recipients','deleted_at');
                                $hasActive  = Schema::hasColumn('future_gift_recipients','is_active');
                                if ($hasDeleted && $hasActive) {
                                    $w->whereNull('rr.deleted_at')
                                      ->orWhere('rr.is_active', 1);
                                } elseif ($hasDeleted) {
                                    $w->whereNull('rr.deleted_at');
                                } elseif ($hasActive) {
                                    $w->where('rr.is_active', 1);
                                }
                            });
                        }
                        return $b->groupBy('f.recipient_no')
                                 ->selectRaw('f.recipient_no, MAX(f.id) as id');
                    })(),
                    'r', fn($j)=>$j->on('r.id','=','x.id')
                )
                ->get(['x.recipient_no','x.settlement_add_cum_thousand']);

            //Log::debug('2025.12.10 10001 [incl_set] per recipient', ['t'=>$t, 'rows'=>$rows]);

            return $k;
        };


        // 1年目以降の cal_cum / set_cum の“当年分”合計を、年ごとSQL集計クロージャで取得（配列はデバッグ用）
        $sumCalCumK = 0;
        $sumSetCumK = 0;
        $perYearCal = [];
        $perYearSet = [];
        for ($t = 1; $t <= 20; $t++) {
            $vCal = (int)$sumCalCumYearK($t); // 千円
            $vSet = (int)$sumSetCumYearK($t); // 千円
            $perYearCal[$t] = $vCal;
            $perYearSet[$t] = $vSet;
            $sumCalCumK += $vCal;
            $sumSetCumK += $vSet;
            //Log::info("cal_cum[$t] (K): ".$vCal);
            //Log::info("2025.12.10 200001 set_cum[$t] (K): ".$vSet);
        }
        if ($sumCalCumK === 0) {
            Log::warning("1年目以降のcal_cum合計が0になっています。データを確認してください。", ['per_year_cal_k' => $perYearCal]);
        }
        if ($sumSetCumK === 0) {
            Log::warning("1年目以降のset_cum合計が0になっています。データを確認してください。", ['per_year_set_k' => $perYearSet]);
        }





        // 1) ベース資産（円）… POST が無ければ DB からフェイルオーバー取得
        //    propertyNowYen は「総資産（現時点）」、cashNowYen はその内訳の一部（運用対象）
        [$propertyNowYen, $cashNowYen, $rate] = $this->resolveBaseFromPayloadOrDb($payload, $dataId);
        $nonCashNowYen = max(0, $propertyNowYen - $cashNowYen); // ★“非現金”部分
        // ★ ここで死亡日を解決しておく（下で $deathDate を使用するため）
        $deathDate = $this->resolveDeathDateFromPayload($payload);
        

        // 2) 法定相続人候補（bunsi>=1 && bunbo>=1 の行2..10）
        // ★ $heirs を必ずここで定義（Undefined variable $heirs 対策）
        $heirs = $this->collectHeirs($payload);
        if (!is_array($heirs)) {
            $heirs = [];
        }

        $bunsiCount = count(array_filter($heirs, function ($h) {
            // 配列でもオブジェクトでも動くように吸収
            $bunsi = is_array($h) ? ($h['bunsi'] ?? 0) : ($h->bunsi ?? 0);
            return (int)$bunsi >= 1;
        }));
 
        Log::debug('2025.12.15 bunsi>=1 count', ['bunsiCount' => $bunsiCount]);
 
        $heirCount = $bunsiCount;

        // ★「課税価格の取得がある人（相続/遺贈で取得する人）」のみを生前贈与加算の対象にする
        //   - auto  : heirs のみ
        //   - manual: id_taxable_manu >0 の行のみ（空なら heirs にフォールバック）
        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);
 


        // 1.5) 0年目の相続財産（対策前：過年度贈与を合算）
        // ★ property は総資産に cash を含むため、ここで cash を再加算しない
        $estateBaseNoGiftsYen = $propertyNowYen;


        // 相続人別の生前贈与加算額（対策前）を先に算定
        $giftIncl   = $this->calcPastGiftsIncludedInEstateByRecipient(
            $dataId,
            $deathDate,
            $taxableAcquirerIdxList
        );


        // 元遺産 + 贈与合計（法上の算入は遺産合計に対して実施）
        $estateYen  = $estateBaseNoGiftsYen + (int)($giftIncl['total_yen'] ?? 0);



        // 3) 基礎控除
        $basicDeduction = 30_000_000 + 6_000_000 * $heirCount;

        // 4) 課税遺産総額（auto用の標準値）
        $taxableEstate = max(0, $estateYen - $basicDeduction);

        // 5) 法定相続割合の正規化用合計
        $totalRatio = 0.0;
        foreach ($heirs as $h) {
            // ★税務上の法定相続割合（bunsi/bunbo）を使用
            $bunsi = (int)($h['bunsi'] ?? 0);
            $bunbo = (int)($h['bunbo'] ?? 0);
            if ($bunsi >= 1 && $bunbo >= 1) {
                $totalRatio += ($bunsi / $bunbo);
            }
        }
        $totalRatio = $totalRatio > 0 ? $totalRatio : 1.0;

        // 以降、各人の按分は「(bunsi/bunbo) / totalRatio」を使う
        // 例：
        // $ratio = (($bunsi / $bunbo) / $totalRatio);
        // $shareYen = (int) floor($taxableEstate * $ratio);


        // (A) manual 表示用
        //     ① 手入力 P_i に各人贈与 G_i を加えて合計 → ②合計から基礎控除を一括控除 → ③残額を P_i 比で按分
        $manualShares = $this->buildManualTaxableShares($payload, $basicDeduction, $giftIncl['per_idx'] ?? []);
        // manual の控除後合計（画面「課税遺産総額」に出す値）を取得し、
        // manual 有効時のみ 6-1 の速算ベースに採用
        $manualTotalTaxableYen = (int)($manualShares['total_taxable_yen'] ?? 0);
        $inputMode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        $isManualActive = ($inputMode === 'manual') && ($manualTotalTaxableYen > 0);
        $taxableEstateUsed = $isManualActive ? $manualTotalTaxableYen : $taxableEstate;


            /*
            // ★ここで課税遺産総額を確認
            Log::info('[ZouyotaxCalc][6-0] legal share', [
                'data_id'                => $dataId,
                'idx'                    => $h['idx'],
                'tax_able_EstateUsed'    => $taxableEstateUsed,
                'is_ManualActive'        => $isManualActive,
                'manual_TotalTaxableYen' => $manualTotalTaxableYen,
                'tax_ableEstate'         => $taxableEstate,
            ]);
            */

        // (B) 6-1 前の法定相続分テーブル
        $legalShareRows = [];

        // (C) 6-1：法定相続分課税の速算（相続税総額のベース）
        // ★税務上の法定相続割合（bunsi/bunbo）の正規化合計を作る
        $totalTaxRatio = 0.0;
        foreach ($heirs as $__h) {
            $bunsi = (int)($__h['bunsi'] ?? 0);
            $bunbo = (int)($__h['bunbo'] ?? 0);
            if ($bunsi >= 1 && $bunbo >= 1) {
                $totalTaxRatio += ($bunsi / $bunbo);
            }
        }
        $totalTaxRatio = $totalTaxRatio > 0 ? $totalTaxRatio : 1.0;

        $totalLegalShareTax = 0;
        foreach ($heirs as $h) {
            // ★税務上の法定相続割合で按分（bunsi/bunbo）
            $bunsi = (int)($h['bunsi'] ?? 0);
            $bunbo = (int)($h['bunbo'] ?? 0);
            $taxRatio = ($bunsi >= 1 && $bunbo >= 1) ? ($bunsi / $bunbo) : 0.0;
            $legalRatio = $taxRatio / $totalTaxRatio;

            $legalShareBase = (int)round($taxableEstateUsed * $legalRatio);
            
            //速算表より計算した各人の税額　相続税の総額の各人の欄に表示
            $legalTax       = $this->applyInheritanceTable($legalShareBase, $brackets);

            $totalLegalShareTax += $legalTax;
        
            
            // ★ここで法定算出税額の中身を確認
            Log::info('2025.12.15 20001 [ZouyotaxCalc][6-1] legal share', [
                'data_id'            => $dataId,
                'idx'                => $h['idx'],
                'bunsi'              => $h['bunsi'],
                'bunbo'              => $h['bunbo'],
                'legal_ratio'        => $legalRatio,
                'taxableEstateUsed'  => $taxableEstateUsed,
                'legal_share_base'   => $legalShareBase,
                'legal_tax_yen'      => $legalTax,
            ]);
            
            
        
            $legalShareRows[$h['idx']] = [
                'legal_ratio'     => $legalRatio,
                'legal_share_yen' => $legalShareBase,
                'legal_tax_yen'   => $legalTax,

                // 表示・保持用（税務上）
                'bunsi'           => (int)($h['bunsi'] ?? 0),
                'bunbo'           => (int)($h['bunbo'] ?? 1),
                // ★民法上（参考として持っておく）
                'civil_bunsi'     => (int)($h['civil_bunsi'] ?? 0),
                'civil_bunbo'     => (int)($h['civil_bunbo'] ?? 1),

                'two_tenths'      => (bool)$h['two_tenths'],
                'rel_code'        => (int)($h['rel_code'] ?? 0),
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$h['idx']] ?? 0),
            ];
        }
        

        /*
        // 合計もログ
        Log::info('[ZouyotaxCalc][6-1] total', [
            'data_id'           => $dataId,
            'taxableEstateUsed' => $taxableEstateUsed,
            'totalLegalShareTax'=> $totalLegalShareTax,
        ]);
        */

        // (D) 6-1直後：あん分割合の構築
        $anbun = $this->buildAnbunRatios($payload, $heirs, $legalShareRows);
        $anbunMode      = $anbun['mode'];    // 'manual' | 'auto'
        $anbunRatios    = $anbun['ratios'];  // idx => ratio（manualは2..10全員）
        $anbunTotalKyen = $anbun['total_kyen'];


        // ★ t=0(before) の「あん分割合／算出税額」はここで確定（課税価格合計割合）
        //    - あん分割合：buildAnbunRatios() が返す ratios（= id_taxable_manu + 生前贈与加算 の合計割合）
        //    - 算出税額：相続税総額 × あん分割合（floor配分 + 端数は最後へ寄せ）
        $sanzutsuTaxByIdx = array_fill(2, 9, 0);
        $allocated = 0;
        $lastIdx = null;
        for ($i = 2; $i <= 10; $i++) {
            $r = (float)($anbunRatios[$i] ?? 0.0);
            if ($r <= 0) continue;
            $lastIdx = $i;
            $tax = (int)floor($totalLegalShareTax * $r);
            $sanzutsuTaxByIdx[$i] = $tax;
            $allocated += $tax;
        }
        if ($lastIdx !== null) {
            $sanzutsuTaxByIdx[$lastIdx] += ($totalLegalShareTax - $allocated);
        }

        // ★ 安全のため初期化（全パスで必ず定義されている状態にする）
        $estateBaseForAlloc = 0;

        // ★ この年(t=0)の「贈与加算前ベース資産」を推定
        //    estateYen = estateBaseForAlloc + 贈与算入額(total_yen) という構造なので、
        //    贈与分を差し引くことで「ベース資産部分」を取り出す。
        $estateBaseForAlloc = $estateYen - (int)($giftIncl['total_yen'] ?? 0);
        if ($estateBaseForAlloc < 0) {
            $estateBaseForAlloc = 0;
        }

        // ★ 各 idx(2..10) について、その年(t=0)の「課税価格」を算定
        //   課税価格 P_i(0) ＝ ベース資産シェア_i(0) ＋ 現時点に算入される贈与分_i(0)
        //   ・manual: 入力された所有財産（id_taxable_manu）をそのままベース資産とする
        //   ・auto  : t=0 時点のあん分比率(anbunRatios)で estateBaseForAlloc を按分
        //   ・法定相続人でない行でも、贈与加算額があれば課税価格に含めて按分対象とする
        $priceForRatioByIdx = [];
        $sumPriceForRatio   = 0;
        for ($idx = 2; $idx <= 10; $idx++) {
            // t=0 のあん分比率（manual: id_taxable_manu 比率 / auto: 法定相続割合）
            $baseRatio  = (float)($anbunRatios[$idx] ?? 0.0);
            $manualKyen = 0; // ログ用に初期化（千円）

            // ベース資産シェア（贈与算入前の部分）
            if ($anbunMode === 'manual') {
                // manual モード：
                //  入力された各相続人の「所有財産（id_taxable_manu：千円）」を
                //  そのままベース資産とする（比率は掛けない）
                $manualKyen = $this->readKyen($payload, 'id_taxable_manu', $idx); // 千円
                if ($manualKyen < 0) {
                    $manualKyen = 0;
                }
                $baseShareYen = $this->toYen((int)$manualKyen); // 円に変換
            } else {
                // auto モード：
                //  法定相続割合ベースのあん分比率で estateBaseForAlloc を按分
                $baseShareYen = (int)round($estateBaseForAlloc * $baseRatio);
            }

            // 現時点で estate に算入される贈与加算額（暦年＋精算）
            $giftYen = (int)($giftIncl['per_idx'][$idx] ?? 0);

            // 課税価格 P_i(0)
            $price = max(0, $baseShareYen + $giftYen);

            if ($price <= 0) {
                continue;
            }
            $priceForRatioByIdx[$idx] = $price;
            $sumPriceForRatio        += $price;

            Log::info('10000_[ZouyotaxCalc][before_proj_per_idx]', [
                'idx'        => $idx,
                'manualKyen' => $manualKyen, // manual 時のみ実値、auto 時は 0
                '$price'     => $price,
            ]);

        }

        // ★ 課税価格に基づく「t=0 のあん分比率」
        $anbunRatiosForYear = [];
        if ($sumPriceForRatio > 0) {
            foreach ($priceForRatioByIdx as $idx => $price) {
                $anbunRatiosForYear[$idx] = $price / $sumPriceForRatio;
            }
        } else {
            // フォールバック：全員0なら従来の比率をそのまま使用
            $anbunRatiosForYear = $anbunRatios;
        }



        // ★ この年(t)の「各相続人の生前贈与後の課税価格 P_i(t)」を per_idx として保持
        //   Blade 側では projections.after[t]['per_idx'][$idx]['price_for_ratio'] から参照できる
        $perIdx = [];
        for ($idx = 2; $idx <= 10; $idx++) {
            $perIdx[$idx] = [
                'price_for_ratio' => (int)($priceForRatioByIdx[$idx] ?? 0),
            ];
        }


        // 贈与控除関係（projection でも compute() と同じロジックを使う）
        $giftTaxCredits      = $this->calcGiftTaxCreditsByRecipient(
            $dataId, $deathDate, $taxableAcquirerIdxList
        );
        $settlementGiftTaxes = $this->calcSettlementGiftTaxesByRecipient(
            $dataId, $taxableAcquirerIdxList
        );

        // 個別集計（projection でも idx=2..10 全員を対象）
        $finalTotalAfterSurcharge  = 0;
        $totalGiftTaxCredits       = 0;
        $totalPayableAfterCredits  = 0;
        $totalSpouseRelief         = 0;
        $totalPayableAfterSpouse   = 0;
        $totalOtherCredits         = 0;
        $totalPayableAfterOthers   = 0;
        $totalSashihikiTax         = 0;
        $totalSettlementGiftTaxes  = 0;
        $totalFinalAfterSettlement = 0;

        // 法定相続人マップ（rel_code / legal_ratio 等を引くため）
        $heirMap = [];
        foreach ($heirs as $h) {
            $idx = $h['idx'];
            $heirMap[$idx] = [
                'rel_code'        => (int)($h['rel_code'] ?? 0),
                'bunsi'           => (int)$h['bunsi'],
                'bunbo'           => (int)$h['bunbo'],
                'legal_ratio'     => $legalShareRows[$idx]['legal_ratio']     ?? 0.0,
                'legal_share_yen' => $legalShareRows[$idx]['legal_share_yen'] ?? 0,
                'legal_tax_yen'   => $legalShareRows[$idx]['legal_tax_yen']   ?? 0,
            ];
        }

        $breakdown = [];
        for ($idx = 2; $idx <= 10; $idx++) {
            $isHeir  = isset($heirMap[$idx]);
            $relCode = $heirMap[$idx]['rel_code'] ?? 0;

            // ★ t=0(before) の最終あん分割合（課税価格合計割合）
            $anbunRatio = (float)($anbunRatios[$idx] ?? 0.0);

            // ★ 算出税額（t=0確定値）：floor配分＋端数寄せで合計が必ず総額に一致する
            $sanzutsu = (int)($sanzutsuTaxByIdx[$idx] ?? 0);

            // 2割加算（チェックボックスで判定：法定相続人限定ではない）
            $twoTenths = $this->checkboxOn($payload, 'twenty_percent_add', $idx);
            $finalTax  = $twoTenths ? (int)round($sanzutsu * 1.2) : $sanzutsu;
            $finalTotalAfterSurcharge += $finalTax;
            
            
            
            // ★ 年次プロジェクション用：各人ごとの算出税額と2割加算後税額をログ出力
                Log::info('10001_[ZouyotaxCalc][before_proj_per_idx]', [
                    'estate_yen'   => $estateYen,
                    'idx'          => $idx,
                    'is_heir'      => $isHeir,
                    'anbun_ratio'  => $anbunRatio,
                    'sanzutsu'     => $sanzutsu,
                    'two_tenths'   => $twoTenths,
                    'final_tax'    => $finalTax,
                ]);
            
            

            // 暦年贈与税額控除
            $creditCalendar  = (int)($giftTaxCredits[$idx]['calendar_yen'] ?? 0);
            $payAfterCalCred = max(0, $finalTax - max(0, $creditCalendar));
            $totalGiftTaxCredits      += min($finalTax, max(0, $creditCalendar));
            $totalPayableAfterCredits += $payAfterCalCred;

            // 配偶者軽減
            $spouseRelief   = 0;
            $payAfterSpouse = $payAfterCalCred;
            if ($isHeir && in_array($relCode, [3,4], true) && $payAfterCalCred > 0) {
                $legalRatioForIdx = (float)($heirMap[$idx]['legal_ratio'] ?? 0.0);
                $actualShareYen   = $this->resolveActualShareYenForIdx($payload, $idx, $estateYen, $legalRatioForIdx);
                $legalAmountYen   = (int)round($estateYen * $legalRatioForIdx);
                $targetBaseYen    = min($actualShareYen, max($legalAmountYen, 160_000_000));
                if ($actualShareYen > 0 && $targetBaseYen > 0) {
                    $spouseRelief = (int)floor($payAfterCalCred * ($targetBaseYen / $actualShareYen));
                    if ($spouseRelief > $payAfterCalCred) $spouseRelief = $payAfterCalCred;
                    if ($spouseRelief < 0) $spouseRelief = 0;
                    $payAfterSpouse = $payAfterCalCred - $spouseRelief;
                }
            }
            $totalSpouseRelief       += $spouseRelief;
            $totalPayableAfterSpouse += $payAfterSpouse;

            // その他控除
            $otherCreditYen = $this->toYen($this->readKyen($payload, 'id_other_credit', $idx));
            if ($otherCreditYen < 0) $otherCreditYen = 0;
            $payAfterOthers = max(0, $payAfterSpouse - $otherCreditYen);
            $totalOtherCredits       += min($payAfterSpouse, $otherCreditYen);
            $totalPayableAfterOthers += $payAfterOthers;

            // 差引税額
            $sashihikiTax = $payAfterOthers;
            $totalSashihikiTax += $sashihikiTax;

            // 精算課税贈与税控除
            $settlementGiftTaxYen = (int)($settlementGiftTaxes[$idx] ?? 0);
            $finalAfterSettlement = $sashihikiTax - max(0, $settlementGiftTaxYen);
            $totalSettlementGiftTaxes  += max(0, $settlementGiftTaxYen);
            $totalFinalAfterSettlement += $finalAfterSettlement;

            $breakdown[] = [
                'row_index'   => $idx,
                'bunsi'       => $isHeir ? ($heirMap[$idx]['bunsi'] ?? 0) : 0,
                'bunbo'       => $isHeir ? ($heirMap[$idx]['bunbo'] ?? 1) : 1,
                'legal_ratio' => $heirMap[$idx]['legal_ratio']     ?? 0.0,
                'legal_share_yen' => $heirMap[$idx]['legal_share_yen'] ?? 0,
                'legal_tax_yen'   => $heirMap[$idx]['legal_tax_yen']   ?? 0,
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$idx] ?? 0),
                'anbun_ratio'     => $anbunRatio,
                'sanzutsu_tax_yen'=> $sanzutsu,
                'final_tax_yen'   => $finalTax,
                'two_tenths_added'=> $twoTenths,
                'is_spouse'       => $isHeir ? in_array($relCode, [3,4], true) : false,
                'gift_tax_credit_calendar_yen'      => max(0, $creditCalendar),
                'payable_after_calendar_credit_yen' => $payAfterCalCred,
                'spouse_relief_yen'  => $spouseRelief,
                'payable_after_spouse_yen' => $payAfterSpouse,
                'other_credit_yen'   => $otherCreditYen,
                'payable_after_others_yen' => $payAfterOthers,
                'sashihiki_tax_yen'  => $sashihikiTax,
                'settlement_gift_tax_yen' => max(0, $settlementGiftTaxYen),
                'final_after_settlement_yen' => $finalAfterSettlement,
                'payable_tax_yen' => $finalAfterSettlement > 0 ? $finalAfterSettlement : 0,
                'refund_tax_yen'  => $finalAfterSettlement < 0 ? abs($finalAfterSettlement) : 0,
            ];
            
            

        }

        /*
        // ここまでで $finalTotalAfterSurcharge / $totalGiftTaxCredits ... が決まる
       Log::info('[ZouyotaxCalc][before_proj_sum_check]', [
           'estate_yen'           => $estateYen,
           'final_total'          => $finalTotalAfterSurcharge,
           'sum_final_tax_yen'    => array_sum(array_column($breakdown, 'final_tax_yen')),
           'total_gift_tax_credits' => $totalGiftTaxCredits,
           'total_pay_after_credits' => $totalPayableAfterCredits,
       ]);
       */


        // -------------------------
        // 対策前（before）サマリ生成
        // -------------------------
        $before = [
            'data_id' => $dataId,
            'summary' => [
                'estate_base_yen'  => $estateBaseNoGiftsYen,          // ★追加：ベース資産
                'estate_yen'       => $estateYen,
                'heir_count'       => $heirCount,
                'basic_deduction'  => $basicDeduction,
                'taxable_estate'                => $taxableEstateUsed,
                'past_gift_included_total_yen'  => (int)($giftIncl['total_yen'] ?? 0),
                // 過年度贈与の内訳（暦年／精算）… lookback ロジックの結果そのもの
                'incl_calendar_yen'             => (int)($giftIncl['calendar_total_yen']   ?? 0),
                'incl_settlement_yen'           => (int)($giftIncl['settlement_total_yen'] ?? 0),
                'past_gift_included_per_idx'    => $giftIncl['per_idx'] ?? [],
                'sozoku_tax_total'              => $totalLegalShareTax,
                'total_after_surcharge'         => $finalTotalAfterSurcharge,
                'total_gift_tax_credits'        => $totalGiftTaxCredits,
                'total_payable_after_calendar_credits' => $totalPayableAfterCredits,
                'total_spouse_relief' => $totalSpouseRelief,
                'total_payable_after_spouse' => $totalPayableAfterSpouse,
                'total_other_credits' => $totalOtherCredits,
                'total_payable_after_others'    => $totalPayableAfterOthers,
                'total_sashihiki_tax'           => $totalSashihikiTax,
                'total_settlement_gift_taxes'   => $totalSettlementGiftTaxes,
                'total_final_after_settlement'  => $totalFinalAfterSettlement,
                // ★最終相続税額（精算課税分控除後）＝画面表示用
                'final_after_settlement_yen'    => $totalFinalAfterSettlement,

                'anbun_mode' => $anbunMode,
                'anbun_total_kyen' => $anbunTotalKyen,
                // ★進行表用：t=0 の減少額（初期値は 0 に固定）
                'gift_decr_calendar_yen' => 0,
                'gift_decr_payment_yen'  => 0, // ← 精算課税（set）の累計マイナス表示用
            ],
            'heirs' => $breakdown,
            'meta'  => [
                'mode'    => 'inheritance_only_without_future_gifts',
                'version' => 'v1.0-manual-total-alloc',
                'ts'      => now()->toDateTimeString(),
                'anbun_mode' => $anbunMode,
            ],
        ];

        /*
        Log::info('[ZouyotaxCalc] computed(before)', [
            'data_id' => $dataId,
            'estate'  => $estateYen,
            'heirs'   => $heirCount,
            'sozoku_tax_total'      => $totalLegalShareTax,
            'total_after_surcharge' => $finalTotalAfterSurcharge,
            'anbun_mode'            => $anbunMode,
            'anbun_total_kyen'      => $anbunTotalKyen,
            // 追記：人別の過年度贈与加算をログに出力
            'past_gift_included_total_yen' => (int)($giftIncl['total_yen'] ?? 0),
            'past_gift_included_per_idx'   => $giftIncl['per_idx'] ?? [],
         ]);
         */

        // -------------------------
        // 対策後（after）を計算
        // -------------------------
        $futurePlan = $this->extractFuturePlanFromPayload($payload);
        
        /*
        Log::info('[DEBUG futurePlan]', $futurePlan);
        */

        // ★ 将来贈与プラン（暦年/精算）の「贈与税額（tax_thousand）」を年次ごとに集計（千円）
        $futureCalendarTaxByYearK  = array_fill(1, 20, 0);
        $futureSettlementTaxByYearK = array_fill(1, 20, 0);
        //暦年贈与
        foreach (($futurePlan['calendar'] ?? []) as $row) {
            $tRow = (int)($row['t'] ?? 0);
            if ($tRow >= 1 && $tRow <= 20) {
                $futureCalendarTaxByYearK[$tRow] += (int)($row['tax_thousand'] ?? 0);
            }
        }
        //精算課税贈与
        foreach (($futurePlan['settlement'] ?? []) as $row) {
            $tRow = (int)($row['t'] ?? 0);
            if ($tRow >= 1 && $tRow <= 20) {
                $futureSettlementTaxByYearK[$tRow] += (int)($row['settlement_tax20_thousand'] ?? 0);
                
                Log::debug('2025.12.08 000001 settlement_tax20_thousand = ',  ['t'=>$t, 'rows'=>$row]);
                
            }
        }

        // ★ t ごとの「これからの贈与税額」（暦年＋精算）の累計（千円）
        $cumFutureCalendarTaxK   = [0 => 0];
        $cumFutureSettlementTaxK = [0 => 0];
        $runCalK = 0;
        $runSetK = 0;
        for ($tt = 1; $tt <= 20; $tt++) {
            $runCalK += $futureCalendarTaxByYearK[$tt]   ?? 0;
            $runSetK += $futureSettlementTaxByYearK[$tt] ?? 0;
            $cumFutureCalendarTaxK[$tt]   = $runCalK;
            $cumFutureSettlementTaxK[$tt] = $runSetK;
        }

        // ★ 過去の「暦年贈与税額（tax_thousand）」累計（千円）→ 円
        $pastCalendarGiftTaxCumK = PastGiftCalendarEntry::query()
            ->where('data_id', $dataId)
            ->sum('tax_thousand');
        $pastCalendarGiftTaxCumYen = $this->toYen((int)$pastCalendarGiftTaxCumK);

        // ★ 過去の「精算課税に係る贈与税額（tax_thousand）」累計（千円）→ 円
        $pastSettlementGiftTaxCumK = PastGiftSettlementEntry::query()
            ->where('data_id', $dataId)
            ->sum('tax_thousand');
        $pastSettlementGiftTaxCumYen = $this->toYen((int)$pastSettlementGiftTaxCumK);

        // ★ ベースとなる「過去分のみの贈与税額累計」（暦年＋精算）
        $baseGiftTaxCumYen = $pastCalendarGiftTaxCumYen + $pastSettlementGiftTaxCumYen;

        // 「これからの贈与」が一切無いかどうか
        //  - 暦年/精算の年次金額（cal_amount / set_amount）がすべて 0
        //  - 将来贈与の calendar/settlement 配列も空
        $hasFuturePlanEntries =
            (array_sum($calAmountByYearK ?? []) > 0)
            || (array_sum($setAmountByYearK ?? []) > 0)
            || !empty($futurePlan['calendar'])
            || !empty($futurePlan['settlement']);

        // ★ 対策後シナリオへは「非現金」を渡す（総資産を再加算しないため）
        // ★ t=0（現時点）の after は「これからの贈与」を一切考慮しない
        //   → before と完全に同じ税額フローになるように、将来贈与プランを無視するフラグを立てて計算
        $after      = $this->computeScenario(
            $payload,
            $heirs,
            $basicDeduction,
            $nonCashNowYen,  // ← 修正：$propertyNowYen ではなく “非現金”
            $cashNowYen,
            $rate,
            $deathDate,
            $brackets,
            $futurePlan,
            true  // ← ignoreFuturePlanAtT0: t=0 では「これからの贈与」を無視
        );

        // ★ after(t=0) の表示用補助フィールドを初期化（現時点から必要なキーをすべて用意）
        $after['summary']['estate_base_yen']        = $estateBaseNoGiftsYen;
        $after['summary']['gift_decr_calendar_yen'] = 0; // 暦年の減少（累計・負値）※t=0は0
        $after['summary']['gift_decr_payment_yen']  = 0; // 精算の減少（累計・負値）※t=0は0
        // ★ t=0 は「過去分のみ」の贈与税額累計（暦年＋精算）
        $after['summary']['calendar_gift_tax_cum_yen'] = $baseGiftTaxCumYen;



        // -------------------------
        // 差額（delta）を生成
        // -------------------------
        $delta = $this->buildDelta($before, $after);

        // 7) 年次プロジェクション（0〜20年）：before / after / delta
        $projBefore = [];
        $projAfter  = [];
        $projDelta  = [];
        $cumCalK = 0;      // 暦年贈与の年次累計（千円）
        $cumSetK = 0;      // 精算課税の年次累計（千円）
        $baseDeathDate = $deathDate;

        for ($t = 0; $t <= 20; $t++) {
            // ★ 年次ごとの死亡日（相続税計算用）
            //   t=0 → 基準年
            //   t=1 → 基準年 +1年
            //   t=2 → 基準年 +2年 ... と「資産成長(t年分)」と整合させる
            $deathDateT = (clone $baseDeathDate)->modify('+' . $t . ' year');

            // 対策前：利回りで増加した現金を反映
            $cashT       = (int)round($cashNowYen * pow(1 + max($rate, -0.999999), $t));
            $estateBaseT = $nonCashNowYen + $cashT;


            // ★修正：過年度贈与は死亡日を変えて再評価してはいけない
            // t=0 の算入結果（giftIncl）を固定して使用する
            if ($t === 0) {
                $giftInclT = $giftIncl; // compute() 冒頭で計算済み
            } else {
                $giftInclT = $giftIncl; // t>=1 も固定値を使う
            }
        

            $estateT = $estateBaseT + (int)($giftInclT['total_yen'] ?? 0);

            // 対策前プロジェクションのフル計算
            $projBefore[$t] = $this->computeForGivenEstateAndDate(
                $t,
                $payload,
                $heirs,
                $basicDeduction,
                $estateT,
                $deathDateT,
                $brackets,
                'before_proj'
            );
            $projBefore[$t]['summary']['estate_base_yen']        = $estateBaseT;
            $projBefore[$t]['summary']['gift_decr_calendar_yen'] = 0;
            $projBefore[$t]['summary']['gift_decr_payment_yen']  = 0;

            
            /*
            // ★ 対策前の課税価格内訳ログ
            Log::info('[ZouyotaxCalc][before_proj_breakdown]', [
                't'                          => $t,
                'death_date'                 => $deathDateT->format('Y-m-d'),
                // 現行仕様では death_date と同じだが、将来 lookback 用に分ける余地を残しておく
                'death_date_lookback'        => $deathDateT->format('Y-m-d'),
                'non_cash_yen'               => $nonCashNowYen,
                'cash_after_growth_yen'      => $cashT,
                'estate_base_yen'            => $estateBaseT,
                'incl_calendar_yen'          => (int)($giftInclT['calendar_total_yen']   ?? 0),
                'incl_settlement_yen'        => (int)($giftInclT['settlement_total_yen'] ?? 0),
                'estate_total_yen'           => $estateT,
                'taxable_estate'             => $projBefore[$t]['summary']['taxable_estate']             ?? null,
                'final_after_settlement_yen' => $projBefore[$t]['summary']['final_after_settlement_yen'] ?? null,
            ]);
            */

            // 対策後：将来贈与プランをT年次まで反映
            $projAfter[$t] = $this->computeScenarioForGivenDate(
                $t,
                $payload, $heirs, $basicDeduction,
                $nonCashNowYen, $cashNowYen, $rate,
                $deathDateT, $brackets, $futurePlan
            );

            // ★ 贈与前の比較用（表示用途のみ）
            //    computeScenarioForGivenDate() で
            //      estate_base_yen  = 贈与前（比較用）
            //      estate_after_yen = 贈与後（実際の贈与額控除後）
            //    を返すので、ここでは “比較用キー” を揃えるだけにする。
            $projAfter[$t]['summary']['estate_before_gifts_yen'] = (int)($projAfter[$t]['summary']['estate_base_yen'] ?? $estateBaseT);

            //生前贈与額
            // UI の cal_amount[t] / set_amount[t] を「累計の減少額」として反映
            if ($t >= 1) {
                $cumCalK += $sumCalAmountK($t);
                $cumSetK += $sumSetAmountK($t);
            }
            $projAfter[$t]['summary']['gift_decr_calendar_yen'] = - $this->toYen($cumCalK);
            $projAfter[$t]['summary']['gift_decr_payment_yen']  = - $this->toYen($cumSetK);

            // ★ estate_after_yen は computeScenarioForGivenDate() が
            //   「実際の贈与額（cash_out_total）控除後」を返すので、ここでは上書きしない。

            // ★ t ごとの「贈与税額累計」（暦年＋精算）の合計（千円）
            //   ※ 未定義エラー防止のため、必ずここで定義してから使用する
            $futureTaxKTillT = (int)($cumFutureCalendarTaxK[$t] ?? 0)
                             + (int)($cumFutureSettlementTaxK[$t] ?? 0);

            // ★ 贈与税額累計（円）：過去分＋将来分（t年次まで）
            $projAfter[$t]['summary']['calendar_gift_tax_cum_yen']
                = $baseGiftTaxCumYen + $this->toYen($futureTaxKTillT);


            $projDelta[$t] = $this->buildDelta($projBefore[$t], $projAfter[$t]);
        }



        // ★ 「これからの贈与」が一切無い場合は、対策後シナリオを対策前と完全一致させる
        //   （相続税・贈与税累計・合計が before / projections.before と同じになるよう強制）
        if (!$hasFuturePlanEntries) {
            // ▼ 贈与税累計額（gift_tax_cum_yen）を1つだけ決めて、
            //    before / projections.before / after / projections.after ですべて同じ値を使う
            $giftCumYen = (int)(
                ($before['summary']['gift_tax_cum_yen'] ?? $before['summary']['gift_tax_total_yen'] ?? null)
                ?? (
                    (int)($before['summary']['total_gift_tax_credits']      ?? 0)
                  + (int)($before['summary']['total_settlement_gift_taxes'] ?? 0)
                )
            );
            // before(t=0) にセット
            $before['summary']['gift_tax_cum_yen'] = $giftCumYen;
            // projections.before[t] 全行に同じ値をセット
            foreach ($projBefore as $tt => $row) {
                if (!isset($projBefore[$tt]['summary']) || !is_array($projBefore[$tt]['summary'])) {
                    continue;
                }
                $projBefore[$tt]['summary']['gift_tax_cum_yen'] = $giftCumYen;
            }

            // after / projections.after は before / projections.before の完全コピー
            $after      = $before;
            $projAfter  = $projBefore;

            // 差額はすべて 0 に揃える
            $delta = $this->buildDelta($before, $before);

            $projDelta = [];
            foreach ($projBefore as $t => $beforeRow) {
                $projDelta[$t] = $this->buildDelta($beforeRow, $beforeRow);
            }

            return [
                'before'      => $before,
                'after'       => $after,
                'delta'       => $delta,
                'projections' => [
                    'before' => $projBefore,
                    'after'  => $projAfter,
                    'delta'  => $projDelta,
                ],
            ];
        }


        // ★ 課税価格の定義を統一：
        //   taxable_estate = estate_after_yen + incl_calendar_yen + incl_settlement_yen
        //   （対策後 after ＋ 年次プロジェクション projections.after に適用）
        [$after, $projAfter] = $this->normalizeTaxableEstateForAfter($after, $projAfter);

        // ★ after／年次プロジェクションの課税遺産総額を「各相続人の課税価格比率」で按分
        [$after, $projAfter] = $this->allocateTaxableEstateByFixedRatios($after, $projAfter);

        // ★ after／年次プロジェクションの所有財産(estate_base_yen)も
        //   同じ比率で各相続人に按分（heirs[].estate_base_share_yen）
        [$after, $projAfter] = $this->allocateEstateBaseByFixedRatios($after, $projAfter);

        // ★ 各受贈者（行2〜10）の「対策前の所有財産の推移」＋
        //   将来贈与・相続取得・相続税を persons.timeline に格納
        //   - asset_total_yen              … 元々の所有財産の推移（運用のみ反映）
        //   - gift_*                       … 将来贈与プランに基づく受領額／贈与税
        //   - inherit_net_yen              … 相続による取得財産（生前贈与加算前）
        //   - inherit_tax_yen              … 相続税額（final_after_settlement_yen）
        //   - investment_gain_yen          … 運用による増加額
        //   - asset_after_yen              … 上記の純増を反映した対策後残高（簡易版）
        $after['persons'] = $this->buildPersonBaselineTimelines(
            $payload,
            $dataId,
            $rate,
            $futurePlan,
            $after,
            $projAfter
        );


        return [
            'before'      => $before,
            'after'       => $after,
            'delta'       => $delta,
            'projections' => [
                'before' => $projBefore,
                'after'  => $projAfter,
                'delta'  => $projDelta,
            ],
        ];


    }




    /**
     * 「対策後(after)」および「年次プロジェクション(projections.after)」の
     * 「課税価格」と「課税遺産総額」を定義し直す。
     *
     *   課税価格（kazei_price_yen）
     *     = estate_after_yen + incl_calendar_yen + incl_settlement_yen
     *
     *   課税遺産総額（taxable_estate）
     *     = max(0, 課税価格 - basic_deduction)
     *
     * とし、summary['taxable_estate'] には「課税遺産総額」を格納する。
     *
     * estate_after_yen が未設定の場合は、
     *   estate_base_yen + gift_decr_calendar_yen + gift_decr_payment_yen
     * から補完する。
     */
    private function normalizeTaxableEstateForAfter(array $after, array $projAfter): array
    {
        $normalize = function (array $summary): array {
            $base    = (int)($summary['estate_base_yen']          ?? 0);
            $decrCal = (int)($summary['gift_decr_calendar_yen']   ?? 0);
            $decrSet = (int)($summary['gift_decr_payment_yen']    ?? 0);

            
            // ★（贈与後）相続財産の額（減額後）
            //   - computeScenarioForGivenDate() が正の値（現金流出控除後）を返している場合があるため、
            //     それを最優先する。
            //   - 無い場合のみ、従来通り base + decr で補完する。
            if (array_key_exists('estate_after_yen', $summary) && $summary['estate_after_yen'] !== null) {
                $estateAfter = (int)$summary['estate_after_yen'];
            } else {
                $estateAfter = $base + $decrCal + $decrSet;
            }
            if ($estateAfter < 0) $estateAfter = 0;

            //生前贈与加算　暦年
            $inclCal = (int)($summary['incl_calendar_yen']        ?? 0);
            //生前贈与加算　精算
            $inclSet = (int)($summary['incl_settlement_yen']      ?? 0);

            // 課税価格（= 相続財産の額 + 贈与加算額）
            $kazeiPrice = $estateAfter + $inclCal + $inclSet;

            // 基礎控除額
            $basicDeduction = (int)($summary['basic_deduction'] ?? 0);

            // 課税価格・課税遺産総額を格納
            $summary['estate_after_yen'] = $estateAfter;
            $summary['kazei_price_yen']  = $kazeiPrice; // 課税価格（参考表示用）

            // ★修正：課税遺産総額を $kazeiPriceYen に基づいて強制的に上書き
            $summary['taxable_estate']   = max(0, $summary['kazei_price_yen'] - $basicDeduction);
            

            return $summary;
        };

        // 対策後(after) 本体
        if (isset($after['summary']) && is_array($after['summary'])) {
            $after['summary'] = $normalize($after['summary']);
        }

        // 年次プロジェクション after[t]
        if (is_array($projAfter)) {
            foreach ($projAfter as $t => $row) {
                if (!isset($row['summary']) || !is_array($row['summary'])) {
                    continue;
                }
                $row['summary']  = $normalize($row['summary']);
                $projAfter[$t]   = $row;
            }
        }

        return [$after, $projAfter];
    }

    /** payload の plan配列（例：cal_amount[i] / set_amount[i]：千円）や *_all を年次合算して返す */
    private function readPlanKyenArrayAllRecipients(array $payload, string $key): array
    {
        $sum = array_fill(1, 20, 0);
        // ① 受贈者横断の集計キー（例：cal_amount_all[recipient_no][t] / set_amount_all[recipient_no][t]）
        for ($rn = 2; $rn <= 10; $rn++) {
            for ($t = 1; $t <= 20; $t++) {
                $v = Arr::get($payload, "{$key}_all.{$rn}.{$t}");
                if ($v === null || $v === '') { continue; }
                $n = (int)preg_replace('/[^\d\-]/u', '', (string)$v);
                $sum[$t] += $n;
            }
        }
        // ② “現在開いている受贈者タブ” の一次元配列（plan[key][t] or key[t]）
        for ($t = 1; $t <= 20; $t++) {
            $v = Arr::get($payload, "{$key}.{$t}");
            if ($v === null) { $v = Arr::get($payload, "plan.{$key}.{$t}"); }
            if ($v === null || $v === '') { continue; }
            $n = (int)preg_replace('/[^\d\-]/u', '', (string)$v);
            $sum[$t] += $n;
        }
        return $sum;
    }




    // ===== 基本ユーティリティ =====

    /**
     * 死亡日（基準日）
     *
     * 優先順位：
     *  1. PastGiftInput の inherit_month / inherit_day ＋ header_year（年だけヘッダ）
     *  2. payload.header_year / header_month / header_day
     *  3. today()
     */
    private function resolveDeathDateFromPayload(array $payload): \DateTimeImmutable
    {
        // ヘッダ側の値（年）だけ先に取っておく
        $rawYear  = Arr::get($payload, 'header_year');
        $rawMonth = Arr::get($payload, 'header_month');
        $rawDay   = Arr::get($payload, 'header_day');

        $headerYear  = (int)preg_replace('/[^\d]/', '', (string)$rawYear)  ?: 0;
        $headerMonth = (int)preg_replace('/[^\d]/', '', (string)$rawMonth) ?: 0;
        $headerDay   = (int)preg_replace('/[^\d]/', '', (string)$rawDay)   ?: 0;

        /*
        Log::info('[ZouyotaxCalc][resolveDeathDate] header raw', [
            'header_year_raw'  => $rawYear,
            'header_month_raw' => $rawMonth,
            'header_day_raw'   => $rawDay,
            'header_year_int'  => $headerYear,
            'header_month_int' => $headerMonth,
            'header_day_int'   => $headerDay,
        ]);
        */

        // ① PastGiftInput の月日を優先して使用（年はヘッダ or 当年）
        try {
            $dataId = (int)($payload['data_id'] ?? 1);

            $pg = PastGiftInput::query()
                ->where('data_id', $dataId)
                ->first(['inherit_year','inherit_month','inherit_day']);

            if ($pg) {
                $yy = (int)($pg->inherit_year ?? 0);
                $mm = (int)($pg->inherit_month ?? 0);
                $dd = (int)($pg->inherit_day ?? 0);

                // 年が PastGiftInput に無い場合はヘッダ年、さらに無ければ当年
                if ($yy < 1900) {
                    $yy = $headerYear >= 1900 ? $headerYear : (int)date('Y');
                }
                if ($mm < 1 || $mm > 12) {
                    $mm = $headerMonth >= 1 && $headerMonth <= 12 ? $headerMonth : 12;
                }
                if ($dd < 1 || $dd > 31) {
                    $dd = $headerDay >= 1 && $headerDay <= 31 ? $headerDay : 31;
                }

                $date = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $yy, $mm, $dd));
                
                /*
                Log::info('[ZouyotaxCalc][resolveDeathDate] use PastGiftInput (month/day) + header/today year', [
                    'data_id'        => $dataId,
                    'inherit_year'   => $pg->inherit_year,
                    'inherit_month'  => $pg->inherit_month,
                    'inherit_day'    => $pg->inherit_day,
                    'resolved'       => $date->format('Y-m-d'),
                ]);
                */
                
                return $date;
            }
        } catch (\Throwable $e) {
            Log::warning('[ZouyotaxCalc][resolveDeathDate] PastGiftInput lookup failed', [
                'error' => $e->getMessage(),
            ]);
        }

        // ② PastGiftInput が使えない場合は、従来どおりヘッダの日付をそのまま使う
        try {
            if ($headerYear >= 1900 && $headerMonth >= 1 && $headerMonth <= 12 && $headerDay >= 1 && $headerDay <= 31) {
                $date = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $headerYear, $headerMonth, $headerDay));
                Log::info('[ZouyotaxCalc][resolveDeathDate] use header date (fallback)', [
                    'resolved' => $date->format('Y-m-d'),
                ]);
                return $date;
            }
        } catch (\Throwable $e) {
            Log::warning('[ZouyotaxCalc][resolveDeathDate] header date invalid, fallback to today', [
                'error' => $e->getMessage(),
            ]);
        }

        // ③ それでも決まらなければ today()
        $today = new \DateTimeImmutable('today');
        Log::info('[ZouyotaxCalc][resolveDeathDate] fallback to today', [
            'resolved' => $today->format('Y-m-d'),
        ]);
        return $today;
    }

 
    /**
     * 相続財産に算入する過年度贈与（相続人別＆合計）
     * - 暦年課税：改正ルックバック期間内のみ
     *   ・2027-01-02 以降に死亡する場合は「受贈者×年」の合計から 1,000,000 円控除した“超過分のみ”算入
     * - 精算課税：全件
     * - 受贈者が「現在の法定相続人かどうか」に関わらず recipient_no=2..10 を集計対象とする
     *
     * @param int   $dataId
     * @param \DateTimeImmutable $deathDate
     * @param int[] $heirIdxList   例: [2,3,5] （※現在は絞り込みには使用しない）
     * @return array{
     *   total_yen:int,
     *   per_idx:array<int,int>,
     *   calendar_total_yen:int,
     *   settlement_total_yen:int,
     *   calendar_per_idx:array<int,int>,
     *   settlement_per_idx:array<int,int>
     * }
     */
    private function calcPastGiftsIncludedInEstateByRecipient(
        int $dataId,
        \DateTimeImmutable $deathDate,
        array $heirIdxList
    ): array {
        // ★ 生前贈与加算の対象：
        //   「相続/遺贈で課税価格を取得する人（=課税価格の取得がある人）」のみ
        //   -> 呼び出し側で決定した $heirIdxList（idx配列）でフィルタする

        $targetSet = [];
        foreach ($heirIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) $targetSet[$i] = true;
        }
        $hasTargetFilter = !empty($targetSet);

        // デバッグ/将来拡張用（未定義Notice回避）
        $perCalYearK = [];

        // 暦年・精算・合計：受贈者2..10 で必ず初期化する（相続人でなくても）
        $perCal = [];
        $perSet = [];
        $per    = [];
        for ($i=2; $i<=10; $i++) {
            $perCal[$i] = 0;
            $perSet[$i] = 0;
            $per[$i]    = 0;
        }


        [$rangeStart, $rangeEnd] = $this->determineCalendarGiftLookbackRange($deathDate);

        // ★ 3年経過判定用の境界日
        //   - deathDate から3年引いた日より前の贈与は「3年超」
        //   - それ以降の贈与は「3年以内」
        $threeYearsAgo = $deathDate->sub(new \DateInterval('P3Y'));

        // ★ 100万円控除の適用開始
        //   2027-01-01以降の死亡について、「3年超」の部分にだけ 100万円控除を適用
        $newRuleStart = new \DateTimeImmutable('2027-01-01');
        $useOneMillionExemption = ($deathDate >= $newRuleStart);

        // 暦年：受贈者×年ごとに「3年以内」と「3年超」の金額を別管理する（単位：千円）
        $perCalWithin3K = []; // [recipient_no][gift_year] => int
        $perCalOver3K   = []; // [recipient_no][gift_year] => int


        $calendar = PastGiftCalendarEntry::query()
             ->where('data_id', $dataId)
             ->get(['recipient_no','gift_year','gift_month','gift_day','amount_thousand']);
             
             
        foreach ($calendar as $row) {
            $no  = (int)($row->recipient_no ?? 0);
            if ($no < 2 || $no > 10) {
                continue; // 想定範囲外は除外
            }
            // ★暦年は「課税価格の取得がある人」のみ生前贈与加算対象
            if ($hasTargetFilter && !isset($targetSet[$no])) {
                continue;
            }
            $amtK = (int)($row->amount_thousand ?? 0);
            if ($amtK <= 0) {
                continue;
            }
            try {
                $gd = new \DateTimeImmutable(sprintf(
                    '%04d-%02d-%02d',
                    (int)$row->gift_year,
                    (int)$row->gift_month,
                    (int)$row->gift_day
                ));
            } catch (\Throwable $e) {
                continue;
            }
            if ($gd < $rangeStart || $gd > $rangeEnd) {
                continue;
            }
            
            $giftYear = (int)$row->gift_year; if (!isset($perCalYearK[$no])) { $perCalYearK[$no] = []; }

            // ★ deathDate から見て「3年以内」か「3年超」かで分ける
            if ($gd >= $threeYearsAgo) {
                // 3年以内：従来どおり全額算入（100万円控除の対象外）
                if (!isset($perCalWithin3K[$no])) {
                    $perCalWithin3K[$no] = [];
                }
                $perCalWithin3K[$no][$giftYear] = ($perCalWithin3K[$no][$giftYear] ?? 0) + $amtK;
            } else {
                // 3年超：100万円控除の対象候補
                if (!isset($perCalOver3K[$no])) {
                    $perCalOver3K[$no] = [];
                }
                $perCalOver3K[$no][$giftYear] = ($perCalOver3K[$no][$giftYear] ?? 0) + $amtK;
            }
            $perCalYearK[$no][$giftYear] = ($perCalYearK[$no][$giftYear] ?? 0) + $amtK;
        }

        // ▼ 修正：受贈者単位で合算し、100万円控除は1回だけ適用する
        foreach (range(2, 10) as $no) {
            // ★課税価格の取得が無い人は対象外（0のまま）
            if ($hasTargetFilter && !isset($targetSet[$no])) {
                continue;
            }
            $within3K = array_sum($perCalWithin3K[$no] ?? []);
            $over3K   = array_sum($perCalOver3K[$no]   ?? []);

            if ($useOneMillionExemption && $over3K > 0) {
                // 受贈者1回限りの控除
                $includedK = $within3K + max(0, $over3K - 1000);
            } else {
                $includedK = $within3K + $over3K;
            }

            $sumYen = $this->toYen($includedK);


            if ($sumYen > 0) {
                $perCal[$no] = $sumYen;
                $per[$no]    = ($per[$no] ?? 0) + $sumYen;
            }
        }


        // 精算：精算課税による贈与を受けた人は全員が生前贈与加算対象（課税価格取得の有無は問わない）
        $settlements = PastGiftSettlementEntry::query()
            ->where('data_id', $dataId)
            ->get(['recipient_no','gift_year','amount_thousand']);
            
            
        
        foreach ($settlements as $r) {


            $no = (int)($r->recipient_no ?? 0);
            if ($no < 2 || $no > 10) continue;

            // ★精算課税：生前贈与加算は「全件算入」（課税価格取得フィルタは掛けない）

            $year = (int)($r->gift_year ?? 0);
            
            // amount_thousand は「千円」単位なので、控除は 1100（=110万円）で行う
            if ($year >= 2024) {
                $amtK = max(0, (int)($r->amount_thousand ?? 0) - 1100);
            } else {
                $amtK = max(0, (int)($r->amount_thousand ?? 0));
            }
            if ($amtK > 0) {
                $yen           = $this->toYen($amtK);
                $perSet[$no]  += $yen;
                $per[$no]     += $yen;

                //Log::debug('2025.12.10 40001 ',  ['no'=>$no, $yen]);

            }


        }

        $totalCal = 0;
        $totalSet = 0;
        $total    = 0;
        // ★ 合計：暦年は（必要なら）取得者のみ、精算は受贈者全員（過去＋将来）
        for ($i = 2; $i <= 10; $i++) {

            $cal = (int)($perCal[$i] ?? 0);

            $set = (int)($perSet[$i] ?? 0);

            $totalCal += $cal;
            $totalSet += $set;
            $total    += (int)($per[$i] ?? ($cal + $set));
        }

        
        
        /*
        // ★ デバッグ用ログ：過年度贈与算入額の集計結果を確認
        Log::info('2025.12.10 300001 [ZouyotaxCalc][past_gifts_included]', [
            'data_id'              => $dataId,
            'death_date'           => $deathDate->format('Y-m-d'),
            'total_yen'            => $total,
            'calendar_total_yen'   => $totalCal,
            'settlement_total_yen' => $totalSet,
            'per_idx'              => $per,
            'calendar_per_idx'     => $perCal,
            'settlement_per_idx'   => $perSet,
        ]);
        */
        


        return [
            // 合算（暦年＋精算）
            'total_yen'             => $total,
            'per_idx'               => $per,
            // 内訳：暦年／精算（相続税の「課税価格」内訳確認用）
            'calendar_total_yen'    => $totalCal,
            'settlement_total_yen'  => $totalSet,
            'calendar_per_idx'      => $perCal,
            'settlement_per_idx'    => $perSet,
        ];
    }



    /**
     * （拡張版）相続財産算入額に「仮想（将来）贈与」も加算
     */
    private function calcPastGiftsIncludedInEstateByRecipientWithVirtual(
        int $dataId,
        \DateTimeImmutable $deathDate,
        array $heirIdxList,
        array $virtual // buildVirtualGiftsIndex() の戻り
    ): array {

        // まず「過去贈与のみ」の集計結果を取得（暦年/精算の内訳付き）
        $base = $this->calcPastGiftsIncludedInEstateByRecipient($dataId, $deathDate, $heirIdxList);

        // ★暦年のみ「課税価格の取得がある人」フィルタ（精算は全員対象）
        $targetSet = [];
        foreach ($heirIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) $targetSet[$i] = true;
        }
        $hasTargetFilter = !empty($targetSet);

        // ベースを展開（存在しないキーは 0 / 空配列で初期化）
        $perCal = $base['calendar_per_idx']     ?? [];
        $perSet = $base['settlement_per_idx']   ?? [];
        $per    = $base['per_idx']              ?? [];

        $totalCal = (int)($base['calendar_total_yen']   ?? 0);
        $totalSet = (int)($base['settlement_total_yen'] ?? 0);

        // 全受贈者分の器を作っておく
        for ($i = 2; $i <= 10; $i++) {
            if (!isset($perCal[$i])) $perCal[$i] = 0;
            if (!isset($perSet[$i])) $perSet[$i] = 0;
            if (!isset($per[$i]))    $per[$i]    = 0;
        }

        // 仮想：暦年算入（lookback 内のみ）＋精算は全件
        $v = $virtual[$deathDate->format('Y-m-d')] ?? [
            'calendar_included' => [],
            'settlement_all'    => [],
        ];

        // 暦年分：lookback 算入対象分（calendar_included）を暦年側に加算
        foreach (($v['calendar_included'] ?? []) as $no => $yen) {
            $idx = (int)$no;
            if ($idx < 2 || $idx > 10) continue;
            if ($hasTargetFilter && !isset($targetSet[$idx])) {
                continue;
            }
            $yen = max(0, (int)$yen);
            $perCal[$idx] += $yen;
            $per[$idx]    += $yen;
            $totalCal     += $yen;
        }

        // 精算分：全件算入（settlement_all）を精算側に加算（★取得者フィルタしない）
        foreach (($v['settlement_all'] ?? []) as $no => $yen) {

            $idx = (int)$no;
            if ($idx < 2 || $idx > 10) continue;
            $yen = max(0, (int)$yen);

            $perSet[$idx] += $yen;
            $per[$idx]    += $yen;
            $totalSet     += $yen;

        }

        // 合算（暦年＋精算）
        $total = 0;
        for ($i = 2; $i <= 10; $i++) {
            $total += (int)($per[$i] ?? 0);
        }

        return [
            'total_yen'             => $total,
            'per_idx'               => $per,
            'calendar_total_yen'    => $totalCal,
            'settlement_total_yen'  => $totalSet,
            'calendar_per_idx'      => $perCal,
            'settlement_per_idx'    => $perSet,
        ];

    }








    /** 画面「千円」→ 円 */
    private function toYen(int $kYen): int
    {
        return $kYen * 1000;
    }


    /**
     * 民法上の法定相続割合（civil_share_*）を優先して ratio を返す
     * - civil が未入力/不正なら bunsi/bunbo（税務上の相続割合）へフォールバック
     */
    private function civilRatio(array $h): float
    {
        $cbunsi = (int)($h['civil_bunsi'] ?? 0);
        $cbunbo = (int)($h['civil_bunbo'] ?? 0);
        if ($cbunsi >= 1 && $cbunbo >= 1) {
            return $cbunsi / $cbunbo;
        }
        $bunsi = (int)($h['bunsi'] ?? 0);
        $bunbo = (int)($h['bunbo'] ?? 0);
        return ($bunsi >= 1 && $bunbo >= 1) ? ($bunsi / $bunbo) : 0.0;
    }


    /** 配列入力（千円）を整数化 */
    private function readKyen(array $payload, string $base, int $idx): int
    {
        $key = sprintf('%s.%d', $base, $idx);
        $raw = Arr::get($payload, $key, '');
        if (!is_string($raw) && !is_numeric($raw)) return 0;
        $normalized = preg_replace('/[^\d\-]/u', '', (string)$raw) ?? '0';
        return (int)$normalized;
    }

    /** 相続人（行2..10）：bunsi>=1 && bunbo>=1 を候補 */
    private function collectHeirs(array $payload): array
    {
        $heirs = [];
        for ($i = 2; $i <= 10; $i++) {

            // 税務上の相続割合（既存）
            $bunsi = $this->readIntFromArray($payload, 'bunsi', $i);
            $bunbo = $this->readIntFromArray($payload, 'bunbo', $i);

            // ★民法上の法定相続割合（新規：こちらを課税価格按分に使用）
            $civilBunsi = $this->readIntFromArray($payload, 'civil_share_bunsi', $i);
            $civilBunbo = $this->readIntFromArray($payload, 'civil_share_bunbo', $i);

            // 相続人判定：civil が入っていれば civil、無ければ従来の bunsi/bunbo
            $hasCivil = ($civilBunsi >= 1 && $civilBunbo >= 1);
            $isHeir   = $hasCivil ? true : ($bunsi >= 1 && $bunbo >= 1);

            if ($isHeir) {

                $relCode = $this->readIntFromArray($payload, 'relationship', $i);
                $twoTenths = $this->checkboxOn($payload, 'twenty_percent_add', $i);
                $heirs[] = [
                    'idx'        => $i,
                    // 税務上（表示・互換用）
                    'bunsi'      => $bunsi,
                    'bunbo'      => $bunbo,
                    // ★民法上（按分計算に使用：未入力なら税務上へフォールバック）
                    'civil_bunsi'=> $hasCivil ? $civilBunsi : $bunsi,
                    'civil_bunbo'=> $hasCivil ? $civilBunbo : $bunbo,

                    'two_tenths' => $twoTenths,
                    'rel_code'   => $relCode,
                ];
            }
        }
        return $heirs;
    }

    private function readIntFromArray(array $payload, string $base, int $idx): int
    {
        $key = sprintf('%s.%d', $base, $idx);
        $s   = preg_replace('/[^\d\-]/u', '', (string)Arr::get($payload, $key, '')) ?? '0';
        return (int)$s;
    }

    private function checkboxOn(array $payload, string $base, int $idx): bool
    {
        $key = sprintf('%s.%d', $base, $idx);
        if (!Arr::has($payload, $key)) return false;
        $s = Str::lower((string)Arr::get($payload, $key));
        return in_array($s, ['1', 'on', 'true', 'yes'], true);
    }

    /**
     * 速算表適用（円）
     * @param int $shareYen
     * @param array<int, array{up_to:int, rate:float, quick:int}> $brackets
     */
    private function applyInheritanceTable(int $shareYen, array $brackets): int
    {
        $share = max(0, $shareYen);
        foreach ($brackets as $b) {
            if ($share <= $b['up_to']) {
                return (int)max(0, round($share * $b['rate']) - $b['quick']);
            }
        }
        return 0;
    }

    /** 速算表の読み込み（DB：sozoku_rates） */
    private function loadInheritanceBrackets(): array
    {
        $targetVersion = (int) SozokuRate::query()->max('version');
        if ($targetVersion === 0) {
            return $this->fallbackInheritanceBrackets();
        }

        $cacheKey = 'sozoku_rates:inheritance:v' . $targetVersion;
        return Cache::remember($cacheKey, now()->addDay(), function () use ($targetVersion) {
            $rows = SozokuRate::query()
                ->where('version', $targetVersion)
                ->orderBy('seq')
                ->get(['lower','upper','rate','deduction_amount']);

            if ($rows->isEmpty()) return $this->fallbackInheritanceBrackets();

            $list = [];
            foreach ($rows as $r) {
                $upper = (int)($r->upper ?? 0);
                $rate  = (float)$r->rate;
                if ($rate > 1) $rate = $rate / 100.0;
                $list[] = [
                    'up_to' => $upper > 0 ? $upper : PHP_INT_MAX,
                    'rate'  => $rate,
                    'quick' => (int)$r->deduction_amount,
                ];
            }
            return !empty($list) ? $list : $this->fallbackInheritanceBrackets();
        });
    }

    /** フォールバック速算表 */
    private function fallbackInheritanceBrackets(): array
    {
        return [
            ['up_to' => 10_000_000,  'rate' => 0.10, 'quick' =>      0],
            ['up_to' => 30_000_000,  'rate' => 0.15, 'quick' =>  500_000],
            ['up_to' => 50_000_000,  'rate' => 0.20, 'quick' => 2_000_000],
            ['up_to' =>100_000_000,  'rate' => 0.30, 'quick' => 7_000_000],
            ['up_to' =>200_000_000,  'rate' => 0.40, 'quick' =>17_000_000],
            ['up_to' =>300_000_000,  'rate' => 0.45, 'quick' =>27_000_000],
            ['up_to' =>600_000_000,  'rate' => 0.50, 'quick' =>42_000_000],
            ['up_to' =>PHP_INT_MAX,  'rate' => 0.55, 'quick' =>72_000_000],
        ];
    }

    /**
     * あん分割合の構築
     * ★あん分割合／算出税額は「課税価格（所有財産＋生前贈与加算）の合計割合」で計算する
     * - manual：入力された id_taxable_manu（千円）＋ past_gift_included（千円換算）で比率化
     * - auto   ：課税価格（id_taxable_manu + past_gift）が >0 の人を対象に比率化（bunsi/bunbo に依存しない）
     *
     * 返却:
     *  - mode       : 'manual' | 'auto'
     *  - ratios     : idx => ratio（0..1）
     *  - total_kyen : 課税価格合計（千円）
    */
    private function buildAnbunRatios(array $payload, array $heirs, array $legalShareRows): array
    {
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        $useManual = ($mode === 'manual');
    
        // 1) 各人の課税価格（千円）＝ 所有財産（id_taxable_manu：千円）＋ 生前贈与加算（円→千円）
        //    ※ auto でも id_taxable_manu は画面側（readonly）で値が入って POST される前提。
        //       bunsi/bunbo が 0（civil_share のみ入力）でも「課税価格>0」なら按分対象に含める。
        $baseKyenByIdx = [];
        for ($i = 2; $i <= 10; $i++) { $baseKyenByIdx[$i] = 0; }

        $totalKyen = 0;
        $targets = [];
        for ($idx = 2; $idx <= 10; $idx++) {
            $ownKyen = (int)$this->readKyen($payload, 'id_taxable_manu', $idx); // 千円
            if ($ownKyen < 0) { $ownKyen = 0; }

            $giftYen  = (int)($legalShareRows[$idx]['past_gift_included_yen'] ?? 0);
            $giftKyen = (int)round($giftYen / 1000);

                //log::Debug('2025.12.15 30002 giftYen ', ['$giftYen' => $giftYen, 'giftKyen' => $giftKyen ]);

            if ($giftKyen < 0) { $giftKyen = 0; }

            $baseKyen = $ownKyen + $giftKyen;
            if ($baseKyen < 0) { $baseKyen = 0; }

            $baseKyenByIdx[$idx] = $baseKyen;
            if ($baseKyen > 0) {
                $targets[] = $idx;         // ★課税価格がある人だけを按分対象にする
                $totalKyen += $baseKyen;
            }
        $targets = array_values(array_unique($targets));
        sort($targets);

        }

        // 3) 比率化（総和0なら全員0）
        $ratios = [];
        for ($i = 2; $i <= 10; $i++) $ratios[$i] = 0.0;
        if ($totalKyen > 0) {
            foreach ($targets as $idx) {
                $ratios[$idx] = ($baseKyenByIdx[$idx] ?? 0) / $totalKyen;
            }
        }

        return [
            'mode'       => $useManual ? 'manual' : 'auto',
            'ratios'     => $ratios,
            'total_kyen' => $totalKyen,
        ];

    }

    /**
     * manualモードの「課税遺産総額（個人）」表示値
     * 手順：
     *  ① 各人の手入力課税価格 P_i に対し、贈与加算 G_i（受贈者=相続人）を用いて合計 S = Σ(P_i + G_i) を作る
     *  ② T = max(0, S - 基礎控除)
     *  ③ T を “手入力課税価格 P_i の比率” で各人に按分（※G_i は配分比には使わない）
     *  ⇒ 各人 manual_taxable_yen = floor(T * (P_i / ΣP_i))（端数は最後の正値行へ寄せ）
     */
    private function buildManualTaxableShares(
            array $payload,
            int $basicDeduction,
            array $perGiftYenByIdx = []
        ): array
    {
        
        
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        
        
        if ($mode !== 'manual') {
            return ['mode' => 'auto', 'sum_kyen' => 0, 'shares' => [], 'total_taxable_yen' => 0];
        }
        
        
        
         // 1) 手入力課税価格（千円）を集計
        $sumKyen = 0;
        $manualKyenByIdx = [];
        for ($i = 2; $i <= 10; $i++) {
            $kyen = $this->readKyen($payload, 'id_taxable_manu', $i);
            if ($kyen < 0) $kyen = 0;
            $manualKyenByIdx[$i] = $kyen;
            $sumKyen += $kyen;
        }
        if ($sumKyen <= 0) {
            return ['mode' => 'manual', 'sum_kyen' => 0, 'shares' => [], 'total_taxable_yen' => 0];
        }
    
        // 2) 合計 S = Σ(P_i + G_i) を求め、T = max(0, S - 基礎控除) を算定
        //   ※ 現時点の生前贈与加算 G_i も「課税価格」に含める（P_i は画面上の課税価格千円）
        $sumYen = $this->toYen($sumKyen);  // ΣP_i（円）

        // 現時点の贈与加算額 G_i（円）を合算
        $giftSum = 0;
        for ($i = 2; $i <= 10; $i++) {
            $giftSum += max(0, (int)($perGiftYenByIdx[$i] ?? 0));
        }

        // ★ 課税遺産総額のベース：S = Σ(P_i + G_i)
        $sumWithGifts = $sumYen + $giftSum;

        // ★ 修正後：課税遺産総額 = Σ(P_i + G_i) − 基礎控除
        //   → 「課税遺産総額の合計 1,722,761千円」に現時点の生前贈与加算も含めた形に揃える
        $totalAfterDeduction = max(0, $sumWithGifts - $basicDeduction);

    
        // 3) 小計用に円へ（※ $sumYen は上で算出済み）


        // 4) 価格>0 の最後のインデックスを特定（残差寄せ用）
        $lastIdxWithPrice = null;
        for ($i = 2; $i <= 10; $i++) {
            if ($this->toYen($manualKyenByIdx[$i]) > 0) {
                $lastIdxWithPrice = $i;
            }
        }
    
        // 5) 按分（残差は最後の人）※配分比は P_i のみ（G_i は配分比に使わない）
        $shares = [];
        $allocated = 0;
        for ($i = 2; $i <= 10; $i++) {
            $priceYen = $this->toYen($manualKyenByIdx[$i] ?? 0);
            $alloc = 0;
            if ($i !== $lastIdxWithPrice) {
                $ratio = $sumYen > 0 ? ($priceYen / $sumYen) : 0.0;
                $alloc = (int)floor($totalAfterDeduction * $ratio);
                $allocated += $alloc;
            }
            $shares[$i] = [
                'manual_price_yen'   => $priceYen,
                'bd_share_yen'       => 0,      // 個人別の基礎控除配分はしない
                'manual_taxable_yen' => $alloc,
            ];
        }
        if (!is_null($lastIdxWithPrice)) {
            $shares[$lastIdxWithPrice]['manual_taxable_yen'] =
                $totalAfterDeduction - $allocated;    
        }

        return [
            'mode'               => 'manual',
            'sum_kyen'           => $sumKyen,
            'shares'             => $shares,
            
            // 合計は T = max(0, Σ(P_i + G_i) − 基礎控除)
            'total_taxable_yen'  => $totalAfterDeduction, // 返すと後段が楽
        ];
    }

    /**
     * 暦年贈与税額控除（3年/改正後ルックバック） recipientごと（円）
     */
    private function calcGiftTaxCreditsByRecipient(int $dataId, \DateTimeImmutable $deathDate, array $targetIdxList = []): array
    {
        $result = [];
        for ($i = 2; $i <= 10; $i++) $result[$i] = ['calendar_yen' => 0, 'total_yen' => 0];


        // ★「課税価格の取得がある人」フィルタ（未定義変数エラー防止）
        //   targetIdxList が空ならフィルタ無し（従来互換）
        $targetSet = [];
        foreach ($targetIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) {
                $targetSet[$i] = true;
            }
        }
        $hasTargetFilter = !empty($targetSet);


        [$rangeStart, $rangeEnd] = $this->determineCalendarGiftLookbackRange($deathDate);

        $rows = PastGiftCalendarEntry::query()
            ->where('data_id', $dataId)
            ->get(['recipient_no','gift_year','gift_month','gift_day','tax_thousand']);

        foreach ($rows as $r) {
            $no  = (int)$r->recipient_no;
            $tax = (int)($r->tax_thousand ?? 0);
            if ($no < 2 || $no > 10 || $tax <= 0) continue;
            // ★課税価格の取得が無い人は、贈与税額控除の対象外
            if ($hasTargetFilter && !isset($targetSet[$no])) continue;
            try {
                $gd = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', (int)$r->gift_year, (int)$r->gift_month, (int)$r->gift_day));
            } catch (\Throwable $e) { continue; }
            if ($gd >= $rangeStart && $gd <= $rangeEnd) {
                $result[$no]['calendar_yen'] += $this->toYen($tax);
            }
        }

        foreach ($result as $no => $v) {
            $result[$no]['total_yen'] = $v['calendar_yen'];
        }
        
        
        return $result;
    }


    /**
     * （拡張版）贈与税額控除（暦年）に仮想（将来）贈与分の“税額”を合算
     * - buildVirtualGiftsIndex() で作った $virtual から、対象死亡日キーの calendar_tax を取り出して合算する
     * - 返却形式は calcGiftTaxCreditsByRecipient() と同一（['calendar_yen','total_yen']）
     */
    private function calcGiftTaxCreditsByRecipientWithVirtual(
        int $dataId,
        \DateTimeImmutable $deathDate,
        array $virtual,
        array $targetIdxList = []
    ): array {

        // 1) まず既存（過去贈与＝PastGiftCalendarEntry 由来）の控除額をベースとして取得
        $base = $this->calcGiftTaxCreditsByRecipient($dataId, $deathDate, $targetIdxList);

        $targetSet = [];
        foreach ($targetIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) $targetSet[$i] = true;
        }
        $hasTargetFilter = !empty($targetSet);

        // 2) 対象死亡日の仮想インデックスを取得（無ければ空配列で扱う）
        $key = $deathDate->format('Y-m-d');
        $v   = $virtual[$key] ?? [
            'calendar_tax' => [],
        ];


        // 3) virtual の calendar_tax（将来贈与分の暦年贈与税額）をマージ
        //    - recipient_no = 2〜10 のみ対象（UI上の受贈者2〜10）
        //    - DB 由来の calendar_yen に“足し込み”する
        foreach (($v['calendar_tax'] ?? []) as $no => $yen) {
            $idx = (int)$no;
            if ($idx < 2 || $idx > 10) {
                continue;
            }
            if ($hasTargetFilter && !isset($targetSet[$idx])) {
                continue;
            }
            if (!isset($base[$idx])) {
                // 過去分が無い受贈者（No.7・8 など「これからの贈与」専用）用の器を用意
                $base[$idx] = [
                    'calendar_yen' => 0,
                    'total_yen'    => 0,
                ];
            }
            // virtual 側は既に「円」単位なので、そのまま加算
            $base[$idx]['calendar_yen'] += max(0, (int)$yen);
        }

        // 4) total_yen フィールドを calendar_yen で上書き整合
        foreach ($base as $no => $rec) {
            $base[$no]['total_yen'] = (int)($rec['calendar_yen'] ?? 0);
        }

        /*
        // ★デバッグ：virtual マージ後の暦年贈与税額控除をログ
        Log::info('[ZouyotaxCalc][gift_tax_credits_with_virtual]', [
            'death_date' => $deathDate->format('Y-m-d'),
            'credits'    => $base,
        ]);
        */



        return $base;

    }




    /** 実取得額（円） */
    private function resolveActualShareYenForIdx(array $payload, int $idx, int $estateYen, float $legalRatio): int
    {
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        if ($mode === 'manual') {
            $kyen = $this->readKyen($payload, 'id_taxable_manu', $idx);
            if ($kyen > 0) return $this->toYen($kyen);
        }
        return (int)round($estateYen * $legalRatio);
    }

    /** 精算課税の贈与税額（円）：recipientごと */
    private function calcSettlementGiftTaxesByRecipient(int $dataId, array $targetIdxList = []): array
    {
        $out = [];
        for ($i = 2; $i <= 10; $i++) $out[$i] = 0;

        $targetSet = [];
        foreach ($targetIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) $targetSet[$i] = true;
        }
        $hasTargetFilter = !empty($targetSet);


        $rows = PastGiftSettlementEntry::query()
            ->where('data_id', $dataId)
            ->get(['recipient_no','tax_thousand']);

        foreach ($rows as $r) {
            $no  = (int)$r->recipient_no;
            $tax = max(0, (int)($r->tax_thousand ?? 0));
            if ($no >= 2 && $no <= 10 && $tax > 0) {
                $out[$no] += $this->toYen($tax);
            }
        }
        return $out;
    }
    
    
    /** （拡張版）精算課税の贈与税（仮想分も加算） */
    private function calcSettlementGiftTaxesByRecipientWithVirtual(
        int $dataId,
        array $virtual,
        \DateTimeImmutable $deathDate,
        array $targetIdxList = []
    ): array {
        $base = $this->calcSettlementGiftTaxesByRecipient($dataId, $targetIdxList);
        $v = $virtual[$deathDate->format('Y-m-d')] ?? ['settlement_tax'=>[]];


        foreach (($v['settlement_tax'] ?? []) as $no => $yen) {
            $idx = (int)$no;
            if ($idx >= 2 && $idx <= 10) {
                $base[$idx] += max(0, (int)$yen);
            }

        }
        return $base;
    }

    

    /**
     * 任意の年（estate/date指定）でフル計算
     * - 上位で構築済みの heirs / basicDeduction / brackets を使う
     */
    private function computeForGivenEstateAndDate(
        int $t,
        array $payload,
        array $heirs,
        int $basicDeduction,
        int $estateYen,
        \DateTimeImmutable $deathDate,
        array $brackets,
        string $context = 'before_proj',
        // ★ after_virtual のときだけ将来贈与(virtual)を使う
        array $virtual = [],
        // ★ after_virtual のときだけ「贈与後遺産（=減額後の遺産）」を明示的に渡す（分割対象を減額後へ統一）
        ?int $estateAfterYenForAlloc = null
    ): array {

        // ★ 現行仕様：compute() と同じく data_id=1 固定でプロジェクションも評価する
        $dataId = 1;


        // ★年次でも「課税価格の取得がある人」を統一して使用（manual/auto）
        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);


        // 6-1 前に：相続人別の贈与加算（参考値）を算出
        // ★ context に応じて「将来贈与分を含める／含めない」を切替
        //   virtual は "empty()" ではなく「キーが存在する」場合に有効とみなす
        $virtualKey = $deathDate->format('Y-m-d');
        $hasVirtual = (is_array($virtual) && array_key_exists($virtualKey, $virtual));

        if ($context === 'after_virtual' && $hasVirtual) {
            $giftIncl = $this->calcPastGiftsIncludedInEstateByRecipientWithVirtual(
                $dataId,
                $deathDate,
                $taxableAcquirerIdxList,
                $virtual
            );
        } else {
            $giftIncl = $this->calcPastGiftsIncludedInEstateByRecipient(
                $dataId,
                $deathDate,
                $taxableAcquirerIdxList
            );
        }

        // ★課税価格（kazei_price_yen）と「贈与後遺産（=将来贈与の現金流出控除後）」を分離して扱う
        //   - after_virtual では $estateYen は「贈与後遺産（控除後）」として受け取る
        //   - before_proj   では $estateYen は従来どおり「贈与算入込みの課税価格」として受け取る
        $inclCalForAlloc = (int)($giftIncl['calendar_total_yen']   ?? 0);
        $inclSetForAlloc = (int)($giftIncl['settlement_total_yen'] ?? 0);

        if ($context === 'after_virtual') {
            // 将来贈与の現金流出控除後の遺産（=贈与後遺産）
            $estateAfterYen = $estateAfterYenForAlloc !== null ? (int)$estateAfterYenForAlloc : (int)$estateYen;
            if ($estateAfterYen < 0) $estateAfterYen = 0;
            // 課税価格 = 贈与後遺産 +（暦年算入＋精算算入）
            $kazeiPriceYen = $estateAfterYen + $inclCalForAlloc + $inclSetForAlloc;
        } else {
            // 従来互換：estateYen を課税価格として扱う（結果として kazeiPriceYen = estateYen）
            $kazeiPriceYen = max(0, (int)$estateYen);
            // 参考：贈与算入を差し引いた「遺産本体」
            $estateAfterYen = max(0, $kazeiPriceYen - $inclCalForAlloc - $inclSetForAlloc);
        }

        // 課税遺産総額 = 課税価格 − 基礎控除
        $taxableEstate     = max(0, $kazeiPriceYen - $basicDeduction);
        $taxableEstateUsed = $taxableEstate;




        $totalRatio = 0.0;
        foreach ($heirs as $h) {
            $totalRatio += $this->civilRatio($h); // ★民法上の法定相続割合
        }
        $totalRatio = $totalRatio > 0 ? $totalRatio : 1.0;

        // 6-1 前に：相続人別の贈与加算（参考値）を算出
        // ★ context に応じて「将来贈与分を含める／含めない」を切替
        
        // （giftIncl は上で context に応じて解決済み）
        $virtualCalendarIncluded = [];
        if (!empty($virtual)) {
            $key = $deathDate->format('Y-m-d');
            $virtualCalendarIncluded = $virtual[$key]['calendar_included'] ?? [];
        }

        
        /*
        Log::info('[ZouyotaxCalc][incl_cal_projection]', [
            'context'                    => $context,                    // 'before_proj' / 'after_virtual'
            't'                          => $t,                          // 0〜20 年
            'death_date'                 => $deathDate->format('Y-m-d'),
            'calendar_total_yen'         => (int)($giftIncl['calendar_total_yen'] ?? 0),
            'calendar_per_idx'           => $giftIncl['calendar_per_idx'] ?? [],
            'virtual_calendar_included'  => $virtualCalendarIncluded,
        ]);
        */

        // manual 表示用：各人の課税価格 P_i（千円）→ 円へ（比率算出などで利用）
        //  ※ただし年次プロジェクションでは「総額の速算ベース」は常に auto 計算にする。
        //    （資金運用利回りで増えた課税価格の総額を、t=0 の比率で横展開するため）
        $manualShares = $this->buildManualTaxableShares($payload, $basicDeduction, $giftIncl['per_idx'] ?? []);

        // ★プロジェクション用の課税遺産総額（速算ベース）
        //   - before_proj : estateYen - basicDeduction
        //   - after_virtual: 上で定義した「課税価格ベース」の taxableEstate
        $taxableEstateUsed = $taxableEstate;




        $legalShareRows = [];
        $totalLegalShareTax = 0;
        foreach ($heirs as $h) {
            $legalRatio     = ($this->civilRatio($h)) / $totalRatio; // ★民法上の法定相続割合で按分

            // ★ 速算ベースはループ前で確定させた $taxableEstateUsed
            $legalShareBase = (int)round($taxableEstateUsed * $legalRatio);

            $legalTax       = $this->applyInheritanceTable($legalShareBase, $brackets);

            $totalLegalShareTax += $legalTax;

            $legalShareRows[$h['idx']] = [
                'legal_ratio'     => $legalRatio,
                'legal_share_yen' => $legalShareBase,
                'legal_tax_yen'   => $legalTax,

                // 表示・保持用（税務上）
                'bunsi'           => (int)($h['bunsi'] ?? 0),
                'bunbo'           => (int)($h['bunbo'] ?? 1),
                // ★民法上（参考として持っておく）
                'civil_bunsi'     => (int)($h['civil_bunsi'] ?? 0),
                'civil_bunbo'     => (int)($h['civil_bunbo'] ?? 1),

                'two_tenths'      => (bool)$h['two_tenths'],
                'rel_code'        => (int)($h['rel_code'] ?? 0),
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$h['idx']] ?? 0),
             ];
        }

        // あん分割合（t=0 時点の入力に基づく固定比率：manual/auto）
        // 　→ これは「ベース財産（贈与加算前）の割り振り比率」として各年共通で使う
        $anbun = $this->buildAnbunRatios($payload, $heirs, $legalShareRows);
        $anbunMode      = $anbun['mode'];
        $anbunRatios    = $anbun['ratios'];   // idx => base ratio（t=0 由来）
        $anbunTotalKyen = $anbun['total_kyen'];

        // ★ この年の「贈与加算前ベース資産」を推定
        //   - 課税価格 kazei_price_yen は
        //       kazei = estate_after_yen + incl_calendar_yen + incl_settlement_yen
        //     という構造なので、
        //       estate_after_yen ≒ kazei_price_yen − (暦年算入＋精算算入)
        //     とみなしてベース資産を復元する。
        $inclCalForAlloc = (int)($giftIncl['calendar_total_yen']   ?? 0);
        $inclSetForAlloc = (int)($giftIncl['settlement_total_yen'] ?? 0);


        // ★ この年の「実際に贈与した額」を推定
        //   実際の贈与額は、加算額ではなく、実際に贈与された金額（贈与後に計算された額）を使用する

// ▼ 暦年贈与の年次合計（千円）は「保存済みのDB（FutureGiftPlanEntry）」から取得（必須要件）
$calAmountByYearK = $this->readSavedFutureCalAmountByYearK($dataId); // [1..20]=>千円
if (empty($calAmountByYearK)) {
    // フォールバック：どうしてもDBに見つからない場合のみ、POST値を使用
    $calAmountByYearK = $this->readPlanKyenArrayAllRecipients($payload, 'cal_amount');
}

// 年次単位の暦年課税（cal_amount）の金額取得（千円）
$sumCalAmountK = function(int $t) use ($calAmountByYearK): int {
    // 特定の年の贈与額を取得する（累計ではなくその年のみ）
    return isset($calAmountByYearK[$t]) ? (int)$calAmountByYearK[$t] : 0;
};

// 精算課税（set_amount）の年次合計（千円）
$setAmountByYearK = $this->readSavedFutureSetAmountByYearK($dataId);
if (empty($setAmountByYearK)) {
    $setAmountByYearK = $this->readPlanKyenArrayAllRecipients($payload, 'set_amount');
}

// 年次単位の精算課税（set_amount）の金額取得（千円）
$sumSetAmountK = function(int $t) use ($setAmountByYearK): int {
    // 特定の年の贈与額を取得する（累計ではなくその年のみ）
    return isset($setAmountByYearK[$t]) ? (int)$setAmountByYearK[$t] : 0;
};

// 実際に贈与された金額の累計（t年次までの累計額）
$actualGiftAmountForAlloc = 0; // 初期化

// t年次までの累計額を計算
for ($i = 0; $i <= $t; $i++) {
    $actualGiftAmountForAlloc += $sumCalAmountK($i) * 1000 + $sumSetAmountK($i) * 1000; // 累計で加算
}

// ★ 分割対象は「減額後（贈与後）の遺産」をベースにする
//   after_virtual の場合：computeScenarioForGivenDate() で算出した estateAfter（贈与後遺産）を優先
//   それ以外：従来通り「課税価格 − 実際に贈与した額」で復元
//if ($context === 'after_virtual' && $estateAfterYenForAlloc !== null) {
//    // 実際に贈与した額を反映させた状態で復元
//    $estateBaseForAlloc = max(0, (int)$estateAfterYenForAlloc);
//} else {

        // ▼ 被相続人(行1)を含む、初期表示用の所有財産をDBから取得（単位：千円）
        $prefillFamily = [];
        $rows = ProposalFamilyMember::query()
            ->where('data_id', $dataId)
            ->whereBetween('row_no', [1, 10])
            ->get(['row_no', 'property_thousand', 'cash_thousand']);

        foreach ($rows as $r) {
            $rn = (int)($r->row_no ?? 0);
            if ($rn < 1 || $rn > 10) continue;
            $prefillFamily[$rn] = [
                // Bladeの property[1] は「千円」想定なので thousand をそのまま渡す
                'property' => (int)($r->property_thousand ?? 0),
                'cash'     => (int)($r->cash_thousand ?? 0),
            ];
        }

        //2025.12.15 00001
        $base    = (int)($prefillFamily[1]['property'] ?? 0) * 1000;


    // 実際に贈与した額を減算する
    //$estateBaseForAlloc = $kazeiPriceYen - $actualGiftAmountForAlloc;
    $estateBaseForAlloc = $base - $actualGiftAmountForAlloc;
    if ($estateBaseForAlloc < 0) {
        $estateBaseForAlloc = 0;
    }
//}


            /*
            Log::DEBUG('2025.12.12 100001 ', [
                't' => $t,
                'context' => $context,
                'kazeiPriceYen' => $kazeiPriceYen,
                'actualGiftAmountForAlloc' => $actualGiftAmountForAlloc,
                'inclCalForAlloc' => $inclCalForAlloc,
                'inclSetForAlloc' => $inclSetForAlloc,
                'estateBaseForAlloc'        => $estateBaseForAlloc,
            ]);
            */



            /*
            Log::info('20000_[ZouyotaxCalc][before_proj_per_idx]', [
                'idx'        => $idx,
                'manualKyen' => $manualKyen, // manual 時のみ実値、auto 時は 0
                '$price'     => $price,
            ]);
            */

        // ------------------------------------------------------------
        // ★ 各人の「生前贈与加算後の課税価格」P_i(t) を作る
        //   P_i(t) = （贈与加算前の遺産部分を“民法上の法定相続割合”で按分した額）＋（その人の生前贈与加算）
        //   ※ auto の anbunRatios は legal_ratio（bunsi/bunbo 正規化）= 民法上法定相続割合
        // ------------------------------------------------------------
        $priceForRatioByIdx = [];
        $sumPriceForRatio   = 0;
        $lastIdxWithPrice   = null;
        // ★「遺産按分に参加している人（baseRatio>0）」の最後（diff寄せ先）
        $lastIdxWithEstateShare = null;

        // ------------------------------------------------------------
        // ① 遺産部分（estateBaseForAlloc）を baseRatio>0 の人だけで 100% 按分する
        //    ※ baseRatio の合計が 1 とは限らないので、正規化してから配分する
        //    ※ 端数は最後の遺産按分参加者へ寄せる（合計が必ず estateBaseForAlloc になる）
        // ------------------------------------------------------------
        $sumBaseRatios = 0.0;
        for ($idx = 2; $idx <= 10; $idx++) {
            $r = (float)($anbunRatios[$idx] ?? 0.0);
            if ($r > 0) $sumBaseRatios += $r;
        }
        if ($sumBaseRatios <= 0) {
            $sumBaseRatios = 1.0; // ゼロ除算ガード（遺産按分参加者が誰もいない場合）
        }

        $baseShareYenByIdx = [];
        $allocatedBase = 0;
        for ($idx = 2; $idx <= 10; $idx++) {
            $baseRatio = (float)($anbunRatios[$idx] ?? 0.0);
            if ($baseRatio <= 0) {
                $baseShareYenByIdx[$idx] = 0;
                continue;
            }
            $norm = $baseRatio / $sumBaseRatios;
            // floor で配分して最後に端数調整
            $share = (int)floor($estateBaseForAlloc * $norm);
            $baseShareYenByIdx[$idx] = $share;
            $allocatedBase += $share;
            $lastIdxWithEstateShare = $idx;
        }
        // 端数を最後の遺産按分参加者へ寄せる（合計=estateBaseForAlloc）
        if ($lastIdxWithEstateShare !== null) {
            $baseShareYenByIdx[$lastIdxWithEstateShare] =
                (int)($baseShareYenByIdx[$lastIdxWithEstateShare] ?? 0) + ($estateBaseForAlloc - $allocatedBase);
        }


        for ($idx = 2; $idx <= 10; $idx++) {
            $baseRatio = (float)($anbunRatios[$idx] ?? 0.0);

            // ② 遺産部分（贈与加算前・贈与後遺産）は上で確定した按分額を使用
            //    baseRatio<=0 の人は 0（=贈与分だけで P_i(t) を持たせる）
            $baseShareYen = (int)($baseShareYenByIdx[$idx] ?? 0);

            // その人の生前贈与加算（暦年＋精算）
            $giftYen = (int)($giftIncl['per_idx'][$idx] ?? 0);

            $price = max(0, $baseShareYen + $giftYen);
            if ($price <= 0) {
                continue;
            }

            $priceForRatioByIdx[$idx] = $price;
            $sumPriceForRatio        += $price;
            $lastIdxWithPrice         = $idx;


            if ($t === 1 ){
                Log::DEBUG('2025.12.15 100000 ', [
                    't' => $t,
                    'idx' => $idx,
                    'base' => $base,
                    'kazeiPriceYen' => $kazeiPriceYen,
                    'estateBaseForAlloc' => $estateBaseForAlloc,
                    'baseRatio' => $baseRatio,
                    'giftYen' => $giftYen,
                    
                ]);
            }

        }


        // ★重要：ここで「合計P_i(t) を kazeiPriceYen に強制一致」させない
        //   あなたの仕様では遺産按分のベースは estateBaseForAlloc であり、
        //   kazeiPriceYen との差は「贈与による現金流出」等の別概念が混ざるため。

        // ★ 課税価格に基づく「その年のあん分比率」
        $anbunRatiosForYear = [];
        if ($sumPriceForRatio > 0) {
            foreach ($priceForRatioByIdx as $idx => $price) {
                $anbunRatiosForYear[$idx] = $price / $sumPriceForRatio;
            }
        } else {
            // 万一すべて 0 なら、従来どおり t=0 の比率をそのまま使用
            $anbunRatiosForYear = $anbunRatios;
        }

        // ★ この年(t)の「各相続人の生前贈与後の課税価格 P_i(t)」を per_idx として保持
        //   Blade 側では projections.after[t]['per_idx'][$idx]['price_for_ratio'] から参照できる
        $perIdx = [];
        for ($idx = 2; $idx <= 10; $idx++) {
            $perIdx[$idx] = [
                'price_for_ratio' => (int)($priceForRatioByIdx[$idx] ?? 0),
            ];
        }


        // 贈与控除関係
        //  before_proj: 過去贈与のみ（従来どおり）
        //  after_virtual: 過去＋これからの贈与（virtual）を含めた控除額を使用

        // ★ virtual は "empty()" ではなく「キーが存在する」場合に有効とみなす（上と同じキーを再利用）
        $virtualKey = $deathDate->format('Y-m-d');
        $hasVirtual = (is_array($virtual) && array_key_exists($virtualKey, $virtual));

        if ($context === 'after_virtual' && $hasVirtual) {
            $giftTaxCredits      = $this->calcGiftTaxCreditsByRecipientWithVirtual(
                $dataId, $deathDate, $virtual, $taxableAcquirerIdxList
            );
            $settlementGiftTaxes = $this->calcSettlementGiftTaxesByRecipientWithVirtual(
                $dataId, $virtual, $deathDate, $taxableAcquirerIdxList
            );
        } else {
            $giftTaxCredits      = $this->calcGiftTaxCreditsByRecipient($dataId, $deathDate, $taxableAcquirerIdxList);
            $settlementGiftTaxes = $this->calcSettlementGiftTaxesByRecipient($dataId, $taxableAcquirerIdxList);
        }

        // 個別集計（projection でも idx=2..10 全員を対象）
        $finalTotalAfterSurcharge  = 0;
        $totalGiftTaxCredits       = 0;
        $totalPayableAfterCredits  = 0;
        $totalSpouseRelief         = 0;
        $totalPayableAfterSpouse   = 0;
        $totalOtherCredits         = 0;
        $totalPayableAfterOthers   = 0;
        $totalSashihikiTax         = 0;
        $totalSettlementGiftTaxes  = 0;
        $totalFinalAfterSettlement = 0;

        // 法定相続人マップ（rel_code / legal_ratio 等を引くため）
        $heirMap = [];
        foreach ($heirs as $h) {
            $idx = $h['idx'];
            $heirMap[$idx] = [
                'rel_code'        => (int)($h['rel_code'] ?? 0),
                'bunsi'           => (int)$h['bunsi'],
                'bunbo'           => (int)$h['bunbo'],
                'legal_ratio'     => $legalShareRows[$idx]['legal_ratio']     ?? 0.0,
                'legal_share_yen' => $legalShareRows[$idx]['legal_share_yen'] ?? 0,
                'legal_tax_yen'   => $legalShareRows[$idx]['legal_tax_yen']   ?? 0,
            ];
        }

        $breakdown = [];
        for ($idx = 2; $idx <= 10; $idx++) {
            $isHeir  = isset($heirMap[$idx]);
            $relCode = $heirMap[$idx]['rel_code'] ?? 0;

            // ★ この年の課税価格に基づくあん分割合（ベース比率＋その年の贈与加算を反映）
            $anbunRatio = (float)($anbunRatiosForYear[$idx] ?? 0.0);

            // 算出税額：相続税総額 × その年のあん分割合
            $sanzutsu = (int)round($totalLegalShareTax * $anbunRatio);

            // 2割加算（チェックボックスで判定：法定相続人限定ではない）
            $twoTenths = $this->checkboxOn($payload, 'twenty_percent_add', $idx);
            $finalTax  = $twoTenths ? (int)round($sanzutsu * 1.2) : $sanzutsu;
            $finalTotalAfterSurcharge += $finalTax;


            /*
            // ★ 年次プロジェクション用：各人ごとの算出税額と2割加算後税額をログ出力
            //   context に応じて「before / after」を識別
                Log::info('20001_[ZouyotaxCalc][' . $context . '_per_idx]', [
                    't'                 => $t,
                    'estate_yen'        => $estateYen,
                    'idx'               => $idx,
                    'is_heir'           => $isHeir,
                    'base_ratio_t0'     => (float)($anbunRatios[$idx] ?? 0.0),
                    'anbun_ratio'       => $anbunRatio,   // その年の課税価格ベース比率
                    'price_for_ratio'   => $priceForRatioByIdx[$idx] ?? null,
                    'sanzutsu'          => $sanzutsu,
                    'two_tenths'        => $twoTenths,
                    'final_tax'         => $finalTax,
                ]);
            */

            // 暦年贈与税額控除
            $creditCalendar  = (int)($giftTaxCredits[$idx]['calendar_yen'] ?? 0);
            $payAfterCalCred = max(0, $finalTax - max(0, $creditCalendar));
            $totalGiftTaxCredits      += min($finalTax, max(0, $creditCalendar));
            $totalPayableAfterCredits += $payAfterCalCred;

            // 配偶者軽減
            $spouseRelief   = 0;
            $payAfterSpouse = $payAfterCalCred;
            if ($isHeir && in_array($relCode, [3,4], true) && $payAfterCalCred > 0) {
                $legalRatioForIdx = (float)($heirMap[$idx]['legal_ratio'] ?? 0.0);
                $actualShareYen   = $this->resolveActualShareYenForIdx($payload, $idx, $estateAfterYen, $legalRatioForIdx);
                $legalAmountYen   = (int)round($estateAfterYen * $legalRatioForIdx);
                $targetBaseYen    = min($actualShareYen, max($legalAmountYen, 160_000_000));
                if ($actualShareYen > 0 && $targetBaseYen > 0) {
                    $spouseRelief = (int)floor($payAfterCalCred * ($targetBaseYen / $actualShareYen));
                    if ($spouseRelief > $payAfterCalCred) $spouseRelief = $payAfterCalCred;
                    if ($spouseRelief < 0) $spouseRelief = 0;
                    $payAfterSpouse = $payAfterCalCred - $spouseRelief;
                }
            }
            $totalSpouseRelief       += $spouseRelief;
            $totalPayableAfterSpouse += $payAfterSpouse;

            // その他控除
            $otherCreditYen = $this->toYen($this->readKyen($payload, 'id_other_credit', $idx));
            if ($otherCreditYen < 0) $otherCreditYen = 0;
            $payAfterOthers = max(0, $payAfterSpouse - $otherCreditYen);
            $totalOtherCredits       += min($payAfterSpouse, $otherCreditYen);
            $totalPayableAfterOthers += $payAfterOthers;

            // 差引税額
            $sashihikiTax = $payAfterOthers;
            $totalSashihikiTax += $sashihikiTax;

            // 精算課税贈与税控除
            $settlementGiftTaxYen = (int)($settlementGiftTaxes[$idx] ?? 0);
            $finalAfterSettlement = $sashihikiTax - max(0, $settlementGiftTaxYen);
            $totalSettlementGiftTaxes  += max(0, $settlementGiftTaxYen);
            $totalFinalAfterSettlement += $finalAfterSettlement;

            $breakdown[] = [
                'row_index'   => $idx,
                'bunsi'       => $isHeir ? ($heirMap[$idx]['bunsi'] ?? 0) : 0,
                'bunbo'       => $isHeir ? ($heirMap[$idx]['bunbo'] ?? 1) : 1,
                'legal_ratio' => $heirMap[$idx]['legal_ratio']     ?? 0.0,
                'legal_share_yen' => $heirMap[$idx]['legal_share_yen'] ?? 0,
                'legal_tax_yen'   => $heirMap[$idx]['legal_tax_yen']   ?? 0,
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$idx] ?? 0),
                'anbun_ratio'     => $anbunRatio,
                'sanzutsu_tax_yen'=> $sanzutsu,
                'final_tax_yen'   => $finalTax,
                'two_tenths_added'=> $twoTenths,
                'is_spouse'       => $isHeir ? in_array($relCode, [3,4], true) : false,
                'gift_tax_credit_calendar_yen'      => max(0, $creditCalendar),
                'payable_after_calendar_credit_yen' => $payAfterCalCred,
                'spouse_relief_yen'  => $spouseRelief,
                'payable_after_spouse_yen' => $payAfterSpouse,
                'other_credit_yen'   => $otherCreditYen,
                'payable_after_others_yen' => $payAfterOthers,
                'sashihiki_tax_yen'  => $sashihikiTax,
                'settlement_gift_tax_yen' => max(0, $settlementGiftTaxYen),
                'final_after_settlement_yen' => $finalAfterSettlement,
                'payable_tax_yen' => $finalAfterSettlement > 0 ? $finalAfterSettlement : 0,
                'refund_tax_yen'  => $finalAfterSettlement < 0 ? abs($finalAfterSettlement) : 0,
            ];
        }


        
        // ★ デバッグ用：年次プロジェクション用の税額フローをログ出力
        //   いったん「対策前（before_proj）のときだけ」出力する
        if ($context === 'before_proj') {
            
            /*
            Log::info('[ZouyotaxCalc][before_proj_tax_flow]', [
                'context'                       => $context,
                't'                             => $t,
                'estate_yen'                    => $estateYen,
                'basic_deduction'               => $basicDeduction,
                'taxable_estate_used'           => $taxableEstateUsed,
                'total_legal_share_tax'         => $totalLegalShareTax,
                'total_after_surcharge'         => $finalTotalAfterSurcharge,
                'total_gift_tax_credits'        => $totalGiftTaxCredits,
                'total_pay_after_calendar'      => $totalPayableAfterCredits,
                'total_spouse_relief'           => $totalSpouseRelief,
                'total_pay_after_spouse'        => $totalPayableAfterSpouse,
                'total_other_credits'           => $totalOtherCredits,
                'total_pay_after_others'        => $totalPayableAfterOthers,
                'total_sashihiki_tax'           => $totalSashihikiTax,
                'total_settlement_gift_taxes'   => $totalSettlementGiftTaxes,
                'total_final_after_settlement'  => $totalFinalAfterSettlement,
                // 念のため、2割加算・配偶者軽減対象の件数も見る
                'heirs_count'                   => count($heirs),
                'anbun_mode'                    => $anbunMode,
                'anbun_total_kyen'              => $anbunTotalKyen,
            ]);
            */
        } else {
            /*
            Log::info('[ZouyotaxCalc][after_proj_tax_flow]', [
                'context'                       => $context,
                't'                             => $t,
                'estate_yen'                    => $estateYen,
                'basic_deduction'               => $basicDeduction,
                'taxable_estate_used'           => $taxableEstateUsed,
                'total_legal_share_tax'         => $totalLegalShareTax,
                'total_after_surcharge'         => $finalTotalAfterSurcharge,
                'total_gift_tax_credits'        => $totalGiftTaxCredits,
                'total_pay_after_calendar'      => $totalPayableAfterCredits,
                'total_spouse_relief'           => $totalSpouseRelief,
                'total_pay_after_spouse'        => $totalPayableAfterSpouse,
                'total_other_credits'           => $totalOtherCredits,
                'total_pay_after_others'        => $totalPayableAfterOthers,
                'total_sashihiki_tax'           => $totalSashihikiTax,
                'total_settlement_gift_taxes'   => $totalSettlementGiftTaxes,
                'total_final_after_settlement'  => $totalFinalAfterSettlement,
                // 念のため、2割加算・配偶者軽減対象の件数も見る
                'heirs_count'                   => count($heirs),
                'anbun_mode'                    => $anbunMode,
                'anbun_total_kyen'              => $anbunTotalKyen,
            ]);
            */
            
        }


        /*
        // ★ 課税ベースの比較ログ：
        //   ・used       … 実際に速算表に使った taxableEstateUsed
        //   ・normalized … 「課税価格(kazei_price_yen) − 基礎控除」で計算した値
        
        if ($context == 'after_virtual'){
            Log::info('[DEBUG taxable compare]', [
                'context'        => $context,
                't'              => $t,
                'used'           => $taxableEstateUsed,
                // normalized … 「課税価格(kazei_price_yen) − 基礎控除」で計算した値
                'normalized'     => $taxableEstate,
                // estate_yen は after

            ]);
        }
        
        */
 
        

        return [
            'summary' => [
                'estate_yen'       => $estateYen,
                // ★ after_virtual のときは「贈与後遺産（将来贈与控除後）」を別キーでも明示
                'estate_after_yen' => $estateAfterYen,
                'basic_deduction'  => $basicDeduction,

                // 課税価格（after_virtual のときは estate_after + 贈与加算）
                'kazei_price_yen'  => $kazeiPriceYen,
                
                // 表示も統一（プロジェクションは estateYen に応じて毎年変動する課税遺産総額）
                'taxable_estate'                => $taxableEstateUsed,
                // 過年度贈与の算入額（暦年／精算）… 各年 t の lookback 結果
                'past_gift_included_total_yen'  => (int)($giftIncl['total_yen'] ?? 0),
                'past_gift_included_per_idx'    => $giftIncl['per_idx'] ?? [],
                'incl_calendar_yen'             => (int)($giftIncl['calendar_total_yen']   ?? 0),
                'incl_settlement_yen'           => (int)($giftIncl['settlement_total_yen'] ?? 0),
                'sozoku_tax_total'              => $totalLegalShareTax,
                'total_after_surcharge'         => $finalTotalAfterSurcharge,
                'total_gift_tax_credits'        => $totalGiftTaxCredits,
                'total_payable_after_calendar_credits' => $totalPayableAfterCredits,
                'total_spouse_relief' => $totalSpouseRelief,
                'total_payable_after_spouse' => $totalPayableAfterSpouse,
                'total_other_credits' => $totalOtherCredits,
                'total_payable_after_others'    => $totalPayableAfterOthers,
                'total_sashihiki_tax'           => $totalSashihikiTax,
                'total_settlement_gift_taxes'   => $totalSettlementGiftTaxes,
                'total_final_after_settlement'  => $totalFinalAfterSettlement,
                // ★最終相続税額（精算課税分控除後）＝画面表示用
                'final_after_settlement_yen'    => $totalFinalAfterSettlement,
                
            ],

            'heirs'   => $breakdown,
            // ★ 年次プロジェクション用：各相続人の課税価格 P_i(t)
            'per_idx' => $perIdx,

        ];
        
        
    }

    /**
     * 暦年課税の対象期間（開始日・終了日）を死亡日に応じて返す
     */
    private function determineCalendarGiftLookbackRange(\DateTimeImmutable $deathDate): array
    {
        $end        = $deathDate;
        $r8End      = new \DateTimeImmutable('2026-12-31');
        $r9Start    = new \DateTimeImmutable('2027-01-01');
        // ★改正特例期間を 2031-12-31 まで拡張
        $r12End     = new \DateTimeImmutable('2031-12-31');
        $fixedStart = new \DateTimeImmutable('2024-01-01');

        if ($deathDate <= $r8End) {
            // ～2026年死亡：従来どおり「死亡前3年」
            $start = $deathDate->sub(new \DateInterval('P3Y')); // 3年
            return [$start, $end];

        } elseif ($deathDate >= $r9Start && $deathDate <= $r12End) {
            // 2027-01-01 ～ 2031-12-31 死亡：
            //   暦年課税の算入期間は一律 2024-01-01 から死亡日まで
            return [$fixedStart, $end]; // 2024-01-01 ～ 当日

        } else {
            // 2032-01-01 以降死亡：一般ルールとして「死亡前7年」
            $start = $deathDate->sub(new \DateInterval('P7Y')); // 7年
            return [$start, $end];
        }
    }

    
    // ===== ここから「対策後」用の補助ロジック =====

    /** POSTから将来贈与プラン（暦年/精算）を読み出す（不正は自動スキップ） */
    private function extractFuturePlanFromPayload(array $payload): array
    {

        /*
        Log::info('[DEBUG cal_amount raw]', Arr::get($payload, 'cal_amount'));

        Log::info('[DEBUG futurePlan extract:start]', ['payload_keys'=>array_keys($payload)]);
        */

        // ★ 初期化（この2キーだけ固定）
        $out = ['calendar' => [], 'settlement' => []];

        // ------------------------------------------------------------
        // ① 将来贈与は payload ではなく DB の future_gift_plan_entries を唯一の正として扱う
        // ------------------------------------------------------------
        $dataId = (int)($payload['data_id'] ?? 1);

        $saved = FutureGiftPlanEntry::where('data_id', $dataId)
                   ->whereBetween('row_no', [1,20])
                   ->whereBetween('recipient_no', [2,10])
                   ->orderBy('row_no')
                   ->get();

        foreach ($saved as $r) {

            // 暦年贈与（calendar）
            if ((int)$r->calendar_amount_thousand > 0) {
                $out['calendar'][] = [
                    // ★重要：贈与日（DB保存値）を唯一の正として渡す
                    //   これが null のままだと buildVirtualGiftsIndex() 側で cash_out_total が積めず、
                    //   将来贈与の現金流出控除が効かない
                    'y' => $r->gift_year  ?? null,
                    'm' => $r->gift_month ?? null,
                    'd' => $r->gift_day   ?? null,
                    'no'=> (int)$r->recipient_no,
                    'amount_thousand' => (int)$r->calendar_amount_thousand,
                    // ★修正ポイント：
                    //   UI 側の cal_tax は FutureGiftPlanEntry.calendar_special_tax_thousand に保存されている。
                    //   従って、virtual 用の tax_thousand も calendar_special_tax_thousand から読む。
                    'tax_thousand'    => (int)$r->calendar_special_tax_thousand,
                    't' => (int)$r->row_no,
                ];
            }

            // 精算課税（settlement）
            if ((int)$r->settlement_amount_thousand > 0) {
                $out['settlement'][] = [
                    'y' => $r->gift_year ?? null,
                    'm' => $r->gift_month ?? null,
                    'd' => $r->gift_day ?? null,
                    'no'=> (int)$r->recipient_no,
                    'amount_thousand' => (int)$r->settlement_amount_thousand,
                    'settlement_tax20_thousand' => (int)$r->settlement_tax20_thousand,
                    't' => (int)$r->row_no,
                ];


                /*
                Log::debug('SET TAX CHECK', [
                    'entry_id' => $r->id,
                    'no'       => $r->recipient_no,
                    't'        => $r->row_no,
                    'sett_amount' => $r->settlement_amount_thousand,
                    'sett_tax'    => $r->settlement_tax20_thousand,
                ]);        
                */


            }
        }
        
        
            
        // ------------------------------------------------------------
        // ② 基準贈与日（future_base_*）
        // ------------------------------------------------------------
        $baseY = (int)Arr::get($payload, 'future_base_year', 0);
        $baseM = (int)Arr::get($payload, 'future_base_month', 0);
        $baseD = (int)Arr::get($payload, 'future_base_day', 0);

        // ★ base が未入力（0）でも動くようにフォールバック
        //   - まず DB 上の将来贈与（暦年/精算）の gift_year/month/day を探す
        //   - それでも無ければ “当年12/31” を使う（贈与日が未確定で控除が死ぬのを防ぐ）
        if ($baseY <= 0 || $baseM <= 0 || $baseD <= 0) {
            foreach (array_merge($out['calendar'] ?? [], $out['settlement'] ?? []) as $row) {
                $yy = (int)($row['y'] ?? 0);
                $mm = (int)($row['m'] ?? 0);
                $dd = (int)($row['d'] ?? 0);
                if ($yy >= 1900 && $mm >= 1 && $mm <= 12 && $dd >= 1 && $dd <= 31) {
                    $baseY = $yy; $baseM = $mm; $baseD = $dd;
                    break;
                }
            }
            if ($baseY <= 0) { $baseY = (int)date('Y'); }
            if ($baseM <= 0) { $baseM = 12; }
            if ($baseD <= 0) { $baseD = 31; }
        }


        $out['base'] = [
            'y' => $baseY,
            'm' => $baseM,
            'd' => $baseD,
        ];

        return $out;

    }

    /**
     * 将来贈与プランを「死亡日までに実施済みのもの」に限定し、
     * - 暦年：lookback算入分 / 暦年税額（控除用）
     * - 精算：全件算入 / 精算税額（控除用）
     * - 現金流出：全実施分の金額合計
     * を「死亡日文字列key」=> インデックスとして構築。
     */
     private function buildVirtualGiftsIndex(
         array $futurePlan,
         \DateTimeImmutable $deathDateT,
         array $pastIncluded,  // ← 過去贈与（calcPastGiftsIncluded... の結果）
         array $taxableIdxList = [], // ← ★課税価格の取得がある人のみ算入・控除の対象
         int $yearsAhead = 0          // ← ★プロジェクション年次 t（この年次まで実施済みの贈与だけを対象）
     ): array
    {
        $key = $deathDateT->format('Y-m-d');
        $idx = [$key => [
            'calendar_included' => [], // recipient_no => yen（lookback内）
            'calendar_tax'      => [], // recipient_no => yen（税額控除）
            'settlement_all'    => [], // recipient_no => yen（全件算入）
            'settlement_tax'    => [], // recipient_no => yen（税額控除）
            'cash_out_total'    => 0,  // 円（現金流出）
        ]];
        [$start, $end] = $this->determineCalendarGiftLookbackRange($deathDateT);

        $targetSet = [];
        foreach ($taxableIdxList as $v) {
            $i = (int)$v;
            if ($i >= 2 && $i <= 10) $targetSet[$i] = true;
        }
        $hasTargetFilter = !empty($targetSet);

        // ★修正：
        //   deathDateT は “その年の死亡日” として computeScenarioForGivenDate() から渡される値を
        //   そのまま使うべきであり、ここで上書きしてはいけない。
        //   → 上記ループは完全削除する。



        // 🎯 毎年の贈与日 = future_base_y + (t-1), base_month, base_day
        $base = $futurePlan['base'] ?? ['y'=>0,'m'=>0,'d'=>0];
        $baseY = (int)$base['y'];
        $baseM = (int)$base['m'];
        $baseD = (int)$base['d'];




        // 100万円控除用
        // ★ 正：3年超判定は「死亡日前◯年」で決定する（改正後は 4～7 年 へ自動延長）
        //   determineCalendarGiftLookbackRange() が「開始日(start)」は算入期間用に決めるが、
        //   控除判定は死亡日からの backwards 年数で行う必要がある。
        //   （2027～2031死亡は start=2024-01-01 だが、控除判定は死亡日前◯年）
        $threeYearsAgo = $deathDateT->sub(new \DateInterval('P3Y'));

        $newRuleStart  = new \DateTimeImmutable('2027-01-01');
        $useOneMillionExemption = ($deathDateT >= $newRuleStart);

        // ★受贈者ごとの「その死亡年における100万円控除適用フラグ」
        $used100mLocal = array_fill(2, 9, false);


        /**
         * ============================================================
         *  暦年贈与（将来贈与）
         *  ・贈与日は hidden の gift_year[i]/gift_month[i]/gift_day[i] を唯一の正として使用する
         *  ・t>=1 なら gift_year = base_year + (t-1)
         *  ・lookback に入る場合のみ算入
         *  ・3年超かつ death>=2027-01-01 の場合「100万円控除」
         * ============================================================
         */

        foreach ((array)$futurePlan['calendar'] as $r) {
            $rowNo = (int)($r['t'] ?? 0);
            if ($rowNo < 1) continue;
            // ★年次tまでに実施済みの贈与だけを対象（控除が確実に効くように）
            if ($yearsAhead >= 0 && $rowNo > $yearsAhead) {
                continue;
            }

            // 🎯 gift_date は FutureGiftPlanEntry に保存した値を唯一使用
            $giftY = (int)($r['y'] ?? 0);
            $giftM = (int)($r['m'] ?? 0);
            $giftD = (int)($r['d'] ?? 0);

            // ★ 万一 DB に日付がない（旧データ）場合は従来ロジックで補完
            if ($giftY <= 0 || $giftM <= 0 || $giftD <= 0) {
                $giftY = $baseY + ($rowNo - 1);
                $giftM = $baseM;
                $giftD = $baseD;
            }


            $no   = (int)($r['no'] ?? 0);
            $amtK = (int)($r['amount_thousand'] ?? 0); // 千円
            $taxK = (int)($r['tax_thousand'] ?? 0);    // 千円
            if ($no < 2 || $no > 10 || $amtK <= 0) {
                continue;
            }

            // ★重要：日付が取れなくても「現金流出（控除）」は必ず積む（控除が死なないように）
            $idx[$key]['cash_out_total'] += $this->toYen($amtK);

            // 日付が取れた場合のみ、算入/税額控除の判定に使う
            $giftDate = null;
            try {
                $giftDate = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $giftY, $giftM, $giftD));
            } catch (\Throwable $e) {
                $giftDate = null; // ← cash_out_total は積んだのでここでは落とさない
            }

            // ★修正：二重加算を削除（上で既に cash_out_total を積んでいる）
            // $idx[$key]['cash_out_total'] += $this->toYen($amtK);

            // ★日付が取れていて、かつ死亡日より後なら「未実施」扱いにして控除も巻き戻す
            if ($giftDate !== null && $giftDate > $deathDateT) {
                $idx[$key]['cash_out_total'] -= $this->toYen($amtK);
                continue;
            }

            // ★算入・税額控除は「課税価格の取得がある人のみ」
            if ($hasTargetFilter && !isset($targetSet[$no])) {
                continue;
            }


            // 日付が無い/壊れている場合は「算入・税額控除」はスキップ（控除だけは効く）
            if ($giftDate === null) {
                continue;
            }


            // ルックバック外は「課税価格への算入」はしない（現金流出だけ反映済み）
            if (!($giftDate >= $start && $giftDate <= $end)) {
                continue;
            }


            // ==========================
            // ★修正仕様：
            //   「過去贈与が無い受贈者だけ」将来贈与で 100 万円控除を 1 回だけ適用する
            //   過去贈与がある受贈者は virtual では控除しない
            // ==========================
        
            // ★修正：過去贈与の有無は「過去贈与算入結果」から判定する
            $pastCal  = (int)($pastIncluded['calendar_per_idx'][$no]   ?? 0);
            $pastSet  = (int)($pastIncluded['settlement_per_idx'][$no] ?? 0);
            $hasPastGift = ($pastCal > 0 || $pastSet > 0);


            if ($giftDate >= $threeYearsAgo) {
                // 3年以内 → 控除なし
                $includeK = $amtK;
        
            } else {
                // 3年超
                if ($useOneMillionExemption && !$hasPastGift) {
        
                    // 過去贈与が無い受贈者のみ 1 回だけ控除
                    if (!$used100mLocal[$no]) {
                        $includeK = max(0, $amtK - 1000);
                        $used100mLocal[$no] = true;
                    } else {
                        $includeK = $amtK; // 2回目以降は控除なし
                    }
        
                } else {
                    // 過去贈与がある受贈者 → virtual では控除しない
                    $includeK = $amtK;
                }
            }
        

            // 暦年贈与算入額（円）
            $idx[$key]['calendar_included'][$no]
                = ($idx[$key]['calendar_included'][$no] ?? 0)
                + $this->toYen($includeK);

            // 贈与税額控除（税額はそのまま）
            $idx[$key]['calendar_tax'][$no]
                = ($idx[$key]['calendar_tax'][$no] ?? 0)
                + $this->toYen($taxK);
        }

        
        // 精算（現金流出は全員 / 算入は全員 / 税額控除は別途ロジックで扱う）
        foreach ((array)$futurePlan['settlement'] as $r){
            $rowNo = (int)($r['t'] ?? 0);
            if ($rowNo < 1) continue;
            // ★年次tまでに実施済みの精算贈与だけを対象
            if ($yearsAhead >= 0 && $rowNo > $yearsAhead) {
                continue;
            }
            $no = (int)($r['no'] ?? 0);
            $amtK = (int)($r['amount_thousand'] ?? 0);
            if ($no < 2 || $no > 10 || $amtK <= 0) {
                continue;
            }

            // ★重要：精算も「現金流出（控除）」は日付に関係なく必ず積む
            $yen = $this->toYen($amtK);
            $idx[$key]['cash_out_total'] += max(0, $yen);

            // 日付が取れた場合のみ「死亡日以降は未実施」判定を行う（算入・税額控除の整合用）
            $gd = null;
            try {
                $yy = (int)($r['y'] ?? 0);
                $mm = (int)($r['m'] ?? 0);
                $dd = (int)($r['d'] ?? 0);
                if ($yy > 0 && $mm > 0 && $dd > 0) {
                    $gd = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', $yy, $mm, $dd));
                }
            } catch (\Throwable $e) {
                $gd = null;
            }
            if ($gd !== null && $gd > $deathDateT) {
                // 日付が明確に死亡日以降なら、控除に積んだ分も巻き戻して未実施扱い
                $idx[$key]['cash_out_total'] -= max(0, $yen);
                continue;
            }

            

        // ★ デバッグ：cash_out_total が 0 のままなら、将来贈与が「読めていない」か「金額が0」。
        Log::debug('[ZouyotaxCalc][virtual] built', [
            'key'          => $key,
            'yearsAhead'   => $yearsAhead,
            'cash_out_yen' => (int)($idx[$key]['cash_out_total'] ?? 0),
            'cal_count'    => count($futurePlan['calendar'] ?? []),
            'set_count'    => count($futurePlan['settlement'] ?? []),
        ]);
            
            // ★精算：現金流出は全員分
            // ★精算：算入・税額控除も「精算課税贈与を受けた人は全員」対象（課税価格取得の有無は問わない）

            $yenKasan = 0;
            
            // $yen は上で確定済み（控除にも使った）
            
               //2025.
               // 2024年以降の場合は1100000円を控除
               $giftYear = (int)substr($deathDateT->format('Y'), 0, 4);  // 贈与年を取得
               if ($giftYear >= 2024) {
                   $yenKasan = max(0, $yen - 1100000);  // 控除後の金額
                   //log::DEBUG('2025.12.10 50001 giftYear = '.$giftYear,['yen',$yenKasan]);
               }
            
            
            $taxYen = $this->toYen((int)($r['settlement_tax20_thousand'] ?? 0));


            $idx[$key]['settlement_all'][$no] = ($idx[$key]['settlement_all'][$no] ?? 0) + max(0,$yenKasan);
            $idx[$key]['settlement_tax'][$no] = ($idx[$key]['settlement_tax'][$no] ?? 0) + max(0,$taxYen);


        }
        
        
        /*
        // ★デバッグ：この死亡日に対して構築された virtual の暦年税額を確認
        Log::info('2025.12.15 10001 [ZouyotaxCalc][virtual_calendar_tax]', [
            'death_date'      => $deathDate->format('Y-m-d'),
            'calendar_tax'    => $idx[$key]['calendar_tax'] ?? [],
            'calendar_incl'   => $idx[$key]['calendar_included'] ?? [],
            'cash_out_total'  => $idx[$key]['cash_out_total'] ?? 0,
        ]);
        */
        


        
        return $idx;
    }

    /** 将来贈与で流出した現金を控除し（下限0）、法上の算入は別途足し戻す */
    private function applyFuturePlanToEstate(int $nonCashYen, int $cashYenGrown, array $virtualByDate, \DateTimeImmutable $deathDate): int    {
        $key = $deathDate->format('Y-m-d');
        $cashAfterGifts = max(0, $cashYenGrown - (int)($virtualByDate[$key]['cash_out_total'] ?? 0));
        // ★ 非現金 + 将来の現金（流出控除後）
        $estateAfter = $nonCashYen + $cashAfterGifts;

        // ★ デバッグ：控除が効いているかを最短で確認
        Log::debug('[ZouyotaxCalc][estate_after]', [
            'key'              => $key,
            'non_cash_yen'     => $nonCashYen,
            'cash_grown_yen'   => $cashYenGrown,
            'cash_out_yen'     => (int)($virtualByDate[$key]['cash_out_total'] ?? 0),
            'cash_after_yen'   => $cashAfterGifts,
            'estate_after_yen' => $estateAfter,
        ]);

        // ★ 非現金 + 将来の現金（流出控除後）
        return $estateAfter;
    }

    /** 共通シナリオ計算（対策前/対策後を切り替え） */
    private function computeScenario(
        array $payload,
        array $heirs,
        int $basicDeduction,
        int $propertyNonCashYen,
        int $cashNowYen,
        float $rate,
        \DateTimeImmutable $deathDate,
        array $brackets,
        array $futurePlan = [],
        bool $ignoreFuturePlanAtT0 = false
    ): array {
        $dataId = 1;

        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);


        // 現金の複利成長
        $cashGrown = $cashNowYen; // 今回は T=0 を想定（本体computeでは0年目 after）

        // ★ 贈与前（比較用）の遺産：非現金 + 成長後現金（t=0なので現金はそのまま）
        $estateBefore = $propertyNonCashYen + $cashGrown;
        

        // 将来贈与を考慮するかどうか（t=0 は無視、それ以外は futurePlan を反映）
        $useFuturePlan = !$ignoreFuturePlanAtT0 && !empty($futurePlan);
        
        if ($useFuturePlan) {
            // 将来贈与インデックス
            $pastOnly = $this->calcPastGiftsIncludedInEstateByRecipient($dataId, $deathDate, $taxableAcquirerIdxList);
            $virtual  = $this->buildVirtualGiftsIndex($futurePlan, $deathDate, $pastOnly, $taxableAcquirerIdxList, 0);

            // ベース遺産（将来贈与の現金流出を控除）
            // ★ 非現金 + 将来現金（流出控除後）
            $estateBase = $this->applyFuturePlanToEstate($propertyNonCashYen, $cashGrown, $virtual, $deathDate);

            // 過年度＋仮想（将来）分の算入
            $giftIncl = $this->calcPastGiftsIncludedInEstateByRecipientWithVirtual(
                $dataId, $deathDate, array_map(fn($h)=>$h['idx'], $heirs), $virtual
            );
        } else {
            // t=0 など「これからの贈与」を無視するケース：
            // ・ベース遺産＝非現金＋現時点の現金
            // ・相続財産に算入するのは過去贈与（PastGift*）のみ
            $virtual = [];
            $estateBase = $propertyNonCashYen + $cashGrown;
            $giftIncl = $this->calcPastGiftsIncludedInEstateByRecipient(
                $dataId,
                $deathDate,
                $taxableAcquirerIdxList
            );
        }

        // ★ 贈与後（実際の贈与額控除後）の遺産（= 相続財産の額のベース）
        $estateAfter = $estateBase;

        // 課税価格（相続税計算用の総額）= 贈与後遺産 +（過去＋将来の算入額）
        $estateYen = $estateAfter + (int)($giftIncl['total_yen'] ?? 0);

        // 以降は compute() 冒頭と同様
        $taxableEstate = max(0, $estateYen - $basicDeduction);

        // manual表示の取り扱い（贈与算入は per_idx を渡す）
        $manualShares = $this->buildManualTaxableShares($payload, $basicDeduction, $giftIncl['per_idx'] ?? []);
        $manualTotalTaxableYen = (int)($manualShares['total_taxable_yen'] ?? 0);
        $inputMode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));
        $isManualActive = ($inputMode === 'manual') && ($manualTotalTaxableYen > 0);
        $taxableEstateUsed = $isManualActive ? $manualTotalTaxableYen : $taxableEstate;

        // 法定分課税
        $totalRatio = 0.0; 
        foreach ($heirs as $h) {
            $totalRatio += $this->civilRatio($h); // ★民法上の法定相続割合
        } 
        
        $totalRatio = $totalRatio>0 ? $totalRatio : 1.0;
        $legalShareRows = []; $totalLegalShareTax = 0;

        foreach ($heirs as $h) {
            $legalRatio     = ($this->civilRatio($h)) / $totalRatio; // ★民法上の法定相続割合で按分
            $legalShareBase = (int)round($taxableEstateUsed * $legalRatio);
            $legalTax       = $this->applyInheritanceTable($legalShareBase, $brackets);
            $totalLegalShareTax += $legalTax;
            $legalShareRows[$h['idx']] = [
                'legal_ratio'     => $legalRatio,
                'legal_share_yen' => $legalShareBase,
                'legal_tax_yen'   => $legalTax,
                'bunsi'           => (int)$h['bunsi'],
                'bunbo'           => (int)$h['bunbo'],
                'two_tenths'      => (bool)($h['two_tenths'] ?? false),
                'rel_code'        => (int)($h['rel_code'] ?? 0),
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$h['idx']] ?? 0),
            ];
        }

        // あん分割合（t=0 時点の入力に基づく比率：manual/auto）
        //   → ここでは「ベース資産（贈与加算前）の割り振り比率」として使い、
        //     さらに「その年に算入される贈与分」を足した課税価格で最終比率を決める。
        $anbun = $this->buildAnbunRatios($payload, $heirs, $legalShareRows);
        $anbunMode      = $anbun['mode'];
        $anbunRatios    = $anbun['ratios'];   // idx => base ratio (t=0 由来)
        $anbunTotalKyen = $anbun['total_kyen'];

        // ★ この年(t=0)の「贈与加算前ベース資産」を推定
        //    estateYen = estateBaseForAlloc + 贈与算入額(total_yen) という構造なので、
        //    贈与分を差し引くことで「ベース資産部分」を取り出す。
        $estateBaseForAlloc = $estateYen - (int)($giftIncl['total_yen'] ?? 0);
        if ($estateBaseForAlloc < 0) {
            $estateBaseForAlloc = 0;
        }

        // ★ 各 idx(2..10) について、その年(t=0)の「課税価格」を算定
        //   課税価格 P_i(0) ＝ ベース資産シェア_i(0) ＋ その年に算入される贈与分_i(0)
        //   ※ manual モードでは非法定相続人も id_taxable_manu に応じて baseRatio が付くため、
        //      2〜10 行すべてを対象にする。
        $priceForRatioByIdx = [];
        $sumPriceForRatio   = 0;

        // ① まず t=0 の baseShareYen を再構築
        $baseShareYenByIdx = [];
        $sumBaseShare      = 0;
        for ($idx = 2; $idx <= 10; $idx++) {
            $ratio0 = (float)($anbunRatios[$idx] ?? 0.0);   // t=0 のベース比率（manual/auto）
            $bs     = (int)round($estateBaseForAlloc * $ratio0);
            $baseShareYenByIdx[$idx] = $bs;
            $sumBaseShare += $bs;
        }
        if ($sumBaseShare <= 0) {
            $sumBaseShare = 1; // ゼロ除算防止
        }

        // ② 比率（固定）を作る：baseShareRatio_i
        $baseShareRatio = [];
        for ($idx = 2; $idx <= 10; $idx++) {
            $baseShareRatio[$idx] = $baseShareYenByIdx[$idx] / $sumBaseShare;
        }


        for ($idx = 2; $idx <= 10; $idx++) {
            // t=0 の anbunRatios をベース資産の分割比率として利用（manual: id_taxable_manu 比率）

            // ★ 生前贈与加算額（暦年＋精算）
            $giftYen = (int)($giftIncl['per_idx'][$idx] ?? 0);

            // ★ 遺産部分（estateBase=贈与後遺産）をベース比率で按分
            $inheritPart = (int)round($estateBase * $baseShareRatio[$idx]);

            // ★ 課税価格 P_i(t)
            $price = max(0, $inheritPart + $giftYen);


            
            $priceForRatioByIdx[$idx] = $price;
            $sumPriceForRatio        += $price;
        }


        // ★ この年(t=0)の「各相続人の生前贈与後の課税価格 P_i(0)」を per_idx として保持
        //   Blade 側では after['per_idx'][$idx]['price_for_ratio'] で参照できる
        $perIdx = [];
        for ($idx = 2; $idx <= 10; $idx++) {

            $inheritPart = (int)round($estateBase * $baseShareRatio[$idx]);
            $giftYen     = (int)($giftIncl['per_idx'][$idx] ?? 0);

            $perIdx[$idx] = [
                'price_for_ratio' => $inheritPart + $giftYen,
                'inherit_part_yen'=> $inheritPart,
                'gift_part_yen'   => $giftYen,
            ];


        }

        // ★ 課税価格に基づく「この年(t=0)のあん分比率」
        $anbunRatiosForYear = [];
        if ($sumPriceForRatio > 0) {
            foreach ($priceForRatioByIdx as $idx => $price) {
                $anbunRatiosForYear[$idx] = $price / $sumPriceForRatio;
            }
        } else {
            // 万一すべて 0 なら、従来どおり t=0 の比率をそのまま使用
            $anbunRatiosForYear = $anbunRatios;
        }

        // 控除（暦年・精算）
        //  - t=0: 「これからの贈与」を無視するため、過去分のみ（従来どおり）
        //  - t>0: 仮想（将来）贈与分も合算した控除額を使用
        if ($useFuturePlan) {
            $giftTaxCredits      = $this->calcGiftTaxCreditsByRecipientWithVirtual($dataId, $deathDate, $virtual);
            $settlementGiftTaxes = $this->calcSettlementGiftTaxesByRecipientWithVirtual($dataId, $virtual, $deathDate);
        } else {
            $giftTaxCredits      = $this->calcGiftTaxCreditsByRecipient($dataId, $deathDate, $taxableAcquirerIdxList);
            $settlementGiftTaxes = $this->calcSettlementGiftTaxesByRecipient($dataId, $taxableAcquirerIdxList);
        }

        $finalTotalAfterSurcharge  = 0;
        $totalGiftTaxCredits       = 0;
        $totalPayableAfterCredits  = 0;
        $totalSpouseRelief         = 0;
        $totalPayableAfterSpouse   = 0;
        $totalOtherCredits         = 0;
        $totalPayableAfterOthers   = 0;
        $totalSashihikiTax         = 0;
        $totalSettlementGiftTaxes  = 0;
        $totalFinalAfterSettlement = 0;
        $breakdown = [];

        for ($idx = 2; $idx <= 10; $idx++) {
            $h = null;
            foreach ($heirs as $_h) {
                if ($_h['idx'] === $idx) {
                    $h = $_h;
                    break;
                }
            }
            $isHeir = !is_null($h);

            // ★ この年の課税価格に基づくあん分割合
            $ratio  = (float)($anbunRatiosForYear[$idx] ?? 0.0);
            $sanzutsu = (int)round($totalLegalShareTax * $ratio);

            // ★ 対策後シナリオでも 2割加算は「チェックボックス」で一元管理」
            $twoTenths = $this->checkboxOn($payload, 'twenty_percent_add', $idx);
            $finalTax  = $twoTenths ? (int)round($sanzutsu * 1.2) : $sanzutsu;

            $finalTotalAfterSurcharge += $finalTax;

            /*
            // ★ ログ：対策後(t=0)の算出税額・あん分割合
            Log::info('30001_[ZouyotaxCalc][before_proj_per_idx]', [
                'estate_yen'        => $estateYen,
                'idx'               => $idx,
                'is_heir'           => $isHeir,
                'base_ratio_t0'     => (float)($anbunRatios[$idx] ?? 0.0),
                'anbun_ratio'       => $ratio,
                'price_for_ratio'   => $priceForRatioByIdx[$idx] ?? null,
                'sanzutsu'          => $sanzutsu,
                'two_tenths'        => $twoTenths,
                'final_tax'         => $finalTax,
            ]);
            */

            $creditCalendar  = (int)($giftTaxCredits[$idx]['calendar_yen'] ?? 0);
            $payAfterCalCred = max(0, $finalTax - max(0, $creditCalendar));
            $totalGiftTaxCredits      += min($finalTax, max(0, $creditCalendar));
            $totalPayableAfterCredits += $payAfterCalCred;
            $spouseRelief = 0; $payAfterSpouse = $payAfterCalCred;
            if ($isHeir && in_array((int)($h['rel_code'] ?? 0), [3,4], true) && $payAfterCalCred > 0) {
                $actualShareYen = $this->resolveActualShareYenForIdx($payload, $idx, $estateYen, $legalShareRows[$idx]['legal_ratio'] ?? 0.0);
                $legalAmountYen = (int)round($estateYen * ($legalShareRows[$idx]['legal_ratio'] ?? 0.0));
                $targetBaseYen  = min($actualShareYen, max($legalAmountYen, 160_000_000));
                if ($actualShareYen > 0 && $targetBaseYen > 0){
                    $spouseRelief = (int)floor($payAfterCalCred * ($targetBaseYen / $actualShareYen));
                    if ($spouseRelief > $payAfterCalCred) $spouseRelief = $payAfterCalCred;
                    if ($spouseRelief < 0) $spouseRelief = 0;
                    $payAfterSpouse = $payAfterCalCred - $spouseRelief;
                }
            }
            $totalSpouseRelief += $spouseRelief;
            $totalPayableAfterSpouse += $payAfterSpouse;
            $otherCreditYen = $this->toYen($this->readKyen($payload, 'id_other_credit', $idx)); if ($otherCreditYen < 0) $otherCreditYen = 0;
            $payAfterOthers = max(0, $payAfterSpouse - $otherCreditYen);
            $totalOtherCredits       += min($payAfterSpouse, $otherCreditYen);
            $totalPayableAfterOthers += $payAfterOthers;
            $sashihikiTax = $payAfterOthers; $totalSashihikiTax += $sashihikiTax;
            $settlementGiftTaxYen = (int)($settlementGiftTaxes[$idx] ?? 0);
            $finalAfterSettlement = $sashihikiTax - max(0, $settlementGiftTaxYen);
            $totalSettlementGiftTaxes  += max(0, $settlementGiftTaxYen);
            $totalFinalAfterSettlement += $finalAfterSettlement;
            $breakdown[] = [
                'row_index'   => $idx,

                // ★ 法定相続分表示用：法定相続人のみ bunsi/bunbo をセット（非法定は 0/1）
                'bunsi'       => $isHeir ? (int)($h['bunsi'] ?? 0) : 0,
                'bunbo'       => $isHeir ? (int)($h['bunbo'] ?? 1) : 1,



                'legal_ratio' => $legalShareRows[$idx]['legal_ratio'] ?? 0.0,
                'legal_share_yen' => $legalShareRows[$idx]['legal_share_yen'] ?? 0,
                'legal_tax_yen'   => $legalShareRows[$idx]['legal_tax_yen'] ?? 0,
                'past_gift_included_yen' => (int)($giftIncl['per_idx'][$idx] ?? 0),
                'manual_price_yen'          => $manualShares['shares'][$idx]['manual_price_yen']   ?? null,
                'manual_bd_share_yen'       => $manualShares['shares'][$idx]['bd_share_yen']       ?? null,
                'manual_taxable_share_yen'  => $manualShares['shares'][$idx]['manual_taxable_yen'] ?? null,
                'anbun_ratio'     => $ratio,
                'sanzutsu_tax_yen'=> $sanzutsu,
                'final_tax_yen'   => $finalTax,
                'two_tenths_added'=> $isHeir ? (bool)($h['two_tenths'] ?? false) : false,
                'is_spouse'       => $isHeir ? in_array((int)($h['rel_code'] ?? 0), [3,4], true) : false,
                'gift_tax_credit_calendar_yen'      => max(0, $creditCalendar),
                'payable_after_calendar_credit_yen' => $payAfterCalCred,
                'spouse_relief_yen'  => $spouseRelief,
                'payable_after_spouse_yen' => $payAfterSpouse,
                'other_credit_yen'   => $otherCreditYen,
                'payable_after_others_yen' => $payAfterOthers,
                'sashihiki_tax_yen'  => $sashihikiTax,
                'settlement_gift_tax_yen' => max(0, $settlementGiftTaxYen),
                'final_after_settlement_yen' => $finalAfterSettlement,
                'payable_tax_yen' => $finalAfterSettlement > 0 ? $finalAfterSettlement : 0,
                'refund_tax_yen'  => $finalAfterSettlement < 0 ? abs($finalAfterSettlement) : 0,
            ];
        }
        
        
        //対策後
        return [
            'data_id' => $dataId,
            'summary' => [
                // ★ 贈与前（比較用） / 贈与後（実際の贈与額控除後）を明確に分離
                'estate_base_yen'  => $estateBefore,
                'estate_after_yen' => $estateAfter,
                'estate_yen'       => $estateYen,
                'heir_count'       => count($heirs),
                'basic_deduction'  => $basicDeduction,
                'taxable_estate'   => $taxableEstateUsed,
                // 過年度＋（必要に応じて）仮想将来贈与の算入額
                'incl_calendar_yen'             => (int)($giftIncl['calendar_total_yen']   ?? 0),
                'incl_settlement_yen'           => (int)($giftIncl['settlement_total_yen'] ?? 0),
                'past_gift_included_total_yen' => (int)($giftIncl['total_yen'] ?? 0),
                'past_gift_included_per_idx'   => $giftIncl['per_idx'] ?? [],
                'sozoku_tax_total' => $totalLegalShareTax,
                'total_after_surcharge' => $finalTotalAfterSurcharge,
                'total_gift_tax_credits' => $totalGiftTaxCredits,
                'total_payable_after_calendar_credits' => $totalPayableAfterCredits,
                'total_spouse_relief' => $totalSpouseRelief,
                'total_payable_after_spouse' => $totalPayableAfterSpouse,
                'total_other_credits' => $totalOtherCredits,
                'total_payable_after_others' => $totalPayableAfterOthers,
                'total_sashihiki_tax'           => $totalSashihikiTax,
                'total_settlement_gift_taxes'   => $totalSettlementGiftTaxes,
                'total_final_after_settlement'  => $totalFinalAfterSettlement,
                // ★最終相続税額（精算課税分控除後）＝画面表示用
                'final_after_settlement_yen'    => $totalFinalAfterSettlement,
                'anbun_mode'        => $anbunMode,
                'anbun_total_kyen'  => $anbunTotalKyen,
                
                // t=0 の暦年贈与による減少額（画面で必須）※将来年分は projections.after 側で設定済み
                'gift_decr_calendar_yen' => 0,
                
            ],

            'heirs'   => $breakdown,
            // ★ t=0（対策後）の各相続人の課税価格 P_i(0)
            'per_idx' => $perIdx,

            'meta'  => [
                'mode'    => 'inheritance_with_future_gifts',
                'version' => 'v1.1-plan-applied',
                'ts'      => now()->toDateTimeString(),
                'anbun_mode' => $anbunMode,
            ],
        ];
    }

    /** 任意日付版の対策後（プロジェクション用）：現金は t 年分の年率で反映 */    
    private function computeScenarioForGivenDate(
        int $t,
        array $payload,
        array $heirs,
        int $basicDeduction,
        int $propertyNonCashYen,
        int $cashNowYen,
        float $rate,
        \DateTimeImmutable $deathDateT,
        array $brackets,
        array $futurePlan
    ): array {
        // ★プロジェクションでも「課税価格の取得がある人」を一貫して使用
        $taxableAcquirerIdxList = $this->resolveTaxableAcquirerIdxList($payload, $heirs);


        // ★ 修正：資産成長は「今日と死亡日の差」ではなく、before 側と同じく t 年分で評価する
        //   - t = 0 → 成長なし
        //   - t = 1 → 1年分の成長
        //   - t = 2 → 2年分の成長 ……
        $yearsAhead = max(0, $t);
        $cashGrown  = (int)round(
            $cashNowYen * pow(1 + max($rate, -0.999999), $yearsAhead)
        );

        // ★ 贈与前（比較用）の遺産
        $estateBefore = $propertyNonCashYen + $cashGrown;

        
        // 将来贈与インデックス（T年の死亡日で評価：lookback や実施タイミング判定用）
        $pastOnlyT = $this->calcPastGiftsIncludedInEstateByRecipient(1, $deathDateT, $taxableAcquirerIdxList);
        $virtual   = $this->buildVirtualGiftsIndex($futurePlan, $deathDateT, $pastOnlyT, $taxableAcquirerIdxList, $t);




        // ★ 贈与後（実際の贈与額=cash_out_total 控除後）の遺産
        $estateAfter = $this->applyFuturePlanToEstate($propertyNonCashYen, $cashGrown, $virtual, $deathDateT);

        // 以降は computeForGivenEstateAndDate に「課税価格（kazei_price_yen）」を
        // 関数内で（estateAfter + 算入額）として組み立てる。
        // → estateYen は「贈与後遺産（控除後）」を渡す（ここが修正点）
        $res = $this->computeForGivenEstateAndDate(
            $t, $payload, $heirs, $basicDeduction,
            $estateAfter, $deathDateT, $brackets,
            'after_virtual', $virtual,
            // ★分割対象は「贈与後遺産（減額後）」を明示指定
            $estateAfter
        );

        // ★ summary を “贈与前/贈与後” で確定させる（normalize 側で誤補完させない）
        $res['summary']['estate_base_yen']        = $estateBefore; // 比較用（贈与前）
        $res['summary']['estate_before_gifts_yen']= $estateBefore; // 互換キー
        $res['summary']['estate_after_yen']       = $estateAfter;  // 実際の贈与額控除後
        return $res;
        
    }

    /** 差額（after - before）を要約と行ごとに生成 */
    private function buildDelta(array $before, array $after): array
    {
        $sumB = $before['summary'] ?? [];
        $sumA = $after['summary']  ?? [];
        $diffSummary = [];
        foreach (array_keys($sumA + $sumB) as $k){
            $diffSummary[$k] = (int)($sumA[$k] ?? 0) - (int)($sumB[$k] ?? 0);
        }
        $rows = [];
        $byIdxA = []; foreach (($after['heirs'] ?? []) as $r){ $byIdxA[$r['row_index']] = $r; }
        $byIdxB = []; foreach (($before['heirs']?? []) as $r){ $byIdxB[$r['row_index']] = $r; }
        for ($i=2;$i<=10;$i++){
            $A = $byIdxA[$i] ?? []; $B = $byIdxB[$i] ?? [];
            $row = ['row_index'=>$i];
            foreach (array_keys(($A+$B)) as $k){
                if ($k==='row_index') continue;
                $row[$k] = (int)($A[$k] ?? 0) - (int)($B[$k] ?? 0);
            }
            $rows[] = $row;
        }
        return [
            'summary' => $diffSummary,
            'heirs'   => $rows,
            'meta'    => ['mode'=>'delta','ts'=>now()->toDateTimeString()],
        ];
    }

    



    /**
     * POST値が無い/0のときは DB から被相続人(行1)の値を取得して返す。
     * 戻り値: [propertyNowYen, cashNowYen, rateFloat]
     *  - property/cash は「千円」→「円」へ
     *  - rate は % → 小数 (ex 1.5 => 0.015)
     */
    private function resolveBaseFromPayloadOrDb(array $payload, int $dataId): array
    {
        $propK = $this->readKyen($payload, 'property', 1); // 千円（POST）
        $cashK = $this->readKyen($payload, 'cash', 1);     // 千円（POST）
        $perRaw = Arr::get($payload, 'per', null);
        $rate = null;
        if ($perRaw !== null && $perRaw !== '') {
            $rate = (float)preg_replace('/[^\d\.\-]/', '', (string)$perRaw) / 100.0;
        }

        // DB フォールバック
        if ($propK === 0 || $cashK === 0 || $rate === null) {
            $pfm = ProposalFamilyMember::query()
                    ->where('data_id', $dataId)->where('row_no', 1)->first();
            if ($pfm) {
                if ($propK === 0) $propK = (int)$pfm->property_thousand;
                if ($cashK === 0) $cashK = (int)$pfm->cash_thousand;
            }
            if ($rate === null) {
                $ph = ProposalHeader::query()->where('data_id', $dataId)->first();
                if ($ph && $ph->after_tax_yield_percent !== null) {
                    $rate = ((float)$ph->after_tax_yield_percent) / 100.0;
                }
            }
        }
        // 千円→円
        $propertyNowYen = $propK * 1000;
        $cashNowYen     = $cashK * 1000;
        // rate が未決定なら 0.0 に
        $rate = $rate ?? 0.0;
        return [$propertyNowYen, $cashNowYen, $rate];
    }

    /**
     * 受贈者（row_no=2..10）について、POST値が無い/0のときは
     * DB から property_thousand / cash_thousand を取得して返す。
     *
     * 戻り値: [propertyYen, cashYen]
     */
    private function resolvePersonBaseFromPayloadOrDb(array $payload, int $dataId, int $rowNo): array
    {
        // 画面からの入力（千円）
        $propK = $this->readKyen($payload, 'property', $rowNo);
        $cashK = $this->readKyen($payload, 'cash', $rowNo);

        // DB フォールバック（proposal_family_members.row_no = $rowNo）
        if ($propK === 0 || $cashK === 0) {
            $pfm = ProposalFamilyMember::query()
                ->where('data_id', $dataId)
                ->where('row_no', $rowNo)
                ->first();

        if ($pfm) {
                if ($propK === 0) {
                    $propK = (int)($pfm->property_thousand ?? 0);
                }
                if ($cashK === 0) {
                    $cashK = (int)($pfm->cash_thousand ?? 0);
                }
            }
        }

        // 千円 → 円
        $propertyYen = max(0, $propK) * 1000;
        $cashYen     = max(0, $cashK) * 1000;

        return [$propertyYen, $cashYen];
    }

    /**
     * 各受贈者（行2〜10）の「対策後 個人別財産推移」タイムラインを構築する。
     *
     * - asset_total_yen:
     *     非金融資産 ＋ 金融資産 * (1 + rate)^t
     *       …元々保有している財産の推移（贈与・相続による増減は含めない）
     * - gift_calendar_received_yen / gift_calendar_tax_yen:
     *     将来暦年贈与プラン（future_gift_plan_entries）の金額・税額（円）
     * - gift_settlement_received_yen / gift_settlement_tax_yen:
     *     将来精算課税贈与プランの金額・税額（円）
     * - inherit_net_yen:
     *     相続による取得財産（各相続人の遺産分割による取得財産で、生前贈与加算前）
     *     → heirs[].estate_base_share_yen を使用
     * - inherit_tax_yen:
     *     相続税額
     *     → heirs[].final_after_settlement_yen を使用
     * - investment_gain_yen:
     *     金融資産部分の運用による増加額のみ
     * - asset_after_yen:
     *     現段階では「元々の財産＋贈与純増（受領額−贈与税）」までを反映した対策後残高
     *
     * 返却形式:
     *   [
     *     2 => ['timeline' => [ t => [...], ... ]],
     *     3 => ['timeline' => [...]],
     *     ...
     *   ]
     */
    private function buildPersonBaselineTimelines(
        array $payload,
        int $dataId,
        float $rate,
        array $futurePlan,
        array $after,
        array $projAfter
    ): array {
        $persons = [];

        // 利回りの下限ガード（元の compute/projection と同じ扱い）
        $safeRate = max($rate, -0.999999);



        // --- 相続取得財産の按分比率（遺産分割比率）を決定 ---
        //   ・manual：heirs[].manual_price_yen の比率
        //   ・auto  ：heirs[].legal_ratio の比率
        $heirsRows0 = $after['heirs'] ?? [];
        $heirsByIdx = [];
        foreach ($heirsRows0 as $row) {
            if (!isset($row['row_index'])) {
                continue;
            }
            $idx = (int)$row['row_index'];
            if ($idx < 2 || $idx > 10) {
                continue;
            }
            $heirsByIdx[$idx] = $row;
        }

        $ratioByIdx = [];
        if (!empty($heirsByIdx)) {
            // 1) manual_price_yen を優先
            $sumPrice   = 0;
            $priceByIdx = [];
            foreach ($heirsByIdx as $idx => $row) {
                $price = (int)($row['manual_price_yen'] ?? 0);
                if ($price > 0) {
                    $priceByIdx[$idx] = $price;
                    $sumPrice        += $price;
                }
            }

            if ($sumPrice > 0) {
                foreach ($priceByIdx as $idx => $price) {
                    $ratioByIdx[$idx] = $price / $sumPrice;
                }
            } else {
                // 2) manual が無ければ legal_ratio で比率を作る
                $sumRatio = 0.0;
                foreach ($heirsByIdx as $idx => $row) {
                    $r = (float)($row['legal_ratio'] ?? 0.0);
                    $ratioByIdx[$idx] = $r;
                    $sumRatio         += $r;
                }
                if ($sumRatio > 0.0) {
                    foreach ($ratioByIdx as $idx => $r) {
                        $ratioByIdx[$idx] = $r / $sumRatio;
                    }
                }
            }
        }

        // --- 年次×idx ごとの「相続取得財産（inherit_net_yen）・相続税（inherit_tax_yen）」マップ ---
        //   inherit_net_yen:
        //     各年の estate_after_yen（= これからの贈与で減少した後の財産）を ratioByIdx で按分
        //   inherit_tax_yen:
        //     heirs[].final_after_settlement_yen をそのまま採用
        $inheritByYearIdx = [];

        // 指定年 t の estate_after_yen を ratioByIdx で按分し、
        //   - inherit_net_yen … 比率に基づく取得財産
        //   - inherit_tax_yen … 各行の final_after_settlement_yen（相続税額）そのもの
        // を返す
        $buildInheritForYear = function (?array $summary, ?array $heirsRows) use ($ratioByIdx): array {
            
            $out = [];
            if (empty($summary) || empty($heirsRows) || empty($ratioByIdx)) {
                return $out;
            }
            $total = (int)($summary['estate_after_yen'] ?? 0);
            if ($total <= 0) {
                return $out;
            }

            $allocated = 0;
            $lastIdx   = null;

            // まず比率に従って floor 配分
            foreach ($heirsRows as $row) {
                $idx = (int)($row['row_index'] ?? 0);

                $ratioForIdx = (float)($ratioByIdx[$idx] ?? 0.0);
                


                // 比率がある場合だけ「取得財産」を按分する
                $share = 0;
                if ($ratioForIdx > 0) {
                    $lastIdx = $idx;
                    $share   = (int)floor($total * $ratioForIdx);
                    $allocated += $share;
                }

                $out[$idx] = [
                    // 相続により取得する財産（もともとの財産から「これからの贈与」で減少した後の遺産を按分）
                    //  …比率が 0 の人は 0 のまま
                    'inherit_net_yen' => $share,
                    // 相続税額（final_after_settlement_yen をそのまま採用）
                    'inherit_tax_yen' => (int)($row['final_after_settlement_yen'] ?? 0),
                ];

            }

            // 端数は最後の一人に寄せる
            if ($lastIdx !== null && $allocated !== $total) {
                $diff = $total - $allocated;

                $out[$lastIdx]['inherit_net_yen'] =
                    ($out[$lastIdx]['inherit_net_yen'] ?? 0) + $diff;

            }

            return $out;
        };

        // t=0（現時点）
        $inheritByYearIdx[0] = $buildInheritForYear(
            $after['summary'] ?? [],
            $after['heirs']   ?? []
        );

        // t=1..20（将来年次）
        if (is_array($projAfter)) {
            for ($t = 1; $t <= 20; $t++) {
                $summaryT   = $projAfter[$t]['summary'] ?? [];
                $heirsRowsT = $projAfter[$t]['heirs']   ?? [];
                $inheritByYearIdx[$t] = $buildInheritForYear($summaryT, $heirsRowsT);
            }
        }

        // まずは「元々の財産」ベースのタイムラインを作る
        for ($idx = 2; $idx <= 10; $idx++) {
            // 受贈者自身の property/cash（現時点）を解決
            [$propertyYen, $cashYen] = $this->resolvePersonBaseFromPayloadOrDb($payload, $dataId, $idx);

            $nonCash = max(0, $propertyYen - $cashYen);

            $timeline = [];

            for ($t = 0; $t <= 20; $t++) {
                // t年後の金融資産（利回り反映）
                $grownCash = (int)round(
                    $cashYen * pow(1 + $safeRate, max(0, $t))
                );

                // 受贈者がもともと持っている財産の推移
                $assetTotal = $nonCash + $grownCash;

                // 運用による増加額（金融資産部分のみ）
                $investmentGain = $grownCash - $cashYen;

                // 相続取得・相続税（該当が無ければ 0）
                $inheritForT = $inheritByYearIdx[$t][$idx] ?? ['inherit_net_yen' => 0, 'inherit_tax_yen' => 0];

                $timeline[$t] = [
                    // 所有財産の額（対策前の推移）
                    'asset_total_yen'              => $assetTotal,

                    // 贈与による純財産の増加（対策前ベース）
                    'gift_net_before_yen'          => 0,
                    'gift_calendar_received_yen'   => 0,
                    'gift_calendar_tax_yen'        => 0,
                    'gift_settlement_received_yen' => 0,
                    'gift_settlement_tax_yen'      => 0,

                    // 相続による純財産の増加（もともとの財産から将来贈与を控除した後、
                    // 各相続人が遺産分割で取得する財産）と相続税額
                    'inherit_net_yen'              => $inheritForT['inherit_net_yen'],
                    'inherit_tax_yen'              => $inheritForT['inherit_tax_yen'],

                    // 資産運用による増加額（★）
                    'investment_gain_yen'          => $investmentGain,

                    // 財産の額（対策後）…現段階では「元々の資産＋贈与純増」を想定
                    'asset_after_yen'              => $assetTotal,
                ];
            }

            $persons[$idx] = [
                'timeline'          => $timeline,
                // ★ 運用益再計算用に「元々の金融資産」と「非金融資産」を保持しておく
                'base_cash_yen'     => $cashYen,
                'base_non_cash_yen' => $nonCash,
            ];


        }

        // --- 将来贈与プランから暦年贈与を反映 ---
        foreach (($futurePlan['calendar'] ?? []) as $row) {
            $no = (int)($row['no'] ?? 0);
            $t  = (int)($row['t']  ?? 0);
            if ($no < 2 || $no > 10 || $t < 1 || $t > 20) {
                continue;
            }
            if (!isset($persons[$no]['timeline'][$t])) {
                continue;
            }

            $amountYen = $this->toYen((int)($row['amount_thousand'] ?? 0));
            $taxYen    = $this->toYen((int)($row['tax_thousand']    ?? 0));
            $netYen    = max(0, $amountYen - $taxYen);

            $persons[$no]['timeline'][$t]['gift_calendar_received_yen'] = $amountYen;
            $persons[$no]['timeline'][$t]['gift_calendar_tax_yen']      = $taxYen;
            $persons[$no]['timeline'][$t]['gift_net_before_yen']       += $netYen;

            // 対策後残高に純増分を足し込む（暫定仕様）
            $persons[$no]['timeline'][$t]['asset_after_yen']
                = ($persons[$no]['timeline'][$t]['asset_after_yen'] ?? 0) + $netYen;
        }


        // --- 贈与プランから精算課税贈与を反映 ---
        foreach (($futurePlan['settlement'] ?? []) as $row) {
            $no = (int)($row['no'] ?? 0);
            $t  = (int)($row['t']  ?? 0);

            if ($no < 2 || $no > 10 || $t < 1 || $t > 20) {
                continue;
            }
            if (!isset($persons[$no]['timeline'][$t])) {
                continue;
            }

            // 金額（円）
            $amountYen = $this->toYen((int)($row['amount_thousand'] ?? 0));
            $taxYen    = $this->toYen((int)($row['settlement_tax20_thousand']    ?? 0));
            $netYen    = max(0, $amountYen - $taxYen);

            // 取得額・贈与税額・純増を記録
            $persons[$no]['timeline'][$t]['gift_settlement_received_yen'] = $amountYen;
            $persons[$no]['timeline'][$t]['gift_settlement_tax_yen']      = $taxYen;
            $persons[$no]['timeline'][$t]['gift_net_before_yen']         += $netYen;

            // asset_after_yen にも純増分を反映（暫定仕様）
            $persons[$no]['timeline'][$t]['asset_after_yen']
                = ($persons[$no]['timeline'][$t]['asset_after_yen'] ?? 0) + $netYen;
        }


        
        
        // --- 贈与で取得した資産(贈与税控除後)も含めた「運用益」と
        //     「財産の額（対策後）」を再計算（いずれも“その年までの累計額”として扱う） ---
        //  ・gift_net_before_yen 累計    … その年までの贈与純増累計（暦年＋精算、受領額−贈与税）
        //  ・inherit_net_yen 累計        … その年までの相続による純財産増加累計
        //  ・investment_gain_yen 累計    … その年までの運用益累計
        //  asset_after_yen(t) = asset_total_yen(t)
        //                      + 累計 gift_net
        //                      + 累計 inherit_net
        //                      − 累計 inherit_tax
        //                      + 累計 investment_gain
        foreach ($persons as $idx => &$person) {
            $timeline    = $person['timeline'] ?? [];
            $cashYen     = (int)($person['base_cash_yen'] ?? 0);      // 元々の金融資産（t=0 の元本）
            $nonCashYen  = (int)($person['base_non_cash_yen'] ?? 0);  // 元々の非金融資産

            if ($cashYen < 0)    { $cashYen = 0; }
            if ($nonCashYen < 0) { $nonCashYen = 0; }

            // 贈与で取得した純資産ポートフォリオの「期首残高」
            $giftValuePrev      = 0;
            // 贈与純増・相続純増・相続税・運用益の累計（t=0 からの累積）
            $giftNetCum         = 0;
            $inheritNetCum      = 0;
            $inheritTaxCum      = 0;
            $investmentGainCum  = 0;

            for ($t = 0; $t <= 20; $t++) {
                if (!isset($timeline[$t])) {
                    continue;
                }

                // ★ 元々の金融資産の当年の運用益（年次差分）
                //   grownCashPrev = 前年末残高
                //   grownCashCurr = 当年末残高
                $grownCashPrev = (int)round(
                    $cashYen * pow(1 + $safeRate, max(0, $t - 1))
                );
                $grownCashCurr = (int)round(
                    $cashYen * pow(1 + $safeRate, max(0, $t))
                );
                $origGainYear  = $grownCashCurr - $grownCashPrev;

                // ベースライン資産（非金融＋元々の金融資産の当年末残高）
                $assetBaseline = $nonCashYen + $grownCashCurr;

                // ★ 当年の「純贈与元本」（受領額−贈与税）※この年だけの増分
                $netGiftThisYear = (int)($timeline[$t]['gift_net_before_yen'] ?? 0);
                // 贈与純増の累計（t=0〜tの合計）
                $giftNetCum += $netGiftThisYear;

                // 将来贈与分については「贈与を受けた翌年から」運用益が発生するようにする。
                //   1) 期首残高 giftValuePrev にだけ利息を付ける
                //   2) 当年の純贈与元本 netGiftThisYear は利息計算の後に元本として追加
                $giftValueGrown = (int)round(
                    $giftValuePrev * (1 + $safeRate)
                );
                // 贈与分の当年運用益 = 期末（贈与前）残高 − 期首残高
                $giftGainYear   = $giftValueGrown - $giftValuePrev;
                // 期末残高（贈与後）＝利息付与後の残高＋当年の純贈与元本
                $giftValueCurr  = $giftValueGrown + $netGiftThisYear;

                // 当年の総運用益（贈与分の運用益はマイナスにならないようガード）
                $investmentGainYear = $origGainYear + max(0, $giftGainYear);
                // 運用益の累計（t=0〜tの合計）
                $investmentGainCum += $investmentGainYear;


                // 対策後の財産額 = 所有財産の額（対策前）＋贈与純増＋相続純増＋当年の運用益
                //  ・贈与純増       = gift_net_before_yen（暦年＋精算の受領額−贈与税）
                //  ・相続純増       = inherit_net_yen − inherit_tax_yen
                //  ・運用益（当年分）= investment_gain_yen
                $giftNet    = (int)($timeline[$t]['gift_net_before_yen'] ?? 0);
                // 相続による純財産増加・相続税（この年の増分）
                $inheritNetThis = (int)($timeline[$t]['inherit_net_yen'] ?? 0);
                $inheritTaxThis = (int)($timeline[$t]['inherit_tax_yen'] ?? 0);
                $inheritNetCum  += $inheritNetThis;
                $inheritTaxCum  += $inheritTaxThis;

                // 表示用の各項目を上書き
                $timeline[$t]['asset_total_yen']     = $assetBaseline;
                // 運用益は「その年までの累計額」として表示
                $timeline[$t]['investment_gain_yen'] = $investmentGainYear;



                // 対策後の財産額（その年までの累計）:
                //   所有財産の額（対策前）＋贈与純増累計＋(単年度相続純増 − 単年度相続税)＋運用益累計
                $timeline[$t]['asset_after_yen']
                    = $assetBaseline + $giftNetCum + $inheritNetThis - $inheritTaxThis + $investmentGainCum;

                // 次年度に繰り越す贈与ポートフォリオ期末残高
                $giftValuePrev = $giftValueCurr;
            }

            $person['timeline'] = $timeline;
        }
        unset($person);

        return $persons;
    }

    /**
     * 保存済みの「これからの贈与」暦年額（年次合計・千円）を
     * FutureGiftPlanEntry から recipient_no=2..10 を横断合算して返す。
     * 戻り値: [1..20] => 千円（int）
     */
    private function readSavedFutureCalAmountByYearK(int $dataId): array
    {
        /** 保存済みの「暦年課税」年次合計（千円）を FutureGift* から集計 */
        $rows = $this->futureGiftPlanFromDb(FutureGiftPlanEntry::query()
            ->where('data_id', $dataId)
            ->whereBetween('row_no', [1, 20])
            ->whereBetween('recipient_no', [2, 10])
            ->select('row_no', DB::raw('SUM(COALESCE(calendar_amount_thousand,0)) as k'))
            ->groupBy('row_no'));
        return $rows;
    }

    /** 保存済みの「精算課税」年次合計（千円）を FutureGift* から集計 */
    private function readSavedFutureSetAmountByYearK(int $dataId): array
    {
        $rows = $this->futureGiftPlanFromDb(FutureGiftPlanEntry::query()
            ->where('data_id', $dataId)
            ->whereBetween('row_no', [1, 20])
            ->whereBetween('recipient_no', [2, 10])
            ->select('row_no', DB::raw('SUM(COALESCE(settlement_amount_thousand,0)) as k'))
            ->groupBy('row_no'));
        return $rows;
    }


    /** 保存済みの「贈与加算累計額（暦年）」= cal_cum（千円）を年次合計で取得（重複行を排除して最新のみ集計） */
    private function readSavedFutureCalCumByYearK(int $dataId): array
    {
        // 重複がある場合でも (data_id, recipient_no, row_no) の最新行だけを採用して row_no ごとに合算
        $latestIds = DB::table('future_gift_plan_entries as f')
            ->where('f.data_id', $dataId)
            ->whereBetween('f.recipient_no', [2, 10])
            ->whereBetween('f.row_no', [1, 20])
            ->selectRaw('MAX(f.id) as id')
            ->groupBy('f.data_id','f.recipient_no','f.row_no')
            ->pluck('id');

        if ($latestIds->isEmpty()) return [];

        $res = DB::table('future_gift_plan_entries')
            ->whereIn('id', $latestIds)
            ->select('row_no', DB::raw('SUM(COALESCE(calendar_add_cum_thousand,0)) as k'))
            ->groupBy('row_no')
            ->get();

        $out = array_fill(1, 20, 0);
        foreach ($res as $r) {
            $t = (int)$r->row_no;
            if ($t >= 1 && $t <= 20) $out[$t] = (int)$r->k;
        }
        return $out;
    }


    /** 保存済みの「贈与加算累計額（精算）」= set_cum（千円）を年次合計で取得（重複行を排除して最新のみ集計） */
    private function readSavedFutureSetCumByYearK(int $dataId): array
    {
        // 重複がある場合でも (data_id, recipient_no, row_no) の最新行だけを採用して row_no ごとに合算
        $latestIds = DB::table('future_gift_plan_entries as f')
            ->where('f.data_id', $dataId)
            ->whereBetween('f.recipient_no', [2, 10])
            ->whereBetween('f.row_no', [1, 20])
            ->selectRaw('MAX(f.id) as id')
            ->groupBy('f.data_id','f.recipient_no','f.row_no')
            ->pluck('id');

        if ($latestIds->isEmpty()) return [];

        $res = DB::table('future_gift_plan_entries')
            ->whereIn('id', $latestIds)
            ->select('row_no', DB::raw('SUM(COALESCE(settlement_add_cum_thousand,0)) as k'))
            ->groupBy('row_no')
            ->get();

        $out = array_fill(1, 20, 0);
        foreach ($res as $r) {
            $t = (int)$r->row_no;
            if ($t >= 1 && $t <= 20) $out[$t] = (int)$r->k;
        }
        
        
        Log::debug('2025_11_12_01 Saved Future Set Cum Rows (dedup latest):', ['rows' => $out]);
        
        
        return $out;
    }


    /** 内部ユーティリティ：row_no→合計(千円) の配列へ変換 */
    private function FutureGiftPlanFromDb($builder): array
    {
        $res = $builder->get();
        if ($res->isEmpty()) { return []; }
        $out = array_fill(1, 20, 0);
        foreach ($res as $r) {
            $t = (int)$r->row_no;
            if ($t >= 1 && $t <= 20) {
                $out[$t] = (int)$r->k;
            }
        }
        return $out;
    }



    /**
     * 0行目（現時点）の死亡日（基準日）を UI と揃えて決定
     * 優先: payload.inherit_base_month/day → DB past_gift_inputs.inherit_month/day → 2024-12-31
     */
    private function resolveRow0DeathDateFromPayloadOrDb(array $payload, int $dataId): \DateTimeImmutable
    {
        $m = (int)preg_replace('/[^\d]/', '', (string)Arr::get($payload, 'inherit_base_month', '')) ?: 0;
        $d = (int)preg_replace('/[^\d]/', '', (string)Arr::get($payload, 'inherit_base_day', '')) ?: 0;
        if ($m <= 0 || $m > 12 || $d <= 0 || $d > 31) {
            try {
                $pg = PastGiftInput::query()->where('data_id', $dataId)->first(['inherit_month','inherit_day']);
                if ($pg) {
                    $m = (int)($pg->inherit_month ?? 0);
                    $d = (int)($pg->inherit_day   ?? 0);
                }
            } catch (\Throwable $e) { /* ignore */ }
        }
        if ($m <= 0 || $m > 12) $m = 12;
        if ($d <= 0 || $d > 31) $d = 31;
        return new \DateTimeImmutable(sprintf('2024-%02d-%02d', $m, $d));
    }




    /**
     * PastGift* から現時点(0行目)の cal_cum / set_cum をサーバ側で算出（単位：千円）
     * - 暦年：改正ルックバックに基づき  within3K  max(0, over3K - 1100)
     * - 精算：afterBasicK = Σ(amountK) - 1100 * 件数( gift_year >= 2024 )（下限0）
     * - recipientNo 指定時はその受贈者のみ、null の場合は 2..10 を合算
     */
    private function fallbackRow0CumFromPast(int $dataId, ?int $recipientNo, \DateTimeImmutable $deathDate): array
    {
        // 対象受贈者集合
        $whereRecipient = function($q) use ($recipientNo) {
            if ($recipientNo !== null && $recipientNo > 0) {
                $q->where('recipient_no', $recipientNo);
            } else {
                $q->whereBetween('recipient_no', [2,10]);
            }
        };

        // 暦年：within3 / over3 の千円集計
        [$start, $end] = $this->determineCalendarGiftLookbackRange($deathDate);
        $calRows = PastGiftCalendarEntry::query()
            ->where('data_id', $dataId)
            ->where(function($q) use ($whereRecipient){ $whereRecipient($q); })
            ->get(['gift_year','gift_month','gift_day','amount_thousand']);
        $within3K = 0; $over3K = 0;
        foreach ($calRows as $r) {
            $ak = (int)($r->amount_thousand ?? 0);
            if ($ak <= 0) continue;
            try {
                $gd = new \DateTimeImmutable(sprintf('%04d-%02d-%02d', (int)$r->gift_year, (int)$r->gift_month, (int)$r->gift_day));
            } catch (\Throwable $e) { continue; }
            if ($gd < $start || $gd > $end) continue;
            $threeYearsAgo = $end->sub(new \DateInterval('P3Y'));
            if ($gd >= $threeYearsAgo) $within3K += $ak; else $over3K += $ak;
        }
        $calCumK = $within3K + max(0, $over3K - 1100); // 千円

        // 精算：afterBasicK（千円）
        $setRows = PastGiftSettlementEntry::query()
            ->where('data_id', $dataId)
            ->where(function($q) use ($whereRecipient){ $whereRecipient($q); })
            ->get(['gift_year','amount_thousand']);
        $sumSetK = 0; $cnt2024 = 0;
        foreach ($setRows as $r) {
            $ak = max(0, (int)($r->amount_thousand ?? 0));
            $sumSetK += $ak;
            $yy = (int)($r->gift_year ?? 0);
            if ($yy >= 2024) $cnt2024++;
        }
        $setCumK = max(0, $sumSetK - 1100 * $cnt2024);
        

        // 合計値のログ
        \Log::info('[computeRow0CumFromPast] settlement summary', [
            'recipient_no' => $recipientNo,
            'sumSetK'      => $sumSetK,      // 精算課税 元本合計（千円）
            'cnt2024'      => $cnt2024,      // 2024年以降の件数
            'setCumK'      => $setCumK,      // 控除後算入額（千円）
        ]);


        return [$calCumK, $setCumK];
    }


    /**
     * 「対策後(after)」および「年次プロジェクション(projections.after)」の
     * 課税遺産総額(taxable_estate) を
     *
     *   各相続人の生前贈与加算後の課税価格 P_i(t)
     *   （= per_idx[idx]['price_for_ratio']）
     *
     * の比率で按分した値を heirs[].taxable_share_yen として付与する。
     *
     * 期待式:
     *   taxable_share_yen_i(t)
     *     = taxable_estate(t) * P_i(t) / Σ_j P_j(t)
     *
     * per_idx が無い／全員0などの場合のみ、
     * manual_price_yen or legal_ratio による従来比率へフォールバックする。
     */
    private function allocateTaxableEstateByFixedRatios(array $after, array $projAfter): array
    {
        if (!isset($after['heirs']) || !is_array($after['heirs'])) {
            return [$after, $projAfter];
        }

        // t=0 after.heirs から row_index => 行 へマップ
        $heirsByIdx = [];
        foreach ($after['heirs'] as $row) {
            if (!isset($row['row_index'])) continue;
            $heirsByIdx[(int)$row['row_index']] = $row;
        }
        if (empty($heirsByIdx)) {
            return [$after, $projAfter];
        }

        // --- 相続取得財産の按分比率（遺産分割比率）を決定 ---
        //   ・manual：heirs[].manual_price_yen の比率
        //   ・auto  ：heirs[].legal_ratio の比率
        $sumPrice   = 0;
        $priceByIdx = [];
        foreach ($heirsByIdx as $idx => $row) {
            $price = (int)($row['manual_price_yen'] ?? 0);
            if ($price > 0) {
                $priceByIdx[$idx] = $price;
                $sumPrice        += $price;
            }
        }

        $fallbackRatioByIdx = [];
        if ($sumPrice > 0) {
            // manual: 課税価格（manual_price_yen）の比率で按分
            foreach ($priceByIdx as $idx => $price) {
                $fallbackRatioByIdx[$idx] = $price / $sumPrice;
            }
        } else {
            // auto: legal_ratio の比率で按分
            $sumRatio = 0.0;
            foreach ($heirsByIdx as $idx => $row) {
                $r = (float)($row['legal_ratio'] ?? 0.0);
                $fallbackRatioByIdx[$idx] = $r;
                $sumRatio                 += $r;
            }
            if ($sumRatio > 0.0) {
                foreach ($fallbackRatioByIdx as $idx => $r) {
                    $fallbackRatioByIdx[$idx] = $r / $sumRatio;
                }
            }
        }

        // per_idx（price_for_ratio）から比率を作るヘルパ
        $buildRatiosFromPerIdx = function (?array $perIdx, array $fallback) {
            $perIdx = $perIdx ?? [];
            $sumP   = 0;
            $ratio  = [];
            foreach ($perIdx as $idx => $rec) {
                $p = (int)($rec['price_for_ratio'] ?? 0);
                if ($p <= 0) continue;
                $ratio[(int)$idx] = $p;
                $sumP            += $p;
            }
            if ($sumP > 0) {
                foreach ($ratio as $idx => $p) {
                    $ratio[$idx] = $p / $sumP;
                }
                return $ratio;
            }
            // 全員0／未設定ならフォールバック（manual / legal_ratio）
            return $fallback;
        };

        // 内部ユーティリティ：指定された合計額を ratio で按分して taxable_share_yen を付与
        $applyAllocation = function (&$heirs, int $total, array $ratios): void {
            if ($total <= 0 || !is_array($heirs)) return;
            $lastKey   = null;
            $allocated = 0;
            foreach ($heirs as $k => &$row) {
                $idx = $row['row_index'] ?? null;
                if ($idx === null || !isset($ratios[$idx])) continue;
                $lastKey = $k;
                $share   = (int)floor($total * $ratios[$idx]);
                $row['taxable_share_yen'] = $share;
                $allocated               += $share;
            }
            // 端数は最後の一人に寄せる
            if ($lastKey !== null) {
                $heirs[$lastKey]['taxable_share_yen'] =
                    ($heirs[$lastKey]['taxable_share_yen'] ?? 0) + ($total - $allocated);
            }
        };

        // 2) after(t=0)：per_idx(0年目の P_i(0)) から比率を作って按分
        $perIdxAfter   = $after['per_idx'] ?? null;
        $ratiosAfter   = $buildRatiosFromPerIdx($perIdxAfter, $fallbackRatioByIdx);
        $totalAfter    = (int)($after['summary']['taxable_estate'] ?? 0);
        $applyAllocation($after['heirs'], $totalAfter, $ratiosAfter);

        // 3) 年次プロジェクション after[t]：各年の per_idx[t] があればそれで比率を作る
        if (is_array($projAfter)) {
            foreach ($projAfter as $t => $row) {
                if (!isset($row['summary']['taxable_estate'], $row['heirs']) || !is_array($row['heirs'])) {
                    continue;
                }
                $perIdxT   = $row['per_idx'] ?? null;
                $ratiosT   = $buildRatiosFromPerIdx($perIdxT, $ratiosAfter); // 年ごとに P_i(t) 優先、無ければ t=0 比率
                $totalT    = (int)$row['summary']['taxable_estate'];
                $heirsT    =& $row['heirs'];
                $applyAllocation($heirsT, $totalT, $ratiosT);
                $row['heirs'] = $heirsT;
                $projAfter[$t] = $row;
            }
        }

        return [$after, $projAfter];
    }



    /**
     * 「対策後(after)」および「年次プロジェクション(projections.after)」の
     * 所有財産（= 贈与後の相続財産の額: estate_after_yen）を
     * 「各相続人の課税価格比率」で按分した値を
     * heirs[].estate_base_share_yen として付与する。
     *
     * ・按分比率の決め方は allocateTaxableEstateByFixedRatios と同じ
     *   - manual: heirs[].manual_price_yen（課税価格）比率
     *   - auto  : heirs[].legal_ratio 比率
     * ・年次プロジェクション after[t] でも、各年の estate_after_yen を按分する
     *
     * NOTE:
     *  - summary['estate_base_yen'] は「贈与前総資産（比較用）」として保持しているため、
     *    “分割の基になる所有財産”は summary['estate_after_yen'] を採用する。
     */
    private function allocateEstateBaseByFixedRatios(array $after, array $projAfter): array
    {
        if (!isset($after['heirs']) || !is_array($after['heirs'])) {
            return [$after, $projAfter];
        }

        // t=0 after.heirs から row_index => 行 へマップ
        $heirsByIdx = [];
        foreach ($after['heirs'] as $row) {
            if (!isset($row['row_index'])) continue;
            $heirsByIdx[(int)$row['row_index']] = $row;
        }
        if (empty($heirsByIdx)) {
            return [$after, $projAfter];
        }

        // 1) manual モード用：manual_price_yen から比率を作成
        $sumPrice   = 0;
        $priceByIdx = [];
        foreach ($heirsByIdx as $idx => $row) {
            $price = (int)($row['manual_price_yen'] ?? 0);
            if ($price > 0) {
                $priceByIdx[$idx] = $price;
                $sumPrice        += $price;
            }
        }

        $ratioByIdx = [];
        if ($sumPrice > 0) {
            // manual: 課税価格（manual_price_yen）の比率で按分
            foreach ($priceByIdx as $idx => $price) {
                $ratioByIdx[$idx] = $price / $sumPrice;
            }
        } else {
            // auto: legal_ratio の比率で按分
            $sumRatio = 0.0;
            foreach ($heirsByIdx as $idx => $row) {
                $r = (float)($row['legal_ratio'] ?? 0.0);
                $ratioByIdx[$idx] = $r;
                $sumRatio         += $r;
            }
            if ($sumRatio <= 0.0) {
                return [$after, $projAfter];
            }
            foreach ($ratioByIdx as $idx => $r) {
                $ratioByIdx[$idx] = $r / $sumRatio;
            }
        }

        // 内部ユーティリティ：指定された合計額を ratio で按分して estate_base_share_yen を付与
        $applyAllocation = function (&$heirs, int $total, array $ratios): void {
            if ($total <= 0 || !is_array($heirs)) return;
            $lastKey   = null;
            $allocated = 0;
            foreach ($heirs as $k => &$row) {
                $idx = $row['row_index'] ?? null;
                if ($idx === null || !isset($ratios[$idx])) continue;
                $lastKey = $k;
                $share   = (int)floor($total * $ratios[$idx]);
                $row['estate_base_share_yen'] = $share;
                $allocated                   += $share;
            }
            // 端数は最後の一人に寄せる
            if ($lastKey !== null) {
                $heirs[$lastKey]['estate_base_share_yen'] =
                    ($heirs[$lastKey]['estate_base_share_yen'] ?? 0) + ($total - $allocated);
            }
        };

        // 2) after(t=0) に按分値を付与
        //    ★分割の基になる「所有財産」は “贈与後の遺産” (= estate_after_yen)
        //    ※未設定の場合のみ従来の estate_base_yen にフォールバック
        $totalAfterEstate = (int)($after['summary']['estate_after_yen'] ?? 0);
        if ($totalAfterEstate <= 0) $totalAfterEstate = (int)($after['summary']['estate_base_yen'] ?? 0);
        $applyAllocation($after['heirs'], $totalAfterEstate, $ratioByIdx);

        // 3) 年次プロジェクション after[t] も “贈与後の遺産” を按分
        if (is_array($projAfter)) {
            foreach ($projAfter as $t => $row) {
                if (!isset($row['summary']['estate_base_yen'], $row['heirs']) || !is_array($row['heirs'])) {
                    continue;
                }
                $totalAfterT = (int)($row['summary']['estate_after_yen'] ?? 0);
                if ($totalAfterT <= 0) $totalAfterT = (int)($row['summary']['estate_base_yen'] ?? 0);
                $applyAllocation($row['heirs'], $totalAfterT, $ratioByIdx);
                $projAfter[$t] = $row;
            }
        }

        return [$after, $projAfter];
    }

    
    /**
     * 過去贈与加算の対象となる受贈者 idx 一覧を解決する
     *
     * - 相続人配列 $heirs の idx
     * - 過去贈与テーブル（暦年／精算）の recipient_no
     *
     * をマージして一意な recipient_no 配列として返す。
     */
    private function resolveGiftRecipientIdxList(int $dataId, array $heirs): array
    {
        // 1) 相続人からの idx（あれば利用）
        $idxFromHeirs = array_map(
            fn (array $h) => $h['idx'] ?? null,
            $heirs
        );
        $idxFromHeirs = array_filter(
            $idxFromHeirs,
            fn ($v) => is_int($v) && $v > 0
        );

        // 2) 過去贈与（暦年）の recipient_no
        $idxFromPastCal = PastGiftCalendarEntry::where('data_id', $dataId)
            ->distinct()
            ->pluck('recipient_no')
            ->all();

        // 3) 過去贈与（精算）の recipient_no
        $idxFromPastSet = PastGiftSettlementEntry::where('data_id', $dataId)
            ->distinct()
            ->pluck('recipient_no')
            ->all();

        // 4) マージして一意化
        $merged = array_merge(
            $idxFromHeirs,
            array_map('intval', $idxFromPastCal),
            array_map('intval', $idxFromPastSet)
        );

        $merged = array_values(array_unique(array_filter($merged, fn ($v) => $v > 0)));
        sort($merged);

        return $merged;
    }
    
    /**
     * 「課税価格の取得がある人（相続/遺贈で財産を取得する人）」の idx(2..10) を決定する。
     *
     * 仕様：
     * - auto  : 法定相続人（bunsi/bunbo がある行）のみ
     * - manual: id_taxable_manu（手入力の課税価格）が >0 の行のみ
     *          ※ manual で 1件も無い場合は互換性のため heirs にフォールバック
     *
     * ここで決まった idx のみが「生前贈与加算」「贈与税額控除」「精算課税贈与税控除」の対象となる。
     *
     * @param array $payload
     * @param array $heirs collectHeirs() の結果
     * @return int[] idx の配列（昇順・ユニーク）
     */
    private function resolveTaxableAcquirerIdxList(array $payload, array $heirs): array
    {
        $mode = strtolower((string)(Arr::get($payload, 'input_mode', 'auto') ?? 'auto'));

        $idxs = [];
        if ($mode === 'manual') {
            for ($i = 2; $i <= 10; $i++) {
                $kyen = $this->readKyen($payload, 'id_taxable_manu', $i);
                if ($kyen > 0) {
                    $idxs[] = $i;
                }
            }
            // manual 入力が1件も無い場合は heirs を採用（互換性確保）
            if (empty($idxs)) {
                foreach ($heirs as $h) {
                    $idx = (int)($h['idx'] ?? 0);
                    if ($idx >= 2 && $idx <= 10) $idxs[] = $idx;
                }
            }
        } else {
            foreach ($heirs as $h) {
                $idx = (int)($h['idx'] ?? 0);
            if ($idx >= 2 && $idx <= 10) $idxs[] = $idx;
            }
        }

        $idxs = array_values(array_unique(array_filter($idxs, fn($v) => is_int($v) && $v >= 2 && $v <= 10)));
        sort($idxs);
        return $idxs;
    }

}
